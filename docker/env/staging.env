# NON-SECRET per-environment container sizing config for the staging host
# (Lightsail nano_3_0, 512MB). The deploy seeds these into /srv/footbag/env
# keyed on FOOTBAG_ENV; this committed file is the source of truth.
#
# Secrets (session, origin-verify, internal-event, API/webhook keys) live in
# /srv/footbag/env (operator-managed) and AWS SSM, NEVER here. Never add a
# secret, API key, identity, hostname, or URL to this file.

NGINX_MEMORY_LIMIT=64M
WEB_MEMORY_LIMIT=192M
WORKER_MEMORY_LIMIT=96M
IMAGE_MEMORY_LIMIT=256M
IMAGE_MAX_CONCURRENT=1
VIDEO_X264_PRESET=veryfast
VIDEO_X264_THREADS=1
VIDEO_X264_RC_LOOKAHEAD=10
