# NON-SECRET per-environment container sizing config for the production host
# (Lightsail medium_3_0, 4GB). The deploy seeds these into /srv/footbag/env
# keyed on FOOTBAG_ENV; this committed file is the source of truth, so the
# production sizing no longer depends on an operator remembering to set it.
#
# Secrets (session, origin-verify, internal-event, API/webhook keys) live in
# /srv/footbag/env (operator-managed) and AWS SSM, NEVER here. Never add a
# secret, API key, identity, hostname, or URL to this file.
#
# The video x264 knobs are intentionally omitted so production uses the
# canonical medium preset (higher quality); only the small staging host
# overrides them down.

NGINX_MEMORY_LIMIT=128M
WEB_MEMORY_LIMIT=512M
WORKER_MEMORY_LIMIT=384M
IMAGE_MEMORY_LIMIT=896M
IMAGE_MAX_CONCURRENT=2
