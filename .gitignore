# Real member data: a normalized extract of the private IFPA admin membership
# report. Operator-provided and held locally only; never committed (same model
# as the mirror above).
legacy_data/membership/inputs/membership_input_normalized.csv

# Freestyle research tree: relocated to the maintainers' private repository.
# On a wired machine this path is a repo-root symlink into the private archive;
# the anchored pattern (no trailing slash) covers the symlink itself, and
# ignoring the path keeps future research output from ever becoming committable
# here again.
/exploration

# Person-attributed freestyle adjudications worklist: relocated to the
# maintainers' private repository. On a wired machine this path is a symlink to
# the private copy so the pipeline scripts keep reading their default path.
legacy_data/freestyle_reconciliation/james_adjudications.csv

