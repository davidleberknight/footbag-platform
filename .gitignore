/.local/
.local/**

# Local symlink into the legacy footbag.org repository clone (canonical link name; machine-specific target)
/footbag_legacy_repo

# Local symlink into the maintainers' private ops checkout (canonical link name; machine-specific target)
/footbag_private_repo

# Local symlink to the footbag.org mirror crawl output (canonical link name; machine-specific target)
/footbag_legacy_mirror

