{
  "name": "footbag-platform",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "IFPA Footbag Platform \u2014 current deployed public baseline and long-term community platform",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:image": "IMAGE_PORT=4001 tsx watch src/imageWorker.ts",
    "dev:all": "bash scripts/dev.sh",
    "compose:dev": "bash scripts/compose-dev.sh",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "audit": "audit-ci --moderate",
    "start": "node dist/server.js",
    "test": "vitest run --exclude 'tests/smoke/**' --exclude 'tests/e2e/**'",
    "test:watch": "vitest --exclude 'tests/smoke/**' --exclude 'tests/e2e/**'",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:smoke": "scripts/test-smoke.sh",
    "test:strong-hash": "FOOTBAG_CHEAP_PASSWORD_HASH=0 vitest run tests/unit/passwordHash.test.ts tests/integration/security.login-timing.test.ts",
    "test:e2e": "playwright test -c tests/playwright.config.ts",
    "test:e2e:smoke": "playwright test -c tests/playwright.config.ts --grep @smoke",
    "test:coverage": "vitest run --exclude 'tests/smoke/**' --exclude 'tests/e2e/**' --coverage",
    "test:pre-pr": "npm run build && bash scripts/ci/assert_conventions.sh && npm test",
    "test:all": "npm run build && bash scripts/ci/assert_conventions.sh && npm test && npm run test:smoke && npm run test:e2e"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "3.1031.0",
    "@aws-sdk/client-s3": "3.1031.0",
    "@aws-sdk/client-ses": "3.1031.0",
    "@aws-sdk/client-ssm": "3.1031.0",
    "@aws-sdk/client-sts": "3.1031.0",
    "@aws-sdk/s3-request-presigner": "^3.1031.0",
    "@playwright/test": "^1.58.2",
    "@types/busboy": "^1.5.4",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.6.2",
    "busboy": "^1.6.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-handlebars": "^7.1.2",
    "helmet": "^8.1.0",
    "marked": "^14.1.4",
    "sharp": "^0.34.5",
    "sns-validator": "^0.3.5",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/sns-validator": "^0.3.3",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "audit-ci": "^7.1.0",
    "eslint": "^10.4.1",
    "fast-check": "^4.8.0",
    "happy-dom": "^20.9.0",
    "supertest": "^7.0.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.5",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "typed-rest-client": {
      "qs": "6.15.2"
    }
  }
}
