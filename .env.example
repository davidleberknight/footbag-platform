# Local development environment — copy to .env and fill in values
# Do NOT commit .env to version control

COMPOSE_FILE=docker/docker-compose.yml
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
FOOTBAG_DB_PATH=./database/footbag.db
PUBLIC_BASE_URL=http://localhost:3000
# SESSION_SECRET — sensitive. Never commit a real value. Production guards reject
# any value containing "changeme" or shorter than 32 chars. Generate fresh per
# environment with:  openssl rand -hex 32
SESSION_SECRET=changeme-use-a-long-random-string-in-production

# Express trust-proxy setting. Controls how req.ip and rate-limit keys resolve
# through X-Forwarded-For. Accepts an integer (hop count), 'true'/'false', or
# a comma-separated subnet list. Default in production: the named-range string
# 'loopback, linklocal, uniquelocal' (trusts loopback, link-local, and the
# private subnets that include the docker bridge). Default elsewhere: 0.
# Leave unset for sensible defaults.
# TRUST_PROXY=loopback, linklocal, uniquelocal

# SES_SANDBOX_MODE signals that the deployment is subject to AWS SES sandbox
# recipient-verification limits. When true, email-gated pages (e.g.
# /register/check-email) render a warning that verification mail only reaches
# pre-verified recipients. Dev (SES_ADAPTER=stub) ignores this flag; staging
# sets it to 1; production flips it to 0 once SES production access is granted.
# Accepts '1', '0', 'true', 'false'. Default: false.
# SES_SANDBOX_MODE=0

# Image worker (Sharp) HTTP boundary. The web app POSTs uploaded image bytes
# to this URL; the worker returns processed thumb/display variants. Required
# in production; defaults to http://localhost:4001 in dev (matches `npm run
# dev:image`). IMAGE_PORT is read by the worker process itself; IMAGE_PROCESSOR_URL
# is read by the web. IMAGE_MAX_CONCURRENT bounds simultaneous Sharp ops in the
# worker (default 2). IMAGE_PROCESS_TIMEOUT_MS is the web-side request timeout
# (default 30000).
# IMAGE_PROCESSOR_URL=http://localhost:4001
# IMAGE_PORT=4000
# IMAGE_MAX_CONCURRENT=2
# IMAGE_PROCESS_TIMEOUT_MS=30000

# INTERNAL_EVENT_SECRET authenticates web↔image-worker and web↔transcode-worker
# HTTP traffic (x-internal-secret header on /process/* and /ipc/job-events).
# Must be the same value across web and worker processes; the simplest way is
# to set it here in .env so both children pick it up via dotenv. Required in
# production. Generate fresh per environment with:  openssl rand -hex 32
INTERNAL_EVENT_SECRET=changeme-internal-event-secret-not-for-production

# Media storage adapter. 'local' writes processed JPEGs and curator media bytes
# to the local filesystem under the configured upload directory; 's3' PUTs to
# MEDIA_STORAGE_S3_BUCKET in AWS_REGION. Required in production (no default;
# fail-fast). Defaults to 'local' in dev. When set to 's3',
# MEDIA_STORAGE_S3_BUCKET and AWS_REGION must also be set, and the bucket must
# be readable by the CloudFront distribution via OAC.
# MEDIA_STORAGE_ADAPTER=local
# MEDIA_STORAGE_S3_BUCKET=

# Safe Browsing v4 API. Default in dev: stub adapter pre-seeded with the
# canonical Google malware test URL — submitting that URL in any external-link
# form rejects with "This URL is not allowed." without an outbound call. To
# exercise the live Google API end-to-end locally, create .local/secrets.json
# (gitignored) with {"safe_browsing_api_key": "<your-key>"}, then uncomment
# the line below. Schema and operator notes in .local/README.md. See
# docs/DEV_ONBOARDING.md §1.10A for the full opt-in walkthrough.
# SAFE_BROWSING_ADAPTER=live

# Dev/staging-only payment stub. When true, the member dashboard shows active
# "Upgrade to Tier 1/2 (Dev testing)" buttons that simulate a successful Stripe
# Checkout without real money. Creates a payments row and applies the tier grant.
# Production boot refuses this var. Accepts '1', '0', 'true', 'false'.
# FOOTBAG_DEV_PAYMENT_STUB=1

