{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./.env)",
      "Bash(sqlite3 database/footbag.db \"SELECT *)",
      "Bash(sqlite3 database/footbag.db \"PRAGMA *)",
      "Bash(sqlite3 database/footbag.db \".schema*)",
      "Bash(sqlite3 database/footbag.db \".tables*)",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(npx tsc*)",
      "Bash(npx vitest*)",
      "Bash(git fetch*)",
      "Bash(git stash list*)",
      "Bash(node --version*)",
      "Bash(npm --version*)"
    ],
    "deny": [
      "Edit(./.env)",
      "Write(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.staging)",
      "Read(./secrets/**)",
      "Read(./.secrets/**)",
      "Read(./.claude/settings.local.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-secrets.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-git-mutations.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-prod-ops.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-db-destructive.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-dangerous-git.sh"
          }
        ]
      }
    ]
  }
}
