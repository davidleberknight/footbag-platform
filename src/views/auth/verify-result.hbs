<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
  </div>
</div>

<div class="wrapper">
  <section>
    <div class="form-error-banner" role="alert">
      {{#if content.signInPrompt}}
        Your email is verified, but we could not sign you in. Please sign in with your email and password.
      {{else}}
        This verification link is invalid, expired, or already used.
      {{/if}}
    </div>
    {{#if content.signInPrompt}}
      <div class="form-actions">
        <a href="/login" class="btn btn-primary">Sign In</a>
      </div>
    {{else}}
      <p>
        If you still need to verify your account, request a new link:
      </p>
      <form method="POST" action="/verify/resend" class="form-block">
        <div class="form-field">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" autocomplete="email" required />
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Resend Verification Email</button>
        </div>
      </form>
    {{/if}}
  </section>
</div>
