{{! Registration page }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    <p>Join the International Footbag Players Association.</p>
  </div>
</div>

<div class="wrapper">

  <section>
    <div class="notice-card notice-card--warn mb-6">
      <p class="m-0 fw-500">Early access notice</p>
      <p class="m-0 mt-2">This site is under active development. Account data may be deleted when we update the site, which happens frequently. Your account is real, but please be aware it may need to be re-created during this early period.</p>
    </div>

    <p class="text-muted fs-sm mb-4">If you had an account on the old footbag.org, start here. After creating your account, the setup wizard will help you link to your historical data, such as event results, and club affiliation.</p>

    {{#if content.error}}
      <p class="form-field-error" role="alert">{{content.error}}</p>
    {{/if}}

    <form method="POST" action="/register" class="login-form">
      <div class="form-field">
        <label for="realName">Full legal name</label>
        <input
          type="text"
          id="realName"
          name="realName"
          value="{{content.realName}}"
          maxlength="64"
          required
          autocomplete="name"
        />
        <small class="form-hint">Your real first and last name, properly capitalized.</small>
      </div>

      <div class="form-field">
        <label for="email">Email address</label>
        <input
          type="email"
          id="email"
          name="email"
          value="{{content.email}}"
          required
          autocomplete="email"
        />
      </div>

      <div class="form-field">
        <label for="password">Password (8 characters minimum)</label>
        <input
          type="password"
          id="password"
          name="password"
          minlength="8"
          maxlength="128"
          required
          autocomplete="new-password"
        />
      </div>

      <div class="form-field">
        <label for="confirmPassword">Confirm password</label>
        <input
          type="password"
          id="confirmPassword"
          name="confirmPassword"
          minlength="8"
          maxlength="128"
          required
          autocomplete="new-password"
        />
      </div>

      <div class="card mb-6">
        <p class="card-title">Sex (competition eligibility)</p>
        <p class="text-muted fs-sm mb-4">Why we ask: IFPA runs sex-based competition categories. Mixed doubles needs one male and one female, and there are women's events. We collect this once so you can register for events later. Choosing 'Prefer not to say' is fine; you can still register for open categories, and you can record your sex anytime in your profile to enter women's or mixed-doubles draws.</p>
        <div class="form-field">
          <label>
            <input type="radio" name="sex" value="male" {{#if (eq content.sex "male")}}checked{{/if}} required />
            Male
          </label>
          <label>
            <input type="radio" name="sex" value="female" {{#if (eq content.sex "female")}}checked{{/if}} required />
            Female
          </label>
          <label>
            <input type="radio" name="sex" value="undisclosed" {{#if (eq content.sex "undisclosed")}}checked{{/if}} required />
            Prefer not to say
          </label>
        </div>
        <small class="form-hint">Private: visible only to you and IFPA admins. Never shown on public pages, member search, or rosters.</small>
      </div>

      <div class="card mb-6">
        <p class="card-title">Display name</p>
        <p class="text-muted fs-sm mb-4">How your name appears across the site: on your profile, in search results, on club rosters, and in competition records. If you leave this blank, your full legal name is used.</p>
        <div class="form-field">
          <label for="displayName">Display name</label>
          <input
            type="text"
            id="displayName"
            name="displayName"
            value="{{content.displayName}}"
            placeholder="Leave blank to use your full name"
            maxlength="64"
            autocomplete="nickname"
          />
        </div>
        <ul class="text-muted fs-sm mt-2 mb-0">
          <li>Must include your last name</li>
          <li>Permanent: cannot be changed after registration</li>
        </ul>
      </div>

      <div class="card mb-6">
        <p class="card-title">Profile URL</p>
        <p class="text-muted fs-sm mb-4">Your permanent address on the site. If you leave this blank, it is generated from your display name (e.g. "david_leberknight"). This also becomes your personal media hashtag: #your_slug.</p>
        <div class="form-field">
          <label for="slug">Profile URL</label>
          <input
            type="text"
            id="slug"
            name="slug"
            value="{{content.slug}}"
            placeholder="Leave blank to generate from display name"
            maxlength="64"
            autocomplete="off"
          />
          <small class="form-hint">footbag.org/members/<strong>your_slug</strong></small>
        </div>
        <ul class="text-muted fs-sm mt-2 mb-0">
          <li>Lowercase letters, numbers, and underscores only</li>
          <li>Must contain your last name</li>
          <li>Permanent: cannot be changed after registration</li>
        </ul>
      </div>

      <button type="submit" class="btn btn-primary">Create account</button>
    </form>

    <p class="mt-6">Already have an account? <a href="/login">Log in</a></p>
  </section>

</div>
<script src="/js/register-defaults.js" defer></script>
