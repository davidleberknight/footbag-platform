{{! Login page }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p>{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  <section>
    {{#if content.authReason}}
      <p class="form-notice">{{content.authReason}}</p>
    {{/if}}
    {{#if content.error}}
      <p class="form-field-error" role="alert">{{content.error}}</p>
    {{/if}}

    <form method="POST" action="/login" class="login-form">
      {{#if content.returnTo}}
        <input type="hidden" name="returnTo" value="{{content.returnTo}}" />
      {{/if}}
      <div class="form-field">
        <label for="email">Email address</label>
        <input type="text" id="email" name="email" autocomplete="email" required />
      </div>
      <div class="form-field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required />
      </div>
      <button type="submit" class="btn btn-primary">Log in</button>
    </form>

    <p class="mt-4"><a href="/password/forgot">Forgot your password?</a></p>
    <p class="mt-4">New to IFPA? <a href="/register">Create an account</a></p>
    <div class="card mt-4">
      <div class="card-title">Had an account on the old footbag.org?</div>
      <p class="card-description">You will need to <a href="/register">create a new account</a> here first to become a member in the new system. During setup, you can link to your historical data, such as event results, and club affiliation.</p>
    </div>
  </section>

</div>
