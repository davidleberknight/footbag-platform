<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p>{{page.intro}}</p>{{/if}}
    {{#if page.notice}}<div class="notice">{{page.notice}}</div>{{/if}}
  </div>
</div>

<div class="wrapper">

  {{#each content.sections}}
    <section>
      <h2 class="section-heading">{{this.heading}}</h2>
      {{!-- Current: paragraphs are static operator-authored string literals with
          intentional inline <a> markup, so unescaped triple-stash render is safe.
          Target: if the paragraph source becomes DB-backed or admin-editable,
          switch to an allowlisted-HTML helper (or escaped render) before that
          lands; unescaped render of untrusted data is stored XSS. --}}
      {{#each this.paragraphs}}
        <p class="ws-pre-line">{{{this}}}</p>
      {{/each}}
    </section>
  {{/each}}

  {{#if content.honorees.length}}
    <section>
      <h2 class="section-heading">Members</h2>
      <ul class="honor-index">
        {{#each content.honorees}}
          <li><a href="{{href}}">{{name}}</a>{{#if nickname}} <span class="text-muted fs-sm">&ldquo;{{nickname}}&rdquo;</span>{{/if}}{{#if year}} <span class="text-muted fs-sm">{{year}}</span>{{/if}}</li>
        {{/each}}
      </ul>
    </section>
  {{/if}}

  {{#if content.externalLink}}
    <p class="mt-2 mb-10">
      <a href="{{content.externalLink.href}}" class="btn btn-outline" target="_blank" rel="noopener noreferrer">{{content.externalLink.label}}</a>
    </p>
  {{/if}}

</div>
