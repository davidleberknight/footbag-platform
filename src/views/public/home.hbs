<div class="hero hero-sm">
  <div>
    <h1>{{hero.heading}}</h1>
    {{#if hero.subheading}}<p>{{hero.subheading}}</p>{{/if}}
    {{#if page.notice}}<div class="notice">{{page.notice}}</div>{{/if}}
  </div>
</div>

<div class="wrapper">

  <section class="tricks-mosaic-section">
    <div class="section-heading">
      <h2>The 12 Foundations of Freestyle</h2>
      <p class="text-muted">Every freestyle trick is built from these core movements.</p>
    </div>
    <div class="tricks-mosaic">
      {{#each tricksMosaic}}
        <figure class="tricks-mosaic-cell">
          {{#if mp4Url}}
            <video class="tricks-mosaic-media" autoplay loop muted playsinline preload="metadata" poster="{{posterUrl}}">
              <source src="{{mp4Url}}" type="video/mp4">
            </video>
          {{else}}
            <div class="tricks-mosaic-media tricks-mosaic-empty" aria-hidden="true"></div>
          {{/if}}
          <figcaption class="tricks-mosaic-label">{{label}}</figcaption>
        </figure>
      {{/each}}
    </div>
  </section>

  <section>
    <div class="section-heading">
      <h2>Explore the World of Footbag</h2>
    </div>
    <div class="card-grid card-grid-2col">
      {{#each primaryLinks}}
        <div class="card">
          <div class="card-title">{{label}}</div>
          <p class="card-description">{{description}}</p>
          <a href="{{href}}" class="btn {{#if (eq variant 'primary')}}btn-primary{{else}}btn-outline{{/if}}">{{label}}</a>
        </div>
      {{/each}}
      {{#each comingSoonSections}}
        <div class="card card-coming-soon">
          <div class="card-title">{{heading}}</div>
          <p class="card-description">{{body}}</p>
          <span class="badge badge-coming-soon">Coming soon</span>
        </div>
      {{/each}}
    </div>
  </section>

  {{#if hero.videoMedia}}
    <section class="home-media">
      {{> video-facade media=hero.videoMedia}}
      {{#if hero.videoCaption}}
        <p class="home-media-caption">{{hero.videoCaption}}</p>
      {{/if}}
    </section>
  {{/if}}

</div>
