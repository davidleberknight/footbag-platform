{{! Public home landing page }}

<div class="hero hero-sm">
  <div>
    <h1>{{hero.heading}}</h1>
    {{#if hero.subheading}}<p>{{hero.subheading}}</p>{{/if}}
    {{#if page.notice}}<div class="notice">{{page.notice}}</div>{{/if}}
  </div>
</div>

<div class="wrapper">

  <section>
    <div class="section-heading">
      <h2>Explore the World of Footbag</h2>
    </div>
    <div class="card-grid card-grid-2col">
      {{#each primaryLinks}}
        <div class="card">
          <div class="card-title">{{label}}</div>
          <p class="card-description">{{description}}</p>
          <a href="{{href}}" class="btn {{#if (eq variant 'primary')}}btn-primary{{else}}btn-outline{{/if}}">{{label}}</a>
        </div>
      {{/each}}
      {{#each comingSoonSections}}
        <div class="card card-coming-soon">
          <div class="card-title">{{heading}}</div>
          <p class="card-description">{{body}}</p>
          <span class="badge badge-coming-soon">Coming soon</span>
        </div>
      {{/each}}
    </div>
  </section>

  {{#if hero.videoMedia}}
    <section class="home-media">
      {{> video-facade media=hero.videoMedia}}
      {{#if hero.videoCaption}}
        <p class="home-media-caption">{{hero.videoCaption}}</p>
      {{/if}}
    </section>
  {{/if}}

</div>
