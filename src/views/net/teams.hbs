{{! /net/teams — doubles teams with division filter }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
    {{#if content.totalShown}}
    <div class="hero-stats">
      {{#if content.pagination}}
      <span>{{content.pagination.total}} teams</span>
      {{else}}
      <span>{{content.totalShown}} teams shown</span>
      {{/if}}
    </div>
    {{/if}}
  </div>
</div>

<div class="wrapper">

  <form method="GET" action="/net/teams" class="filter-bar">
    <label>
      Division
      <select name="division" data-auto-submit>
        {{#each content.divisionOptions}}
        <option value="{{value}}"{{#if selected}} selected{{/if}}>{{label}}{{#if appearanceCount}} ({{appearanceCount}} appearances){{/if}}</option>
        {{/each}}
      </select>
    </label>
    <label>
      Search
      <input type="text" name="q" value="{{content.activeSearch}}" placeholder="Player name..." />
    </label>
    <button type="submit">Filter</button>
    {{#if content.activeDivision}}
    <a href="/net/teams" class="btn-link">Clear</a>
    {{else if content.activeSearch}}
    <a href="/net/teams" class="btn-link">Clear</a>
    {{/if}}
  </form>

  <p class="source-note">{{content.disclaimer}}</p>

  {{#if content.teams}}
  <div class="records-table-wrap">
    <table class="records-table">
      <thead>
        <tr>
          <th class="col-rank">#</th>
          <th>Team</th>
          <th class="col-num">Appearances</th>
          <th class="col-num">Wins</th>
          <th class="col-num">Podiums</th>
          <th>Years</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.teams}}
        <tr>
          <td class="col-rank">{{add @index ../content.rankStart}}</td>
          <td>
            <a href="{{{teamHref}}}">{{teamName}}</a>
          </td>
          <td class="col-num">{{appearanceCount}}</td>
          <td class="col-num">{{winCount}}</td>
          <td class="col-num">{{podiumCount}}</td>
          <td>{{#if yearSpan}}{{yearSpan}}{{else}}&mdash;{{/if}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{#if content.pagination}}
    <nav class="gallery-pagination" aria-label="Pagination">
      {{#if content.pagination.hasPrev}}<a href="{{content.pagination.prevHref}}" rel="prev">&larr; Previous</a>{{/if}}
      <span class="gallery-pagination-status">Page {{content.pagination.page}} of {{content.pagination.totalPages}}</span>
      {{#if content.pagination.hasNext}}<a href="{{content.pagination.nextHref}}" rel="next">Next &rarr;</a>{{/if}}
    </nav>
  {{/if}}
  {{else}}
  <div class="empty-state">No teams found for this division.</div>
  {{/if}}

</div>
