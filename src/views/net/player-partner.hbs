{{! /net/players/:personId/partners/:teamId — player × partner detail }}

<div class="hero hero-sm">
  <div>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/net/teams">Net Teams</a> <span class="breadcrumb-sep">/</span>
      <a href="{{content.player.href}}">{{content.player.personName}}</a> <span class="breadcrumb-sep">/</span>
      <span>{{content.partner.personName}}</span>
    </nav>
    <h1>{{page.title}}</h1>
    <div class="hero-stats">
      <span>{{content.appearanceCount}} {{#if (eq content.appearanceCount 1)}}appearance{{else}}appearances{{/if}} together</span>
      {{#if content.bestPlacementLabel}}<span>Best: {{content.bestPlacementLabel}}</span>{{/if}}
      {{#if content.yearSpan}}<span>{{content.yearSpan}}</span>{{/if}}
    </div>
  </div>
</div>

<div class="wrapper">

  <p class="source-note">{{content.disclaimer}}</p>

  <section class="content-section">
    <div class="section-heading">
      <h2>Players</h2>
    </div>
    <ul class="plain-list">
      <li><a href="{{content.player.href}}">{{content.player.personName}}</a>{{#if content.player.country}} — {{content.player.country}}{{/if}}</li>
      <li><a href="{{content.partner.href}}">{{content.partner.personName}}</a>{{#if content.partner.country}} — {{content.partner.country}}{{/if}}</li>
    </ul>
    <p class="source-note"><a href="{{content.teamDetailHref}}">View full team record &rarr;</a></p>
  </section>

  {{#if content.byYear}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Results Together</h2>
    </div>

    {{#each content.byYear}}
    <h3 class="year-heading">{{year}}</h3>
    <table class="records-table">
      <thead>
        <tr>
          <th>Event</th>
          <th>Discipline</th>
          <th class="col-rank">Place</th>
        </tr>
      </thead>
      <tbody>
        {{#each appearances}}
        <tr>
          <td><a href="{{eventHref}}">{{eventTitle}}</a></td>
          <td>{{disciplineLabel}}</td>
          <td class="col-rank">{{placementLabel}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{/each}}
  </section>
  {{else}}
  <div class="empty-state">No results found.</div>
  {{/if}}

</div>
