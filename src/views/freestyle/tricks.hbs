{{! /freestyle/tricks — trick dictionary index }}

<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  {{! ── Page intro — plain, movement-first. Shown on every browse view. ── }}
  {{#if content.dictionaryIntro}}
  <p class="browse-view-intro">{{content.dictionaryIntro}}
    <a class="dictionary-intro-glossary-link" href="/freestyle/glossary">New to the words? Open the glossary &rarr;</a></p>
  {{/if}}

  {{! ── DL-1+2+5 landing grid (2026-05-26): 3-band conceptual map of the
      dictionary's browse axes. Renders ONLY on the default landing view
      (?view=add, the default) to orient first-time readers. On secondary
      views (?view=family, ?view=sets, etc.) the inline view-toggle below
      handles persistent quick-switching nav. Emerging Vocabulary lives
      under the third band (Tracking & Expansion), promoted from its
      previous separate footer-style paragraph. }}
  {{#if (eq content.activeView "add")}}
  {{#unless content.activeFamily}}
  <div class="dict-landing-grid" aria-label="Dictionary browse axes">
    {{#each content.landingGrid.bands}}
    <section class="dict-landing-band">
      <p class="dict-landing-band-eyebrow">{{eyebrow}}</p>
      <div class="dict-landing-band-cards">
        {{#each cards}}
        <article class="dict-landing-card">
          <header class="dict-landing-card-header">
            <h2 class="dict-landing-card-label"><a href="{{href}}">{{label}}</a></h2>
            <span class="dict-landing-card-count" aria-label="{{countDisplay}} {{countSuffix}}"><span class="dict-landing-card-count-num">{{countDisplay}}</span> {{countSuffix}}</span>
          </header>
          <p class="dict-landing-card-question">{{lensQuestion}}</p>
          {{#if chips.length}}
          <p class="dict-landing-card-chips" aria-label="Jump to section">
            {{#each chips}}<a class="dict-landing-card-chip" href="{{href}}">{{label}}{{#if count}} <span class="dict-landing-card-chip-count">{{count}}</span>{{/if}}</a>{{#unless @last}} <span class="dict-landing-card-chip-sep">·</span> {{/unless}}{{/each}}
          </p>
          {{/if}}
          <p class="dict-landing-card-open"><a href="{{href}}">Open &rarr;</a></p>
          {{#if crossLink}}
          <p class="dict-landing-card-crosslink"><a href="{{crossLink.href}}">{{crossLink.label}}</a></p>
          {{/if}}
        </article>
        {{/each}}
      </div>
    </section>
    {{/each}}
  </div>
  {{/unless}}
  {{/if}}

  {{#if content.activeFamily}}
  <p class="family-filter-pill">
    Filtering by family: <strong>{{content.activeFamily}}</strong>
    &nbsp;<a href="/freestyle/tricks">Clear filter</a>
  </p>
  {{#if content.relatedSetGroups.length}}
  <nav class="related-set-groups" aria-label="Related set or modifier groups">
    <span class="related-set-groups-label">Related set/modifier groups:</span>
    {{#each content.relatedSetGroups}}
      <a class="related-set-group-link" href="{{{href}}}">{{modifierName}} <span class="related-set-group-count">({{count}})</span></a>{{#unless @last}} <span class="related-set-group-sep">·</span> {{/unless}}
    {{/each}}
  </nav>
  {{/if}}
  {{/if}}

  {{! ── Browse navigation. "By ADD" is the default; the other systems are
      secondary ways to navigate the same movement universe. No JavaScript;
      view selected via the ?view= query param. ── }}
  <nav class="trick-view-toggle" aria-label="Browse the dictionary">
    {{#if (eq content.activeView "add")}}
      <span class="trick-view-toggle-active">By ADD</span>
    {{else}}
      <a href="/freestyle/tricks?view=add">By ADD</a>
    {{/if}}
    <span class="trick-view-toggle-sep">·</span>
    {{#if (eq content.activeView "family")}}
      <span class="trick-view-toggle-active">By family</span>
    {{else}}
      <a href="/freestyle/tricks?view=family">By family</a>
    {{/if}}
    <span class="trick-view-toggle-sep">·</span>
    {{#if (eq content.activeView "movement-system")}}
      <span class="trick-view-toggle-active">By movement system</span>
    {{else}}
      <a href="/freestyle/tricks?view=movement-system">By movement system</a>
    {{/if}}
    <span class="trick-view-toggle-sep">·</span>
    {{#if (eq content.activeView "topology")}}
      <span class="trick-view-toggle-active">Movement Neighborhoods</span>
    {{else}}
      <a href="/freestyle/tricks?view=topology">Movement Neighborhoods</a>
    {{/if}}
    <span class="trick-view-toggle-sep">·</span>
    {{#if (eq content.activeView "dex-count")}}
      <span class="trick-view-toggle-active">By dex count</span>
    {{else}}
      <a href="/freestyle/tricks?view=dex-count">By dex count</a>
    {{/if}}
    <span class="trick-view-toggle-sep">·</span>
    {{#if (eq content.activeView "sets")}}
      <span class="trick-view-toggle-active">By modifier</span>
    {{else}}
      <a href="/freestyle/tricks?view=sets">By modifier</a>
    {{/if}}
  </nav>
  {{#unless (eq content.activeView "add")}}
  {{! Secondary-view reachability for cross-link surfaces. On the default
      landing view, the dict-landing-grid above carries Operators / Set
      Encyclopedia cross-links in their respective cards; on secondary
      views, this aside paragraph preserves reachability without requiring
      a return trip to the landing. }}
  <p class="trick-view-toggle-aside">For modifier and operator vocabulary, see the <a href="/freestyle/operators">Operators &amp; Modifiers reference</a> (not a dictionary browse axis; it's vocabulary that helps you read trick names). For set systems as first-class objects (what is pixie / stepping / atomic as a system?), see the <a href="/freestyle/sets">Set Encyclopedia</a>.</p>
  {{/unless}}

  {{! ── Default ADD-grouped view — two-line row contract (2026-05-27).
       Every row: line 1 = name/hashtag/≡interpretation/media; line 2 =
       JOB: + ADD:. No green ADD chip (the value is in the section header
       + the line-2 ADD: formula). See dictionary-trick-row.hbs. }}
  {{#if (eq content.activeView "add")}}
  {{#each content.addGroups}}
  <section class="content-section trick-add-group trick-group--trick-rows" id="{{anchorId}}">
    <div class="section-heading">
      <h2>{{addLabel}}</h2>
      <span class="section-count">{{cards.length}}</span>
    </div>
    <div class="dict-trick-row-stack">
      {{#each cards}}
        {{> dictionary-trick-row}}
      {{/each}}
    </div>
  </section>
  {{/each}}
  {{/if}}

  {{! ── Dex Count view — two-line row contract (2026-05-27 migration).
      Buckets active tricks by the number of [DEX] tokens in their operational
      notation. Same generalized dictionary-trick-row partial as the ADD and
      Family views; only the bucketing axis differs. }}
  {{#if (eq content.activeView "dex-count")}}
  <p class="browse-view-intro">Tricks grouped by the number of dex events in their operational notation. How many dex moves does this trick involve?</p>
  {{#if content.dexCountScale}}<p class="browse-view-scale">{{content.dexCountScale}}</p>{{/if}}
  {{#each content.dexCountGroups}}
  <section class="content-section trick-dex-count-group trick-group--trick-rows" id="{{bucketId}}">
    <div class="section-heading">
      <h2>{{dexLabel}}</h2>
      <span class="section-count">{{cards.length}}</span>
    </div>
    {{#unless dexCount}}{{#if (eq bucketId "dex-unknown")}}
    <p class="dex-count-unknown-note"><em>These canonical rows do not yet have operational notation populated. The trick exists; its dex count cannot be derived without notation.</em></p>
    {{/if}}{{/unless}}
    <div class="dict-trick-row-stack">
      {{#each cards}}
        {{> dictionary-trick-row}}
      {{/each}}
    </div>
  </section>
  {{/each}}
  {{/if}}

  {{! ── Set Hub view (Phase A of the set-system refactor, 2026-05-25).
      Sets are first-class ontology objects, not trick-grouped browse
      filters. Six subtype sections; each card carries hashtag, formula,
      movement explanation, equivalence readings, derived / related
      systems, and provenance. Phase B will add /freestyle/sets/<slug>
      detail pages. }}
  {{! ── By Set view — modifier-grouped trick lists (answers "which tricks
       use this set?"). Distinct from the Set Encyclopedia at /freestyle/sets
       which answers "what is this set system?" — that surface remains
       separate and intentional. This view uses content.setGroups (the
       trick-grouping projection); content.setsBrowseView (the encyclopedia
       projection) is reserved for /freestyle/sets. }}
  {{#if (eq content.activeView "sets")}}
  <p class="browse-view-intro">Tricks grouped by the set or body modifier they use. Each section answers: which tricks use this set or modifier? For "what IS this set system?", see the <a href="/freestyle/sets">Set Encyclopedia</a>.</p>
  {{#if content.setsScale}}<p class="browse-view-scale">{{content.setsScale}}</p>{{/if}}
  {{#if content.setsClusterView.length}}
  <p class="sets-view-total detail-muted"><strong>{{content.setGroups.length}}</strong> sets and modifiers, grouped into {{content.setsClusterView.length}} clusters. Each cluster expands into its individual modifiers below.</p>

  <nav class="sets-view-jump" aria-label="Modifier cluster jump">
    {{#each content.setsClusterView}}
      <a href="#cluster-{{key}}">{{label}}</a>{{#unless @last}} <span class="component-axis-jump-sep">·</span> {{/unless}}
    {{/each}}
  </nav>

  {{#each content.setsClusterView}}
  <section class="content-section sets-cluster" id="cluster-{{key}}" data-anchor-style="solid">
    <div class="section-heading">
      <h2>{{label}}</h2>
      <span class="section-count">{{groups.length}}</span>
    </div>
    <p class="sets-cluster-blurb detail-muted">{{blurb}}</p>
    {{#each groups}}
    <section class="trick-set-group trick-group--trick-rows" id="set-{{modifierSlug}}" data-anchor-style="dotted">
      <div class="section-heading">
        <h3><a href="/freestyle/tricks?view=sets#set-{{modifierSlug}}">{{modifierName}}</a></h3>
        <span class="section-count">{{trickCount}}</span>
      </div>
      <p class="trick-set-group-meta detail-muted">
        {{#if (eq modifierType "set")}}Set modifier{{else}}{{#if (eq modifierType "body")}}Body modifier{{else}}Modifier{{/if}}{{/if}}{{#if addBonus}} · +{{addBonus}} ADD{{#if addBonusRotational}} (+{{addBonusRotational}} on rotational bases){{/if}}{{/if}}
      </p>
      <div class="dict-trick-row-stack">
        {{#each cards}}
          {{> dictionary-trick-row}}
        {{/each}}
      </div>
    </section>
    {{/each}}
  </section>
  {{/each}}
  {{else}}
  <section class="content-section">
    <p class="detail-muted"><em>No tricks currently link to a registered modifier. As the dictionary expands, this view populates from <code>freestyle_trick_modifier_links</code>.</em></p>
  </section>
  {{/if}}
  {{/if}}

  {{! ── Family view — two-line row contract (2026-05-27 migration).
      Same generalized dictionary-trick-row partial as the ADD view; only the
      grouping (family sections + family-anchor sublabel) differs. }}
  {{#if (eq content.activeView "family")}}
  {{#if content.familyViewIntro}}
  <p class="browse-view-intro">{{content.familyViewIntro}}</p>
  {{/if}}
  <p class="family-view-ordering-note"><em>Families are ordered by structural anchor weight, not alphabetically. Whirl, butterfly, mirage, osis, and other foundational families anchor the most compound rows.</em></p>
  {{#if content.familyScale}}<p class="browse-view-scale">{{content.familyScale}}</p>{{/if}}
  {{#if content.familyGroups.length}}
  {{#each content.familyGroups}}
  <section class="content-section trick-family-group trick-group--trick-rows" id="family-{{familySlug}}" data-anchor-style="solid">
    <div class="section-heading">
      <h2><a href="/freestyle/tricks?family={{familySlug}}">{{familyName}} family</a></h2>
      <span class="section-count">{{cards.length}}</span>
    </div>
    {{! Family-anchor sub-label (Dictionary Pedagogy Phase 2). Names
        the canonical family-anchor trick so readers connect the
        glossary's "family-anchor trick" vocabulary to the dictionary
        surface. Links to the anchor's trick-detail page. }}
    <p class="trick-family-anchor-sublabel"><span class="trick-family-anchor-label">Family-anchor:</span> <a class="trick-family-anchor-link" href="/freestyle/tricks/{{familySlug}}">{{familyName}}</a></p>
    {{! Family-level shared-terminal-structure invariant. Curator-authored per
        family slug; rendered between the heading and the card stack.
        Source: src/content/freestyleFamilyInvariants.ts. }}
    {{#if sharedStructure}}
    <p class="trick-family-shared-structure">Shared terminal structure: <code>{{sharedStructure}}</code></p>
    {{/if}}
    {{#if crossLink}}
    <p class="trick-family-cross-link"><a href="{{crossLink.href}}">{{crossLink.label}} &rarr;</a></p>
    {{/if}}
    <div class="dict-trick-row-stack">
      {{#each cards}}
        {{> dictionary-trick-row}}
      {{/each}}
    </div>
  </section>
  {{/each}}
  {{/if}}
  {{/if}}

  {{! ── Component view — symbolic trick cards (DSC-2 slice 3A) ─────────────
       Soft-retired 2026-05-18 per the component_view_retirement_audit
       in exploration/freestyle-public-coherence-wave-2026-05-18/. The
       toggle entry was removed from the view-toggle row above, so the
       only paths reaching this view are bookmarked or external links.
       Movement System (?view=movement-system) is the canonical
       modifier-grouped browse surface. }}
  {{#if (eq content.activeView "component")}}
  <div class="component-view-retirement-notice" role="status" aria-live="polite">
    <p>
      <strong>This view is being retired.</strong> The
      <a href="/freestyle/tricks?view=movement-system">By Movement System</a>
      view groups tricks by modifier within four pedagogical axes
      (set / uptime · entry topology · midtime body · no-plant suspension)
      and is now the canonical modifier-grouped browse surface.
    </p>
    <p class="component-view-retirement-notice-detail">
      This page still renders so bookmarks and external links keep
      resolving, but new discovery happens through Movement System.
    </p>
  </div>
  <p class="component-view-note">{{content.componentView.duplicationNote}}</p>

  {{! Axis-jump nav. Static; no JS. Hash anchors only. }}
  <nav class="component-axis-jump" aria-label="Component axes">
    {{#each content.componentView.axes}}
      {{#if groups.length}}
      <a href="#{{anchorId}}">{{axisLabel}}</a>{{#unless @last}} <span class="component-axis-jump-sep">·</span> {{/unless}}
      {{/if}}
    {{/each}}
  </nav>

  {{#each content.componentView.axes}}
    {{#if groups.length}}
    <section class="content-section trick-component-axis" id="{{anchorId}}">
      <div class="section-heading">
        <h2>{{axisLabel}}</h2>
        <span class="section-count">{{groups.length}}</span>
      </div>
      {{#each groups}}
      <section class="trick-component-group trick-group--registry" id="{{anchorId}}" data-anchor-style="solid">
        <div class="component-group-heading">
          <h3><a href="/freestyle/tricks?view=component#{{anchorId}}">{{componentName}}</a></h3>
          <span class="section-count">{{memberCount}}</span>
        </div>
        {{#if bodyDefinition}}
        <p class="component-group-definition">{{bodyDefinition}}</p>
        {{/if}}
        <div class="dict-card-stack dict-card-stack--registry">
          {{#each cards}}
            {{> dictionary-trick-card density="registry"}}
          {{/each}}
        </div>
      </section>
      {{/each}}
    </section>
    {{/if}}
  {{/each}}

  {{#unless content.componentView.axes.0.groups.length}}
  {{#unless content.componentView.axes.1.groups.length}}
  <section class="content-section">
    <p class="detail-muted">
      <em>No tricks currently link to a registered body or set modifier. As the
      dictionary expands, this view will populate from
      <code>freestyle_trick_modifier_links</code>.</em>
    </p>
  </section>
  {{/unless}}
  {{/unless}}
  {{/if}}

  {{! ── Category view — registry density (dense tag-based scan) ────────────
       Soft-retired per the category_view_retirement_review audit in
       exploration/dictionary-coherence-2026-05-18/. Toggle entry removed
       from the view-toggle row above; the route still resolves so
       bookmarks and external links keep working. Family + Movement System
       are the canonical replacements. }}
  {{#if (eq content.activeView "category")}}
  <div class="category-view-retirement-notice" role="status" aria-live="polite">
    <p>
      <strong>This view is being retired.</strong> The
      <a href="/freestyle/tricks?view=family">By Family</a> view groups
      dex-anchored tricks by structural lineage, and the
      <a href="/freestyle/tricks?view=movement-system">By Movement System</a>
      view groups body and set primitives by pedagogical axis. The
      grammatical buckets (dex / body / set / compound) duplicate those
      organizations with lower density.
    </p>
    <p class="category-view-retirement-notice-detail">
      This page still renders so bookmarks and external links keep
      resolving, but new discovery happens through Family and Movement
      System.
    </p>
  </div>
  {{#each content.groups}}
  <section class="content-section trick-category-group trick-group--registry" id="{{anchorId}}">
    <div class="section-heading">
      <h2><a href="/freestyle/tricks?view=category#{{anchorId}}">{{label}}</a></h2>
      <span class="section-count">{{cards.length}}</span>
    </div>
    <div class="dict-card-stack dict-card-stack--registry">
      {{#each cards}}
        {{> dictionary-trick-card density="registry"}}
      {{/each}}
    </div>
  </section>
  {{/each}}
  {{/if}}

  {{! ── Movement Neighborhoods view (CR-6 of dictionary-coherence-2026-05-18;
       public label renamed from "Topology"). The backend slug + URL
       parameter `?view=topology` are preserved for URL stability. ── }}
  {{#if (eq content.activeView "topology")}}
  <p class="browse-view-status-label"><strong>Exploratory / pedagogical — not canonical taxonomy.</strong></p>
  <p class="topology-view-note">
    {{content.topologyView.observationalNote}}
  </p>
  {{#if content.topologyScale}}<p class="browse-view-scale">{{content.topologyScale}}</p>{{/if}}

  {{#if content.topologyView.groups.length}}
  <nav class="topology-jump" aria-label="Movement Neighborhood categories">
    {{#each content.topologyView.groups}}
      <a href="#{{anchorId}}">{{topologyName}}</a>{{#unless @last}} <span class="topology-jump-sep">·</span> {{/unless}}
    {{/each}}
  </nav>
  {{#each content.topologyView.groups}}
  <section class="content-section trick-topology-group trick-group--trick-rows" id="{{anchorId}}" data-anchor-style="dotted">
    <div class="section-heading">
      <h2><a href="/freestyle/tricks?view=topology#{{anchorId}}">{{topologyName}}</a></h2>
      <span class="section-count">{{memberCount}}</span>
    </div>
    <p class="topology-group-definition">{{bodyDefinition}}</p>
    <div class="dict-trick-row-stack">
      {{#each cards}}
        {{> dictionary-trick-row}}
      {{/each}}
    </div>
  </section>
  {{/each}}
  {{else}}
  <section class="content-section">
    <p class="detail-muted">
      <em>No tricks currently match any of the six Movement Neighborhood groupings. As the
      dictionary expands, groupings populate from base trick + modifier link data.</em>
    </p>
  </section>
  {{/if}}

  <p class="symbolic-layer-footer">Movement Neighborhoods group tricks that share a movement feel, timing pattern, or structural relationship across families. They are a way to explore similarity, not an official family classification. The <a href="/freestyle/tricks?view=family">By family</a> view remains the structural reference.</p>
  {{/if}}

  {{! ── Movement System view ──────────────────────────────────────────────
      Curator-authored four-axis ontology projecting modifier groups under
      pedagogical axes. Source: src/content/freestyleMovementSystems.ts.
      Axes shaped in declaration order; empty axes pruned. Modifier groups
      render in author order (no priority-by-frequency re-sort). }}
  {{#if (eq content.activeView "movement-system")}}
  <p class="browse-view-status-label"><strong>Exploratory / pedagogical — not canonical taxonomy.</strong></p>
  <p class="browse-view-intro"><strong>By movement system = the four higher-level conceptual axes</strong> (set/uptime · entry topology · midtime body · no-plant suspension). Each axis groups the modifiers that belong to it. The model also recognizes <strong>Alternative surfaces</strong> (tricks defined by an unusual catch surface), grouped separately below the four axes. To find every trick that uses a <em>specific</em> modifier (pixie, fairy, ducking, spinning, …), use <a href="/freestyle/tricks?view=sets">By modifier</a>. For "what IS this set system?", see the <a href="/freestyle/sets">Set Encyclopedia</a>.</p>
  <p class="movement-system-view-note">{{content.movementSystemView.observationalNote}}</p>
  {{#if content.movementSystemScale}}<p class="browse-view-scale">{{content.movementSystemScale}}</p>{{/if}}

  {{! Axis-jump nav. Mirror of the Component view's pattern. }}
  <nav class="movement-axis-jump" aria-label="Movement System axes">
    {{#each content.movementSystemView.axes}}
      <a href="#{{anchorId}}">{{axisName}}</a>{{#unless @last}} <span class="movement-axis-jump-sep">·</span> {{/unless}}
    {{/each}}
    {{#if content.movementSystemView.alternativeSurfaces.groups.length}} <span class="movement-axis-jump-sep">·</span> <a href="#alt-surfaces">Alternative surfaces</a>{{/if}}
  </nav>

  {{#if content.movementSystemView.axes.length}}
  {{#each content.movementSystemView.axes}}
  <section class="content-section trick-movement-axis" id="{{anchorId}}">
    <div class="section-heading">
      <h2>{{axisName}}</h2>
      <span class="section-count">{{groups.length}}</span>
    </div>
    <p class="movement-axis-definition">{{axisDefinition}}</p>
    {{#each groups}}
    <section class="trick-movement-group trick-group--trick-rows" id="{{anchorId}}" data-anchor-style="solid">
      <div class="movement-group-heading">
        <h3><a href="/freestyle/tricks?view=movement-system#{{anchorId}}">{{modifierName}}</a></h3>
        <span class="section-count">{{memberCount}}</span>
      </div>
      {{#if bodyDefinition}}
      <p class="movement-group-definition">{{bodyDefinition}}</p>
      {{/if}}
      {{#if compositionGloss}}
      <p class="movement-group-composition-gloss"><em>{{compositionGloss}}</em></p>
      {{/if}}
      <div class="dict-trick-row-stack">
        {{#each cards}}
          {{> dictionary-trick-row}}
        {{/each}}
      </div>
    </section>
    {{/each}}
  </section>
  {{/each}}
  {{else}}
  <section class="content-section">
    <p class="detail-muted">
      <em>No tricks currently link to a Movement System modifier. As the
      dictionary expands, axis sections populate from
      <code>freestyle_trick_modifier_links</code>.</em>
    </p>
  </section>
  {{/if}}

  {{! ── Alternative surfaces (compact educational subsection, 2026-05-24).
      Rendered after the 4 movement-system axes. Compact-list density
      (NOT registry density / NOT dictionary-trick-card). Each group
      shows trick name + ADD + raw op_notation as an inline list. Per
      the topology audit, this is the right surface for sparse-
      categorical exception data; a separate ?view= would waste the
      toggle slot. }}
  {{#if content.movementSystemView.alternativeSurfaces.groups.length}}
  <section class="content-section alt-surfaces" id="alt-surfaces" aria-label="Alternative surfaces">
    <div class="section-heading">
      <h2>Alternative surfaces</h2>
      <span class="section-count">{{content.movementSystemView.alternativeSurfaces.groups.length}}</span>
    </div>
    <p class="movement-axis-definition">{{content.movementSystemView.alternativeSurfaces.intro}}</p>
    {{#each content.movementSystemView.alternativeSurfaces.groups}}
    <section class="alt-surface-group" id="{{slug}}">
      <h3 class="alt-surface-group-label">{{label}}</h3>
      <p class="alt-surface-group-note">{{note}}</p>
      <ul class="alt-surface-trick-list">
        {{#each tricks}}
        <li class="alt-surface-trick">
          <a href="{{href}}">{{displayName}}</a>
          <span class="alt-surface-add">({{addsLabel}})</span>
          {{#if operationalNotation}}<code class="alt-surface-notation">{{operationalNotation}}</code>{{/if}}
        </li>
        {{/each}}
      </ul>
