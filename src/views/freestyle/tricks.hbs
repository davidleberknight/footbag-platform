{{! /freestyle/tricks — trick dictionary index }}

<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  {{! ── Beginner-first landing lede. The "New to freestyle? Start here"
      onboarding block leads the page so orientation, not a number, is the first
      thing a newcomer reads; the corpus-count line follows it (prominent near the
      top, supporting metadata, not the opening lede). Default landing only:
      secondary views and the family filter carry their own state-specific
      orientation, and the search box below leads on those. ── }}
  {{#if (eq content.activeView "add")}}
  {{#unless content.activeFamily}}
  {{#if content.landingOnboarding}}
  <aside class="dict-onboarding" aria-label="New to freestyle? Start here">
    <h2 class="dict-onboarding-heading">{{content.landingOnboarding.heading}}</h2>
    {{#each content.landingOnboarding.intro}}<p class="dict-onboarding-intro">{{this}}</p>{{/each}}
    {{#if content.landingOnboarding.definitions.length}}
    <dl class="dict-onboarding-defs">
      {{#each content.landingOnboarding.definitions}}<div class="dict-onboarding-def"><dt>{{term}}</dt><dd>{{plain}}</dd></div>{{/each}}
    </dl>
    {{/if}}
    <p class="dict-onboarding-example">
      <span class="dict-onboarding-example-label">{{content.landingOnboarding.example.label}}:</span>
      {{#each content.landingOnboarding.example.steps}}<span class="dict-onboarding-step"><strong>{{name}}</strong> <span class="dict-onboarding-step-note">{{note}}</span></span>{{#unless @last}} <span class="dict-onboarding-arrow">&rarr;</span> {{/unless}}{{/each}}
    </p>
    <ul class="dict-onboarding-lenses">
      {{#each content.landingOnboarding.lenses}}<li><strong>{{label}}</strong> <span class="dict-onboarding-lens-note">{{note}}</span></li>{{/each}}
    </ul>
    <p class="dict-onboarding-links">
      {{#each content.landingOnboarding.links}}<a href="{{href}}">{{label}}</a>{{#unless @last}} <span class="dict-onboarding-link-sep">·</span> {{/unless}}{{/each}}
    </p>
  </aside>
  {{/if}}
  {{#if content.dictionaryStats}}
  <p class="browse-view-scale">{{content.dictionaryStats}}</p>
  {{/if}}
  {{/unless}}
  {{/if}}

  {{! ── Trick search: name/alias lookup. Submits to the dedicated search page
      (typeahead lives there); works without JS. Placed after the orientation
      intro so beginner context leads the page. ── }}
  <div class="card search-box-card">
    <div class="search-box-section">
      <form method="GET" action="/freestyle/search" class="search-box-form" role="search">
        <input type="text" name="q" minlength="2" maxlength="100"
               placeholder="Name or alias"
               aria-label="Search tricks by name or alias"
               title="Search tricks by name or alias"
               autocomplete="off"
               class="search-box-input" />
        <button type="submit" class="btn btn-primary">Search</button>
      </form>
    </div>
  </div>

  {{! ── Landing grid: 3-band conceptual map of the
      dictionary's browse axes. Renders ONLY on the default landing view
      (?view=add, the default) to orient first-time readers. On secondary
      views (?view=family, ?view=sets, etc.) the inline view-toggle below
      handles persistent quick-switching nav. Emerging Vocabulary lives
      under the third band (Tracking & Expansion), promoted from its
      previous separate footer-style paragraph. }}
  {{#if (eq content.activeView "add")}}
  {{#unless content.activeFamily}}
  <div class="dict-landing-grid" aria-label="Dictionary browse axes">
    {{#each content.landingGrid.bands}}
    <section class="dict-landing-band">
      <p class="dict-landing-band-eyebrow">{{eyebrow}}</p>
      <div class="dict-landing-band-cards">
        {{#each cards}}
        <article class="dict-landing-card">
          <header class="dict-landing-card-header">
            <h2 class="dict-landing-card-label"><a href="{{href}}">{{label}}</a></h2>
            <span class="dict-landing-card-count" aria-label="{{countDisplay}} {{countSuffix}}"><span class="dict-landing-card-count-num">{{countDisplay}}</span> {{countSuffix}}</span>
          </header>
          <p class="dict-landing-card-question">{{lensQuestion}}</p>
          {{#if chips.length}}
          <p class="dict-landing-card-chips" aria-label="Jump to section">
            {{#each chips}}<a class="dict-landing-card-chip" href="{{href}}">{{label}}{{#if count}} <span class="dict-landing-card-chip-count">{{count}}</span>{{/if}}</a>{{#unless @last}} <span class="dict-landing-card-chip-sep">·</span> {{/unless}}{{/each}}
          </p>
          {{/if}}
          <p class="dict-landing-card-open"><a href="{{href}}">Open &rarr;</a></p>
          {{#if crossLink}}
          <p class="dict-landing-card-crosslink"><a href="{{crossLink.href}}">{{crossLink.label}}</a></p>
          {{/if}}
        </article>
        {{/each}}
      </div>
    </section>
    {{/each}}
  </div>
  {{/unless}}
  {{/if}}

  {{#if content.activeFamily}}
  <p class="browse-view-intro">{{content.familyFilterIntro}}
    <a class="dictionary-intro-glossary-link" href="/freestyle/glossary">New to the dictionary? Open the glossary &rarr;</a>
    &nbsp;<a href="/freestyle/tricks">Clear the filter</a> to see the full dictionary.</p>
  {{#if content.relatedSetGroups.length}}
  <nav class="related-set-groups" aria-label="Related set or modifier groups">
    <span class="related-set-groups-label">Related set/modifier groups:</span>
    {{#each content.relatedSetGroups}}
      <a class="related-set-group-link" href="{{{href}}}">{{modifierName}} <span class="related-set-group-count">({{count}})</span></a>{{#unless @last}} <span class="related-set-group-sep">·</span> {{/unless}}
    {{/each}}
  </nav>
  {{/if}}
  {{/if}}

  {{! ── Browse navigation. "By ADD" is the default; the other systems are
      secondary ways to navigate the same movement universe. No JavaScript;
      view selected via the ?view= query param. ── }}
  <nav class="trick-view-toggle" aria-label="Browse the dictionary">
    {{#if (eq content.activeView "add")}}
      <span class="trick-view-toggle-active">By ADD</span>
    {{else}}
      <a href="/freestyle/tricks?view=add">By ADD</a>
    {{/if}}
    <span class="trick-view-toggle-sep">·</span>
    {{#if (eq content.activeView "family")}}
      <span class="trick-view-toggle-active">By family</span>
    {{else}}
      <a href="/freestyle/tricks?view=family">By family</a>
    {{/if}}
    <span class="trick-view-toggle-sep">·</span>
    {{#if (eq content.activeView "movement-system")}}
      <span class="trick-view-toggle-active">By movement system</span>
    {{else}}
      <a href="/freestyle/tricks?view=movement-system">By movement system</a>
    {{/if}}
    <span class="trick-view-toggle-sep">·</span>
    {{#if (eq content.activeView "topology")}}
      <span class="trick-view-toggle-active">Movement Neighborhoods</span>
    {{else}}
      <a href="/freestyle/tricks?view=topology">Movement Neighborhoods</a>
    {{/if}}
    <span class="trick-view-toggle-sep">·</span>
    {{#if (eq content.activeView "dex-count")}}
      <span class="trick-view-toggle-active">By dex count</span>
    {{else}}
      <a href="/freestyle/tricks?view=dex-count">By dex count</a>
    {{/if}}
    <span class="trick-view-toggle-sep">·</span>
    {{#if (eq content.activeView "sets")}}
      <span class="trick-view-toggle-active">By modifier</span>
    {{else}}
      <a href="/freestyle/tricks?view=sets">By modifier</a>
    {{/if}}
  </nav>
  {{#unless (eq content.activeView "add")}}
  {{! Secondary-view reachability for cross-link surfaces. On the default
      landing view, the dict-landing-grid above carries Operators / Set
      Encyclopedia cross-links in their respective cards; on secondary
      views, this aside paragraph preserves reachability without requiring
      a return trip to the landing. }}
  <p class="trick-view-toggle-aside">New to the dictionary? Start with the <a href="/freestyle/glossary">glossary</a>. For modifier and operator vocabulary, see the <a href="/freestyle/operators">Operators &amp; Modifiers reference</a> (not a dictionary browse axis; it's vocabulary that helps you read trick names). For set systems as first-class objects (what is pixie / stepping / atomic as a system?), see the <a href="/freestyle/sets">Set Encyclopedia</a>.</p>
  {{/unless}}

  {{! ── Default ADD-grouped view — two-line row contract.
       Every row: line 1 = name/hashtag/≡interpretation/media; line 2 =
       JOB: + ADD:. No green ADD chip (the value is in the section header
       + the line-2 ADD: formula). See dictionary-trick-row.hbs. }}
  {{#if (eq content.activeView "add")}}
  {{! Within-tier browse mode: Alphabetical (default, flat A-Z for lookup) or
      By family (nearest-anchor family bands in public-family order). Selected
      via ?sort=; server-rendered, no JavaScript. }}
  <nav class="trick-view-toggle" aria-label="Sort within each ADD tier">
    {{#if (eq content.addSort "alpha")}}
      <a href="/freestyle/tricks?view=add&amp;sort=family">By family</a>
      <span class="trick-view-toggle-sep">·</span>
      <span class="trick-view-toggle-active">Alphabetical</span>
    {{else}}
      <span class="trick-view-toggle-active">By family</span>
      <span class="trick-view-toggle-sep">·</span>
      <a href="/freestyle/tricks?view=add&amp;sort=alpha">Alphabetical</a>
    {{/if}}
  </nav>
  {{#if content.addJumpChips.length}}
  <nav class="add-jump" aria-label="Jump to ADD level">
    <span class="add-jump-label">Jump to:</span>
    {{#each content.addJumpChips}}
      <a href="{{href}}">{{label}}</a>{{#unless @last}} <span class="component-axis-jump-sep">·</span> {{/unless}}
    {{/each}}
  </nav>
  {{/if}}
  {{#each content.addGroups}}
  <section class="content-section trick-add-group" id="{{anchorId}}">
    <div class="section-heading">
      <h2>{{addLabel}}</h2>
      <span class="section-count">{{cards.length}}</span>
    </div>
    {{#if (eq @root.content.addSort "alpha")}}
    {{! Alphabetical: flat A-Z across the whole tier, by canonical name. }}
    <div class="dict-trick-row-stack">
      {{#each cards}}
        {{> dictionary-trick-row}}
      {{/each}}
    </div>
    {{else}}
    {{! By family: nearest-anchor family bands in public-family order; the
        "Other / standalone tricks" band trails, alphabetized. Family parents
        / minor lineages only — no surface/root buckets. }}
    {{#each lineageBands}}
    <div class="trick-add-lineage">
      <h3 class="add-lineage-header">{{rootLabel}}</h3>
      <div class="dict-trick-row-stack">
        {{#each cards}}
          {{> dictionary-trick-row}}
        {{/each}}
      </div>
    </div>
    {{/each}}
    {{/if}}
  </section>
  {{/each}}
  {{/if}}

  {{! ── Dex Count view — two-line row contract.
      Buckets active tricks by the number of [DEX] tokens in their operational
      notation. Same generalized dictionary-trick-row partial as the ADD and
      Family views; only the bucketing axis differs. }}
  {{#if (eq content.activeView "dex-count")}}
  {{#if content.dexCountIntro}}<p class="browse-view-intro">{{content.dexCountIntro}}</p>{{/if}}
  {{#if content.dexCountScale}}<p class="browse-view-scale">{{content.dexCountScale}}</p>{{/if}}
  {{! In-view jump nav (mirrors By ADD). Static hash anchors into each dex bucket. }}
  {{#if content.dexCountGroups.length}}
  <nav class="add-jump" aria-label="Jump to dex bucket">
    <span class="add-jump-label">Jump to:</span>
    {{#each content.dexCountGroups}}
      <a href="#{{bucketId}}">{{dexLabel}} <span class="family-jump-count">{{cards.length}}</span></a>{{#unless @last}} <span class="component-axis-jump-sep">·</span> {{/unless}}
    {{/each}}
  </nav>
  {{/if}}
  {{#each content.dexCountGroups}}
  <section class="content-section trick-dex-count-group" id="{{bucketId}}">
    <div class="section-heading">
      <h2>{{dexLabel}}</h2>
      <span class="section-count">{{cards.length}}</span>
    </div>
    {{! Secondary ADD bands: cards are ordered by ADD, each run gets a header. }}
    {{#each addBands}}
    <div class="trick-add-lineage">
      <h3 class="add-lineage-header">{{addLabel}}</h3>
      <div class="dict-trick-row-stack">
        {{#each cards}}
          {{> dictionary-trick-row}}
        {{/each}}
      </div>
    </div>
    {{/each}}
  </section>
  {{/each}}
  {{/if}}

  {{! ── Set Hub view.
      Sets are first-class ontology objects, not trick-grouped browse
      filters. Six subtype sections; each card carries hashtag, formula,
      movement explanation, equivalence readings, derived / related
      systems, and provenance. Per-set detail pages live at
      /freestyle/sets/<slug>. }}
  {{! ── By Set view — modifier-grouped trick lists (answers "which tricks
       use this set?"). Distinct from the Set Encyclopedia at /freestyle/sets
       which answers "what is this set system?" — that surface remains
       separate and intentional. This view uses content.setGroups (the
       trick-grouping projection); content.setsBrowseView (the encyclopedia
       projection) is reserved for /freestyle/sets. }}
  {{#if (eq content.activeView "sets")}}
  {{#if content.setsIntro}}<p class="browse-view-intro">{{content.setsIntro}} For what a set system actually is, see the <a href="/freestyle/sets">Set Encyclopedia</a>.</p>{{/if}}
  <p class="browse-view-lens-note detail-muted">These cluster totals count tricks by the modifier they use, so they will not match the grouping totals in <a href="/freestyle/tricks?view=movement-system">By movement system</a>, which sorts some of the same modifiers into different groups. The two are different lenses on the same tricks, not the same tally.</p>
  {{#if content.setsScale}}<p class="browse-view-scale">{{content.setsScale}}</p>{{/if}}
  {{#if content.setsClusterView.length}}
  <p class="sets-view-total detail-muted"><strong>{{content.setsClusterView.length}}</strong> modifier clusters, each banded by operator count.</p>

  <nav class="sets-view-jump" aria-label="Modifier cluster jump">
    {{#each content.setsClusterView}}
      <a href="#cluster-{{key}}">{{label}}</a>{{#unless @last}} <span class="component-axis-jump-sep">·</span> {{/unless}}
    {{/each}}
  </nav>

  {{#each content.setsClusterView}}
  <section class="content-section" id="cluster-{{key}}" data-anchor-style="solid">
    <div class="section-heading">
      <h2>{{label}}</h2>
      <span class="section-count">{{trickCount}}</span>
    </div>
    <p class="sets-cluster-blurb detail-muted">{{blurb}}</p>
    {{#each bands}}
    <section class="trick-set-group" data-anchor-style="dotted">
      <div class="section-heading">
        <h3>{{label}}</h3>
        <span class="section-count">{{cards.length}}</span>
      </div>
      <div class="dict-trick-row-stack">
        {{#each cards}}
          {{> dictionary-trick-row}}
        {{/each}}
      </div>
    </section>
    {{/each}}
  </section>
  {{/each}}
  {{else}}
  <section class="content-section">
    <p class="detail-muted"><em>No tricks currently link to a registered modifier. As the dictionary expands, this view populates from <code>freestyle_trick_modifier_links</code>.</em></p>
  </section>
  {{/if}}
  {{/if}}

  {{! ── Family view — two-line row contract.
      Same generalized dictionary-trick-row partial as the ADD view; only the
      grouping (family sections + family-anchor sublabel) differs. }}
  {{#if (eq content.activeView "family")}}
  {{#if content.familyViewIntro}}
  <p class="browse-view-intro">{{content.familyViewIntro}}</p>
  {{/if}}
  <p class="family-view-ordering-note"><em>Families are listed in the dictionary's canonical order: the root families first, then the derived branch families (torque and blender under osis; double legover and eggbeater under legover).</em></p>
  {{#if content.familyScale}}<p class="browse-view-scale">{{content.familyScale}}</p>{{/if}}
  {{! Family jump index. Static hash-anchor chips (no JS), grouped into root
      families and derived branch families, plus a link to the minor-lineages
      band. Lets readers skip between family sections without scrolling. }}
  {{#if content.familyJumpIndex.roots.length}}
  <nav class="family-jump" aria-label="Jump to family">
    <span class="family-jump-label">Root families:</span>
    {{#each content.familyJumpIndex.roots}}
      <a href="{{anchor}}">{{name}} <span class="family-jump-count">{{count}}</span></a>{{#unless @last}} <span class="component-axis-jump-sep">·</span> {{/unless}}
    {{/each}}
    {{#if content.familyJumpIndex.branches.length}}
    <span class="family-jump-label family-jump-label--branch">Derived / branch:</span>
    {{#each content.familyJumpIndex.branches}}
      <a href="{{anchor}}">{{name}} <span class="family-jump-count">{{count}}</span></a>{{#unless @last}} <span class="component-axis-jump-sep">·</span> {{/unless}}
    {{/each}}
    {{/if}}
    {{#if content.familyJumpIndex.hasMinorLineages}}
    <span class="family-jump-label family-jump-label--minor">Minor lineages:</span>
    <a href="#minor-lineages">All minor lineages</a>
    {{/if}}
  </nav>
  {{/if}}
  {{#if content.familyGroups.length}}
  {{#each content.familyGroups}}
  <section class="content-section trick-family-group" id="family-{{familySlug}}" data-anchor-style="solid">
    <div class="section-heading">
      <h2><a href="/freestyle/tricks?family={{familySlug}}">{{familyName}} family</a></h2>
      <span class="section-count">{{cards.length}}</span>
    </div>
    {{#if branchParentName}}
    <p class="trick-family-branch-of">Branch of the {{branchParentName}} family.</p>
    {{/if}}
    {{! Family-anchor sub-label. Names
        the canonical family-anchor trick so readers connect the
        glossary's "family-anchor trick" vocabulary to the dictionary
        surface. The name links to the family page when one exists (the
        primary explanation of the family), otherwise to the anchor trick. }}
    <p class="trick-family-anchor-sublabel"><span class="trick-family-anchor-label">Family-anchor:</span> {{#if familyAnchorHref}}<a class="trick-family-anchor-link" href="{{familyAnchorHref}}">{{familyName}}</a>{{else}}<span class="trick-family-anchor-link">{{familyName}}</span>{{/if}}</p>
    {{! Family-level shared-terminal-structure invariant. Curator-authored per
        family slug; rendered between the heading and the card stack.
        Source: src/content/freestyleFamilyInvariants.ts. }}
    {{#if sharedStructure}}
    <p class="trick-family-shared-structure">Shared terminal structure: <code>{{sharedStructure}}</code></p>
    {{/if}}
    {{#if crossLink}}
    <p class="trick-family-cross-link"><a href="{{crossLink.href}}">{{crossLink.label}} &rarr;</a></p>
    {{/if}}
    {{! Operator-rung bands: simplest/base forms first, then 1-, 2-, 3+-operator
        forms. Band headers show only when a family spans more than one rung
        (showRungLabels), so single-rung families stay header-free. }}
    {{#each rungGroups}}
    <div class="trick-family-rung">
      {{#if ../showRungLabels}}<h3 class="family-rung-header">{{label}}</h3>{{/if}}
      <div class="dict-trick-row-stack">
        {{#each cards}}
          {{> dictionary-trick-row}}
        {{/each}}
      </div>
    </div>
    {{/each}}
  </section>
  {{/each}}
  {{/if}}
  {{#if content.minorLineages.length}}
  <section class="content-section trick-minor-lineage-band" id="minor-lineages" aria-label="Minor lineages">
    <div class="section-heading">
      <h2>Minor lineages</h2>
      <span class="section-count">{{content.minorLineages.length}}</span>
    </div>
    <p class="trick-minor-lineage-intro">Small trick groups that share a landing, but do not have enough documented descendants to be treated as full families. They are real and browsable; they just stay below the main family list.</p>
    <ul class="trick-minor-lineage-list">
      {{#each content.minorLineages}}
      <li><a href="/freestyle/tricks?family={{slug}}">{{name}}</a> <span class="trick-minor-lineage-count">{{count}}</span></li>
      {{/each}}
    </ul>
  </section>
  {{/if}}
  {{/if}}

  {{! ── Component view — symbolic trick cards ──────────────────────────────
       Soft-retired: the toggle entry is absent from the view-toggle row
       above, so the only paths reaching this view are bookmarked or
       external links, which must keep resolving.
       Movement System (?view=movement-system) is the canonical
       modifier-grouped browse surface. }}
  {{#if (eq content.activeView "component")}}
  <div class="component-view-retirement-notice" role="status" aria-live="polite">
    <p>
      <strong>This view is being retired.</strong> The
      <a href="/freestyle/tricks?view=movement-system">By Movement System</a>
      view groups tricks by modifier within four pedagogical axes
      (set / uptime · entry topology · midtime body · no-plant suspension)
      and is now the canonical modifier-grouped browse surface.
    </p>
    <p class="component-view-retirement-notice-detail">
      This page still renders so bookmarks and external links keep
      resolving, but new discovery happens through Movement System.
    </p>
  </div>
  <p class="component-view-note">{{content.componentView.duplicationNote}}</p>

  {{! Axis-jump nav. Static; no JS. Hash anchors only. }}
  <nav class="component-axis-jump" aria-label="Component axes">
    {{#each content.componentView.axes}}
      {{#if groups.length}}
      <a href="#{{anchorId}}">{{axisLabel}}</a>{{#unless @last}} <span class="component-axis-jump-sep">·</span> {{/unless}}
      {{/if}}
    {{/each}}
  </nav>

  {{#each content.componentView.axes}}
    {{#if groups.length}}
    <section class="content-section trick-component-axis" id="{{anchorId}}">
      <div class="section-heading">
        <h2>{{axisLabel}}</h2>
        <span class="section-count">{{groups.length}}</span>
      </div>
      {{#each groups}}
      <section class="trick-component-group" id="{{anchorId}}" data-anchor-style="solid">
        <div class="component-group-heading">
          <h3><a href="/freestyle/tricks?view=component#{{anchorId}}">{{componentName}}</a></h3>
          <span class="section-count">{{memberCount}}</span>
        </div>
        {{#if bodyDefinition}}
        <p class="component-group-definition">{{bodyDefinition}}</p>
        {{/if}}
        <div class="dict-card-stack dict-card-stack--registry">
          {{#each cards}}
            {{> dictionary-trick-card density="registry"}}
          {{/each}}
        </div>
      </section>
      {{/each}}
    </section>
    {{/if}}
  {{/each}}

  {{#unless content.componentView.axes.0.groups.length}}
  {{#unless content.componentView.axes.1.groups.length}}
  {{#unless content.componentView.axes.2.groups.length}}
  <section class="content-section">
    <p class="detail-muted">
      <em>No tricks currently link to a registered body, entry-topology, or set
      modifier. As the dictionary expands, this view will populate from
      <code>freestyle_trick_modifier_links</code>.</em>
    </p>
  </section>
  {{/unless}}
  {{/unless}}
  {{/unless}}
  {{/if}}

  {{! ── Category view — registry density (dense tag-based scan) ────────────
       Soft-retired: the toggle entry is absent from the view-toggle row
       above; the route still resolves so bookmarks and external links
       keep working. Family + Movement System are the canonical
       replacements. }}
  {{#if (eq content.activeView "category")}}
  <div class="category-view-retirement-notice" role="status" aria-live="polite">
    <p>
      <strong>This view is being retired.</strong> The
      <a href="/freestyle/tricks?view=family">By Family</a> view groups
      dex-anchored tricks by structural lineage, and the
      <a href="/freestyle/tricks?view=movement-system">By Movement System</a>
      view groups body and set primitives by pedagogical axis. The
      grammatical buckets (dex / body / set / compound) duplicate those
      organizations with lower density.
    </p>
    <p class="category-view-retirement-notice-detail">
      This page still renders so bookmarks and external links keep
      resolving, but new discovery happens through Family and Movement
      System.
    </p>
  </div>
  {{#each content.groups}}
  <section class="content-section trick-category-group" id="{{anchorId}}">
    <div class="section-heading">
      <h2><a href="/freestyle/tricks?view=category#{{anchorId}}">{{label}}</a></h2>
      <span class="section-count">{{cards.length}}</span>
    </div>
    <div class="dict-card-stack dict-card-stack--registry">
      {{#each cards}}
        {{> dictionary-trick-card density="registry"}}
      {{/each}}
    </div>
  </section>
  {{/each}}
  {{/if}}

  {{! ── Movement Neighborhoods view. The public label is "Movement
       Neighborhoods" while the backend slug + URL parameter
       `?view=topology` are preserved for URL stability. ── }}
  {{#if (eq content.activeView "topology")}}
  <p class="browse-view-status-label"><strong>An exploratory view, not an official grouping.</strong></p>
  <p class="topology-view-note">
    {{content.topologyView.observationalNote}}
  </p>
  {{#if content.topologyScale}}<p class="browse-view-scale">{{content.topologyScale}}</p>{{/if}}

  {{#if content.topologyView.groups.length}}
  <nav class="topology-jump" aria-label="Movement Neighborhood categories">
    {{#each content.topologyView.groups}}
      <a href="#{{anchorId}}">{{topologyName}}</a>{{#unless @last}} <span class="topology-jump-sep">·</span> {{/unless}}
    {{/each}}
  </nav>
  {{#each content.topologyView.groups}}
  <section class="content-section trick-topology-group" id="{{anchorId}}" data-anchor-style="dotted">
    <div class="section-heading">
      <h2><a href="/freestyle/tricks?view=topology#{{anchorId}}">{{topologyName}}</a></h2>
      <span class="section-count">{{memberCount}}</span>
    </div>
    <p class="topology-group-definition">{{bodyDefinition}}</p>
    {{! Secondary ADD bands: cards are ordered by ADD, each run gets a header. }}
    {{#each addBands}}
    <div class="trick-add-lineage">
      <h3 class="add-lineage-header">{{addLabel}}</h3>
      <div class="dict-trick-row-stack">
        {{#each cards}}
          {{> dictionary-trick-row}}
        {{/each}}
      </div>
    </div>
    {{/each}}
  </section>
  {{/each}}
  {{else}}
  <section class="content-section">
    <p class="detail-muted">
      <em>No tricks currently match any of the six Movement Neighborhood groupings. As the
      dictionary expands, groupings populate from base trick + modifier link data.</em>
    </p>
  </section>
  {{/if}}

  <p class="symbolic-layer-footer">Movement Neighborhoods group tricks that share a movement feel, timing pattern, or structural relationship across families. They are a way to explore similarity, not an official family classification. The <a href="/freestyle/tricks?view=family">By family</a> view remains the structural reference.</p>
  {{/if}}

  {{! ── Movement System view ──────────────────────────────────────────────
      Curator-authored four-axis ontology projecting modifier groups under
      pedagogical axes. Source: src/content/freestyleMovementSystems.ts.
      Axes shaped in declaration order; empty axes pruned. Modifier groups
      render in author order (no priority-by-frequency re-sort). }}
  {{#if (eq content.activeView "movement-system")}}
  <p class="browse-view-status-label"><strong>An exploratory view, not an official grouping.</strong></p>
  <p class="browse-view-intro">{{content.movementSystemIntro}} To find every trick that uses a specific modifier (pixie, fairy, ducking, spinning, and so on), use <a href="/freestyle/tricks?view=sets">By modifier</a>. For what a set system actually is, see the <a href="/freestyle/sets">Set Encyclopedia</a>.</p>
  <p class="browse-view-lens-note detail-muted">Each grouping total here counts the distinct tricks in that movement grouping. It will not match the per-cluster totals in <a href="/freestyle/tricks?view=sets">By modifier</a>, because the two views place some modifiers in different groups. They are different lenses on the same tricks.</p>
  <p class="movement-system-view-note">{{content.movementSystemView.observationalNote}}</p>
  {{#if content.movementSystemScale}}<p class="browse-view-scale">{{content.movementSystemScale}}</p>{{/if}}

  {{! Axis-jump nav. Mirror of the Component view's pattern. }}
  <nav class="movement-axis-jump" aria-label="Movement System axes">
    {{#each content.movementSystemView.axes}}
      <a href="#{{anchorId}}">{{axisName}}</a>{{#unless @last}} <span class="movement-axis-jump-sep">·</span> {{/unless}}
    {{/each}}
    {{#if content.movementSystemView.alternativeSurfaces.groups.length}} <span class="movement-axis-jump-sep">·</span> <a href="#alt-surfaces">Alternative surfaces</a>{{/if}}
  </nav>

  {{#if content.movementSystemView.axes.length}}
  {{#each content.movementSystemView.axes}}
  <section class="content-section trick-movement-axis" id="{{anchorId}}">
    <div class="section-heading">
      <h2>{{axisName}}</h2>
      <span class="section-count">{{cards.length}}</span>
    </div>
    <p class="movement-axis-definition">{{axisDefinition}}</p>
    {{! Secondary ADD bands: cards are ordered by ADD, each run gets a header. }}
    {{#each addBands}}
    <div class="trick-add-lineage">
      <h3 class="add-lineage-header">{{addLabel}}</h3>
      <div class="dict-trick-row-stack">
        {{#each cards}}
          {{> dictionary-trick-row}}
        {{/each}}
      </div>
    </div>
    {{/each}}
  </section>
  {{/each}}
  {{else}}
  <section class="content-section">
    <p class="detail-muted">
      <em>No tricks currently link to a Movement System modifier. As the
      dictionary expands, axis sections populate from
      <code>freestyle_trick_modifier_links</code>.</em>
    </p>
  </section>
  {{/if}}

  {{! ── Alternative surfaces. A browse section organized on one principle:
      what surface the bag is controlled on. Each group renders the shared
      dictionary-trick-row, so its rows match every other browse view (name
      + Trick Detail link + media hashtag, JOB and ADD on the second line). }}
  {{#if content.movementSystemView.alternativeSurfaces.groups.length}}
  <section class="content-section alt-surfaces" id="alt-surfaces" aria-label="Alternative surfaces">
    <div class="section-heading">
      <h2>Alternative surfaces</h2>
      <span class="section-count">{{content.movementSystemView.alternativeSurfaces.groups.length}}</span>
    </div>
    <p class="movement-axis-definition">{{content.movementSystemView.alternativeSurfaces.intro}}</p>
    {{#each content.movementSystemView.alternativeSurfaces.groups}}
    <section class="alt-surface-group" id="{{slug}}">
      <h3 class="alt-surface-group-label">{{label}}</h3>
      <p class="alt-surface-group-note">{{note}}</p>
      <div class="dict-trick-row-stack">
        {{#each cards}}
          {{> dictionary-trick-row}}
        {{/each}}
      </div>
    </section>
    {{/each}}
  </section>
  {{/if}}
  {{/if}}

  <p class="source-note">
    Trick data sourced from community documentation.
    ADD values reflect the standard difficulty scoring system;
    see <a href="/freestyle/add-analysis">ADD Accounting &amp; Analysis</a> for
    a step-by-step walkthrough of how totals are constructed, with worked
    examples and discrepancy case studies.
    Tricks with documented records are linked to their record pages.
  </p>

</div>
