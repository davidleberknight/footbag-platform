{{! /freestyle/tricks — trick dictionary index }}

<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
    <div class="hero-stats">
      <span>{{content.totalTricks}} canonical tricks</span>
      {{#if content.coverage.externalOnlyCount}}<span>{{content.coverage.externalOnlyCount}} external placeholders</span>{{/if}}
    </div>
    <p class="hero-cross-link"><a href="/freestyle/glossary">Learn the language &rarr;</a></p>
  </div>
</div>

<div class="wrapper">

  {{#if content.activeFamily}}
  <p class="family-filter-pill">
    Filtering by family: <strong>{{content.activeFamily}}</strong>
    &nbsp;<a href="/freestyle/tricks">Clear filter</a>
  </p>
  {{#if content.relatedSetGroups.length}}
  <nav class="related-set-groups" aria-label="Related set or modifier groups">
    <span class="related-set-groups-label">Related set/modifier groups:</span>
    {{#each content.relatedSetGroups}}
      <a class="related-set-group-link" href="{{{href}}}">{{modifierName}} <span class="related-set-group-count">({{count}})</span></a>{{#unless @last}} <span class="related-set-group-sep">·</span> {{/unless}}
    {{/each}}
  </nav>
  {{/if}}
  {{/if}}

  {{! ── View toggle (no JS; query-string driven) ─────────────────────────── }}
  <nav class="trick-view-toggle" aria-label="Dictionary view">
    {{#if (eq content.activeView "add")}}
      <span class="trick-view-toggle-active">By ADD</span>
    {{else}}
      <a href="/freestyle/tricks">By ADD</a>
    {{/if}}
    <span class="trick-view-toggle-sep">·</span>
    {{#if (eq content.activeView "family")}}
      <span class="trick-view-toggle-active">By family</span>
    {{else}}
      <a href="/freestyle/tricks?view=family">By family</a>
    {{/if}}
    <span class="trick-view-toggle-sep">·</span>
    {{#if (eq content.activeView "category")}}
      <span class="trick-view-toggle-active">By category</span>
    {{else}}
      <a href="/freestyle/tricks?view=category">By category</a>
    {{/if}}
    <span class="trick-view-toggle-sep">·</span>
    {{#if (eq content.activeView "component")}}
      <span class="trick-view-toggle-active">By component</span>
    {{else}}
      <a href="/freestyle/tricks?view=component">By component</a>
    {{/if}}
    <span class="trick-view-toggle-sep">·</span>
    {{#if (eq content.activeView "topology")}}
      <span class="trick-view-toggle-active">By topology</span>
    {{else}}
      <a href="/freestyle/tricks?view=topology">By topology</a>
    {{/if}}
  </nav>

  {{! ── Coverage summary ─────────────────────────────────────────────────── }}
  <section class="trick-coverage-summary" aria-label="Coverage summary">
    <p class="trick-coverage-counts">
      <strong>{{content.coverage.canonicalCount}}</strong> canonical tricks
      {{#if content.coverage.externalOnlyCount}} · <strong>{{content.coverage.externalOnlyCount}}</strong> external-only placeholders{{/if}}
      {{#if content.coverage.sourcesLoaded.length}} · sources loaded: {{#each content.coverage.sourcesLoaded}}{{#unless @first}}, {{/unless}}{{this}}{{/each}}{{/if}}
      {{#if content.coverage.sourcesUnavailable.length}} · sources unavailable: {{#each content.coverage.sourcesUnavailable}}{{#unless @first}}, {{/unless}}{{this}}{{/each}}{{/if}}
    </p>
    <p class="trick-coverage-note"><em>{{content.coverage.transparencyNote}}</em></p>
  </section>

  {{#if content.dictNote}}
  <p class="detail-muted dict-note"><em>{{content.dictNote}}</em></p>
  {{/if}}

  {{! ── Default ADD-grouped view — registry density per BROWSE-REFACTOR-1 ── }}
  {{#if (eq content.activeView "add")}}
  {{#each content.addGroups}}
  <section class="content-section trick-add-group trick-group--registry" id="add-{{#if addNumeric}}{{addNumeric}}{{else}}unrated{{/if}}">
    <div class="section-heading">
      <h2>{{addLabel}}</h2>
      <span class="section-count">{{cards.length}}</span>
    </div>
    <div class="dict-card-stack dict-card-stack--registry">
      {{#each cards}}
        {{> dictionary-trick-card density="registry"}}
      {{/each}}
    </div>
  </section>
  {{/each}}
  {{/if}}

  {{! ── Family view — browse density (family-anchor underline emphasis) ─── }}
  {{#if (eq content.activeView "family")}}
  {{#if content.familyGroups.length}}
  {{#each content.familyGroups}}
  <section class="content-section trick-family-group trick-group--browse" id="family-{{familySlug}}" data-anchor-style="solid">
    <div class="section-heading">
      <h2><a href="/freestyle/tricks?family={{familySlug}}">{{familyName}} family</a></h2>
      <span class="section-count">{{cards.length}}</span>
    </div>
    {{#if crossLink}}
    <p class="trick-family-cross-link"><a href="{{crossLink.href}}">{{crossLink.label}} &rarr;</a></p>
    {{/if}}
    <div class="dict-card-stack">
      {{#each cards}}
        {{> dictionary-trick-card density="browse"}}
      {{/each}}
    </div>
  </section>
  {{/each}}
  {{/if}}
  {{/if}}

  {{! ── Component view — symbolic trick cards (DSC-2 slice 3A) ───────────── }}
  {{#if (eq content.activeView "component")}}
  <p class="component-view-note">{{content.componentView.duplicationNote}}</p>

  {{! Axis-jump nav. Static; no JS. Hash anchors only. }}
  <nav class="component-axis-jump" aria-label="Component axes">
    {{#each content.componentView.axes}}
      {{#if groups.length}}
      <a href="#{{anchorId}}">{{axisLabel}}</a>{{#unless @last}} <span class="component-axis-jump-sep">·</span> {{/unless}}
      {{/if}}
    {{/each}}
  </nav>

  {{#each content.componentView.axes}}
    {{#if groups.length}}
    <section class="content-section trick-component-axis" id="{{anchorId}}">
      <div class="section-heading">
        <h2>{{axisLabel}}</h2>
        <span class="section-count">{{groups.length}}</span>
      </div>
      {{#each groups}}
      <section class="trick-component-group trick-group--browse" id="{{anchorId}}" data-anchor-style="solid">
        <div class="component-group-heading">
          <h3><a href="/freestyle/tricks?view=component#{{anchorId}}">{{componentName}}</a></h3>
          <span class="section-count">{{memberCount}}</span>
        </div>
        {{#if bodyDefinition}}
        <p class="component-group-definition">{{bodyDefinition}}</p>
        {{/if}}
        <div class="dict-card-stack">
          {{#each cards}}
            {{> dictionary-trick-card density="browse"}}
          {{/each}}
        </div>
      </section>
      {{/each}}
    </section>
    {{/if}}
  {{/each}}

  {{#unless content.componentView.axes.0.groups.length}}
  {{#unless content.componentView.axes.1.groups.length}}
  <section class="content-section">
    <p class="detail-muted">
      <em>No tricks currently link to a registered body or set modifier. As the
      dictionary expands, this view will populate from
      <code>freestyle_trick_modifier_links</code>.</em>
    </p>
  </section>
  {{/unless}}
  {{/unless}}
  {{/if}}

  {{! ── Category view — registry density (dense tag-based scan) ──────────── }}
  {{#if (eq content.activeView "category")}}
  {{#each content.groups}}
  <section class="content-section trick-category-group trick-group--registry" id="{{anchorId}}">
    <div class="section-heading">
      <h2><a href="/freestyle/tricks?view=category#{{anchorId}}">{{label}}</a></h2>
      <span class="section-count">{{cards.length}}</span>
    </div>
    <div class="dict-card-stack dict-card-stack--registry">
      {{#each cards}}
        {{> dictionary-trick-card density="registry"}}
      {{/each}}
    </div>
  </section>
  {{/each}}
  {{/if}}

  {{! ── Topology view — observational symbolic-grammar layer (DSC-2 topology slice) ── }}
  {{#if (eq content.activeView "topology")}}
  <p class="topology-view-note">
    {{content.topologyView.observationalNote}}
    <span class="symbolic-layer-badge" title="Observational symbolic-grammar layer — supplementary; does not change canonical classifications">observational</span>
  </p>

  {{#if content.topologyView.groups.length}}
  {{#each content.topologyView.groups}}
  <section class="content-section trick-topology-group trick-group--browse" id="{{anchorId}}" data-anchor-style="dotted">
    <div class="section-heading">
      <h2><a href="/freestyle/tricks?view=topology#{{anchorId}}">{{topologyName}}</a></h2>
      <span class="section-count">{{memberCount}}</span>
    </div>
    <p class="topology-group-definition">{{bodyDefinition}}</p>
    <div class="dict-card-stack">
      {{#each cards}}
        {{> dictionary-trick-card density="browse"}}
      {{/each}}
    </div>
  </section>
  {{/each}}
  {{else}}
  <section class="content-section">
    <p class="detail-muted">
      <em>No tricks currently match any of the six topology groupings. As the
      dictionary expands, groupings populate from base trick + modifier link data.</em>
    </p>
  </section>
  {{/if}}

  <p class="symbolic-layer-footer">Observational symbolic-grammar layer. These groupings surface body mechanics across families and do not override canonical IFPA family classifications. The dictionary's <a href="/freestyle/tricks?view=family">By family</a> view remains the canonical structural source.</p>
  {{/if}}

  <p class="source-note">
    Trick data sourced from community documentation.
    ADD values reflect the standard difficulty scoring system.
    Tricks with passback records are linked to their record pages.
  </p>

</div>
