<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p>{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">
  {{#each content.sections}}
  <section class="content-section">
    {{#if heading}}
    <div class="section-heading"><h2>{{heading}}</h2></div>
    {{/if}}
    <div class="card-grid card-grid-2col">
      {{#each folders}}
      <div class="card">
        <div class="card-title">{{label}}</div>
        {{#if description}}<p>{{description}}</p>{{/if}}
        <div class="card-actions">
          {{#if available}}
          <a href="{{href}}" class="btn btn-outline">Watch &rarr;</a>
          {{else}}
          <span class="media-hub-soon">Coming soon</span>
          {{/if}}
        </div>
      </div>
      {{/each}}
    </div>
  </section>
  {{/each}}
</div>
