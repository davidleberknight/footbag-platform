{{!--
  /freestyle/tricks/:slug -- universal trick-detail shell (UX3b0 convergence).
  Replaces the prior legacy/pilot split (trick.hbs + trick-ux2.hbs). One
  template, composed from named partials, with conditional ORDERING based on
  content.ux2Pilot presence. Functional equivalence is preserved: pilot pages
  render the UX2 section sequence; non-pilot pages render the legacy sequence.

  Future phases (UX3c+) collapse the ordering branch by gating section presence
  on data alone, but the convergence prototype keeps both shapes side by side
  so the prior pilot rendering is bit-for-bit preserved during the partial
  extraction pass.
--}}

{{> trick-hero summary=content.ux2Pilot.shortDescription}}

<div class="wrapper">

  {{#if content.ux2Pilot}}
    {{!-- ───────────────────────────────── UX2 SEQUENCE ──────────────────── --}}

    {{> trick-featured-preview}}

    {{> trick-about}}

    {{> trick-notation}}

    {{> trick-operational}}

    {{#if content.ux2Pilot.executionParagraphs.length}}
    {{> trick-prose
        heading="Execution"
        intro="A plain-English walkthrough of the mechanics."
        paragraphs=content.ux2Pilot.executionParagraphs
        sectionClass="trick-execution-summary"}}
    {{/if}}

    {{#if content.ux2Pilot.learningParagraphs.length}}
    {{> trick-prose
        heading="Learning notes"
        paragraphs=content.ux2Pilot.learningParagraphs
        sectionClass="trick-learning-notes"}}
    {{/if}}

    {{#if content.ux2Pilot.prerequisiteParagraphs.length}}
    {{> trick-prose
        heading="Before you try this"
        paragraphs=content.ux2Pilot.prerequisiteParagraphs
        sectionClass="trick-prerequisites"
        extraLink=content.ux2Pilot.prereqExtraLink}}
    {{/if}}

    {{> trick-family}}

    {{> trick-related}}

    {{!-- MEDIA block: UX2 always renders the section with empty state + grid --}}
    <section id="media" class="content-section trick-media-block" aria-label="Media">
      <div class="section-heading">
        <h2>Media</h2>
        {{#if content.hasReferenceMedia}}
        <p class="section-intro">Curated videos referencing {{content.trickName}}.</p>
        {{else}}
        <p class="section-intro">Tutorials and demonstrations referencing this trick will appear here as they are added.</p>
        {{/if}}
      </div>

      {{#if content.ux2Pilot.featuredMedia}}
        <div class="trick-featured-media-card">
          {{#if content.ux2Pilot.featuredMedia.media}}
            {{> video-facade media=content.ux2Pilot.featuredMedia.media}}
          {{/if}}
          {{#if content.ux2Pilot.featuredMedia.caption}}
          <p class="reference-media-caption">{{content.ux2Pilot.featuredMedia.caption}}</p>
          {{/if}}
          {{#if content.ux2Pilot.featuredMedia.sourceLabel}}
          <p class="reference-media-source"><span class="reference-media-source-label">{{content.ux2Pilot.featuredMedia.sourceLabel}}</span></p>
          {{/if}}
        </div>
      {{else}}
        <div class="trick-featured-media-empty">
          <p>{{content.ux2Pilot.featuredMediaEmptyState}}</p>
        </div>
      {{/if}}

      {{> trick-media-grid}}
    </section>

    {{> trick-pathways}}

    {{> trick-previous}}

    {{> trick-next}}

    {{> trick-records}}

    {{> trick-progression}}

    {{> trick-structural collapsed=true}}

  {{else}}
    {{!-- ──────────────────────────────── LEGACY SEQUENCE ────────────────── --}}

    {{> trick-about}}

    {{> trick-notation}}

    {{> trick-operational}}

    {{> trick-structural collapsed=false}}

    {{> trick-pathways}}

    {{> trick-related}}

    {{> trick-previous}}

    {{!-- Reference Media (legacy: omits section entirely when no media) --}}
    {{#if content.hasReferenceMedia}}
    <section id="reference-media" class="content-section">
      <div class="section-heading">
        <h2>{{content.referenceMediaHeading}}</h2>
        <p class="section-intro">Curated videos referencing {{content.trickName}}.</p>
      </div>
      {{> trick-media-grid}}
    </section>
    {{/if}}

    {{> trick-next}}

    {{> trick-family}}

    {{> trick-records}}

    {{> trick-progression}}

  {{/if}}

  <p class="source-note">
    Records sourced from the freestyle passback video archive.
    Dates marked <em>approx.</em> are confirmed only to the month or year.
    <a href="/freestyle/records">View all records</a>
    &mdash;
    <a href="/freestyle/tricks">Trick Dictionary</a>
  </p>

</div>
