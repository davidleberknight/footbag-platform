{{!--
  /freestyle/tricks/:slug -- universal trick-detail shell.

  Single canonical section flow. No pilot-vs-legacy branch. Each section
  partial gates internally on its own data; sparse rows skip silently.

  Sections appear in scan -> study -> diagnostic order. Featured-media
  preview surfaces only when editorial prose is authored. Media block
  surfaces when curated reference media exists or when prose is authored.
  Structural decomposition collapses behind a <details> universally;
  grammar-aware visitors expand on demand.
--}}

{{> trick-hero summary=content.ux2Pilot.shortDescription}}

<div class="wrapper trick-shell">

  {{!-- Taxonomy ribbon: identity tag, family, and ADD. Lives in the body,
       not the hero. The hashtag links to the trick's media gallery only
       when reference media exists; otherwise it is a plain identity token. --}}
  <p class="trick-hero-meta-ribbon" aria-label="Trick metadata">
    {{#if content.trickTag}}
      {{#if content.hasReferenceMedia}}
      <a class="trick-hero-meta-chip trick-hero-meta-chip--media" href="{{content.referenceGalleryHref}}" aria-label="Media for this trick">{{content.trickTag}}</a>
      {{else}}
      <span class="trick-hero-meta-chip">{{content.trickTag}}</span>
      {{/if}}
    {{/if}}
    {{#if content.familyChip}}
    <a class="trick-hero-meta-chip trick-hero-meta-chip-family{{#if content.familyChip.isMinorLineage}} trick-hero-meta-chip-family--minor{{/if}}" href="/freestyle/tricks?family={{content.familyChip.slug}}">{{content.familyChip.label}}{{#if content.familyChip.isMinorLineage}} &middot; minor lineage{{/if}}</a>
    {{/if}}
    {{#if content.dictEntry}}
      {{#if content.dictEntry.isModifier}}
      <span class="trick-hero-meta-chip trick-hero-meta-chip-modifier">Modifier</span>
      {{else}}
        {{#if content.dictEntry.adds}}
        <span class="trick-hero-meta-chip trick-hero-meta-chip-adds">{{content.dictEntry.adds}} ADD</span>
        {{/if}}
      {{/if}}
    {{/if}}
    {{#if content.pronunciation}}
    <span class="trick-hero-meta-chip trick-hero-meta-chip-pronunciation" aria-label="Pronunciation: {{content.pronunciation}}">{{content.pronunciation}}</span>
    {{/if}}
  </p>

  {{> trick-compressed-from}}

  {{!--
    Trick-detail architecture: one universal shell with variable depth,
    movement-language-first → structure-second. Curated movement-language
    prose suppresses cleanly when unauthored. Relationship sections follow
    a single-owner rule so nothing is shown twice: the Family ladder owns
    same-family progression, Related Tricks owns conceptual movement
    neighbours, and Structural Neighbors owns cross-base composition only.
    The parent-delta line lives in Movement Intuition and the build path in
    About, so no standalone mechanical-delta or progressive-readings
    section is needed.
  --}}
  {{!-- Above the fold: the universal notation card (Movement notation ->
       Execution notation -> ADD), then About (description / how it's built /
       compared with base), then the compact structural-fact block, so a reader
       grasps what the trick is, how it is executed, and how it is built without
       scrolling. --}}
  {{> trick-notation}}

  {{> trick-about}}

  {{> trick-relative-side}}

  {{> trick-structural-facts}}

  {{!-- Wayfinding summary: jump-links to learn / watch / family. --}}
  {{> trick-pathways}}

  {{!-- Below the fold: reference depth, progressive disclosure. Movement
       intuition and Equivalent readings lead the deeper layer. --}}
  {{> trick-intuition}}

  {{> trick-equivalent-readings}}

  {{> trick-primitive-note}}

  {{> trick-interpretation}}

  {{> trick-transform}}

  {{> trick-modifiers}}

  {{> trick-modifier-layering}}

  {{> trick-scoring-notes}}

  {{> trick-equivalence-topology}}

  {{!-- Technique Notes: execution, learning, and prerequisites grouped into one
       compact disclosure, collapsed by default so the page does not grow. Sits
       below the canonical reference material and stays distinct from the
       canonical About explanation and from community-contributed tips. --}}
  {{#if content.ux2Pilot.hasTechniqueNotes}}
  <section id="technique-notes" class="content-section" aria-label="Technique Notes">
    <details class="trick-technique-collapsible">
      <summary>Technique Notes</summary>
      {{#if content.ux2Pilot.executionParagraphs.length}}
      <div class="trick-technique-part">
        <h3 class="trick-technique-heading">Execution</h3>
        {{#each content.ux2Pilot.executionParagraphs}}
        <p class="trick-prose-paragraph">{{this}}</p>
        {{/each}}
      </div>
      {{/if}}
      {{#if content.ux2Pilot.learningParagraphs.length}}
      <div class="trick-technique-part">
        <h3 class="trick-technique-heading">Learning Notes</h3>
        {{#each content.ux2Pilot.learningParagraphs}}
        <p class="trick-prose-paragraph">{{this}}</p>
        {{/each}}
      </div>
      {{/if}}
      {{#if content.ux2Pilot.prerequisiteParagraphs.length}}
      <div class="trick-technique-part">
        <h3 class="trick-technique-heading">Before You Try This</h3>
        {{#each content.ux2Pilot.prerequisiteParagraphs}}
        <p class="trick-prose-paragraph">{{this}}</p>
        {{/each}}
      </div>
      {{/if}}
    </details>
  </section>
  {{/if}}

  {{!-- Structurally related tricks: the single ranked relatives section (same
       base, same family or terminal, operator overlap, curated). It subsumes the
       former Structural Neighbors block (operator kin / twins), so that block is
       no longer rendered. The full family browser below is secondary. --}}
  {{> trick-similar}}

  {{!-- Terminal-derived "what lands here" cohort for non-family terminal atoms
       (toe_stall / clipper_stall); a reciprocal "lands in" backlink on cohort
       members. Suppressed where the Family ladder already owns the terminal. --}}
  {{> trick-terminal-derived}}

  {{> trick-family}}

  {{> trick-quantity-ladder}}

  {{> trick-related}}

  {{> symbolic-related-topology}}

  {{#if content.referenceGalleryHref}}
  <section id="media" class="content-section trick-media-block" aria-label="Media">
    <div class="section-heading">
      <h2>Media</h2>
      <p class="section-intro">Videos referencing {{content.trickName}}.</p>
    </div>

    <p class="mt-4">
      <a href="{{content.referenceGalleryHref}}" class="btn btn-outline">See All Videos for {{content.trickName}} &rarr;</a>
    </p>
  </section>
  {{/if}}

  {{#if content.hasCommunityTips}}
  <section id="community-tips" class="content-section" aria-label="Community Tips">
    <details class="community-tips-collapsible">
      <summary>Community Tips ({{content.communityTipsCount}})</summary>
      <p class="community-tips-note text-muted fs-sm">
        Legacy footbag.org community advice, contributed by players over the years.
        Helpful technique notes, not official doctrine.
      </p>
      <ol class="community-tips-list">
        {{#each content.communityTips}}
        <li class="community-tip">
          {{#each (splitParagraphs this.text)}}
          <p>{{this}}</p>
          {{/each}}
        </li>
        {{/each}}
      </ol>
    </details>
  </section>
  {{/if}}

  {{> trick-records}}

  {{> trick-progression}}

  {{> trick-structural collapsed=true}}

  <p class="source-note">
    Records sourced from documented freestyle video archives.
    Dates marked <em>approx.</em> are confirmed only to the month or year.
    <a href="/freestyle/records">View all records</a>
    &middot;
    <a href="/freestyle/tricks">Trick Dictionary</a>
  </p>

</div>
