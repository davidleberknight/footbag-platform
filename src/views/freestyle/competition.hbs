{{! /freestyle/competition — results-derived competition history }}

<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  <p>
    Freestyle footbag has been competed for over four decades. The picture
    below is compiled from documented historical events; coverage varies by
    era, and the archive keeps improving as more results are recovered.
    Unfamiliar terms are explained in the
    <a href="/freestyle/glossary">freestyle glossary</a>.
  </p>

  {{! ── Competition Through the Years — events by era + recent events ───── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>Competition Through the Years</h2>
    </div>
    <p class="section-intro">
      How documented freestyle competition has grown, decade by decade.
    </p>

    <h3 class="content-subheading">Events by Era</h3>
    <div class="records-table-wrap">
      <table class="records-table records-table-sm">
        <thead>
          <tr>
            <th>Decade</th>
            <th class="col-num">Freestyle Events</th>
          </tr>
        </thead>
        <tbody>
          {{#each content.eventsByEra}}
          <tr>
            <td>{{era}}</td>
            <td class="col-num">{{events}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    {{#if content.recentEvents}}
    <h3 class="content-subheading">Recent Events</h3>
    <div class="records-table-wrap">
      <table class="records-table records-table-sm">
        <thead>
          <tr>
            <th>Event</th>
            <th>Location</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          {{#each content.recentEvents}}
          <tr>
            <td><a href="{{href}}">{{title}}</a></td>
            <td class="detail-muted">{{city}}, {{country}}</td>
            <td class="detail-muted">{{startDate}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{/if}}
  </section>

  {{! ── Documented Competitors — podium results, honestly framed ───────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>Documented Competitors</h2>
    </div>
    <p class="section-intro">
      Freestyle singles competitors with the most documented podium finishes
      (Open, Intermediate, and Women's divisions), ranked by gold medals then
      total podiums. Based on currently documented historical event results
      &mdash; one view of the sport's history, not a definitive all-time ranking.
    </p>
    <div class="records-table-wrap">
      <table class="records-table records-table-sm">
        <thead>
          <tr>
            <th class="col-rank">#</th>
            <th>Player</th>
            <th>Country</th>
            <th class="col-num" title="1st place finishes">Gold</th>
            <th class="col-num" title="2nd place finishes">Silver</th>
            <th class="col-num" title="3rd place finishes">Bronze</th>
            <th class="col-num">Podiums</th>
          </tr>
        </thead>
        <tbody>
          {{#each content.topCompetitors}}
          <tr>
            <td class="col-rank">{{add @index 1}}</td>
            <td><a href="{{profileHref}}">{{name}}</a></td>
            <td class="detail-muted">{{#if country}}{{country}}{{else}}&mdash;{{/if}}</td>
            <td class="col-num">{{golds}}</td>
            <td class="col-num">{{silvers}}</td>
            <td class="col-num">{{bronzes}}</td>
            <td class="col-num">{{totalPodiums}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </section>

  <p class="source-note">{{content.dataNote}}</p>

</div>
