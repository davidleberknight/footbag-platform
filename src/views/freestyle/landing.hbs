{{! /freestyle — landing page. Two-band structure: What is Freestyle? →
    Start Here (beginner paths) → Go Deeper (reference / archive / analysis)
    → Featured videos. }}

<div class="hero hero-sm hero-with-mascot">
  <div class="hero-text">
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
  <img class="hero-mascot" src="{{content.mascotSrc}}" alt="{{content.mascotAlt}}" width="150" height="150">
</div>

<div class="wrapper freestyle-landing">

  {{! ── What is Freestyle? — plain intro + demo video ───────────────────── }}
  {{#if content.intro.paragraphs.length}}
  <section class="content-section freestyle-portal-lede">
    {{#if content.intro.heading}}<h2>{{content.intro.heading}}</h2>{{/if}}
    {{#each content.intro.paragraphs}}
    <p class="freestyle-portal-lede-paragraph">{{this}}</p>
    {{/each}}
    {{#if content.demoVideo}}
    <figure class="demo-video">
      <video autoplay loop muted playsinline preload="metadata" poster="{{content.demoVideo.posterUrl}}">
        <source src="{{content.demoVideo.mp4Url}}" type="video/mp4">
        <p>{{content.demoVideo.caption}}</p>
      </video>
      <figcaption>{{content.demoVideo.caption}}</figcaption>
    </figure>
    {{/if}}
  </section>
  {{/if}}

  {{! ── Start Here — beginner paths ──────────────────────────────────────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>Start Here</h2>
      <p class="section-intro">New to freestyle? These are the best places to begin.</p>
    </div>
    <div class="card-grid card-grid-2col">

      <div class="card">
        <div class="card-title">Watch &amp; Learn</div>
        <p>
          See freestyle footbag in motion. Video tutorials and demonstrations
          from players around the world.
        </p>
        <div class="card-actions">
          <a href="/media/gallery_tricks_of_the_trade" class="btn btn-outline">Tricks of the Trade — Kenny Shults &rarr;</a>
          <a href="/media/gallery_passback_tutorials" class="btn btn-outline">Tutorials — PassbackFootbag &rarr;</a>
          <a href="/media/gallery_anz_trikz" class="btn btn-outline">Tutorials — AnzTrikz &rarr;</a>
          <a href="/media/gallery_shred_global" class="btn btn-outline">Tutorials — Shred Global &rarr;</a>
          <a href="/media/gallery_footbag_finland" class="btn btn-outline">Tutorials — Footbag Finland &rarr;</a>
        </div>
      </div>

      <div class="card{{#unless content.totalTricks}} card-coming-soon{{/unless}}">
        <div class="card-title">Trick Dictionary</div>
        <p>
          Every freestyle trick has a name. Browse them, see how they fit
          together, and find the moves to learn next.
        </p>
        {{#if content.totalTricks}}
        <div class="card-actions">
          <a href="/freestyle/tricks" class="btn btn-outline">Browse the trick dictionary &rarr;</a>
        </div>
        {{else}}
        <span class="badge badge-coming-soon">Coming soon</span>
        {{/if}}
      </div>

      <div class="card">
        <div class="card-title">Glossary</div>
        <p>
          New to the words? Plain-language explanations of the terms, moves,
          and abbreviations you'll hear in tutorials and at contests.
        </p>
        <div class="card-actions">
          <a href="/freestyle/glossary" class="btn btn-outline">Open the glossary &rarr;</a>
        </div>
      </div>

      <div class="card">
        <div class="card-title">The Story of Freestyle</div>
        <p>
          How freestyle footbag grew from kicking circles in the 1980s into a
          technical, creative sport played around the world.
        </p>
        <div class="card-actions">
          <a href="/freestyle/history" class="btn btn-outline">Freestyle history &rarr;</a>
        </div>
      </div>

    </div>
  </section>

  {{! ── Go Deeper — reference, archive & analysis ────────────────────────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>Go Deeper</h2>
      <p class="section-intro">Records, competition history, and the deeper analysis behind elite freestyle.</p>
    </div>
    <div class="card-grid card-grid-2col">

      <div class="card{{#unless content.totalRecords}} card-coming-soon{{/unless}}">
        <div class="card-title">Trick Records</div>
        <p>
          Documented freestyle trick achievements and consecutive-completion
          records &mdash; how many times in a row a trick has been landed.
        </p>
        {{#if content.totalRecords}}
        <div class="card-actions">
          <a href="/freestyle/records" class="btn btn-outline">Trick records &rarr;</a>
          <a href="/freestyle/leaders" class="btn btn-outline">Record leaders &rarr;</a>
        </div>
        {{else}}
        <span class="badge badge-coming-soon">Coming soon</span>
        {{/if}}
      </div>

      <div class="card">
        <div class="card-title">Competition</div>
        <p>
          Decades of documented freestyle events and results, plus the doubles
          partnerships that shaped the sport.
        </p>
        <div class="card-actions">
          <a href="/freestyle/competition" class="btn btn-outline">Competition history &rarr;</a>
          <a href="/freestyle/partnerships" class="btn btn-outline">Partnerships &rarr;</a>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Scoring &amp; Combos</div>
        <p>
          How freestyle measures trick difficulty, and how single tricks link
          into longer flowing combinations and runs.
        </p>
        <div class="card-actions">
          <a href="/freestyle/add-analysis" class="btn btn-outline">ADD analysis &rarr;</a>
          <a href="/freestyle/combo-analysis" class="btn btn-outline">Combo analysis &rarr;</a>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Operators &amp; Modifiers</div>
        <p>
          The movement ideas that transform one trick into many related
          variations.
        </p>
        <div class="card-actions">
          <a href="/freestyle/operators" class="btn btn-outline">Operators &amp; modifiers &rarr;</a>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Insights</div>
        <p>
          Patterns drawn from decades of documented competitive freestyle
          &mdash; the tricks and combinations that defined each era.
        </p>
        <div class="card-actions">
          <a href="/freestyle/insights" class="btn btn-outline">Freestyle insights &rarr;</a>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Observed Tricks</div>
        <p>
          Trick names documented from the wider community that haven't been
          fully reviewed yet.
        </p>
        <div class="card-actions">
          <a href="/freestyle/observational" class="btn btn-outline">Observed tricks &rarr;</a>
        </div>
      </div>

      <div class="card">
        <div class="card-title">About Freestyle Footbag</div>
        <p>
          The sport in brief &mdash; competition formats, how routines are
          judged, and the set-notation system behind trick names.
        </p>
        <div class="card-actions">
          <a href="/freestyle/about" class="btn btn-outline">About freestyle &rarr;</a>
        </div>
      </div>

    </div>
  </section>

  {{! ── Featured — competition formats + curated demonstrations ──────────── }}
  {{#if content.featured.length}}
  <section class="content-section freestyle-featured" id="featured">
    <h2>Featured</h2>
    <div class="freestyle-featured-grid">
      {{#each content.featured}}
      <article class="card featured-card" id="featured-{{key}}">
        <div class="video-embed">
          {{> video-facade media=media}}
        </div>
        <div class="card-title">{{title}}</div>
        {{#if caption}}<p class="featured-caption">{{caption}}</p>{{/if}}
        {{> media-tag-strip tags=tags}}
      </article>
      {{/each}}
    </div>
  </section>
  {{/if}}

</div>
