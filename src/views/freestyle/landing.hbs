{{! /freestyle — landing. Hero → What is Freestyle? (tight lede) → Banner 1
    (Language) → Banner 2 (Analysis & Competition) → the language in practice
    (mosaic + by-the-numbers) → Featured videos → Media → History. }}

<div class="hero hero-sm hero-with-mascot">
  <div class="hero-text">
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
  <img class="hero-mascot" src="{{content.mascotSrc}}" alt="{{content.mascotAlt}}" width="150" height="150">
</div>

<div class="wrapper freestyle-landing">

  {{! ── What is Freestyle? — tight, big-font lede + demo video ─────────────── }}
  <section class="content-section freestyle-lede">
    <p class="freestyle-lede-big">Freestyle footbag is a language. A handful of core movements (kicks, stalls, delays, spins) combine into thousands of named tricks.</p>
    {{#if content.demoVideo}}
    <figure class="demo-video">
      <video autoplay loop muted playsinline preload="metadata" poster="{{content.demoVideo.posterUrl}}">
        <source src="{{content.demoVideo.mp4Url}}" type="video/mp4">
        <p>{{content.demoVideo.caption}}</p>
      </video>
      <figcaption>{{content.demoVideo.caption}}</figcaption>
    </figure>
    {{/if}}
  </section>

  {{! ── Banner 1 — The Language of Freestyle (reference / vocabulary) ───────── }}
  <section class="content-section freestyle-banner">
    <div class="section-heading">
      <h2>The Language of Freestyle</h2>
      <p class="section-intro">Core reference for understanding the vocabulary.</p>
    </div>
    <div class="banner-grid">
      {{#if content.totalTricks}}
      <a class="banner-tile" href="/freestyle/tricks">
        <span class="banner-tile-title">Trick Dictionary</span>
        <span class="banner-tile-blurb">Every named trick, and how they connect.</span>
      </a>
      {{/if}}
      <a class="banner-tile" href="/freestyle/glossary">
        <span class="banner-tile-title">Glossary</span>
        <span class="banner-tile-blurb">Plain-language terms and abbreviations.</span>
      </a>
      <a class="banner-tile" href="/freestyle/sets">
        <span class="banner-tile-title">Set Encyclopedia</span>
        <span class="banner-tile-blurb">The named uptime sets every trick opens with.</span>
      </a>
      <a class="banner-tile" href="/freestyle/operators">
        <span class="banner-tile-title">Operators &amp; Modifiers</span>
        <span class="banner-tile-blurb">The ideas that turn one trick into many.</span>
      </a>
      <a class="banner-tile" href="/freestyle/observational">
        <span class="banner-tile-title">Emerging Vocabulary</span>
        <span class="banner-tile-blurb">New trick names still being confirmed.</span>
      </a>
      <a class="banner-tile" href="/freestyle/about">
        <span class="banner-tile-title">About Freestyle</span>
        <span class="banner-tile-blurb">Formats, judging, and set notation.</span>
      </a>
    </div>
  </section>

  {{! ── Banner 2 — Analysis & Competition ──────────────────────────────────── }}
  <section class="content-section freestyle-banner">
    <div class="section-heading">
      <h2>Analysis &amp; Competition</h2>
      <p class="section-intro">Higher-level analysis: how freestyle behaves in practice.</p>
    </div>
    <div class="banner-grid">
      {{#if content.totalRecords}}
      <a class="banner-tile" href="/freestyle/records">
        <span class="banner-tile-title">Trick Records</span>
        <span class="banner-tile-blurb">Consecutive-completion records and leaders.</span>
      </a>
      {{/if}}
      <a class="banner-tile" href="/freestyle/competition">
        <span class="banner-tile-title">Competition</span>
        <span class="banner-tile-blurb">Decades of documented events and results.</span>
      </a>
      <a class="banner-tile" href="/freestyle/partnerships">
        <span class="banner-tile-title">Partnerships</span>
        <span class="banner-tile-blurb">The doubles pairings that shaped the sport.</span>
      </a>
      <a class="banner-tile" href="/freestyle/combo-analysis">
        <span class="banner-tile-title">Scoring &amp; Combos</span>
        <span class="banner-tile-blurb">How single tricks link into flowing runs.</span>
      </a>
      <a class="banner-tile" href="/freestyle/add-analysis">
        <span class="banner-tile-title">ADD Analysis</span>
        <span class="banner-tile-blurb">How freestyle measures trick difficulty.</span>
      </a>
      <a class="banner-tile" href="/freestyle/insights">
        <span class="banner-tile-title">Freestyle Patterns</span>
        <span class="banner-tile-blurb">The tricks and combinations that defined each era.</span>
      </a>
    </div>
  </section>

  {{! ── The language in practice: mosaic + by-the-numbers ───────────────────── }}
  <div class="section-heading freestyle-showcase-heading">
    <h2>The Language of Freestyle, in practice</h2>
  </div>

  {{! ── The 12 Foundations: core-atom mosaic ───────────────────────────────── }}
  <section class="content-section tricks-mosaic-section{{#unless content.tricksMosaicHasClips}} tricks-mosaic-section--placeholder{{/unless}}">
    <div class="section-heading">
      <h2>The 12 Foundations of Freestyle</h2>
      <p class="section-intro">Every freestyle trick is built from these core movements.</p>
    </div>
    <div class="tricks-mosaic">
      {{#each content.tricksMosaic}}
        <figure class="tricks-mosaic-cell">
          {{#if mp4Url}}
            <button type="button" class="tricks-mosaic-toggle" aria-label="Play {{label}}" aria-pressed="false" data-trick="{{label}}">
              <video class="tricks-mosaic-media" loop muted playsinline preload="none" poster="{{posterUrl}}">
                <source src="{{mp4Url}}" type="video/mp4">
              </video>
              <span class="tricks-mosaic-playicon" aria-hidden="true"></span>
            </button>
          {{else}}
            <div class="tricks-mosaic-media tricks-mosaic-empty" aria-hidden="true"></div>
          {{/if}}
          <figcaption class="tricks-mosaic-label">{{label}}</figcaption>
        </figure>
      {{/each}}
    </div>
  </section>

  {{! ── Freestyle by the Numbers: six live histogram cards ─────────────────── }}
  {{#if content.byTheNumbers.length}}
  <section class="content-section by-numbers" id="by-the-numbers">
    <div class="section-heading">
      <h2>Freestyle by the Numbers</h2>
      <p class="section-intro">{{content.byTheNumbersNote}} Each card opens its browse view.</p>
    </div>
    <div class="by-numbers-grid">
      {{#each content.byTheNumbers}}
      <a class="by-numbers-card" href="/freestyle/tricks?view={{viewKey}}">
        <span class="by-numbers-eyebrow">{{eyebrow}}</span>
        <span class="by-numbers-title">{{title}}</span>
        <span class="by-numbers-bars">
          {{#each bars}}
          <span class="by-numbers-bar">
            <span class="by-numbers-bar-label">{{label}}</span>
            <span class="by-numbers-bar-track"><span class="by-numbers-bar-fill gloss-bar-fill--w{{widthBucket}}"></span></span>
            <span class="by-numbers-bar-count">{{count}}</span>
          </span>
          {{/each}}
        </span>
        {{#if footnote}}<span class="by-numbers-footnote">{{footnote}}</span>{{/if}}
        <span class="by-numbers-cta">Browse &rarr;</span>
      </a>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{! ── Featured videos — the visual showcase ──────────────────────────────── }}
  {{#if content.featured.length}}
  <section class="content-section freestyle-featured" id="featured">
    <h2>Featured Videos</h2>
    <div class="freestyle-featured-grid">
      {{#each content.featured}}
      <article class="card featured-card" id="featured-{{key}}">
        <div class="video-embed">
          {{> video-facade media=media}}
        </div>
        <div class="card-title">{{title}}</div>
        {{#if caption}}<p class="featured-caption">{{caption}}</p>{{/if}}
        {{> media-tag-strip tags=tags}}
      </article>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{! ── Freestyle Media (supporting) ───────────────────────────────────────── }}
  <section class="content-section freestyle-supporting">
    <div class="section-heading"><h2>Freestyle Media</h2></div>
    <div class="banner-grid banner-grid--compact">
      <a class="banner-tile" href="/media/freestyle-tutorials">
        <span class="banner-tile-title">Tutorials &amp; Demos</span>
        <span class="banner-tile-blurb">Instructional and demonstration galleries.</span>
      </a>
      {{#if content.mediaRecordsHref}}
      <a class="banner-tile" href="{{content.mediaRecordsHref}}">
        <span class="banner-tile-title">Freestyle Records Videos</span>
        <span class="banner-tile-blurb">PassBack record-attempt footage.</span>
      </a>
      {{else}}
      <span class="banner-tile banner-tile--soon">
        <span class="banner-tile-title">Freestyle Records Videos</span>
        <span class="banner-tile-soon">Coming soon</span>
      </span>
      {{/if}}
      {{#if content.mediaCuratedHref}}
      <a class="banner-tile" href="{{content.mediaCuratedHref}}">
        <span class="banner-tile-title">Curated Trick Videos</span>
        <span class="banner-tile-blurb">Reference clips for individual tricks.</span>
      </a>
      {{else}}
      <span class="banner-tile banner-tile--soon">
        <span class="banner-tile-title">Curated Trick Videos</span>
        <span class="banner-tile-soon">Coming soon</span>
      </span>
      {{/if}}
    </div>
  </section>

  {{! ── History of Freestyle (supporting) ──────────────────────────────────── }}
  <section class="content-section freestyle-supporting">
    <div class="section-heading"><h2>History of Freestyle</h2></div>
    <div class="banner-grid banner-grid--compact">
      <a class="banner-tile" href="/freestyle/history">
        <span class="banner-tile-title">Story of Freestyle</span>
        <span class="banner-tile-blurb">How the sport grew from kicking circles.</span>
      </a>
      <span class="banner-tile banner-tile--soon">
        <span class="banner-tile-title">History Timeline</span>
        <span class="banner-tile-soon">Coming soon</span>
      </span>
      <span class="banner-tile banner-tile--soon">
        <span class="banner-tile-title">Historical Milestones</span>
        <span class="banner-tile-soon">Coming soon</span>
      </span>
      <span class="banner-tile banner-tile--soon">
        <span class="banner-tile-title">Evolution of Vocabulary</span>
        <span class="banner-tile-soon">Coming soon</span>
      </span>
    </div>
  </section>

</div>
