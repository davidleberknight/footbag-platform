{{! /freestyle — portal landing page }}

<div class="hero hero-sm hero-with-mascot">
  <div class="hero-text">
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
  <img class="hero-mascot" src="{{content.mascotSrc}}" alt="{{content.mascotAlt}}" width="150" height="150">
</div>

<div class="wrapper freestyle-landing">

  {{! ── What is Freestyle Footbag? (single narrative section) ──────────────── }}
  <section class="content-section">
    <h2>{{content.intro.heading}}</h2>
    {{#each content.intro.paragraphs}}
    <p>{{this}}</p>
    {{/each}}
    {{#if content.demoVideo}}
    <figure class="demo-video">
      <video autoplay loop muted playsinline preload="metadata" poster="{{content.demoVideo.posterUrl}}">
        <source src="{{content.demoVideo.mp4Url}}" type="video/mp4">
        <p>{{content.demoVideo.caption}}</p>
      </video>
      <figcaption>{{content.demoVideo.caption}}</figcaption>
    </figure>
    {{/if}}
  </section>

  {{! ── Competition Formats ────────────────────────────────────────────────── }}
  <section class="content-section">
    <h2>Competition Formats</h2>
    <div class="card-grid card-grid-2col">
      {{#each content.competitionFormats}}
      <div class="card format-card">
        <div class="card-title">{{title}}</div>
        <p>{{paragraph}}</p>
        <div class="video-embed">
          {{> video-facade media=media}}
        </div>
      </div>
      {{/each}}
    </div>
  </section>

  {{! ── Featured video ─────────────────────────────────────────────────── }}
  {{#if content.featuredVideo}}
  <section class="content-section freestyle-featured-video">
    <div class="section-heading">
      <h2>{{content.featuredVideo.title}}</h2>
      {{#if content.featuredVideo.caption}}<p class="section-intro">{{content.featuredVideo.caption}}</p>{{/if}}
    </div>
    {{#if content.featuredVideo.media}}
    <figure class="demo-video">
      <div class="video-embed">
        {{> video-facade media=content.featuredVideo.media}}
      </div>
    </figure>
    {{else}}
    <p class="freestyle-featured-fallback">Video temporarily unavailable. Try again later.</p>
    {{/if}}
  </section>
  {{/if}}

  {{! ── Three-layer reference orientation ─────────────────────────────────── }}
  <section class="content-section">
    <h2>The Freestyle Reference</h2>
    <p>
      Freestyle footbag has its own structural language. Three reference layers explain it,
      each at a different depth — start where it suits you and follow links between them.
    </p>
    <ul class="reference-layer-list">
      <li><strong>Glossary</strong> — plain-English vocabulary for newcomers and returning players. Run-quality terms, trick components, style words, common abbreviations.</li>
      <li><strong>Dictionary</strong> — the canonical catalog of named tricks with ADD values, modifier links, and family relationships. The structural source of truth.</li>
      <li><strong>Notation</strong> — Jobs notation: a compact symbolic shorthand that decomposes a trick into the sets, modifiers, and base components that build it.</li>
    </ul>
    <p class="freestyle-learn-pointer">
      Want to learn freestyle physically and mechanically rather than look up a definition?
      The <a href="/freestyle/learn">educational pathways</a> page collects modifier-pedagogy
      pages, family progressions, and glossary connective panels — a companion to the canonical
      reference for learners.
    </p>
  </section>

  {{! ── Portal cards (intent-ordered: learn → reference → records → competition → context → analysis) ── }}
  <section class="content-section">
    <div class="card-grid card-grid-2col">

      <div class="card">
        <div class="card-title">Tutorials &amp; Learning</div>
        <p>
          Curated video series for newcomers and returning players. Each tutorial
          walks through one or more named tricks, with technique cues and
          progression paths into harder material.
        </p>
        <div class="card-actions">
          <a href="/media/gallery_tricks_of_the_trade" class="btn btn-outline">Tricks of the Trade &rarr;</a>
          <a href="/media/gallery_anz_trikz" class="btn btn-outline">AnzTrikz &rarr;</a>
          <a href="/media/gallery_shred_global" class="btn btn-outline">Shred Global &rarr;</a>
          <a href="/media/gallery_footbag_finland" class="btn btn-outline">Footbag Finland &rarr;</a>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Glossary</div>
        <p>
          Beginner-friendly explanations of freestyle vocabulary: run-quality terms,
          components of a trick, set / modifier / catch concepts, and the abbreviations
          you'll encounter in tutorials and contests.
        </p>
        <div class="card-actions">
          <a href="/freestyle/glossary" class="btn btn-outline">Open glossary &rarr;</a>
        </div>
      </div>

      <div class="card{{#unless content.totalTricks}} card-coming-soon{{/unless}}">
        <div class="card-title">Trick Dictionary</div>
        <p>
          Canonical reference for named tricks: ADD difficulty values, structural decomposition,
          modifier links, and family groupings. Browse by ADD bucket, by family, or by the
          set/modifier each trick uses.
        </p>
        {{#if content.totalTricks}}
        <div class="card-actions">
          <a href="/freestyle/tricks" class="btn btn-outline">Browse tricks &rarr;</a>
          <a href="/freestyle/tricks?view=sets" class="btn btn-outline">Browse by sets &rarr;</a>
        </div>
        {{else}}
        <span class="badge badge-coming-soon">Coming soon</span>
        {{/if}}
      </div>

      <div class="card">
        <div class="card-title">Notation Reference</div>
        <p>
          Jobs notation is the community's compact shorthand for trick structure —
          how a set, modifiers, and a base combine into a named move. The reference
          page shows the conventions in use; per-trick pages render notation with
          color-coded structural roles.
        </p>
        <div class="card-actions">
          <a href="/freestyle/moves" class="btn btn-outline">Notation reference &rarr;</a>
        </div>
      </div>

      <div class="card{{#unless content.totalRecords}} card-coming-soon{{/unless}}">
        <div class="card-title">World Records</div>
        <p>
          Per-trick consecutive-completion records, drawn from the long-running
          Passback record community. Browse by trick, or see the all-time leaderboard
          across record-holders.
        </p>
        {{#if content.totalRecords}}
        <div class="card-actions">
          <a href="/freestyle/records" class="btn btn-outline">View records &rarr;</a>
          <a href="/freestyle/leaders" class="btn btn-outline">Leaderboard &rarr;</a>
        </div>
        {{else}}
        <span class="badge badge-coming-soon">Coming soon</span>
        {{/if}}
      </div>

      <div class="card">
        <div class="card-title">Competition</div>
        <p>
          Top competitors, podium counts, and event history across documented
          freestyle events from the 1980s to the present. Includes solo and
          partnership records.
        </p>
        <div class="card-actions">
          <a href="/freestyle/competition" class="btn btn-outline">Competition history &rarr;</a>
          <a href="/freestyle/partnerships" class="btn btn-outline">Partnerships &rarr;</a>
        </div>
      </div>

      <div class="card">
        <div class="card-title">History &amp; ADD System</div>
        <p>
          How freestyle's vocabulary, scoring, and competitive geography evolved —
          from the foundational 1980s clipper-and-mirage era through modifier stacking
          in the 2000s and the modern European-led refinement.
        </p>
        <div class="card-actions">
          <a href="/freestyle/history" class="btn btn-outline">Full history &rarr;</a>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Insights</div>
        <p>
          Data-driven sequence analysis across decades of competitive freestyle:
          how trick combinations evolved, which modifiers anchored each era, and
          the patterns visible in the long-form record.
        </p>
        <div class="card-actions">
          <a href="/freestyle/insights" class="btn btn-outline">Insights &rarr;</a>
        </div>
      </div>

    </div>
  </section>

  {{! ── Get started tiles (placeholders) ───────────────────────────────────── }}
  <section class="content-section">
    <h2>Get Started</h2>
    <div class="card-grid card-grid-3col get-started-tiles">
      {{#each content.getStartedTiles}}
      <a class="card card-tile{{#if comingSoon}} card-coming-soon{{/if}}" href="{{href}}">
        <div class="card-title">{{label}}</div>
        {{#if comingSoon}}<span class="badge badge-coming-soon">Coming soon</span>{{/if}}
      </a>
      {{/each}}
    </div>
  </section>

</div>
