{{! /freestyle — portal landing page }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
    {{#if content.totalRecords}}
    <div class="hero-stats">
      <span>{{content.totalEvents}} events</span>
      <span>{{content.totalRecords}} passback records</span>
      <span>{{content.totalTricks}} documented tricks</span>
    </div>
    {{/if}}
  </div>
</div>

<div class="wrapper">

  {{! ── Four pillars ─────────────────────────────────────────────────────────── }}
  <section class="content-section">
    <div class="review-summary-grid">

      <div class="review-card">
        <h3>Competition</h3>
        <p>
          Top competitors, podium counts, and event history from
          {{content.totalEvents}} documented freestyle events (1980–present).
          Derived from canonical competition records.
        </p>
        <p>
          <a href="/freestyle/competition" class="btn btn-primary btn-sm">Competition history &rarr;</a>
        </p>
      </div>

      <div class="review-card">
        <h3>Passback Records</h3>
        <p>
          Per-trick consecutive completion records from the freestyle
          passback community. {{content.totalRecords}} records across {{content.recordTypes}} disciplines.
        </p>
        <p>
          <a href="/freestyle/records" class="btn btn-outline btn-sm">View records &rarr;</a>
          <a href="/freestyle/leaders" class="btn btn-outline btn-sm">Leaderboard &rarr;</a>
        </p>
      </div>

      <div class="review-card">
        <h3>Trick Dictionary</h3>
        <p>
          Reference for {{content.totalTricks}} documented tricks — ADD values, categories,
          descriptions, base components, and modifier relationships.
        </p>
        <p>
          <a href="/freestyle/tricks" class="btn btn-outline btn-sm">Browse tricks &rarr;</a>
          <a href="/freestyle/moves"  class="btn btn-outline btn-sm">Move sets &rarr;</a>
        </p>
      </div>

      <div class="review-card">
        <h3>History &amp; Insights</h3>
        <p>
          From the foundational 1980s vocabulary to the technical peak of the 2000s
          and the modern European era. Data-driven sequence analysis from 395 documented chains.
        </p>
        <p>
          <a href="/freestyle/history"  class="btn btn-outline btn-sm">History &rarr;</a>
          <a href="/freestyle/insights" class="btn btn-outline btn-sm">Insights &rarr;</a>
        </p>
      </div>

    </div>
  </section>

  {{! ── Top Record Holders ────────────────────────────────────────────────────── }}
  {{#if content.topHolders}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Top Passback Record Holders</h2>
    </div>
    <table class="records-table leaders-table">
      <thead>
        <tr>
          <th class="col-rank">#</th>
          <th>Player</th>
          <th class="col-num">Records</th>
          <th>Top Trick</th>
          <th class="col-num">Count</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.topHolders}}
        <tr>
          <td class="col-rank">{{rank}}</td>
          <td>
            {{#if holderHref}}
              <a href="{{holderHref}}">{{holderName}}</a>
            {{else}}
              {{holderName}}
            {{/if}}
          </td>
          <td class="col-num">{{recordCount}}</td>
          <td>{{#if topTrick}}{{topTrick}}{{else}}&mdash;{{/if}}</td>
          <td class="col-num">{{topValue}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    <p class="source-note"><a href="/freestyle/leaders">Full leaderboard &rarr;</a></p>
  </section>
  {{/if}}

  {{! ── Recent Records ─────────────────────────────────────────────────────────── }}
  {{#if content.recentRecords}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Recent Passback Records</h2>
    </div>
    <table class="records-table">
      <thead>
        <tr>
          <th>Trick</th>
          <th>Adds</th>
          <th class="col-num">Count</th>
          <th>Holder</th>
          <th>Date</th>
          <th>Video</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.recentRecords}}
        <tr class="record-row{{#if isProbable}} record-probable{{/if}}">
          <td class="col-trick">
            {{#if trickHref}}
              <a href="{{trickHref}}">{{trickName}}</a>
            {{else}}
              <span class="trick-name">{{trickName}}</span>
            {{/if}}
            {{#if sortName}}<span class="trick-sort-name">{{sortName}}</span>{{/if}}
          </td>
          <td class="col-adds">{{#if addsCount}}{{addsCount}}{{else}}&mdash;{{/if}}</td>
          <td class="col-num">{{valueNumeric}}</td>
          <td class="col-holder">
            {{#if holderHref}}
              <a href="{{holderHref}}">{{holderName}}</a>
            {{else}}
              {{holderName}}
            {{/if}}
          </td>
          <td class="col-date">
            {{#if achievedDate}}
              {{formatDate achievedDate}}{{#if dateApproximate}} <em>(approx.)</em>{{/if}}
            {{else}}
              &mdash;
            {{/if}}
          </td>
          <td class="col-video">
            {{#if videoUrl}}
              <a href="{{videoUrl}}" class="video-link" target="_blank" rel="noopener noreferrer"
                 aria-label="Watch {{holderName}} {{trickName}} record video">
                ▶{{#if videoTimecode}} {{videoTimecode}}{{/if}}
              </a>
            {{else}}
              &mdash;
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    <p class="source-note"><a href="/freestyle/records">All records &rarr;</a></p>
  </section>
  {{/if}}

  <section class="content-section">
    <h2 class="section-heading">About Freestyle Footbag</h2>
    <p>
      Freestyle footbag is a discipline built on creativity, technical difficulty, and
      individual style. Unlike net footbag — which is scored on rallies and placement —
      freestyle rewards trick diversity, add difficulty, and sequence length.
    </p>
    <p>
      The ADD (Additional Degree of Difficulty) system assigns a numerical value to each trick,
      enabling objective difficulty scoring alongside subjective execution judging. The core vocabulary
      was established by the early 1990s; modifier stacking extended it through the 2000s.
    </p>
    <p>
      <a href="/freestyle/history">Full history &rarr;</a>
    </p>
  </section>

</div>
