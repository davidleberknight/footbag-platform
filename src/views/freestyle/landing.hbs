{{! /freestyle — portal landing page }}

<div class="hero hero-sm hero-with-mascot">
  <div class="hero-text">
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
  <img class="hero-mascot" src="{{content.mascotSrc}}" alt="{{content.mascotAlt}}" width="150" height="150">
</div>

<div class="wrapper freestyle-landing">

  {{! ── Top reference jump: compact shortcuts to the two core reference
      surfaces. Sits before the in-page section jump-nav so visitors can
      reach the Trick Dictionary or Glossary without scrolling the landing. }}
  <nav class="freestyle-top-reference-jump" aria-label="Reference shortcuts">
    <a class="freestyle-top-reference-link" href="/freestyle/tricks">Trick Dictionary &rarr;</a>
    <a class="freestyle-top-reference-link" href="/freestyle/glossary">Glossary &rarr;</a>
  </nav>

  {{! ── Under-hero jump nav: compact in-page nav that breaks the linear
      essay scroll. Anchors point at the four primary landing sections;
      non-sticky by design. }}
  <nav class="page-jump-nav" aria-label="On this page">
    <a href="#basic-components">Basic Components</a>
    <a href="#core-tricks">Core Tricks</a>
    <a href="#featured">Featured</a>
    <a href="#operators">Operators</a>
  </nav>

  {{! ── The Language of Freestyle Footbag ──────────────────────────────────── }}
  {{! Intro lede + autoplay demo loop; secondary to the structured surfaces below. }}
  <section class="content-section freestyle-language-intro" id="language-intro">
    <h2>{{content.intro.heading}}</h2>
    {{#each content.intro.paragraphs}}
    <p class="freestyle-language-lede">{{this}}</p>
    {{/each}}
    {{#if content.demoVideo}}
    <figure class="demo-video">
      <video autoplay loop muted playsinline preload="metadata" poster="{{content.demoVideo.posterUrl}}">
        <source src="{{content.demoVideo.mp4Url}}" type="video/mp4">
        <p>{{content.demoVideo.caption}}</p>
      </video>
      <figcaption>{{content.demoVideo.caption}}</figcaption>
    </figure>
    {{/if}}
  </section>

  {{! ── Basic Components — Contact / Set / Dex / Spin / Duck / Delay ─────────
      Heading + the six cards carry the teaching; no prose paragraph. }}
  <section class="content-section freestyle-basic-components" id="basic-components">
    <h3 class="freestyle-section-eyebrow">Basic Components</h3>
    <div class="freestyle-basic-components-grid">
      {{#each content.basicComponents}}
      <article class="freestyle-component-card" id="component-{{key}}">
        <h4 class="freestyle-component-name">{{name}}</h4>
        <p class="freestyle-component-desc">{{description}}</p>
        {{#if subfields.length}}
        <dl class="freestyle-component-subfields">
          {{#each subfields}}
          <dt>{{label}}</dt>
          <dd>{{#each values}}{{#unless @first}} <span class="freestyle-subfield-sep">·</span> {{/unless}}<span class="freestyle-subfield-value">{{this}}</span>{{/each}}</dd>
          {{/each}}
        </dl>
        {{/if}}
      </article>
      {{/each}}
    </div>
  </section>

  {{! ── Core Tricks — compact symbolic objects ─────────────────────────────
      Each card: #slug + zero-or-more ≡ readings + optional symbolic notation
      + ADD. Rendering rule: slug links to /freestyle/tricks/{slug}; ≡ readings
      are equivalence aliases from freestyleSymbolicEquivalences.ts. }}
  <section class="content-section freestyle-core-tricks" id="core-tricks">
    <h3 class="freestyle-section-eyebrow">Core Tricks</h3>
    <p class="freestyle-section-sub">The irreducible base tricks. Most named tricks descend from one of these.</p>
    {{> core-tricks-grid tricks=content.coreTricks}}
    <p class="core-trick-footnote">Cards marked <span class="core-trick-add-pending">&mdash;</span> have a pending dictionary entry.</p>
  </section>

  {{! ── Featured — merged Competition Formats + Demonstrations strip ──────
      One compact grid; format names (Routine / Circle / Sick 3 / Shred 30)
      preserved as card titles (cultural + navigational anchors); curated
      demonstrations carry hashtag chips. No prose paragraphs. }}
  {{#if content.featured.length}}
  <section class="content-section freestyle-featured" id="featured">
    <h2>Featured</h2>
    <div class="freestyle-featured-grid">
      {{#each content.featured}}
      <article class="card featured-card" id="featured-{{key}}">
        <div class="video-embed">
          {{> video-facade media=media}}
        </div>
        <div class="card-title">{{title}}</div>
        {{#if caption}}<p class="featured-caption">{{caption}}</p>{{/if}}
        {{> media-tag-strip tags=tags}}
      </article>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{! ── Operator board — Tier-1 vocabulary primer ─────────────────────────── }}
  {{> operator-board heading=content.operatorBoard.heading lede=content.operatorBoard.lede tiers=content.operatorBoard.tiers}}
  <p class="operator-board-footer-link"><a href="/freestyle/sets">Full set notation reference &rarr;</a></p>

  {{! ── Portal cards (intent-ordered: learn → reference → records → competition → context → analysis) ── }}
  <section class="content-section">
    <div class="card-grid card-grid-2col">

      <div class="card">
        <div class="card-title">Tutorials &amp; Learning</div>
        <p>
          Curated tutorial series and demonstration archives from the wider
          freestyle community.
        </p>
        <div class="card-actions">
          <a href="/media/gallery_tricks_of_the_trade" class="btn btn-outline">Tricks of the Trade &rarr;</a>
          <a href="/media/gallery_passback_tutorials" class="btn btn-outline">PassBack Tutorials &rarr;</a>
          <a href="/media/gallery_anz_trikz" class="btn btn-outline">AnzTrikz &rarr;</a>
          <a href="/media/gallery_shred_global" class="btn btn-outline">Shred Global &rarr;</a>
          <a href="/media/gallery_footbag_finland" class="btn btn-outline">Footbag Finland &rarr;</a>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Glossary</div>
        <p>
          Beginner-friendly explanations of freestyle vocabulary: run-quality terms,
          components of a trick, set / modifier / catch concepts, and the abbreviations
          you'll encounter in tutorials and contests.
        </p>
        <div class="card-actions">
          <a href="/freestyle/glossary" class="btn btn-outline">Open glossary &rarr;</a>
        </div>
      </div>

      <div class="card{{#unless content.totalTricks}} card-coming-soon{{/unless}}">
        <div class="card-title">Trick Dictionary</div>
        <p>
          Canonical reference for named tricks: ADD difficulty values, structural decomposition,
          modifier links, and family groupings. Browse by ADD bucket, by family, or by the
          set/modifier each trick uses.
        </p>
        {{#if content.totalTricks}}
        <div class="card-actions">
          <a href="/freestyle/tricks" class="btn btn-outline">Browse the trick dictionary &rarr;</a>
        </div>
        {{else}}
        <span class="badge badge-coming-soon">Coming soon</span>
        {{/if}}
      </div>

      <div class="card{{#unless content.totalRecords}} card-coming-soon{{/unless}}">
        <div class="card-title">World Records</div>
        <p>
          Per-trick consecutive-completion records, drawn from the long-running
          Passback record community. Browse by trick, or see the all-time leaderboard
          across record-holders.
        </p>
        {{#if content.totalRecords}}
        <div class="card-actions">
          <a href="/freestyle/records" class="btn btn-outline">View records &rarr;</a>
          <a href="/freestyle/leaders" class="btn btn-outline">Leaderboard &rarr;</a>
        </div>
        {{else}}
        <span class="badge badge-coming-soon">Coming soon</span>
        {{/if}}
      </div>

      <div class="card">
        <div class="card-title">Competition</div>
        <p>
          Top competitors, podium counts, and event history across documented
          freestyle events from the 1980s to the present. Includes solo and
          partnership records.
        </p>
        <div class="card-actions">
          <a href="/freestyle/competition" class="btn btn-outline">Competition history &rarr;</a>
          <a href="/freestyle/partnerships" class="btn btn-outline">Partnerships &rarr;</a>
        </div>
      </div>

      <div class="card">
        <div class="card-title">History &amp; ADD System</div>
        <p>
          How freestyle's vocabulary, scoring, and competitive geography evolved &mdash;
          from the foundational 1980s clipper-and-mirage era through modifier stacking
          in the 2000s and the modern European-led refinement.
        </p>
        <div class="card-actions">
          <a href="/freestyle/history" class="btn btn-outline">Full history &rarr;</a>
          <a href="/freestyle/add-analysis" class="btn btn-outline">ADD analysis &rarr;</a>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Insights</div>
        <p>
          Data-driven sequence analysis across decades of competitive freestyle:
          how trick combinations evolved, which modifiers anchored each era, and
          the patterns visible in the long-form record.
        </p>
        <div class="card-actions">
          <a href="/freestyle/insights" class="btn btn-outline">Insights &rarr;</a>
        </div>
      </div>

    </div>
  </section>

  {{! ── Get started tiles (placeholders) ───────────────────────────────────── }}
  <section class="content-section">
    <h2>Get Started</h2>
    <div class="card-grid card-grid-3col get-started-tiles">
      {{#each content.getStartedTiles}}
      <a class="card card-tile{{#if comingSoon}} card-coming-soon{{/if}}" href="{{href}}">
        <div class="card-title">{{label}}</div>
        {{#if comingSoon}}<span class="badge badge-coming-soon">Coming soon</span>{{/if}}
      </a>
      {{/each}}
    </div>
  </section>

</div>
