{{! /freestyle/history — the encyclopedia's introduction: how freestyle became a language }}

<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  {{! ── Thesis + opening ─────────────────────────────────────────────── }}
  <section class="content-section">
    <p class="history-thesis">{{content.thesis}}</p>
    {{#each content.intro}}<p>{{this}}</p>{{/each}}
  </section>

  {{! ── The narrative, one section per idea, each evidence for the thesis ── }}
  {{#each content.sections}}
  <section id="{{id}}" class="content-section">
    <div class="section-heading">
      <h2>{{heading}}</h2>
    </div>
    {{#each paragraphs}}<p>{{this}}</p>{{/each}}
    {{#if links.length}}
    <ul class="history-link-list">
      {{#each links}}<li><a href="{{href}}">{{label}}</a></li>{{/each}}
    </ul>
    {{/if}}
  </section>
  {{/each}}

  {{! ── Sources on this site ──────────────────────────────────────────── }}
  {{#if content.references.length}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Where these facts come from</h2>
      <p class="section-intro">
        This history is drawn from the encyclopedia's own pages. Follow them for the fuller record.
      </p>
    </div>
    <ul class="history-link-list">
      {{#each content.references}}<li><a href="{{href}}">{{label}}</a></li>{{/each}}
    </ul>
  </section>
  {{/if}}

  {{! ── Where to go next ──────────────────────────────────────────────── }}
  {{#if content.whereNext.length}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Where to go next</h2>
    </div>
    <ul class="history-link-list">
      {{#each content.whereNext}}<li><a href="{{href}}">{{label}}</a></li>{{/each}}
    </ul>
  </section>
  {{/if}}

</div>
