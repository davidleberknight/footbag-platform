{{! /freestyle/history — editorial history, pioneers, eras }}

<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  {{! ── Hero/intro media panel ──────────────────────────────────────────── }}
  {{#if content.heroMedia}}
  <section class="content-section history-media history-media--hero">
    {{#if content.heroMedia.media}}
    <div class="video-embed">
      {{> video-facade media=content.heroMedia.media}}
    </div>
    {{/if}}
    {{#if content.heroMedia.caption}}<p class="history-media-caption">{{content.heroMedia.caption}}</p>{{/if}}
    {{#if content.heroMedia.placeholderNote}}<p class="history-media-placeholder">{{content.heroMedia.placeholderNote}}</p>{{/if}}
  </section>
  {{/if}}

  {{! ── Competitive Eras ──────────────────────────────────────────────────────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>Competitive Eras</h2>
      <p class="section-intro">
        Five overlapping chapters in the sport's competitive life — each shaped by
        the players, technology, and cultural energy of its time.
      </p>
    </div>
    {{#each content.eras}}
    <div class="history-era">
      <h3>{{period}} — {{label}}</h3>
      <p>{{summary}}</p>
      {{#if keyFigures.length}}
      <p class="detail-muted">Key figures: {{#each keyFigures}}{{#unless @first}}, {{/unless}}{{this}}{{/each}}</p>
      {{/if}}
    </div>
    {{/each}}
  </section>

  {{! ── Evolution of Difficulty ────────────────────────────────────────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>Evolution of Difficulty</h2>
      <p class="section-intro">
        A more focused lens on the same history: how the sport's working
        difficulty grammar grew, decade by decade.
      </p>
    </div>
    <div class="evolution-strip">
      {{#each content.evolution}}
      <div class="evolution-card">
        <div class="evolution-period">{{period}}</div>
        <h3 class="evolution-label">{{label}}</h3>
        <p>{{summary}}</p>
      </div>
      {{/each}}
    </div>
  </section>

  {{! ── How combos grew ───────────────────────────────────────────────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>How Combos Grew</h2>
      <p class="section-intro">
        The story of how multi-trick sequences evolved from isolated kicks
        into the linked, density-driven runs that define modern competition.
      </p>
    </div>
    {{#each content.comboEvolution}}<p>{{this}}</p>{{/each}}
    <p class="detail-muted">
      Run-quality terms used here — <strong>guiltless</strong>, <strong>fearless</strong>,
      <strong>density</strong> — are defined in the
      <a href="/freestyle/glossary#1-add-system--run-quality">glossary's run-quality section</a>.
    </p>
  </section>

  {{! ── From routines to guiltless: how judging evolved ──────────────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>From Routines to Guiltless: How Judging Evolved</h2>
      <p class="section-intro">
        Why a 1985 freestyle routine and a 2025 fearless run can both be the
        peak of their era — and how the language for "good" expanded along the way.
      </p>
    </div>
    {{#each content.earlyRoutineEvolution}}<p>{{this}}</p>{{/each}}
    <p class="detail-muted">
      See the <a href="/freestyle/glossary#1-add-system--run-quality">run-quality vocabulary</a>
      for the definitions of Tiltless, Guiltless, Tripless, Fearless, Beastly, and Godly.
    </p>
  </section>

  {{! ── Pioneers ────────────────────────────────────────────────────────────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>Founders &amp; Pioneers</h2>
    </div>
    <p class="section-intro">
      The early BAP (Big ADD Posse) inductees of the early 1990s were establishing
      freestyle's visual identity, trick taxonomy, and competition culture in the
      years before the ADD table was widely standardized. They built the language
      the sport still speaks — and the contests, friendships, and recordings that
      kept it alive.
    </p>

    {{#if content.pioneersMedia}}
    <div class="history-media history-media--pioneers">
      {{#if content.pioneersMedia.media}}
      <div class="video-embed">
        {{> video-facade media=content.pioneersMedia.media}}
      </div>
      {{/if}}
      {{#if content.pioneersMedia.caption}}<p class="history-media-caption">{{content.pioneersMedia.caption}}</p>{{/if}}
      {{#if content.pioneersMedia.placeholderNote}}<p class="history-media-placeholder">{{content.pioneersMedia.placeholderNote}}</p>{{/if}}
    </div>
    {{/if}}
    <div class="records-table-wrap">
      <table class="records-table records-table-sm">
        <thead>
          <tr>
            <th>Player</th>
            <th>Contribution</th>
          </tr>
        </thead>
        <tbody>
          {{#each content.pioneers}}
          <tr>
            <td>
              {{#if profileHref}}
                <a href="{{profileHref}}">{{name}}</a>
              {{else}}
                {{name}}
              {{/if}}
              {{#if recognitions.length}}
              {{#each recognitions}}<span class="pioneer-recognition" title="Recognition: {{this}}">{{this}}</span>{{/each}}
              {{/if}}
            </td>
            <td>{{note}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </section>

  {{! ── ADD System ───────────────────────────────────────────────────────────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>The ADD System</h2>
    </div>
    {{#each content.addSystem}}
    <p>{{this}}</p>
    {{/each}}
    <p>
      See the <a href="/freestyle/tricks">Trick Dictionary</a> for ADD values and modifier relationships,
      and <a href="/freestyle/insights">Freestyle Insights</a> for data-driven difficulty analysis.
    </p>
  </section>

  {{! ── Regional Shift ──────────────────────────────────────────────────────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>The Geographic Shift</h2>
    </div>
    <p>{{content.regionalShift}}</p>
    <p>
      See <a href="/freestyle/competition">Freestyle Competition</a> for podium counts and career records.
    </p>
  </section>

  {{! ── Modern Era ────────────────────────────────────────────────────────────── }}
  <section class="content-section">
    <div class="section-heading">
      <h2>The Modern Game</h2>
    </div>
    <p>{{content.modernEra}}</p>

    {{#if content.modernEraMedia}}
    <div class="history-media history-media--modern">
      {{#if content.modernEraMedia.media}}
      <div class="video-embed">
        {{> video-facade media=content.modernEraMedia.media}}
      </div>
      {{/if}}
      {{#if content.modernEraMedia.caption}}<p class="history-media-caption">{{content.modernEraMedia.caption}}</p>{{/if}}
      {{#if content.modernEraMedia.placeholderNote}}<p class="history-media-placeholder">{{content.modernEraMedia.placeholderNote}}</p>{{/if}}
    </div>
    {{/if}}
  </section>

  <p class="source-note">
    Based on analysis of 774 documented competitive events (1980–2026) and 395 Sick 3 format sequences.
    Player descriptions draw from competition records and community documentation.
  </p>

</div>
