{{!--
  /freestyle/sets — Set Encyclopedia.

  Standalone minimalist index of canonical sets as first-class ontology
  objects. Distinct from /freestyle/tricks?view=sets (Trick Dictionary's
  By-Set view) and from /freestyle/compositional-sets (exploratory hub).

  Curator UX directive: cards stay compact + scan-friendly — name, hashtag,
  formula, one-sentence movement, one provenance line, up to 3 quick-
  relation tags, "View details →". Deep prose lives on the detail pages
  at /freestyle/sets/<slug>.

  Visual goal: compositional vocabulary board, not glossary essay.
--}}
<div class="wrapper sets-encyclopedia">

  <header class="sets-encyclopedia-head">
    <p class="hero-eyebrow">Compositional vocabulary</p>
    <h1>Set Encyclopedia</h1>
    <p class="sets-encyclopedia-intro">{{content.intro}}</p>
    <p class="detail-muted">
      Why an encyclopedia instead of a dictionary? The trick dictionary defines
      individual tricks. The Set Encyclopedia explores the movement systems that
      tricks are built from, and how those systems relate to one another.
    </p>
    <p class="sets-encyclopedia-total detail-muted"><strong>{{content.totalSets}}</strong> documented sets across {{content.subtypeSections.length}} subtypes.</p>
  </header>

  <nav class="sets-encyclopedia-cross-nav" aria-label="Related surfaces">
    <p class="sets-encyclopedia-cross-nav-intro">Related surfaces, different questions:</p>
    <ul class="sets-encyclopedia-cross-nav-list">
      <li><a href="{{content.crossLinks.dictionaryBysetHref}}">{{content.crossLinks.dictionaryBysetLabel}}</a> <span class="sets-encyclopedia-cross-nav-question">(which tricks use this set?)</span></li>
      <li><a href="{{content.crossLinks.compositionalHubHref}}">{{content.crossLinks.compositionalHubLabel}}</a> <span class="sets-encyclopedia-cross-nav-question">(how do sets relate as families?)</span></li>
      <li><a href="{{content.crossLinks.operatorsPageHref}}">{{content.crossLinks.operatorsPageLabel}}</a> <span class="sets-encyclopedia-cross-nav-question">(what transformations act on tricks?)</span></li>
    </ul>
  </nav>

  {{#if content.subtypeMiniToc.length}}
  {{! Mini-TOC pill row — one anchor per rendered subtype section, in
      render order. Reuses the shared .glossary-mini-toc styling. }}
  <nav class="glossary-mini-toc" aria-label="In this encyclopedia">
    <span class="glossary-mini-toc-label">In this encyclopedia:</span>
    <ol class="glossary-mini-toc-list">
      {{#each content.subtypeMiniToc}}
      <li><a href="#{{anchorId}}">{{label}}</a></li>
      {{/each}}
    </ol>
  </nav>
  {{/if}}

  {{#each content.subtypeSections}}
  <section class="sets-encyclopedia-subtype" id="set-subtype-{{key}}" aria-label="{{label}}">
    <div class="sets-encyclopedia-subtype-head">
      <h2>{{label}}</h2>
      <span class="sets-encyclopedia-subtype-count">{{count}}</span>
    </div>
    {{#if intro}}
    <p class="sets-encyclopedia-subtype-intro">{{intro}}</p>
    {{/if}}
    {{! Compact rows that mirror the trick-dictionary row contract (reusing the
        dict-trick-row structure + the SET notation slot). Long prose (Derived,
        Common in, full explanation) lives on the set detail page. }}
    <div class="dict-trick-row-stack">
      {{#each cards}}
      <article class="dict-trick-row" id="enc-set-{{slug}}" data-set-slug="{{slug}}">
        <div class="dict-trick-row-head">
          <a class="dict-trick-row-title" href="{{detailHref}}">{{displayName}}</a>
          {{#if isFlagship}}<span class="sets-encyclopedia-card-flagship" title="{{flagshipTitle}}">&#9733;</span>{{/if}}
          <span class="dict-trick-row-hashtag" aria-label="Tag identity">{{hashtag}}</span>
          <span class="sets-encyclopedia-card-status sets-encyclopedia-card-status--{{statusPill.key}}">{{statusPill.label}}</span>
          <span class="sets-encyclopedia-card-role-chip sets-encyclopedia-card-role-chip--{{roleKey}}">{{roleLabel}}</span>
        </div>
        <div class="dict-trick-row-notation">
          <span class="dict-trick-row-job">
            <span class="dict-trick-row-label">SET</span>
            <code class="dict-trick-row-job-value">{{formula}}</code>
          </span>
          <a class="sets-encyclopedia-card-detail-link" href="{{detailHref}}">View details &rarr;</a>
        </div>
        <p class="sets-encyclopedia-card-movement">{{compactMovement}}</p>
      </article>
      {{/each}}
    </div>
    {{#if nextSubtypeAnchor}}
    {{! Read-next footer — forward pointer to the next rendered
        subtype. Suppresses on the last section. Reuses the shared
        .glossary-section-next styling. }}
    <p class="glossary-section-next">Next &mdash; <a href="#{{nextSubtypeAnchor}}">{{nextSubtypeLabel}}</a>: {{nextSubtypeTagline}}.</p>
    {{/if}}
  </section>
  {{/each}}

</div>
