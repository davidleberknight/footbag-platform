{{! /freestyle/tt-series — Tricks of the Trade lesson series, ordered by lesson number. }}
{{! Read-only view. URL-reference media (YouTube) only; never the MP4 gallery model. }}

<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  <section class="content-section tt-counts" aria-label="Series status counts">
    <ul class="tt-counts-list">
      <li><strong>{{content.counts.active}}</strong> active</li>
      <li><strong>{{content.counts.pending}}</strong> awaiting dictionary activation</li>
      <li><strong>{{content.counts.missing}}</strong> no video staged</li>
      <li><strong>{{content.counts.meta}}</strong> meta</li>
      <li><span class="tt-counts-total">{{content.total}} lessons total</span></li>
    </ul>
  </section>

  <section class="content-section">
    <ol class="tt-series-list">
      {{#each content.items}}
        <li class="tt-item tt-status-{{status}}" data-tt-number="{{ttNumber}}">
          <div class="tt-item-num">TT #{{ttNumber}}</div>
          <div class="tt-item-body">
            <h2 class="tt-item-title">
              {{#if trickHref}}<a href="{{trickHref}}">{{lessonTitle}}</a>{{else}}{{lessonTitle}}{{/if}}
            </h2>

            <p class="tt-item-status">
              {{#if (eq status 'ACTIVE')}}<span class="tt-chip tt-chip-active">Active in dictionary</span>{{/if}}
              {{#if (eq status 'PENDING')}}<span class="tt-chip tt-chip-pending">Awaiting dictionary activation</span>{{/if}}
              {{#if (eq status 'MISSING')}}<span class="tt-chip tt-chip-missing">No video staged</span>{{/if}}
              {{#if (eq status 'META')}}<span class="tt-chip tt-chip-meta">Meta lesson</span>{{/if}}
              {{#if duplicateCount}}<span class="tt-chip tt-chip-warn">{{duplicateCount}} sidecars (duplicate)</span>{{/if}}
            </p>

            {{#if videoUrl}}
              <a class="tt-item-video video-facade"
                 href="{{videoUrl}}"
                 target="_blank" rel="noopener noreferrer"
                 data-platform="youtube"
                 {{#if videoEmbedUrl}}data-embed-url="{{videoEmbedUrl}}"{{/if}}
                 aria-label="Play TT #{{ttNumber}}: {{lessonTitle}}">
                {{#if thumbnailUrl}}<img src="{{thumbnailUrl}}" alt="" loading="lazy" />{{/if}}
                <span class="tt-item-play" aria-hidden="true">&#9654;</span>
              </a>
              {{#if creator}}<p class="tt-item-creator">{{creator}}</p>{{/if}}
            {{/if}}

            {{#if notes}}<p class="tt-item-notes">{{notes}}</p>{{/if}}
          </div>
        </li>
      {{/each}}
    </ol>
  </section>

</div>
