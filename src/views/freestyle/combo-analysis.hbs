{{!--
  /freestyle/combo-analysis — Combo Analysis.

  Educational page operating at the sequence level above the trick
  dictionary. Pure curator content via FREESTYLE_COMBO_ANALYSIS_CONTENT;
  logic-light template; no client JS.
--}}

<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper combo-analysis-page">

  <p>
    Freestyle isn't only single tricks; players link them into longer,
    flowing runs. This page looks at how those sequences are built: what turns
    a string of tricks into a combo worth watching.
  </p>

  {{!-- Philosophy ─────────────────────────────────────────────────────── --}}
  <section id="philosophy" class="content-section">
    <div class="section-heading">
      <h2>Philosophy</h2>
    </div>
    {{#each content.philosophyParagraphs}}
    <p>{{this}}</p>
    {{/each}}
  </section>

  {{!-- §2 — Run-quality terminology ───────────────────────────────────── --}}
  <section id="run-quality" class="content-section">
    <div class="section-heading">
      <h2>Run-quality terminology</h2>
      <p class="section-intro">{{content.runQualityIntro}}</p>
    </div>

    <table class="combo-analysis-run-quality">
      <thead>
        <tr>
          <th>Term</th>
          <th>Definition</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.runQualityEntries}}
        <tr id="{{anchorId}}">
          <td><strong>{{term}}</strong></td>
          <td>{{definition}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </section>

  {{!-- §3-§4 — Sequence + Difficulty architecture ────────────────────── --}}
  {{#each content.architectureSections}}
  <section id="{{anchorId}}" class="content-section">
    <div class="section-heading">
      <h2>{{heading}}</h2>
      <p class="section-intro">{{lede}}</p>
    </div>

    <dl class="combo-analysis-architecture-list">
      {{#each terms}}
      <dt id="{{anchorId}}">{{term}}</dt>
      <dd>{{definition}}</dd>
      {{/each}}
    </dl>
  </section>
  {{/each}}

  {{!-- §5 — Worked examples ───────────────────────────────────────────── --}}
  <section id="worked-examples" class="content-section">
    <div class="section-heading">
      <h2>Worked examples</h2>
      <p class="section-intro">
        Five vignettes, ordered from standard to extreme. Each grounds a real
        corpus pattern in the §3 / §4 vocabulary.
      </p>
    </div>

    <ol class="combo-analysis-worked-examples">
      {{#each content.workedExamples}}
      <li id="{{anchorId}}" class="combo-analysis-worked-example">
        <h3 class="combo-analysis-example-heading">{{title}}</h3>
        <pre class="combo-analysis-example-diagram">{{diagram}}</pre>
        <p class="combo-analysis-example-total"><strong>{{totalLine}}</strong></p>
        <p class="combo-analysis-example-what">{{whatHappens}}</p>
        <h4 class="combo-analysis-example-why-heading">Why this architecture works</h4>
        <ul class="combo-analysis-example-why">
          {{#each whyItWorks}}
          <li>{{this}}</li>
          {{/each}}
        </ul>
        {{#if conceptsSurfaced.length}}
        <p class="combo-analysis-example-concepts">
          <strong>Concepts surfaced:</strong>
          {{#each conceptsSurfaced}}<a href="#{{anchorId}}">{{label}}</a>{{#unless @last}}; {{/unless}}{{/each}}.
        </p>
        {{/if}}
        <p class="combo-analysis-example-corpus"><em>{{corpusNote}}</em></p>
      </li>
      {{/each}}
    </ol>
  </section>

  {{!-- §6 — Transition topology ───────────────────────────────────────── --}}
  <section id="transition-topology" class="content-section">
    <div class="section-heading">
      <h2>Transition topology</h2>
      <p class="section-intro">{{content.topologyIntro}}</p>
    </div>

    <dl class="combo-analysis-topology-list">
      {{#each content.topologyPatterns}}
      <dt id="{{anchorId}}">{{name}}</dt>
      <dd>{{definition}}</dd>
      {{/each}}
    </dl>
  </section>

  {{!-- §7 — Caveats ───────────────────────────────────────────────────── --}}
  <section id="caveats" class="content-section">
    <div class="section-heading">
      <h2>Honesty &amp; uncertainty</h2>
      <p class="section-intro">
        What the documented patterns describe, and what they don&rsquo;t.
      </p>
    </div>

    <ul class="combo-analysis-caveats">
      {{#each content.caveats}}
      <li>{{this}}</li>
      {{/each}}
    </ul>
  </section>

  {{!-- §8 — Cross-references ──────────────────────────────────────────── --}}
  <nav id="further-reading" class="combo-analysis-cross-links" aria-label="Related pages">
    <h2>Further reading</h2>
    <ul>
      {{#each content.crossLinks}}
      <li>
        <a href="{{href}}">{{label}}</a>: {{description}}
      </li>
      {{/each}}
    </ul>
  </nav>

</div>
