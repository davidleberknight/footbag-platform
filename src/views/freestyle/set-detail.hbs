{{!--
  Set detail page.
  One page per canonical set. Mirrors the trick-detail information order so the
  two surfaces read the same way: identity (name / hashtag) then notation
  (formula) then explanation (movement) near the top, then equivalent names,
  then the structural equivalence readings, then related / derived systems,
  then example tricks, then cross-links, sibling navigation, and source / audit
  provenance last. Equivalent names (alternate set names) and the structural
  equivalence readings are separate sections and are never merged.
--}}
<article class="set-detail" data-set-slug="{{content.slug}}">

  <header class="set-detail-head">
    <p class="set-detail-eyebrow">{{content.subtypeLabel}}</p>
    <h1 class="set-detail-name">{{content.displayName}}</h1>
    <code class="set-detail-hashtag">{{content.hashtag}}</code>
  </header>

  {{#if content.education}}
  {{!-- Concept-first teaching layer (migrated sets only). Reads in lockstep
        with the operator template; "How it launches" / "Launch notes" replace
        the operator slots "How it changes the base trick" / "Execution notes".
        When present it absorbs the thin Formula / Movement sections below, which
        are suppressed; the structural reference sections still render beneath. --}}
  <p class="modifier-subtitle">{{content.education.pageSubtitle}}</p>

  <section class="set-detail-section" aria-label="What it is">
    <h2>What it is</h2>
    <p>{{content.education.definition}}</p>
  </section>

  <section class="set-detail-section" aria-label="Why it exists">
    <h2>Why it exists</h2>
    <p>{{content.education.whyItExists}}</p>
  </section>

  <section class="set-detail-section" aria-label="How it launches">
    <h2>How it launches</h2>
    <p>{{content.education.howItLaunches}}</p>
  </section>

  <section class="set-detail-section" aria-label="JOB notation">
    <h2>JOB notation</h2>
    <p>{{content.education.jobNotation}}</p>
  </section>

  <section class="set-detail-section" aria-label="Where it appears">
    <h2>Where it appears</h2>
    <p>{{content.education.whereItAppears}}</p>
  </section>

  <section class="set-detail-section" aria-label="How it composes">
    <h2>How it composes</h2>
    <p>{{content.education.howItComposes}}</p>
  </section>

  <section class="set-detail-section symbolic-walking-progression" aria-label="Progression {{content.education.progression.anchorBaseLabel}}">
    <h2>Progression {{content.education.progression.anchorBaseLabel}}</h2>
    <ol class="progression-chain" role="list">
      {{#each content.education.progression.steps}}
      <li class="progression-step{{#if isAnchor}} is-anchor{{/if}}" id="set-step-{{stepNumber}}-{{slug}}">
        <div class="step-header">
          <span class="step-number" aria-hidden="true">{{stepNumber}}</span>
          {{#if isPilot}}<a class="step-name" href="{{detailHref}}">{{canonicalName}}</a>{{else}}<span class="step-name">{{canonicalName}}</span>{{/if}}
          {{#if adds}}<span class="step-adds" aria-label="ADD {{adds}}">{{adds}} ADD</span>{{/if}}
          <span class="step-modifier">{{addedLabel}}</span>
        </div>
        <p class="step-rationale">{{rationale}}</p>
      </li>
      {{/each}}
    </ol>
  </section>

  <section class="set-detail-section" aria-label="Representative tricks">
    <h2>Representative tricks</h2>
    <p>{{content.education.representativeTricks.framingLine}}</p>
    <ul class="cross-base-list">
      {{#each content.education.representativeTricks.examples}}
      <li>
        <span class="cross-base-base">{{baseLabel}}</span>
        {{#if isPilot}}<a class="cross-base-name" href="{{detailHref}}">{{canonicalName}}</a>{{else}}<span class="cross-base-name">{{canonicalName}}</span>{{/if}}
        {{#if adds}}<span class="cross-base-adds">{{adds}} ADD</span>{{/if}}
        <p class="cross-base-prose">{{prose}}</p>
      </li>
      {{/each}}
    </ul>
  </section>

  <section class="set-detail-section" aria-label="Common confusions">
    <h2>Common confusions</h2>
    {{#each content.education.confusions}}
    <div class="confusion-card">
      <h3>{{heading}}</h3>
      <p>{{prose}}</p>
    </div>
    {{/each}}
  </section>

  <section class="set-detail-section" aria-label="Related concepts">
    <h2>Related concepts</h2>
    <ul class="related-modifiers-list">
      {{#each content.education.relatedConcepts}}
      <li><span class="related-name">{{name}}</span>: {{prose}}</li>
      {{/each}}
    </ul>
  </section>

  <section class="set-detail-section" aria-label="Launch notes">
    <h2>Launch notes</h2>
    <p>{{content.education.launchNotes}}</p>
  </section>
  {{/if}}

  {{#unless content.education}}
  <section class="set-detail-section" aria-label="Formula">
    <h2>Formula</h2>
    {{#if content.formula}}<code class="set-detail-formula">{{content.formula}}</code>{{else}}<p class="set-detail-component-note">Canonical JOB notation is pending: the launch mechanics are defined, but the bracket-grammar form is not yet authored.</p>{{/if}}
  </section>

  <section class="set-detail-section" aria-label="Movement explanation">
    <h2>Movement</h2>
    <p class="set-detail-movement">{{content.movementExplanation}}</p>
  </section>
  {{/unless}}

  {{#if content.xDexReceiverNote}}
  <section class="set-detail-section" aria-label="X-Dex receiver behavior">
    <h2>X-Dex behavior</h2>
    <p class="set-detail-component-note">{{content.xDexReceiverNote}} <a href="/freestyle/glossary#term-x-dex">See the X-Dex glossary entry.</a></p>
  </section>
  {{/if}}

  {{#if content.equivalentNames.length}}
  <section class="set-detail-section" aria-label="Equivalent names">
    <h2>Equivalent names</h2>
    <ul class="set-detail-equivalent-names">
      {{#each content.equivalentNames}}
      <li>
        <strong>{{name}}</strong>
        {{#if structuralReading}}<span class="set-detail-equivalent-structural">Structural reading: {{structuralReading}}</span>{{/if}}
        {{#if note}}<span class="set-detail-equivalent-note">{{note}}</span>{{/if}}
      </li>
      {{/each}}
    </ul>
  </section>
  {{/if}}

  {{#if content.equivalenceReadings.length}}
  <section class="set-detail-section" aria-label="Equivalence readings">
    <h2>Equivalence readings</h2>
    <ul class="set-detail-equivalences">
      {{#each content.equivalenceReadings}}<li>{{this}}</li>{{/each}}
    </ul>
  </section>
  {{/if}}

  {{#if content.derivedSystems.length}}
  <section class="set-detail-section" aria-label="Derived systems">
    <h2>Derived systems</h2>
    <ul class="set-detail-link-list">
      {{#each content.derivedSystems}}<li><a href="{{href}}">{{label}}</a></li>{{/each}}
    </ul>
  </section>
  {{/if}}

  {{#if content.relatedSystems.length}}
  <section class="set-detail-section" aria-label="Related systems">
    <h2>Related systems</h2>
    <ul class="set-detail-link-list">
      {{#each content.relatedSystems}}<li><a href="{{href}}">{{label}}</a></li>{{/each}}
    </ul>
  </section>
  {{/if}}

  {{#if content.hasExampleTricks}}
  <section class="set-detail-section set-detail-examples-section" aria-label="Example tricks">
    <h2>Example tricks</h2>
    <ul class="set-detail-trick-list">
      {{#each content.exampleTricks}}
      <li class="set-detail-trick">
        <a href="{{href}}">{{displayName}}</a>
        <span class="set-detail-trick-add">({{addsLabel}})</span>
        {{#if operationalNotation}}<code class="set-detail-trick-notation">{{operationalNotation}}</code>{{/if}}
      </li>
      {{/each}}
    </ul>
  </section>
  {{else}}
  <section class="set-detail-section set-detail-examples-section set-detail-examples-section--empty" aria-label="Example tricks">
    <h2>Example tricks</h2>
    <p class="set-detail-examples-empty">No tricks are linked to this set yet. Some sets are documented before any trick is connected to them.</p>
  </section>
  {{/if}}

  <section class="set-detail-section" aria-label="Cross-references">
    <h2>Cross-references</h2>
    <ul class="set-detail-cross-links">
      <li><a href="{{content.crossLinks.setHubHref}}">Back to Set Hub</a></li>
      <li><a href="{{content.crossLinks.compositionalHubHref}}">View on Compositional Sets hub</a></li>
      <li><a href="{{content.crossLinks.movementSystemAxisHref}}">Set / Uptime Systems axis on Movement Systems</a></li>
      {{#if content.crossLinks.operatorReferenceHref}}
      <li><a href="{{content.crossLinks.operatorReferenceHref}}">Operator entry on Operators &amp; Modifiers</a></li>
      {{/if}}
    </ul>
    <p class="set-detail-component-note">{{content.componentMechanicsNote}}</p>
  </section>

  {{#if (or content.previousSet content.nextSet)}}
  {{! S5: subtype-internal sibling navigation. Suppresses entirely when
      both are null (single-set subtype, edge case only). Renders prev
      on the left, next on the right; either side may be absent
      independently. }}
  <nav class="set-detail-sibling-nav" aria-label="Subtype navigation">
    {{#if content.previousSet}}
    <a class="set-detail-sibling-nav-prev" href="{{content.previousSet.href}}">
      <span class="set-detail-sibling-nav-arrow" aria-hidden="true">&larr;</span>
      <span class="set-detail-sibling-nav-label">Previous in {{content.subtypeLabel}}</span>
      <span class="set-detail-sibling-nav-name">{{content.previousSet.displayName}}</span>
    </a>
    {{/if}}
    {{#if content.nextSet}}
    <a class="set-detail-sibling-nav-next" href="{{content.nextSet.href}}">
      <span class="set-detail-sibling-nav-label">Next in {{content.subtypeLabel}}</span>
      <span class="set-detail-sibling-nav-name">{{content.nextSet.displayName}}</span>
      <span class="set-detail-sibling-nav-arrow" aria-hidden="true">&rarr;</span>
    </a>
    {{/if}}
  </nav>
  {{/if}}

  <footer class="set-detail-provenance" aria-label="Source provenance">
    <span class="set-card-source set-card-source--{{content.source}}">{{content.sourceLabel}}</span>
    {{#if content.auditStatusLabel}}<span class="set-card-audit set-card-audit--{{content.auditStatus}}">{{content.auditStatusLabel}}</span>{{/if}}
    <p class="set-detail-citation">{{content.sourceCitation}}</p>
  </footer>

</article>
