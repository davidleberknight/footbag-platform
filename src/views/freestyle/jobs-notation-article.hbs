{{! /freestyle/notation-article — verbatim reproduction of Ben Job's 1995 notation proposal }}

<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    {{#if page.eyebrow}}<p class="hero-eyebrow">{{page.eyebrow}}</p>{{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  <section class="content-section">
    <p class="text-muted">
      The original message in full, reproduced verbatim including its period spelling.
    </p>
    <pre class="notation-article-text">{{content.articleText}}</pre>
    <p class="source-note">
      Source: Ben Job, <em>{{content.articleTitle}}</em>, message to
      <code>footbag@footbag.org</code>, October 31, 1995.
    </p>
    <p class="mt-4">
      <a class="btn btn-outline" href="/freestyle/glossary#jobs-notation">Back to the Glossary</a>
    </p>
  </section>

</div>
