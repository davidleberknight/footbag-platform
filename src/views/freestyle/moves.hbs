{{! /freestyle/sets — move set notation reference }}

<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  <section class="content-section">
    <h2 class="section-heading">Reading Set Notation</h2>
    <p>
      Each set prefix describes the arc of the bag from plant to catch. The notation uses four
      components: the <strong>set type</strong> (TOE, CLIP, or SET), the <strong>side</strong>
      (SAME or OP: same side as the plant foot, or opposite), the <strong>direction</strong>
      (IN or OUT), and optional <strong>modifiers</strong> ([DEX] for dexterity, [BOD] for body
      move). A &ldquo;&gt;&rdquo; between components means the next element follows before the catch.
    </p>
    <p>
      Example: <code>Pixie = TOE &gt; SAME IN [DEX] &gt;</code>, toe set, dexterity on the same
      side inward arc.
    </p>
  </section>

  <section class="content-section">
    <h2 class="section-heading">Basic Sets</h2>
    <div class="moves-table-wrap">
      <table class="moves-table">
        <thead>
          <tr><th>Set Name</th><th>Notation</th></tr>
        </thead>
        <tbody>
          {{#each content.basicSets}}
          <tr id="{{anchorId}}">
            <td>{{#if trickHref}}<a href="{{trickHref}}">{{label}}</a>{{else}}{{label}}{{/if}}</td>
            <td>{{#if notation}}<code>{{notation}}</code>{{/if}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </section>

  <section class="content-section">
    <h2 class="section-heading">Spinning Variants</h2>
    <div class="moves-tag-list">
      {{#each content.spinningVariants}}
      <span class="moves-tag" id="{{anchorId}}">{{#if trickHref}}<a href="{{trickHref}}">{{label}}</a>{{else}}{{label}}{{/if}}</span>
      {{/each}}
    </div>
  </section>

  <section class="content-section">
    <h2 class="section-heading">Whirl / Swirl Variants</h2>
    <div class="moves-tag-list">
      {{#each content.whirlSwirlVariants}}
      <span class="moves-tag" id="{{anchorId}}">{{#if trickHref}}<a href="{{trickHref}}">{{label}}</a>{{else}}{{label}}{{/if}}</span>
      {{/each}}
    </div>
  </section>

  <section class="content-section">
    <h2 class="section-heading">UNS Set Variants</h2>
    <div class="moves-tag-list">
      {{#each content.unsVariants}}
      <span class="moves-tag" id="{{anchorId}}">{{#if trickHref}}<a href="{{trickHref}}">{{label}}</a>{{else}}{{label}}{{/if}}</span>
      {{/each}}
    </div>
  </section>

  <section class="content-section">
    <h2 class="section-heading">Antisymposium</h2>
    <div class="moves-tag-list">
      {{#each content.antisymposium}}
      <span class="moves-tag" id="{{anchorId}}">{{#if trickHref}}<a href="{{trickHref}}">{{label}}</a>{{else}}{{label}}{{/if}}</span>
      {{/each}}
    </div>
  </section>

  <section class="content-section">
    <h2 class="section-heading">Components</h2>
    <p>These are modifiers or partial sets, not standalone set prefixes.</p>
    <div class="moves-tag-list">
      {{#each content.components}}
      <span class="moves-tag" id="{{anchorId}}">{{#if trickHref}}<a href="{{trickHref}}">{{label}}</a>{{else}}{{label}}{{/if}}</span>
      {{/each}}
    </div>
  </section>

  <p class="source-note">
    Set notation sourced from the freestyle discussion archive.
    Original reference: <a href="https://www.footbag.org/freestyle/sets.html" target="_blank" rel="noopener noreferrer">footbag.org/freestyle/sets.html</a>
  </p>

</div>
