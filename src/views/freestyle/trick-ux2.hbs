{{!
  UX2 single-page pilot (2026-05-11) -- flagship editorial trick-page layout.
  Active only when content.ux2Pilot is populated by the service layer; today
  that means slug === 'montage' and nothing else. The legacy trick.hbs
  continues to render every other trick. See exploration/freestyle-notation-
  grammar/UX2_EDITORIAL_LAYOUT_PLAN.md for the design rationale; this template
  is a single-page validation of that plan, not a sitewide rollout.

  Section order:
    1  HERO          (title, ADD, badges, featured-media slot, short summary)
    2  LEARN         (semantic notation, operational notation, execution,
                      learning notes, prerequisites, family ladder, related)
    3  MEDIA         (featured-media reprise, tutorial+demo grid, empty state)
    4  REFERENCE     (pathways, previous/next ladder, passback records,
                      record progression, structural decomposition collapsed,
                      footer)

  Reuses existing classes / partials so all warm-vs-cool palette,
  notation-token rendering, video-facade behaviour, and glossary deeplinks
  remain identical to the legacy template. The pilot adds only structural
  containers and four new prose blocks.
}}

<div class="hero hero-sm trick-hero-ux2">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    {{#if page.eyebrow}}<p class="hero-eyebrow">{{page.eyebrow}}</p>{{/if}}
    <h1>{{page.title}}</h1>
    {{#if content.dictEntry.trickFamily}}
    <p><a class="family-badge" href="/freestyle/tricks?family={{content.dictEntry.trickFamily}}">{{content.dictEntry.trickFamily}} family</a></p>
    {{/if}}
    {{#if content.sortName}}<p class="hero-subtitle">{{content.sortName}}</p>{{/if}}
    <div class="hero-stats">
      {{#if content.dictEntry}}
        {{#unless content.dictEntry.isModifier}}
          {{#if content.dictEntry.adds}}<span>{{content.dictEntry.adds}} ADD</span>{{/if}}
        {{/unless}}
        {{#if content.dictEntry.category}}<span class="hero-stat-label">{{content.dictEntry.category}}</span>{{/if}}
      {{/if}}
      {{#if content.recordCount}}<span>{{content.topValue}} kicks (record)</span>{{/if}}
    </div>

    {{#if content.ux2Pilot.shortDescription}}
    <p class="trick-hero-summary">{{content.ux2Pilot.shortDescription}}</p>
    {{/if}}
  </div>
</div>

<div class="wrapper">

  {{! ── HERO featured-media slot (inline preview) ──────────────────────────── }}
  {{! Compact preview directly under the hero. Full-spread featured-media     }}
  {{! reprise lives in the MEDIA block below. When no featured media exists,  }}
  {{! the empty-state pill renders here so the page does not silently drop a  }}
  {{! promised section. Wave-1 dominant case: featuredMedia is null.          }}
  <section class="content-section trick-featured-preview" aria-label="Featured demonstration preview">
    {{#if content.ux2Pilot.featuredMedia}}
      <div class="trick-featured-preview-card">
        <div class="trick-featured-preview-thumb">
          {{#if content.ux2Pilot.featuredMedia.media}}
            {{> video-facade media=content.ux2Pilot.featuredMedia.media}}
          {{/if}}
        </div>
        <div class="trick-featured-preview-meta">
          <h2 class="trick-featured-preview-title">Featured demonstration</h2>
          {{#if content.ux2Pilot.featuredMedia.caption}}
          <p class="trick-featured-preview-caption">{{content.ux2Pilot.featuredMedia.caption}}</p>
          {{/if}}
          {{#if content.ux2Pilot.featuredMedia.sourceLabel}}
          <p class="trick-featured-preview-source">{{content.ux2Pilot.featuredMedia.sourceLabel}}</p>
          {{/if}}
          <p class="trick-featured-preview-jump"><a href="#media">Full media gallery &darr;</a></p>
        </div>
      </div>
    {{else}}
      <div class="trick-featured-preview-empty">
        <span class="trick-featured-preview-empty-label">Featured demonstration</span>
        <span class="trick-featured-preview-empty-text">{{content.ux2Pilot.featuredMediaEmptyState}}</span>
      </div>
    {{/if}}
  </section>

  {{! ───────────────────────────────── LEARN ───────────────────────────────── }}

  {{! About prose -- existing description + ADD composition + aliases.         }}
  {{! Kept exactly as legacy trick.hbs renders so the curator-authored prose   }}
  {{! flows the same shape. Pilot adds new fields below; existing field stays. }}
  {{#if content.dictEntry}}
  <section class="content-section">
    <div class="section-heading">
      <h2>About this trick</h2>
    </div>

    {{#if content.dictEntry.description}}
    <p class="trick-description">{{content.dictEntry.description}}</p>
    {{/if}}

    {{#if content.dictEntry.isModifier}}
    <p class="trick-description">
      This is a <strong>modifier</strong> -- it has no fixed ADD value of its own. It adds difficulty
      when layered onto a base trick, and the bonus depends on whether the base is rotational
      (whirl, mirage, torque, blender) or non-rotational.
    </p>
    {{/if}}

    <dl class="detail-list">
      {{#if content.dictEntry.addComposition}}
      <dt>How it's built</dt>
      <dd class="add-composition">{{content.dictEntry.addComposition}}</dd>
      {{else if content.dictEntry.baseTrick}}
      <dt>Base trick</dt>
      <dd>
        {{#if content.dictEntry.baseTrickSlug}}
          <a href="/freestyle/tricks/{{content.dictEntry.baseTrickSlug}}">{{content.dictEntry.baseTrick}}</a>
        {{else}}
          {{content.dictEntry.baseTrick}}
        {{/if}}
        {{#if content.dictEntry.baseTrickAdds}} ({{content.dictEntry.baseTrickAdds}} ADD){{/if}}
      </dd>
      {{/if}}

      {{#unless content.dictEntry.addComposition}}
        {{#unless content.dictEntry.isModifier}}
          {{#if content.dictEntry.adds}}
          <dt>ADD value</dt>
          <dd>{{content.dictEntry.adds}}</dd>
          {{/if}}
        {{/unless}}
      {{/unless}}

      {{#if content.dictEntry.aliases.length}}
      <dt>Also known as</dt>
      <dd>{{#each content.dictEntry.aliases}}{{#unless @first}}, {{/unless}}{{this}}{{/each}}</dd>
      {{/if}}
    </dl>

    {{#if content.dictEntry.familyNote}}
    <div class="family-note">
      <p>{{content.dictEntry.familyNote}}</p>
    </div>
    {{/if}}
  </section>
  {{/if}}

  {{! Semantic notation -- cool palette, primary in LEARN per pilot brief.    }}
  {{#if content.notationDisplay}}
  <section class="content-section notation-display" aria-label="Trick notation">
    <div class="section-heading">
      <h2>Notation</h2>
      <p class="section-intro">A token-level reading of this trick, color-coded by structural role.</p>
    </div>
    <code class="notation-display-tokens">{{#each content.notationDisplay.tokens}}<span class="notation-token notation-{{cssRole}}" data-role="{{role}}" title="{{label}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}</code>
    <p class="notation-glossary-link">
      <a href="/freestyle/glossary#notation">Token reference &rarr;</a>
    </p>
  </section>
  {{/if}}

  {{! Set notation (operational) -- warm palette, sits alongside semantic.    }}
  {{#if content.operationalNotation}}
  <section class="content-section operational-notation-display" aria-label="Set notation (operational)">
    <div class="section-heading">
      <h2>Set notation (operational)</h2>
      <p class="section-intro">Execution mechanics -- how the body performs the trick. Independent of the semantic notation above.</p>
    </div>
    <code class="operational-notation-tokens">{{#each content.operationalNotation.tokens}}<span class="op-token op-token--{{cssRole}}" data-role="{{role}}" title="{{label}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}</code>
    {{#if content.operationalNotation.sourceNote}}
    <p class="operational-notation-source-note">{{content.operationalNotation.sourceNote}}</p>
    {{/if}}
    <p class="operational-notation-glossary-link">
      <a href="/freestyle/glossary#operational-notation">Token reference &rarr;</a>
    </p>
  </section>
  {{/if}}

  {{! Execution summary -- pilot prose. Plain-English mechanics.              }}
  {{#if content.ux2Pilot.executionParagraphs.length}}
  <section class="content-section trick-execution-summary">
    <div class="section-heading">
      <h2>Execution</h2>
      <p class="section-intro">A plain-English walkthrough of the mechanics.</p>
    </div>
    {{#each content.ux2Pilot.executionParagraphs}}
    <p class="trick-prose-paragraph">{{this}}</p>
    {{/each}}
  </section>
  {{/if}}

  {{! Learning notes -- pilot prose. Curator-authored gotchas.                }}
  {{#if content.ux2Pilot.learningParagraphs.length}}
  <section class="content-section trick-learning-notes">
    <div class="section-heading">
      <h2>Learning notes</h2>
    </div>
    {{#each content.ux2Pilot.learningParagraphs}}
    <p class="trick-prose-paragraph">{{this}}</p>
    {{/each}}
  </section>
  {{/if}}

  {{! Prerequisites -- pilot prose, with auto-derived fallback link.          }}
  {{#if content.ux2Pilot.prerequisiteParagraphs.length}}
  <section class="content-section trick-prerequisites">
    <div class="section-heading">
      <h2>Before you try this</h2>
    </div>
    {{#each content.ux2Pilot.prerequisiteParagraphs}}
    <p class="trick-prose-paragraph">{{this}}</p>
    {{/each}}
    {{#if content.previousTricks.length}}
    <p class="trick-prereq-anchor">
      <a href="#previous-tricks">See lower-ADD tricks in this family &darr;</a>
    </p>
    {{/if}}
  </section>
  {{/if}}

  {{! Family ladder -- primary lateral discovery surface in LEARN.            }}
  {{#if content.hasFamilyMembers}}
  <section class="content-section">
    <div class="section-heading">
      <h2>{{page.title}} Family</h2>
      <p class="section-intro">Tricks in this family, from simplest to most complex.</p>
    </div>
    <div class="family-ladder">
      {{#each content.familyMembers}}
      <div class="family-ladder-item{{#if isCurrentTrick}} family-ladder-current{{/if}}">
        <span class="family-ladder-adds">{{#if adds}}{{adds}}{{else}}mod{{/if}}</span>
        <span class="family-ladder-name">
          {{#if isCurrentTrick}}
            <strong>{{canonicalName}}</strong>
          {{else}}
            <a href="{{detailHref}}">{{canonicalName}}</a>
          {{/if}}
          {{#if hasRecords}}<span class="record-indicator" title="Has passback records">&#9733;</span>{{/if}}
        </span>
        {{#if isCurrentTrick}}<span class="family-ladder-here">&larr;</span>{{/if}}
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{! Related tricks -- cross-family token-shared discovery.                  }}
  {{#if content.relatedTricks.length}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Related Tricks</h2>
    </div>
    <ul class="related-tricks-list">
      {{#each content.relatedTricks}}
      <li>
        <a href="{{detailHref}}">{{canonicalName}}</a>
        <a class="trick-hashtag" href="{{detailHref}}">{{hashtag}}</a>
      </li>
      {{/each}}
    </ul>
  </section>
  {{/if}}

  {{! ───────────────────────────────── MEDIA ──────────────────────────────── }}

  <section id="media" class="content-section trick-media-block" aria-label="Media">
    <div class="section-heading">
      <h2>Media</h2>
      {{#if content.hasReferenceMedia}}
      <p class="section-intro">Curated videos referencing {{content.trickName}}.</p>
      {{else}}
      <p class="section-intro">Tutorials and demonstrations referencing this trick will appear here as they are added.</p>
      {{/if}}
    </div>

    {{! Featured media reprise -- the full-width slot promised by the hero }}
    {{#if content.ux2Pilot.featuredMedia}}
      <div class="trick-featured-media-card">
        {{#if content.ux2Pilot.featuredMedia.media}}
          {{> video-facade media=content.ux2Pilot.featuredMedia.media}}
        {{/if}}
        {{#if content.ux2Pilot.featuredMedia.caption}}
        <p class="reference-media-caption">{{content.ux2Pilot.featuredMedia.caption}}</p>
        {{/if}}
        {{#if content.ux2Pilot.featuredMedia.sourceLabel}}
        <p class="reference-media-source"><span class="reference-media-source-label">{{content.ux2Pilot.featuredMedia.sourceLabel}}</span></p>
        {{/if}}
      </div>
    {{else}}
      <div class="trick-featured-media-empty">
        <p>{{content.ux2Pilot.featuredMediaEmptyState}}</p>
      </div>
    {{/if}}

    {{#if content.tutorialMedia.length}}
    <div class="reference-media-subsection reference-media-subsection--tutorials">
      <h3 class="reference-media-subheading">Tutorials</h3>
      <ul class="reference-media-grid">
        {{#each content.tutorialMedia}}
          <li class="reference-media-tile">
            {{#if media}}
              {{> video-facade media=media}}
            {{/if}}
            {{#if caption}}<p class="reference-media-caption">{{caption}}</p>{{/if}}
            {{#if sourceLabel}}<p class="reference-media-source"><span class="reference-media-source-label">{{sourceLabel}}</span></p>{{/if}}
          </li>
        {{/each}}
      </ul>
    </div>
    {{/if}}

    {{#if content.demoMedia.length}}
    <div class="reference-media-subsection reference-media-subsection--demos">
      <h3 class="reference-media-subheading">Demonstrations</h3>
      <ul class="reference-media-grid">
        {{#each content.demoMedia}}
          <li class="reference-media-tile">
            {{#if media}}
              {{> video-facade media=media}}
            {{/if}}
            {{#if caption}}<p class="reference-media-caption">{{caption}}</p>{{/if}}
            {{#if sourceLabel}}<p class="reference-media-source"><span class="reference-media-source-label">{{sourceLabel}}</span></p>{{/if}}
          </li>
        {{/each}}
      </ul>
    </div>
    {{/if}}
  </section>

  {{! ─────────────────────────── REFERENCE & TAIL ─────────────────────────── }}

  {{! Pathways summary -- demoted from LEARN to REFERENCE tail.               }}
  <section class="content-section trick-pathways" aria-label="What you can do with this trick">
    <div class="section-heading">
      <h2>What you can do with this trick</h2>
    </div>
    <ul class="trick-pathway-list">
      <li class="trick-pathway trick-pathway--learn{{#unless content.pathways.learn.available}} trick-pathway--empty{{/unless}}">
        <h3 class="trick-pathway-title">Learn this trick</h3>
        <p class="trick-pathway-primary">{{content.pathways.learn.primaryText}}</p>
        {{#if content.pathways.learn.secondaryText}}
        <p class="trick-pathway-secondary">{{content.pathways.learn.secondaryText}}</p>
        {{/if}}
        {{#if content.pathways.learn.href}}
        <a class="trick-pathway-link" href="{{{content.pathways.learn.href}}}">{{content.pathways.learn.hrefLabel}} &rarr;</a>
        {{/if}}
      </li>
      <li class="trick-pathway trick-pathway--watch{{#unless content.pathways.watch.available}} trick-pathway--empty{{/unless}}">
        <h3 class="trick-pathway-title">Watch records</h3>
        <p class="trick-pathway-primary">{{content.pathways.watch.primaryText}}</p>
        {{#if content.pathways.watch.secondaryText}}
        <p class="trick-pathway-secondary">{{content.pathways.watch.secondaryText}}</p>
        {{/if}}
        {{#if content.pathways.watch.href}}
        <a class="trick-pathway-link" href="{{{content.pathways.watch.href}}}">{{content.pathways.watch.hrefLabel}} &rarr;</a>
        {{/if}}
      </li>
      <li class="trick-pathway trick-pathway--family{{#unless content.pathways.family.available}} trick-pathway--empty{{/unless}}">
        <h3 class="trick-pathway-title">Related families</h3>
        <p class="trick-pathway-primary">{{content.pathways.family.primaryText}}</p>
        {{#if content.pathways.family.secondaryText}}
        <p class="trick-pathway-secondary">{{content.pathways.family.secondaryText}}</p>
        {{/if}}
        {{#if content.pathways.family.href}}
        <a class="trick-pathway-link" href="{{{content.pathways.family.href}}}">{{content.pathways.family.hrefLabel}} &rarr;</a>
        {{/if}}
      </li>
    </ul>
  </section>

  {{#if content.previousTricks.length}}
  <section id="previous-tricks" class="content-section">
    <div class="section-heading">
      <h2>Previous Tricks</h2>
      <p class="section-intro">Lower-ADD variations in the same family.</p>
    </div>
    <ul class="next-tricks-list">
      {{#each content.previousTricks}}
      <li>
        <a href="{{detailHref}}">{{canonicalName}}</a>
        <span class="next-tricks-adds">{{adds}} ADD</span>
        <a class="trick-hashtag" href="{{detailHref}}">{{hashtag}}</a>
      </li>
      {{/each}}
    </ul>
  </section>
  {{/if}}

  {{#if content.nextTricks.length}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Next Tricks</h2>
      <p class="section-intro">Higher-ADD tricks in the same family -- natural next steps.</p>
    </div>
    <ul class="next-tricks-list">
      {{#each content.nextTricks}}
      <li>
        <a href="{{detailHref}}">{{canonicalName}}</a>
        <span class="next-tricks-adds">{{adds}} ADD</span>
        <a class="trick-hashtag" href="{{detailHref}}">{{hashtag}}</a>
      </li>
      {{/each}}
    </ul>
  </section>
  {{/if}}

  {{#if content.recordCount}}
  <section id="passback-records" class="content-section">
  <div class="section-heading"><h2>Passback Records</h2></div>
  <div class="records-table-wrap">
    <table class="records-table">
      <thead>
        <tr>
          <th class="col-rank">#</th>
          <th>Holder</th>
          <th class="col-num">Count</th>
          <th>Adds</th>
          <th>Date</th>
          <th>Video</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.records}}
        <tr class="record-row">
          <td class="col-rank">{{add @index 1}}</td>
          <td class="col-holder">
            {{#if holderHref}}
              <a href="{{holderHref}}">{{holderName}}</a>
            {{else}}
              {{holderName}}
            {{/if}}
          </td>
          <td class="col-num">{{valueNumeric}}</td>
          <td class="col-adds">{{#if addsCount}}{{addsCount}}{{else}}&mdash;{{/if}}</td>
          <td class="col-date">
            {{#if achievedDate}}
              {{formatDate achievedDate}}{{#if dateApproximate}} <em>(approx.)</em>{{/if}}
            {{else}}
              &mdash;
            {{/if}}
          </td>
          <td class="col-video">
            {{#if videoUrl}}
              <a href="{{videoUrl}}" class="video-link" target="_blank" rel="noopener noreferrer"
                 aria-label="Watch {{holderName}} {{../page.title}} record video">
                &#9654;{{#if videoTimecode}} {{videoTimecode}}{{/if}}
              </a>
            {{else}}
              &mdash;
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  </section>
  {{/if}}

  {{#if content.hasProgression}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Record Progression</h2>
    </div>
    <table class="records-table">
      <thead>
        <tr>
          <th class="col-rank">#</th>
          <th>Holder</th>
          <th class="col-num">Count</th>
          <th>Adds</th>
          <th>Date</th>
          <th>Video</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.progression}}
        <tr class="record-row">
          <td class="col-rank">{{add @index 1}}</td>
          <td class="col-holder">
            {{#if holderHref}}
              <a href="{{holderHref}}">{{holderName}}</a>
            {{else}}
              {{holderName}}
            {{/if}}
          </td>
          <td class="col-num">{{valueNumeric}}</td>
          <td class="col-adds">{{#if addsCount}}{{addsCount}}{{else}}&mdash;{{/if}}</td>
          <td class="col-date">
            {{#if achievedDate}}
              {{formatDate achievedDate}}{{#if dateApproximate}} <em>(approx.)</em>{{/if}}
            {{else}}
              &mdash;
            {{/if}}
          </td>
          <td class="col-video">
            {{#if videoUrl}}
              <a href="{{videoUrl}}" class="video-link" target="_blank" rel="noopener noreferrer"
                 aria-label="Watch {{holderName}} {{../page.title}} record video">
                &#9654;{{#if videoTimecode}} {{videoTimecode}}{{/if}}
              </a>
            {{else}}
              &mdash;
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </section>
  {{/if}}

  {{! Structural decomposition -- collapsed by default. Pilot demotes the    }}
  {{! parser-diagnostic surface to a tail <details> region so that learners  }}
  {{! arriving cold are not led with the QC panel. Editorial intent stays   }}
  {{! the same; only the affordance changes.                                }}
  {{#if content.notationGrammar}}
  <section class="content-section notation-grammar-panel" aria-label="Structural decomposition">
    <details class="notation-grammar-collapsible">
      <summary>
        <span class="notation-grammar-summary-title">Structural decomposition</span>
        <span class="notation-grammar-summary-hint">Parser diagnostic. Click to expand.</span>
      </summary>

      <p class="section-intro">A token-level reading of this trick's name. Asserted ADD is editorial truth; the computed value below is diagnostic.</p>

      <dl class="detail-list">
        <dt>Status</dt>
        <dd>
          <strong>{{content.notationGrammar.statusLabel}}</strong>
          <span class="notation-grammar-status-key"> ({{content.notationGrammar.status}})</span>
          <p class="notation-grammar-status-description">{{content.notationGrammar.statusDescription}}</p>
        </dd>

        <dt>Asserted ADD</dt>
        <dd>{{#if content.notationGrammar.assertedAdds}}{{content.notationGrammar.assertedAdds}}{{else}}&mdash;{{/if}}</dd>

        <dt>Computed ADD</dt>
        <dd>
          {{#if content.notationGrammar.computedAdds}}{{content.notationGrammar.computedAdds}}{{else}}&mdash;{{/if}}
          {{#if content.notationGrammar.addsAgree}}
          <span class="notation-grammar-agree">(agrees with asserted)</span>
          {{else}}
          <span class="notation-grammar-disagree">(disagrees with asserted; asserted value is editorial truth)</span>
          {{/if}}
        </dd>

        {{#if content.notationGrammar.formula}}
        <dt>Derivation</dt>
        <dd><code>{{content.notationGrammar.formula}}</code></dd>
        {{/if}}
      </dl>

      {{#if content.notationGrammar.descriptiveRoles.length}}
      <div class="notation-grammar-layer">
        <h3>Descriptive roles</h3>
        <p class="notation-grammar-layer-intro">Per-token classification before any self-canonical-atom collapse. Preserves what the parser saw at each position.</p>
        <ul class="notation-grammar-role-list">
          {{#each content.notationGrammar.descriptiveRoles}}
          <li>
            <strong>{{label}}:</strong>
            {{#each tokens}}{{#unless @first}}, {{/unless}}<code>{{token}}</code>{{#if atomResolved}} <em>(atom)</em>{{/if}}{{/each}}
          </li>
          {{/each}}
        </ul>
      </div>
      {{/if}}

      {{#if content.notationGrammar.addContributingRoles.length}}
      <div class="notation-grammar-layer">
        <h3>ADD-contributing roles</h3>
        <p class="notation-grammar-layer-intro">Tokens whose weights feed the ADD math. May differ from the descriptive layer when a self-atom subsumes its components.</p>
        <ul class="notation-grammar-role-list">
          {{#each content.notationGrammar.addContributingRoles}}
          <li>
            <strong>{{label}}:</strong>
            {{#each tokens}}{{#unless @first}}, {{/unless}}<code>{{token}}</code>{{#if atomResolved}} <em>(atom)</em>{{/if}}{{/each}}
          </li>
          {{/each}}
        </ul>
      </div>
      {{/if}}

      {{#if content.notationGrammar.editorialDecomposition}}
      <div class="notation-grammar-editorial-decomposition" data-source="editorial">
        <h3>Editorial decomposition</h3>
        <p class="notation-grammar-layer-intro">Curator-asserted lineage from this row's <code>base_trick</code> and modifier links. Independent of the parser-derived structural decomposition above. Asserted ADD remains editorial truth.</p>

        <dl class="detail-list">
          <dt>Base</dt>
          <dd>
            {{#if content.notationGrammar.editorialDecomposition.baseSlug}}<code>{{content.notationGrammar.editorialDecomposition.baseSlug}}</code>{{else}}&mdash;{{/if}}
            {{#if content.notationGrammar.editorialDecomposition.baseAdds}}({{content.notationGrammar.editorialDecomposition.baseAdds}}){{/if}}
            {{#unless (eq content.notationGrammar.editorialDecomposition.baseStatus 'resolved')}}
            <span class="notation-grammar-editorial-flag">broken upstream link (<code>{{content.notationGrammar.editorialDecomposition.baseSlug}}</code> is not in the dictionary)</span>
            {{/unless}}
          </dd>

          {{#if content.notationGrammar.editorialDecomposition.modifiers.length}}
          <dt>Modifiers</dt>
          <dd>
            <ul class="notation-grammar-role-list">
              {{#each content.notationGrammar.editorialDecomposition.modifiers}}
              <li>
                <strong>{{name}}</strong>
                <span class="notation-grammar-editorial-modifier-meta">({{modifierType}}; +{{effectiveBonus}}{{#if rotBonusApplied}} on rotational base{{/if}})</span>
                {{#if notes}}<p class="notation-grammar-editorial-modifier-notes">{{notes}}</p>{{/if}}
              </li>
              {{/each}}
            </ul>
          </dd>
          {{else}}
          <dt>Modifiers</dt>
          <dd><span class="notation-grammar-editorial-flag">modifier coverage absent</span></dd>
          {{/if}}

          {{#if content.notationGrammar.editorialDecomposition.derivationText}}
          <dt>Composed</dt>
          <dd>
            <code>{{content.notationGrammar.editorialDecomposition.derivationText}}</code>
            {{#if (eq content.notationGrammar.editorialDecomposition.matchesAsserted true)}}
            <span class="notation-grammar-agree">(matches asserted)</span>
            {{else if (eq content.notationGrammar.editorialDecomposition.matchesAsserted false)}}
            <span class="notation-grammar-disagree">(differs from asserted; asserted is editorial truth)</span>
            {{/if}}
          </dd>
          {{/if}}
        </dl>
      </div>
      {{/if}}

      {{#if content.notationGrammar.editorialContext}}
      <div class="notation-grammar-editorial">
        <h3>Editorial context</h3>
        <p class="notation-grammar-editorial-text">{{content.notationGrammar.editorialContext}}</p>
      </div>
      {{/if}}

      {{#if content.notationGrammar.policyTokens.length}}
      <div class="notation-grammar-policy">
        <h3>Policy tokens</h3>
        <p class="notation-grammar-layer-intro">Tokens whose ADD weight or ontology placement is contested and pending expert review.</p>
        <ul class="notation-grammar-flat-list">
          {{#each content.notationGrammar.policyTokens}}
          <li><code>{{this}}</code></li>
          {{/each}}
        </ul>
      </div>
      {{/if}}

      {{#if content.notationGrammar.hasDiagnosticDetails}}
      <details class="notation-grammar-diagnostics">
        <summary>Diagnostic details</summary>
        {{#if content.notationGrammar.jobsNotationRaw}}
        <dl class="detail-list">
          <dt>Jobs notation</dt>
          <dd><code>{{content.notationGrammar.jobsNotationRaw}}</code></dd>
        </dl>
        {{/if}}
        {{#if content.notationGrammar.parseWarnings.length}}
        <div class="notation-grammar-warnings">
          <h3>Parse warnings</h3>
          <ul class="notation-grammar-flat-list">
            {{#each content.notationGrammar.parseWarnings}}
            <li><code>{{this}}</code></li>
            {{/each}}
          </ul>
        </div>
        {{/if}}
      </details>
      {{/if}}
    </details>
  </section>
  {{/if}}

  <p class="source-note">
    Records sourced from the freestyle passback video archive.
    Dates marked <em>approx.</em> are confirmed only to the month or year.
    <a href="/freestyle/records">View all records</a>
    &mdash;
    <a href="/freestyle/tricks">Trick Dictionary</a>
  </p>

</div>
