{{!--
  /freestyle/add-analysis — ADD Accounting & Analysis.

  Educational page explaining how ADD values are constructed mechanically,
  with worked examples and discrepancy case studies. Pure curator content
  via FREESTYLE_ADD_ANALYSIS_CONTENT; logic-light template; no client JS.
--}}

<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper add-analysis-page">

  <p class="page-philosophy">{{content.philosophyParagraph}}</p>

  <section id="how-add-is-built" class="content-section">
    <div class="section-heading">
      <h2>How ADD is built</h2>
      <p class="section-intro">
        The ADD (Additional Degree of Difficulty) score measures how
        structurally demanding a trick is. It isn&rsquo;t a stylistic rating
        &mdash; it counts the mechanical components a trick is made of.
      </p>
    </div>

    <table class="add-analysis-components">
      <thead>
        <tr>
          <th>Component</th>
          <th>Typical contribution</th>
          <th>Example</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.componentClasses}}
        <tr>
          <td>{{componentClass}}</td>
          <td>{{contribution}}</td>
          <td>{{example}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <p class="add-analysis-callout add-analysis-callout--spin"><strong>What &ldquo;spin&rdquo; means.</strong> {{content.spinNote}}</p>
    <p class="add-analysis-callout"><strong>The editorial-truth rule.</strong> {{content.editorialTruthRule}}</p>
    <p class="add-analysis-callout add-analysis-callout--incompleteness"><strong>Honest incompleteness.</strong> {{content.incompletenessNote}}</p>
  </section>

  <section id="worked-examples" class="content-section">
    <div class="section-heading">
      <h2>Worked examples</h2>
      <p class="section-intro">Foundational atoms first (1-3 ADD), then compounds. Each shows components, the explicit additive breakdown, and a one-line why. The breakdown line is the central pedagogy &mdash; it makes visible where each ADD comes from.</p>
    </div>

    <ol class="add-analysis-worked-examples">
      {{#each content.workedExamples}}
      <li class="add-analysis-worked-example">
        <h3 class="add-analysis-example-heading">
          {{#if trickSlug}}<a href="/freestyle/tricks/{{trickSlug}}">{{trickName}}</a>{{else}}{{trickName}}{{/if}}
          <span class="add-analysis-add-label">&middot; {{addLabel}}</span>
        </h3>
        <p class="add-analysis-components-line"><strong>Components:</strong> {{components}}</p>
        <p class="add-analysis-derivation-line"><strong>Breakdown:</strong> <code>{{derivation}}</code></p>
        <p class="add-analysis-why-line">{{whyNote}}</p>
      </li>
      {{/each}}
    </ol>
  </section>

  {{#if content.osisBranch.length}}
  <section id="osis-branch" class="content-section">
    <div class="section-heading">
      <h2>Reading a branch: the Osis family</h2>
      <p class="section-intro">{{content.osisBranchFraming}}</p>
    </div>
    <ol class="add-analysis-osis-branch">
      {{#each content.osisBranch}}
      <li class="add-analysis-branch-step">
        <a class="add-analysis-branch-name" href="/freestyle/tricks/{{trickSlug}}">{{trickName}}</a>
        <span class="add-analysis-branch-eq">=</span>
        <code class="add-analysis-branch-reading">{{reading}}</code>
        <span class="add-analysis-branch-total">{{total}}</span>
      </li>
      {{/each}}
    </ol>
  </section>
  {{/if}}

  {{!-- Compact reference table of mechanical +1-stack compositions; not a
       worked-examples expansion. --}}
  {{#if content.resolvedFormulas.length}}
  <section id="resolved-formulas" class="content-section">
    <div class="section-heading">
      <h2>Common formula patterns</h2>
      <p class="section-intro">{{content.resolvedFormulasFraming}}</p>
    </div>
    <table class="resolved-formulas-table">
      <thead>
        <tr>
          <th scope="col">Trick</th>
          <th scope="col">Breakdown</th>
          <th scope="col">ADD</th>
          <th scope="col">Provenance</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.resolvedFormulas}}
        <tr>
          <td><a href="/freestyle/tricks/{{slug}}">{{name}}</a></td>
          <td><code class="resolved-formula-derivation">{{derivation}}</code></td>
          <td class="resolved-formula-add">{{totalAdd}}</td>
          <td class="resolved-formula-provenance">{{provenance}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </section>
  {{/if}}

  <section id="discrepancies" class="content-section">
    <div class="section-heading">
      <h2>ADD discrepancies &mdash; why they happen</h2>
      <p class="section-intro">
        Different sources count the same trick differently. The reasons fall
        into a small number of recognizable patterns. Below are real cases
        &mdash; each with the IFPA reading, the external reading, and the
        mechanical interpretation that changes the count. None of these mean
        any source is &ldquo;wrong&rdquo; &mdash; they are differing
        interpretations or structural assumptions.
      </p>
      <p class="section-intro">
        <strong>Multi-depth readings are not real disagreements.</strong>
        Cases DC-04 through DC-07 below are not discrepancies in the
        differing-source sense &mdash; they are the movement structure
        working as intended. A compressed folk name (<em>blurry whirl</em>,
        <em>food processor</em>, <em>mobius</em>) and one or more deeper
        expansions (<em>stepping paradox whirl</em>, <em>spinning ss
        miraging osis</em>) both reach the same ADD via different stopping
        depths. Stopping-depth equivalence is foundational to how the
        movement language compresses; the cases below catalogue the
        recognizable patterns so readers can identify them in any source.
      </p>
    </div>

    <ol class="add-analysis-discrepancy-cases">
      {{#each content.discrepancyCases}}
      <li class="add-analysis-case" id="case-{{caseId}}">
        <h3 class="add-analysis-case-heading">
          {{#if trickSlug}}<a href="/freestyle/tricks/{{trickSlug}}">{{trickName}}</a>{{else}}{{trickName}}{{/if}}
          {{#if delta}}<span class="add-analysis-delta">&middot; &Delta; {{delta}}</span>{{/if}}
        </h3>
        <dl class="add-analysis-case-detail">
          <dt>IFPA</dt>
          <dd>{{ifpaAdd}} ADD</dd>
          <dt>{{externalSourceLabel}}</dt>
          <dd>{{externalAdd}} ADD</dd>
          <dt>Breakdown difference</dt>
          <dd>{{decompositionDifference}}</dd>
          <dt>Pattern</dt>
          <dd>{{pattern}}</dd>
          <dt>IFPA status</dt>
          <dd>{{ifpaStatusLine}}</dd>
        </dl>
      </li>
      {{/each}}
    </ol>

    {{#if content.edgeCases.length}}
    <h3 id="edge-cases" class="add-analysis-subheading">Edge cases</h3>
    <ul class="add-analysis-edge-cases">
      {{#each content.edgeCases}}
      <li>
        <strong>{{#if trickSlug}}<a href="/freestyle/tricks/{{trickSlug}}">{{trickName}}</a>{{else}}{{trickName}}{{/if}}</strong>
        &mdash; {{ifpaAdd}} ADD. {{briefNote}}
      </li>
      {{/each}}
    </ul>
    {{/if}}

    {{!-- PassBack-vs-IFPA ADD counting reconciliation (Batch C of the
         PassBack-first ingestion sequence). 68 name-matched rows where
         the PB ADD claim differs from IFPA canonical; framing makes
         the structural reconciliation explicit. --}}
    {{#if content.passbackAddDisagreements.length}}
    <h3 id="passback-add-framing" class="add-analysis-subheading">
      External-source ADD framings &mdash; PassBack vs IFPA counting
    </h3>
    <p class="passback-add-framing-prose">{{content.passbackAddFraming}}</p>
    <details class="passback-add-disagreement-details">
      <summary>
        <strong>{{content.passbackAddDisagreements.length}}</strong>
        rows with name-matched ADD divergence
        <span class="passback-add-disagreement-hint">(click to expand)</span>
      </summary>
      <table class="passback-add-disagreement-table">
        <thead>
          <tr>
            <th scope="col">IFPA trick</th>
            <th scope="col">IFPA structural reading</th>
            <th scope="col">PB dex_count</th>
            <th scope="col">Note</th>
          </tr>
        </thead>
        <tbody>
          {{#each content.passbackAddDisagreements}}
          <tr>
            <td><a href="/freestyle/tricks/{{ifpaSlug}}">{{ifpaName}}</a></td>
            <td>{{#if ifpaFormula}}<code>{{ifpaFormula}}</code>{{else}}<em class="passback-add-no-formula">&mdash;</em>{{/if}}</td>
            <td class="passback-add-claim-cell">{{passbackAdd}}</td>
            <td>{{#if curatorNote}}{{curatorNote}}{{else}}<em class="passback-add-no-note">PB dex count; IFPA structural ADD per reviewed row</em>{{/if}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </details>
    {{/if}}
  </section>

  <section id="interpretation-notes" class="content-section">
    <div class="section-heading">
      <h2>Interpretation notes</h2>
    </div>

    {{#each content.closingParagraphs}}
    <p>{{this}}</p>
    {{/each}}
  </section>

  {{!-- Cross-references ───────────────────────────────────────────────── --}}
  {{#if content.crossLinks.length}}
  <nav class="add-analysis-cross-links" aria-label="Related pages">
    <h3>Where to go next</h3>
    <ul>
      {{#each content.crossLinks}}
      <li><a href="{{href}}">{{label}}</a></li>
      {{/each}}
    </ul>
  </nav>
  {{/if}}

</div>
