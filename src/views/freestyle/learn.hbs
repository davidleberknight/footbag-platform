{{!--
  /freestyle/learn — symbolic-subsystem index.

  All content pre-shaped in symbolicLearnIndex.ts; template is logic-light.
--}}

<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{content.pageHeading}}</h1>
  </div>
</div>

<div class="wrapper">
  <article class="content-section symbolic-learn-index">

    <p class="learn-intro">{{content.pageIntro}}</p>

    {{! Six-lesson vocabulary tour: conceptual pedagogy in reading order. The
        first physical steps live on the getting-started page. }}
    <section class="learn-foundational-path" aria-label="Six lessons: how the vocabulary fits together">
      <div class="section-heading">
        <h2>{{content.foundationalPath.heading}}</h2>
      </div>
      <p class="learn-section-intro">{{content.foundationalPath.intro}}</p>
      <ol class="learn-path-steps">
        {{#each content.foundationalPath.steps}}
        <li class="learn-path-step">
          <span class="learn-path-step-num">{{step}}</span>
          <div class="learn-path-step-body">
            <a class="learn-path-step-name" href="{{href}}">{{name}}</a>
            <p class="learn-path-step-lesson">{{lesson}}</p>
          </div>
        </li>
        {{/each}}
      </ol>
    </section>

    {{#each content.sections}}
    <section class="learn-section">
      <h2 class="learn-section-heading">{{heading}}</h2>
      <p class="learn-section-intro">{{introBlurb}}</p>
      <ul class="learn-entries">
        {{#each entries}}
        <li class="learn-entry{{#unless isShipped}} learn-entry-planned{{/unless}}">
          {{#if isShipped}}
          <a class="learn-entry-title" href="{{href}}">{{title}} →</a>
          {{else}}
          <span class="learn-entry-title">{{title}} <span class="learn-entry-status">planned</span></span>
          {{/if}}
          <p class="learn-entry-blurb">{{shortBlurb}}</p>
        </li>
        {{/each}}
      </ul>
    </section>
    {{/each}}

    {{! Operator board — the movement-language index, demoted below the guided
        pathways so the card wall never sits between a reader and the lessons. }}
    {{> operator-board heading=content.operatorBoard.heading lede=content.operatorBoard.lede tiers=content.operatorBoard.tiers}}

    <p class="symbolic-layer-footer">Guided learning paths. For the official trick definitions, ADD values, and modifier rules, see the <a href="/freestyle/tricks">trick dictionary</a>, the <a href="/freestyle/glossary">glossary</a>, and the <a href="/freestyle/operators">operator reference</a>.</p>
  </article>
</div>
