{{! /freestyle/tricks/:slug — trick reference and record page }}

<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    {{#if page.eyebrow}}<p class="hero-eyebrow">{{page.eyebrow}}</p>{{/if}}
    <h1>{{page.title}}</h1>
    {{#if content.dictEntry.trickFamily}}
    <p><a class="family-badge" href="/freestyle/tricks?family={{content.dictEntry.trickFamily}}">{{content.dictEntry.trickFamily}} family</a></p>
    {{/if}}
    {{#if content.sortName}}<p class="hero-subtitle">{{content.sortName}}</p>{{/if}}
    <div class="hero-stats">
      {{#if content.dictEntry}}
        {{#unless content.dictEntry.isModifier}}
          {{#if content.dictEntry.adds}}<span>{{content.dictEntry.adds}} ADD</span>{{/if}}
        {{/unless}}
        {{#if content.dictEntry.category}}<span class="hero-stat-label">{{content.dictEntry.category}}</span>{{/if}}
      {{/if}}
      {{#if content.recordCount}}<span>{{content.topValue}} kicks (record)</span>{{/if}}
    </div>
  </div>
</div>

<div class="wrapper">

  {{! ── About This Trick ───────────────────────────────────────────────────── }}
  {{#if content.dictEntry}}
  <section class="content-section">
    <div class="section-heading">
      <h2>About This Trick</h2>
    </div>

    {{! Prose description — the primary human-readable explanation }}
    {{#if content.dictEntry.description}}
    <p class="trick-description">{{content.dictEntry.description}}</p>
    {{/if}}

    {{! Modifier special case }}
    {{#if content.dictEntry.isModifier}}
    <p class="trick-description">
      This is a <strong>modifier</strong> — it has no fixed ADD value of its own. It adds difficulty
      when layered onto a base trick, and the bonus depends on whether the base is rotational
      (whirl, mirage, torque, blender) or non-rotational.
    </p>
    {{/if}}

    <dl class="detail-list">

      {{! ADD composition — the key insight for compound tricks }}
      {{#if content.dictEntry.addComposition}}
      <dt>How it's built</dt>
      <dd class="add-composition">{{content.dictEntry.addComposition}}</dd>
      {{else if content.dictEntry.baseTrick}}
      <dt>Base trick</dt>
      <dd>
        {{#if content.dictEntry.baseTrickSlug}}
          <a href="/freestyle/tricks/{{content.dictEntry.baseTrickSlug}}">{{content.dictEntry.baseTrick}}</a>
        {{else}}
          {{content.dictEntry.baseTrick}}
        {{/if}}
        {{#if content.dictEntry.baseTrickAdds}} ({{content.dictEntry.baseTrickAdds}} ADD){{/if}}
      </dd>
      {{/if}}

      {{! Only show ADD separately when there's no composition formula }}
      {{#unless content.dictEntry.addComposition}}
        {{#unless content.dictEntry.isModifier}}
          {{#if content.dictEntry.adds}}
          <dt>ADD value</dt>
          <dd>{{content.dictEntry.adds}}</dd>
          {{/if}}
        {{/unless}}
      {{/unless}}

      {{#if content.dictEntry.aliases.length}}
      <dt>Also known as</dt>
      <dd>{{#each content.dictEntry.aliases}}{{#unless @first}}, {{/unless}}{{this}}{{/each}}</dd>
      {{/if}}

    </dl>

    {{! Family editorial note for major families }}
    {{#if content.dictEntry.familyNote}}
    <div class="family-note">
      <p>{{content.dictEntry.familyNote}}</p>
    </div>
    {{/if}}

  </section>
  {{/if}}

  {{! ── Related Tricks ─────────────────────────────────────────────────────── }}
  {{#if content.relatedTricks.length}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Related Tricks</h2>
    </div>
    <ul class="related-tricks-list">
      {{#each content.relatedTricks}}
      <li>
        <a href="{{detailHref}}">{{canonicalName}}</a>
        <a class="trick-hashtag" href="{{detailHref}}">{{hashtag}}</a>
      </li>
      {{/each}}
    </ul>
  </section>
  {{/if}}

  {{! ── Previous Tricks — same-family easier prerequisites ───────────────── }}
  {{#if content.previousTricks.length}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Previous Tricks</h2>
      <p class="section-intro">Lower-ADD variations in the same family.</p>
    </div>
    <ul class="next-tricks-list">
      {{#each content.previousTricks}}
      <li>
        <a href="{{detailHref}}">{{canonicalName}}</a>
        <span class="next-tricks-adds">{{adds}} ADD</span>
        <a class="trick-hashtag" href="{{detailHref}}">{{hashtag}}</a>
      </li>
      {{/each}}
    </ul>
  </section>
  {{/if}}

  {{! ── Reference Media — curator videos tagged with this trick's slug ─── }}
  {{#if content.referenceMedia.length}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Reference Media</h2>
      <p class="section-intro">Curated videos referencing {{content.trickName}}.</p>
    </div>
    <ul class="reference-media-grid">
      {{#each content.referenceMedia}}
        <li class="reference-media-tile{{#if isTtLesson}} reference-media-tt{{/if}}">
          {{#if videoUrl}}
            <a class="reference-media-link video-facade"
               href="{{videoUrl}}"
               target="_blank" rel="noopener noreferrer"
               data-platform="{{videoPlatform}}"
               {{#if videoEmbedUrl}}data-embed-url="{{videoEmbedUrl}}"{{/if}}
               aria-label="Play: {{#if caption}}{{caption}}{{else}}reference video{{/if}}">
              {{#if thumbnailUrl}}<img src="{{thumbnailUrl}}" alt="" loading="lazy" />{{/if}}
              <span class="reference-media-play" aria-hidden="true">&#9654;</span>
            </a>
          {{/if}}
          {{#if caption}}<p class="reference-media-caption">{{caption}}</p>{{/if}}
          <p class="reference-media-source">
            {{#if sourceLabel}}<span class="reference-media-source-label">{{sourceLabel}}</span>{{/if}}
            {{#if isTtLesson}}<a class="reference-media-tt-link" href="{{ttSeriesHref}}">View in TT series &rarr;</a>{{/if}}
          </p>
        </li>
      {{/each}}
    </ul>
  </section>
  {{/if}}

  {{! ── Next Tricks — same-family ADD progression ─────────────────────────── }}
  {{#if content.nextTricks.length}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Next Tricks</h2>
      <p class="section-intro">Higher-ADD tricks in the same family — natural next steps.</p>
    </div>
    <ul class="next-tricks-list">
      {{#each content.nextTricks}}
      <li>
        <a href="{{detailHref}}">{{canonicalName}}</a>
        <span class="next-tricks-adds">{{adds}} ADD</span>
        <a class="trick-hashtag" href="{{detailHref}}">{{hashtag}}</a>
      </li>
      {{/each}}
    </ul>
  </section>
  {{/if}}

  {{! ── Trick Family — difficulty ladder ──────────────────────────────────── }}
  {{#if content.hasFamilyMembers}}
  <section class="content-section">
    <div class="section-heading">
      <h2>{{page.title}} Family</h2>
      <p class="section-intro">Tricks in this family, from simplest to most complex:</p>
    </div>
    <div class="family-ladder">
      {{#each content.familyMembers}}
      <div class="family-ladder-item{{#if isCurrentTrick}} family-ladder-current{{/if}}">
        <span class="family-ladder-adds">{{#if adds}}{{adds}}{{else}}mod{{/if}}</span>
        <span class="family-ladder-name">
          {{#if isCurrentTrick}}
            <strong>{{canonicalName}}</strong>
          {{else}}
            <a href="{{detailHref}}">{{canonicalName}}</a>
          {{/if}}
          {{#if hasRecords}}<span class="record-indicator" title="Has passback records">&#9733;</span>{{/if}}
        </span>
        {{#if isCurrentTrick}}<span class="family-ladder-here">&larr;</span>{{/if}}
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{! ── Passback Records ───────────────────────────────────────────────────── }}
  {{#if content.recordCount}}
  <section class="content-section">
  <div class="section-heading"><h2>Passback Records</h2></div>
  <div class="records-table-wrap">
    <table class="records-table">
      <thead>
        <tr>
          <th class="col-rank">#</th>
          <th>Holder</th>
          <th class="col-num">Count</th>
          <th>Adds</th>
          <th>Date</th>
          <th>Video</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.records}}
        <tr class="record-row">
          <td class="col-rank">{{add @index 1}}</td>
          <td class="col-holder">
            {{#if holderHref}}
              <a href="{{holderHref}}">{{holderName}}</a>
            {{else}}
              {{holderName}}
            {{/if}}
          </td>
          <td class="col-num">{{valueNumeric}}</td>
          <td class="col-adds">{{#if addsCount}}{{addsCount}}{{else}}&mdash;{{/if}}</td>
          <td class="col-date">
            {{#if achievedDate}}
              {{formatDate achievedDate}}{{#if dateApproximate}} <em>(approx.)</em>{{/if}}
            {{else}}
              &mdash;
            {{/if}}
          </td>
          <td class="col-video">
            {{#if videoUrl}}
              <a href="{{videoUrl}}" class="video-link" target="_blank" rel="noopener noreferrer"
                 aria-label="Watch {{holderName}} {{../page.title}} record video">
                ▶{{#if videoTimecode}} {{videoTimecode}}{{/if}}
              </a>
            {{else}}
              &mdash;
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  </section>
  {{/if}}

  {{! ── Record Progression ─────────────────────────────────────────────────── }}
  {{#if content.hasProgression}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Record Progression</h2>
    </div>
    <table class="records-table">
      <thead>
        <tr>
          <th class="col-rank">#</th>
          <th>Holder</th>
          <th class="col-num">Count</th>
          <th>Adds</th>
          <th>Date</th>
          <th>Video</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.progression}}
        <tr class="record-row">
          <td class="col-rank">{{add @index 1}}</td>
          <td class="col-holder">
            {{#if holderHref}}
              <a href="{{holderHref}}">{{holderName}}</a>
            {{else}}
              {{holderName}}
            {{/if}}
          </td>
          <td class="col-num">{{valueNumeric}}</td>
          <td class="col-adds">{{#if addsCount}}{{addsCount}}{{else}}&mdash;{{/if}}</td>
          <td class="col-date">
            {{#if achievedDate}}
              {{formatDate achievedDate}}{{#if dateApproximate}} <em>(approx.)</em>{{/if}}
            {{else}}
              &mdash;
            {{/if}}
          </td>
          <td class="col-video">
            {{#if videoUrl}}
              <a href="{{videoUrl}}" class="video-link" target="_blank" rel="noopener noreferrer"
                 aria-label="Watch {{holderName}} {{../page.title}} record video">
                ▶{{#if videoTimecode}} {{videoTimecode}}{{/if}}
              </a>
            {{else}}
              &mdash;
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </section>
  {{/if}}

  <p class="source-note">
    Records sourced from the freestyle passback video archive.
    Dates marked <em>approx.</em> are confirmed only to the month or year.
    <a href="/freestyle/records">View all records</a>
    &mdash;
    <a href="/freestyle/tricks">Trick Dictionary</a>
  </p>

</div>
