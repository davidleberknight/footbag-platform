{{!--
  /freestyle/compositional-sets — dictionary-hub exploration of how named
  freestyle sets compose from a small grammar.

  Sibling to /freestyle/sets (the flat Holden reference table). This
  surface organizes the same corpus into structural families, surfaces
  uptime-reinterpretation ladders, and cross-links each canonical-named
  set to its dictionary entry.

  Design discipline: operator cards in grids; visual ladders for the
  uptime reinterpretation section; family branching with curator-authored
  intros — never giant notation blocks.
--}}
<section class="hero hero-sm">
  <div class="wrapper">
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if this.href}}<a href="{{this.href}}">{{this.label}}</a>{{else}}<span>{{this.label}}</span>{{/if}}
        {{#unless @last}} <span class="breadcrumb-sep" aria-hidden="true">/</span> {{/unless}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    <p class="hero-subtitle">{{page.intro}}</p>
  </div>
</section>

<div class="wrapper compositional-sets-page">

  {{!-- §1 — The compositional premise --}}
  <section class="content-section compositional-sets-premise" aria-label="The compositional premise">
    <h2 class="section-heading">The compositional premise</h2>
    <p>
      Named freestyle sets compose from a small grammar. Notation work
      originating with Ben Job (1995) proposes that every set can be
      expressed as a sequence of set-type, side, direction, and dexterity
      tokens. The dictionary's operational notation system descends from
      that grammar.
    </p>

    <figure class="compositional-sets-canonical-formula">
      <code>{{content.premise.canonicalFormula}}</code>
      <figcaption>The canonical base shape.</figcaption>
    </figure>

    <p class="compositional-sets-softener">{{content.premise.softenerNote}}</p>

    <p class="compositional-sets-premise-bridge">
      Within that scope, many named "sets" turn out to be recognizable
      trick structures performed uptime &mdash; miraging reads as the mirage
      shape, illusioning mirrors illusion, blurry reads as stepping with
      a paradox second dex. The structural relationships are explored
      below.
    </p>

    <p class="compositional-sets-cross-link detail-muted">
      For tricks grouped by which modifier they use rather than which set
      they descend from, see <a href="/freestyle/tricks?view=movement-system">Movement System</a>.
    </p>

    <div class="compositional-set-grid compositional-set-grid--premise">
      {{#each content.premise.examples}}
        <article class="compositional-set-card compositional-set-card--canonical">
          <p class="compositional-set-card-name">
            {{#if this.trickHref}}
              <a href="{{this.trickHref}}">{{this.name}}</a>
            {{else}}
              {{this.name}}
            {{/if}}
          </p>
          <code class="compositional-set-card-notation">{{this.notation}}</code>
        </article>
      {{/each}}
    </div>

    <p class="compositional-sets-cross-link-row">
      <a href="{{content.crossLinks.glossaryNotationHref}}">Glossary primer on operational notation &rarr;</a>
      <span class="compositional-sets-cross-link-sep" aria-hidden="true">·</span>
      <a href="{{content.crossLinks.setsReferenceHref}}">Reference table at /freestyle/sets &rarr;</a>
    </p>
  </section>

  {{!-- §2 — Family branching --}}
  {{#each content.families}}
    <section class="content-section compositional-set-family" id="family-{{this.key}}" aria-label="{{this.name}}">
      <h2 class="section-heading">{{this.name}}</h2>
      <p class="compositional-set-family-intro">{{this.intro}}</p>
      <div class="compositional-set-grid">
        {{#each this.members}}
          <article
            id="{{this.anchorId}}"
            class="compositional-set-card compositional-set-card--{{this.status}}"
          >
            <p class="compositional-set-card-name">
              {{#if this.trickHref}}
                <a href="{{this.trickHref}}">{{this.name}}</a>
              {{else}}
                {{this.name}}
              {{/if}}
            </p>
            <code class="compositional-set-card-notation">{{this.notation}}</code>
            {{#if this.structuralNote}}
              <p class="compositional-set-card-note">{{this.structuralNote}}</p>
            {{/if}}
            {{#unless (eq this.status 'canonical')}}
              <p class="compositional-set-card-status compositional-set-card-status--{{this.status}}">
                {{#if (eq this.status 'platform-tracked')}}platform-tracked{{/if}}
                {{#if (eq this.status 'holden-only')}}Holden-only{{/if}}
              </p>
            {{/unless}}
          </article>
        {{/each}}
      </div>
    </section>
  {{/each}}

  {{!-- §3 — Uptime reinterpretation ladders --}}
  <section class="content-section compositional-sets-ladders" id="uptime-reinterpretation" aria-label="Uptime reinterpretation ladders">
    <h2 class="section-heading">Uptime reinterpretation</h2>
    <p class="compositional-sets-ladders-intro">
      Several named sets read as trick structures performed uptime. The
      ladders below show the relationship between a set and its
      trick-structural source. Where Holden's compilation and later
      platform analysis disagree, both readings are recorded.
    </p>

    {{#each content.ladders}}
      <article
        id="{{this.anchorId}}"
        class="compositional-ladder{{#if this.conflictNote}} compositional-ladder--conflict{{/if}}"
      >
        <header class="compositional-ladder-header">
          <p class="compositional-ladder-set-name">{{this.setName}}</p>
          <code class="compositional-ladder-set-notation">{{this.setNotation}}</code>
        </header>
        <p class="compositional-ladder-reinterpretation">&rarr; {{this.reinterpretation}}</p>
        <ol class="compositional-ladder-steps">
          {{#each this.steps}}
            <li class="compositional-ladder-step"><code>{{this}}</code></li>
          {{/each}}
        </ol>
        <p class="compositional-ladder-source"><span class="compositional-ladder-source-label">Source:</span> {{this.sourceCitation}}</p>
        {{#if this.conflictNote}}
          <p class="compositional-ladder-conflict">{{this.conflictNote}}</p>
        {{/if}}
      </article>
    {{/each}}
  </section>

  {{!-- §4 — Consistency audit (Holden ⇄ platform) --}}
  <section class="content-section compositional-sets-audit" id="audit" aria-label="Holden and platform consistency audit">
    <h2 class="section-heading">Consistency audit</h2>
    <p class="compositional-sets-audit-intro">
      How Holden's compilation aligns with the platform's other movement-language
      sources (operator reference, resolved formulas, symbolic equivalences,
      movement-systems classification). The audit is curatorial transparency,
      not a normalization pass &mdash; Holden-only entries are <em>not</em>
      promoted to canonical, and conflicts are <em>not</em> silently resolved.
    </p>

    <dl class="compositional-sets-audit-summary" aria-label="Audit summary counts">
      <dt>Aligned</dt>
      <dd>{{content.audit.summary.aligned}}<span class="compositional-sets-audit-summary-context"> &mdash; notation and decomposition agree</span></dd>
      <dt>Partial fit</dt>
      <dd>{{content.audit.summary.partial}}<span class="compositional-sets-audit-summary-context"> &mdash; notation matches; ontological framing diverges</span></dd>
      <dt>Conflict</dt>
      <dd>{{content.audit.summary.conflict}}<span class="compositional-sets-audit-summary-context"> &mdash; substantive decomposition disagreement</span></dd>
      <dt>Holden-only</dt>
      <dd>{{content.audit.summary.holdenOnly}}<span class="compositional-sets-audit-summary-context"> &mdash; community-cited; no platform entry</span></dd>
    </dl>

    <p class="compositional-sets-audit-headline-intro">
      Headline rows below sample each category. Of {{content.audit.summary.total}} audited entries:
    </p>

    <ol class="compositional-sets-audit-rows">
      {{#each content.audit.headlineRows}}
        <li class="compositional-sets-audit-row compositional-sets-audit-row--{{this.status}}">
          <div class="compositional-sets-audit-row-header">
            <span class="compositional-sets-audit-row-name">{{this.holdenName}}</span>
            <span class="compositional-sets-audit-status-badge compositional-sets-audit-status-badge--{{this.status}}">{{this.statusLabel}}</span>
          </div>
          <p class="compositional-sets-audit-row-holden"><span class="compositional-sets-audit-row-label">Holden:</span> {{this.holdenReading}}</p>
          {{#if this.platformReading}}
            <p class="compositional-sets-audit-row-platform"><span class="compositional-sets-audit-row-label">Platform:</span> {{this.platformReading}}</p>
          {{else}}
            <p class="compositional-sets-audit-row-platform compositional-sets-audit-row-platform--absent"><span class="compositional-sets-audit-row-label">Platform:</span> no current entry.</p>
          {{/if}}
          {{#if this.note}}
            <p class="compositional-sets-audit-row-note">{{this.note}}</p>
          {{/if}}
        </li>
      {{/each}}
    </ol>

    <p class="compositional-sets-audit-full-note">{{content.audit.fullAuditNote}}</p>
  </section>

  {{!-- §5 — Sources & cross-links --}}
  <section class="content-section compositional-sets-sources" aria-label="Sources and cross-links">
    <h2 class="section-heading">Sources &amp; attribution</h2>
    <p>
      Notation grammar originates with Ben Job's 1995 proposal to the
      footbag discussion list. The family compilation below the premise
      is Chris Holden's community-curated list (circa 2003), preserved
      verbatim at <a href="/freestyle/sets">/freestyle/sets</a>. Holden's
      compilation is a community archive, not platform-canonical doctrine —
      entries marked <em>Holden-only</em> above are surfaced as
      community-cited rather than promoted to canonical without curator
      review.
    </p>
    <p class="compositional-sets-cross-link-row">
      <a href="{{content.crossLinks.setsReferenceHref}}">Reference table &rarr;</a>
      <span class="compositional-sets-cross-link-sep" aria-hidden="true">·</span>
      <a href="{{content.crossLinks.operatorsHref}}">Operators &amp; modifiers &rarr;</a>
      <span class="compositional-sets-cross-link-sep" aria-hidden="true">·</span>
      <a href="{{content.crossLinks.glossaryNotationHref}}">Glossary §7: notation &rarr;</a>
    </p>
  </section>

</div>
