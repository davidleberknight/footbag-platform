{{!--
  /freestyle/observational — Emerging Vocabulary frontier map (EV2/EV3 hybrid).

  Status-first, ADD-ordered. Observational layer ONLY: provisional ADD /
  decomposition are observationally extrapolated, NEVER canonical; cards carry
  a tracked tag (not a canonical hashtag), no detail-page link, no media. The
  page reads as a curator work queue: Awaiting Ruling first (lowest derived ADD
  first), then frontier-health metrics, then Needs Authoring, then Doctrine
  Blocked clusters, then the long-tail folk / alias / ecosystem material behind
  disclosure.
--}}
<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper freestyle-observational">
  <section class="content-section">

    {{#if content.isEmpty}}
    <p class="observational-empty-state">
      No observational entries currently staged. The
      <a href="/freestyle/tricks">trick dictionary</a> carries the canonical curated set.
    </p>
    {{else}}

    {{! ── Section A — Awaiting Ruling (FIRST; grouped by derived ADD) ── }}
    {{#if content.readyTotal}}
    <section class="observed-section" id="promotion-ready" aria-label="Awaiting ruling">
      <div class="section-heading">
        <h2>Awaiting Ruling</h2>
        <span class="section-count">{{content.readyTotal}}</span>
      </div>
      <p class="observed-section-intro">
        Structurally understood, with a clean derived ADD, but blocked on a curator
        ruling, an operator chassis, or a missing base before promotion. Ordered by
        derived ADD, lowest first.
      </p>
      {{#each content.readyGroups}}
      <div class="observed-eco-group">
        <h3 class="observed-eco-heading">{{label}} <span class="text-muted">({{count}})</span></h3>
        <div class="observed-card-grid">
          {{#each cards}}{{> observed-card-fields}}{{/each}}
        </div>
      </div>
      {{/each}}
    </section>
    {{/if}}

    {{! ── Frontier-health metrics (under the ready list, not above it) ── }}
    <div class="observed-stats" aria-label="Frontier health">
      {{#each content.stats}}
      <div class="observed-stat">
        <span class="observed-stat-value">{{value}}</span>
        <span class="observed-stat-label">{{label}}</span>
        <span class="observed-stat-hint">{{hint}}</span>
      </div>
      {{/each}}
    </div>
    <p class="observed-stats-note text-muted">{{content.statsNote}}</p>
    {{#if content.sources.length}}
    <p class="observed-source-strip" aria-label="Sources represented on this page">
      Sources:
      {{#each content.sources}}
        {{#unless @first}} &middot; {{/unless}}<span class="observed-source-strip-item observed-source-strip-item--{{badge}}">{{label}}</span>
      {{/each}}
    </p>
    {{/if}}
    <p class="observational-layer-note">{{content.layerNote}}</p>

    {{! ── Section B — Needs Authoring (grouped by derived ADD) ── }}
    {{#if content.frontierTotal}}
    <section class="observed-section" id="needs-authoring" aria-label="Needs authoring">
      <div class="section-heading">
        <h2>Needs Authoring</h2>
        <span class="section-count">{{content.frontierTotal}}</span>
      </div>
      <p class="observed-section-intro">
        Structure is understood, but the notation or decomposition is not yet authored,
        one small judgment from promotion-ready. Grouped by derived ADD.
      </p>
      {{#each content.frontierGroups}}
      <div class="observed-eco-group">
        <h3 class="observed-eco-heading">{{label}} <span class="text-muted">({{count}})</span></h3>
        <div class="observed-card-grid">
          {{#each cards}}{{> observed-card-fields}}{{/each}}
        </div>
      </div>
      {{/each}}
    </section>
    {{/if}}

    {{! ── Section C — Doctrine Blocked (clusters; preserved) ── }}
    {{#if content.doctrineTotal}}
    <section class="observed-section" id="doctrine-blocked" aria-label="Doctrine blocked">
      <div class="section-heading">
        <h2>Doctrine Blocked</h2>
        <span class="section-count">{{content.doctrineTotal}}</span>
      </div>
      <p class="observed-section-intro">
        These are not random unresolved tricks: they are governance bottlenecks
        concentrated in a few ecosystems, each waiting on a single ontology ruling.
        Resolve the ruling and the whole cluster unblocks.
      </p>
      <div class="observed-cluster-grid">
        {{#each content.doctrineClusters}}
        <div class="observed-cluster">
          <div class="observed-cluster-head">
            <h3>{{label}}</h3>
            <span class="observed-cluster-count">{{count}}</span>
          </div>
          <p class="observed-cluster-q">{{blockingQuestion}}</p>
          {{#if sampleNames.length}}
          <p class="observed-cluster-samples text-muted">e.g. {{#each sampleNames}}{{#unless @first}}, {{/unless}}{{this}}{{/each}}</p>
          {{/if}}
        </div>
        {{/each}}
      </div>
    </section>
    {{/if}}

    {{! ── Long tail (collapsed by default) ── }}
    <details class="observed-disclosure">
      <summary class="observed-disclosure-summary">Folk names &amp; unresolved structures <span class="text-muted">({{content.folk.total}} + {{content.parser.total}})</span></summary>
      {{> observed-summary-section section=content.folk title="Folk-name & historical unresolved" anchor="folk-unresolved"}}
      {{> observed-summary-section section=content.parser title="Parser uncertainty" anchor="parser-uncertainty"}}
    </details>

    <details class="observed-disclosure">
      <summary class="observed-disclosure-summary">Alias / duplicate archive <span class="text-muted">({{content.aliasArchive.total}})</span></summary>
      {{> observed-summary-section section=content.aliasArchive title="Resolves to an existing trick" anchor="alias-archive"}}
    </details>

    {{#if content.ecosystemMatrix.length}}
    <details class="observed-disclosure">
      <summary class="observed-disclosure-summary">Frontier by ecosystem</summary>
      <div class="observed-matrix-wrap">
        <table class="observed-matrix">
          <thead>
            <tr><th>Ecosystem</th><th>Ready</th><th>Frontier</th><th>Doctrine</th><th>Unresolved</th><th>Total</th></tr>
          </thead>
          <tbody>
            {{#each content.ecosystemMatrix}}
            <tr>
              <td class="observed-matrix-eco">{{label}}</td>
              <td>{{ready}}</td><td>{{frontier}}</td><td>{{doctrine}}</td><td>{{unresolved}}</td>
              <td class="fw-600">{{total}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </details>
    {{/if}}

    {{/if}}

    <p class="observational-footer">
      Official trick definitions live in the
      {{#each content.canonicalReferences}}{{#unless @first}}, {{/unless}}<a href="{{href}}">{{label}}</a>{{/each}}.
      Every entry above is a name we are still confirming, not an official trick yet.
      <span class="text-muted">Generated {{content.generatedOn}}.</span>
    </p>
  </section>
</div>
