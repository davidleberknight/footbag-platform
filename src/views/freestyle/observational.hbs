{{!--
  /freestyle/observational — Emerging Vocabulary distance-to-canonical ladder.

  Observational layer ONLY: provisional ADD / decomposition are observationally
  extrapolated, NEVER canonical; cards carry a tracked tag (not a canonical
  hashtag), no detail-page link, no media. The page renders the nine-state
  ladder the generator stamps on every row (evState), closest to canonical
  publication first: ready for curation, needs authoring, awaiting doctrine,
  awaiting curator review, awaiting identification, awaiting parser resolution,
  undefined operator, folk / unrecoverable, then the alias archive. Every count
  comes from the generated data; the template computes nothing.
--}}
<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper freestyle-observational">
  <section class="content-section">

    {{#if content.isEmpty}}
    <p class="observational-empty-state">
      No observational entries currently staged. The
      <a href="/freestyle/tricks">trick dictionary</a> carries the canonical curated set.
    </p>
    {{else}}

    {{! ── Step 1 — Ready for Curation (closest to canonical; grouped by derived ADD) ── }}
    {{#if content.readyTotal}}
    <section class="observed-section" id="ready-for-curation" aria-label="Ready for curation">
      <div class="section-heading">
        <h2>Ready for Curation</h2>
        <span class="section-count">{{content.readyTotal}}</span>
      </div>
      <p class="observed-section-intro">
        Every part of these names is understood and the derived ADD is complete, so a
        curator can review and publish them as-is. Ordered by derived ADD, lowest first.
      </p>
      {{#each content.readyGroups}}
      <div class="observed-eco-group">
        <h3 class="observed-eco-heading">{{label}} <span class="text-muted">({{count}})</span></h3>
        <div class="observed-card-grid">
          {{#each cards}}{{> observed-card-fields}}{{/each}}
        </div>
      </div>
      {{/each}}
    </section>
    {{/if}}

    {{! ── Ladder overview (one tile per step, closest to canonical first) ── }}
    <div class="observed-stats" aria-label="Distance to canonical publication">
      {{#each content.stats}}
      <div class="observed-stat">
        <span class="observed-stat-value">{{value}}</span>
        <span class="observed-stat-label">{{label}}</span>
        <span class="observed-stat-hint">{{hint}}</span>
      </div>
      {{/each}}
    </div>
    <p class="observed-stats-note fw-600">{{content.progressHeadline}}</p>
    <p class="observed-stats-note text-muted">{{content.statsNote}}</p>
    {{#if content.sources.length}}
    <p class="observed-source-strip" aria-label="Sources represented on this page">
      Sources:
      {{#each content.sources}}
        {{#unless @first}} &middot; {{/unless}}<span class="observed-source-strip-item observed-source-strip-item--{{badge}}">{{label}}</span>
      {{/each}}
    </p>
    {{/if}}
    <p class="observational-layer-note">{{content.layerNote}}</p>

    {{! ── Step 2 — Needs Authoring (one authoring pass away; grouped by derived ADD) ── }}
    {{#if content.authoringTotal}}
    <section class="observed-section" id="needs-authoring" aria-label="Needs authoring">
      <div class="section-heading">
        <h2>Needs Authoring</h2>
        <span class="section-count">{{content.authoringTotal}}</span>
      </div>
      <p class="observed-section-intro">
        The movement is understood, but the notation or decomposition write-up is not done
        yet: one authoring pass separates these from curator review. Grouped by derived ADD.
      </p>
      {{#each content.authoringGroups}}
      <div class="observed-eco-group">
        <h3 class="observed-eco-heading">{{label}} <span class="text-muted">({{count}})</span></h3>
        <div class="observed-card-grid">
          {{#each cards}}{{> observed-card-fields}}{{/each}}
        </div>
      </div>
      {{/each}}
    </section>
    {{/if}}

    {{! ── Steps 3-5 — the holds, most binding first ── }}
    {{> observed-summary-section section=content.doctrineHold title="Awaiting Doctrine" anchor="awaiting-doctrine"}}
    {{> observed-summary-section section=content.curatorHold title="Awaiting Curator Review" anchor="awaiting-curator-review"}}
    {{> observed-summary-section section=content.identificationHold title="Awaiting Identification" anchor="awaiting-identification"}}

    {{! ── Steps 6-9 — the long tail, collapsed by default ── }}
    {{#if content.parserHold.total}}
    <details class="observed-disclosure">
      <summary class="observed-disclosure-summary">Awaiting parser resolution <span class="text-muted">({{content.parserHold.total}})</span></summary>
      {{> observed-summary-section section=content.parserHold title="Documented execution, decomposition unresolved" anchor="awaiting-parser-resolution"}}
    </details>
    {{/if}}

    {{#if content.undefinedOperatorHold.total}}
    <details class="observed-disclosure">
      <summary class="observed-disclosure-summary">Undefined operator <span class="text-muted">({{content.undefinedOperatorHold.total}})</span></summary>
      {{> observed-summary-section section=content.undefinedOperatorHold title="Blocked on an undefined operator" anchor="undefined-operator"}}
    </details>
    {{/if}}

    <details class="observed-disclosure">
      <summary class="observed-disclosure-summary">Folk / unrecoverable <span class="text-muted">({{content.folkHold.total}})</span></summary>
      {{> observed-summary-section section=content.folkHold title="Community names, structure not yet recovered" anchor="folk-names"}}
    </details>

    <details class="observed-disclosure">
      <summary class="observed-disclosure-summary">Alias / duplicate archive <span class="text-muted">({{content.aliasArchive.total}})</span></summary>
      {{> observed-summary-section section=content.aliasArchive title="Resolves to an existing trick" anchor="alias-archive"}}
    </details>

    {{! ── Database-tracked pending names (outside the generated universe; never double-counted) ── }}
    {{#if content.externalEntries.total}}
    <details class="observed-disclosure">
      <summary class="observed-disclosure-summary">External / unadjudicated (database-tracked) <span class="text-muted">({{content.externalEntries.total}})</span></summary>
      {{> observed-summary-section section=content.externalEntries title="Tracked in the database, not yet adjudicated" anchor="external-unadjudicated"}}
    </details>
    {{/if}}

    {{#if content.ecosystemMatrix.length}}
    <details class="observed-disclosure">
      <summary class="observed-disclosure-summary">Frontier by ecosystem</summary>
      <div class="observed-matrix-wrap">
        <table class="observed-matrix">
          <thead>
            <tr><th>Ecosystem</th><th>Ready</th><th>Authoring</th><th>Holds</th><th>Unresolved</th><th>Total</th></tr>
          </thead>
          <tbody>
            {{#each content.ecosystemMatrix}}
            <tr>
              <td class="observed-matrix-eco">{{label}}</td>
              <td>{{ready}}</td><td>{{authoring}}</td><td>{{holds}}</td><td>{{unresolved}}</td>
              <td class="fw-600">{{total}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </details>
    {{/if}}

    {{/if}}

    <p class="observational-footer">
      Official trick definitions live in the
      {{#each content.canonicalReferences}}{{#unless @first}}, {{/unless}}<a href="{{href}}">{{label}}</a>{{/each}}.
      Every entry above is a name we are still confirming, not an official trick yet.
      <span class="text-muted">Generated {{content.generatedOn}}.</span>
    </p>
  </section>
</div>
