{{!--
  /freestyle/observational — Emerging Vocabulary, organized by what each name
  actually waits on.

  Observational layer ONLY: provisional ADD / decomposition are observationally
  extrapolated, NEVER canonical; cards carry a tracked tag (not a canonical
  hashtag), no detail-page link, no media. Four sections derived from the
  lifecycle model the generator stamps on every row (publicSection): decide now
  (curator decision clusters), waiting on a named ruling (grouped by open
  question with unlock counts), needs evidence, and the documented vocabulary
  archive. Duplicate spellings of one identity render once; malformed and
  rejected rows never render. Every count comes from the generated data plus
  the live publication filter; the template computes nothing.
--}}
<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper freestyle-observational">
  <section class="content-section">

    {{#if content.isEmpty}}
    <p class="observational-empty-state">
      No observational entries currently staged. The
      <a href="/freestyle/tricks">trick dictionary</a> carries the canonical curated set.
    </p>
    {{else}}

    <p class="text-muted">Source key: PB is PassBack, FM is FootbagMoves, SG is Stanford shorthand.</p>

    {{! ── Overview tiles (four sections + the open-question figure) ── }}
    <div class="observed-stats" aria-label="Emerging Vocabulary overview">
      {{#each content.stats}}
      <div class="observed-stat">
        <span class="observed-stat-value">{{value}}</span>
        <span class="observed-stat-label">{{label}}</span>
        <span class="observed-stat-hint">{{hint}}</span>
      </div>
      {{/each}}
    </div>
    <p class="observed-stats-note fw-600">{{content.statsNote}}</p>
    {{#if content.sources.length}}
    <p class="observed-source-strip" aria-label="Sources represented on this page">
      Sources:
      {{#each content.sources}}
        {{#unless @first}} &middot; {{/unless}}<span class="observed-source-strip-item observed-source-strip-item--{{badge}}">{{label}}</span>
      {{/each}}
    </p>
    {{/if}}
    <p class="observational-layer-note">{{content.layerNote}}</p>

    {{! ── Section 1 — Decide now ── }}
    {{#if content.decideTotal}}
    <section class="observed-section" id="decide-now" aria-label="Decide now">
      <div class="section-heading">
        <h2>Decide now</h2>
        <span class="section-count">{{content.decideTotal}}</span>
      </div>
      <p class="observed-section-intro">
        Names with enough evidence for a curator decision, grouped so one answer
        resolves a whole cluster. Nothing here is promoted automatically.
      </p>
      {{#each content.decideClusters}}
      <div class="observed-eco-group" id="decision-{{id}}">
        <h3 class="observed-eco-heading">{{title}} <span class="text-muted">({{count}})</span></h3>
        <p class="observed-decision-question">{{question}}</p>
        <details class="observed-decision-detail">
          <summary class="observed-decision-detail-summary">Recommendation and evidence</summary>
          <dl class="observed-decision-facts">
            <dt>Recommended</dt><dd>{{recommendation}}</dd>
            <dt>Alternatives</dt><dd>{{alternatives}}</dd>
            <dt>Evidence</dt><dd>{{evidence}}</dd>
            <dt>Consequence</dt><dd>{{consequences}}</dd>
          </dl>
        </details>
        {{#if cards.length}}
        <div class="observed-card-grid">
          {{#each cards}}{{> observed-card-fields}}{{/each}}
        </div>
        {{/if}}
        {{#if externalNames.length}}
        <ul class="observational-tracked-list">
          {{#each externalNames}}
          <li>{{name}} <span class="tracked-tag">database-tracked</span></li>
          {{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
    </section>
    {{/if}}

    {{! ── Section 2 — Waiting on a named ruling ── }}
    {{#if content.rulingTotal}}
    <section class="observed-section" id="waiting-on-a-ruling" aria-label="Waiting on a named ruling">
      <div class="section-heading">
        <h2>Waiting on a named ruling</h2>
        <span class="section-count">{{content.rulingTotal}}</span>
      </div>
      <p class="observed-section-intro">
        Every name here is gated by one of the {{content.openQuestionCount}} named open
        questions below, shown with exactly what each answer unlocks. Nothing waits on a
        vague category.
      </p>
      {{#each content.questions}}
      <details class="observed-disclosure" id="question-{{id}}">
        <summary class="observed-disclosure-summary">{{title}} <span class="text-muted">(unlocks {{unlockCount}})</span></summary>
        <p class="observed-question-text">{{question}}</p>
        <p class="observed-question-meta">Status: {{status}} &middot; Owner: {{owner}} &middot; Vehicle: {{vehicle}}</p>
        <ul class="observational-tracked-list observed-fulllist-grid">
          {{#each names}}
          <li>{{name}} <span class="tracked-tag">{{source}}</span>{{#if publishedTarget}} <span class="text-muted">published as {{publishedTarget}}; name form only</span>{{/if}}</li>
          {{/each}}
        </ul>
      </details>
      {{/each}}
    </section>
    {{/if}}

    {{! ── Section 3 — Needs evidence ── }}
    {{#if content.evidenceRows.length}}
    <section class="observed-section" id="needs-evidence" aria-label="Needs evidence">
      <div class="section-heading">
        <h2>Needs evidence</h2>
        <span class="section-count">{{content.evidenceRows.length}}</span>
      </div>
      <p class="observed-section-intro">
        The identity cannot be recovered from the record; each entry states the missing
        evidence.
      </p>
      <ul class="observational-tracked-list">
        {{#each content.evidenceRows}}
        <li>{{name}} <span class="tracked-tag">{{source}}</span> <span class="text-muted">{{missing}}</span></li>
        {{/each}}
      </ul>
    </section>
    {{/if}}

    {{! ── Section 4 — Documented vocabulary archive ── }}
    <section class="observed-section" id="documented-archive" aria-label="Documented vocabulary archive">
      <div class="section-heading">
        <h2>Documented vocabulary archive</h2>
        <span class="section-count">{{content.archiveTotal}}</span>
      </div>
      <p class="observed-section-intro">
        Recorded vocabulary kept for reference, not active publication candidates:
        names already represented by a published trick or alias, observational history,
        and operator or notation terms.
      </p>
      {{#if content.archiveRepresented.total}}
      <details class="observed-disclosure">
        <summary class="observed-disclosure-summary">Already represented <span class="text-muted">({{content.archiveRepresented.total}})</span></summary>
        {{> observed-summary-section section=content.archiveRepresented title="Already represented" anchor="archive-represented"}}
      </details>
      {{/if}}
      {{#if content.archiveObservational.total}}
      <details class="observed-disclosure">
        <summary class="observed-disclosure-summary">Observational names <span class="text-muted">({{content.archiveObservational.total}})</span></summary>
        {{> observed-summary-section section=content.archiveObservational title="Observational names" anchor="archive-observational"}}
      </details>
      {{/if}}
      {{#if content.archiveTerms.total}}
      <details class="observed-disclosure">
        <summary class="observed-disclosure-summary">Recorded terms (not tricks) <span class="text-muted">({{content.archiveTerms.total}})</span></summary>
        {{> observed-summary-section section=content.archiveTerms title="Recorded terms" anchor="archive-terms"}}
      </details>
      {{/if}}
      {{#if content.externalUnadjudicated.length}}
      <details class="observed-disclosure">
        <summary class="observed-disclosure-summary">Database-tracked, not yet adjudicated <span class="text-muted">({{content.externalUnadjudicated.length}})</span></summary>
        <ul class="observational-tracked-list">
          {{#each content.externalUnadjudicated}}
          <li>{{name}} <span class="tracked-tag">{{source}}</span></li>
          {{/each}}
        </ul>
      </details>
      {{/if}}
    </section>

    {{/if}}

    <p class="observational-footer">
      Official trick definitions live in the
      {{#each content.canonicalReferences}}{{#unless @first}}, {{/unless}}<a href="{{href}}">{{label}}</a>{{/each}}.
      Every entry above is a name we are still confirming, not an official trick yet.
    </p>
  </section>
</div>
