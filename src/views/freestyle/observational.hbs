{{!--
  /freestyle/observational — observational-layer trick entries.

  Layer-separation contract (per
  exploration/freestyle-public-coherence-wave-2026-05-18/
  curated_vs_observational_boundary.md):

    - Cards on this surface are visually distinct from canonical cards
      (no hashtag chip, no canonical ADD chip, no trick-detail link).
    - Each card carries a source badge with tooltip attribution.
    - Status chip surfaces curator-review state.
    - NO links to /freestyle/tricks/{folkSlug} (these entries have no
      canonical detail page).

  Density contract (per
  exploration/workbook-completion-2026-05-19/
  observed_tricks_scalability_plan.md):

    - Compact 2-line default visible per card.
    - <details> expansion for additional readings, formula, curator
      note, blockers, full source citation.
    - Hybrid grouping: ADD primary, A-Z secondary within bucket.
--}}
<div class="hero hero-sm">
  <div>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/freestyle">Freestyle</a> &rsaquo;
      <span aria-current="page">Observed Tricks</span>
    </nav>
    <h1>{{page.title}}
      <span class="symbolic-layer-badge" title="Observational layer — external-source documented, not canonical">observational</span>
    </h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper freestyle-observational observed-page">
  <section class="content-section">
    <p class="observational-layer-note">{{content.layerNote}}</p>

    <p class="observational-canonical-refs">
      Canonical references:
      {{#each content.canonicalReferences}}
        {{#unless @first}} &middot; {{/unless}}<a href="{{href}}">{{label}}</a>
      {{/each}}
    </p>

    {{#if content.sources.length}}
    <p class="observed-source-strip" aria-label="Sources represented on this page">
      Sources:
      {{#each content.sources}}
        {{#unless @first}} &middot; {{/unless}}<span class="observed-source-strip-item observed-source-strip-item--{{this}}">{{this}}</span>
      {{/each}}
    </p>
    {{/if}}

    {{#if content.totalEntries}}
      {{#each content.byAdd}}
      <h2 class="observed-bucket-heading">
        {{addLabel}}
        <span class="observed-bucket-count">({{cards.length}})</span>
      </h2>
      <div class="observed-card-grid">
        {{#each cards}}
        <article class="observed-card" data-folk-slug="{{folkSlug}}">
          <header class="observed-card-head">
            <span class="observed-card-source-badge observed-card-source-badge--{{sourceBadge}}" title="{{sourceTooltip}}" aria-label="Source: {{sourceTooltip}}">{{sourceBadge}}</span>
            <h3 class="observed-card-name">{{displayName}}</h3>
            <span class="observed-card-status-chip observed-card-status-chip--{{statusChip.tone}}">{{statusChip.label}}</span>
          </header>
          <p class="observed-card-meta">
            {{#if shortReading}}<span class="observed-card-reading"><span class="observed-card-equiv-sigil" aria-hidden="true">&equiv;</span> {{shortReading}}</span>{{/if}}
            <span class="observed-card-add">{{externalAddLabel}}</span>
          </p>
          {{#if hasDetails}}
          <details class="observed-card-details">
            <summary class="observed-card-details-summary">More</summary>
            {{#if detailExpansion.additionalReadings.length}}
            <ul class="observed-card-detail-readings">
              {{#each detailExpansion.additionalReadings}}
              <li><span class="observed-card-equiv-sigil" aria-hidden="true">&equiv;</span> {{this}}</li>
              {{/each}}
            </ul>
            {{/if}}
            {{#if detailExpansion.formula}}
            <p class="observed-card-detail-formula"><code>{{detailExpansion.formula}}</code></p>
            {{/if}}
            {{#if detailExpansion.curatorNote}}
            <p class="observed-card-detail-note"><em>Curator note:</em> {{detailExpansion.curatorNote}}</p>
            {{/if}}
            {{#if detailExpansion.blockers.length}}
            <p class="observed-card-detail-blockers">
              <em>Blockers:</em>
              {{#each detailExpansion.blockers}}{{#unless @first}}; {{/unless}}{{this}}{{/each}}
            </p>
            {{/if}}
            <p class="observed-card-detail-source">Source: {{detailExpansion.sourceCitation}}</p>
          </details>
          {{/if}}
        </article>
        {{/each}}
      </div>
      {{/each}}
    {{else}}
    <p class="observational-empty-state">
      No observational entries currently staged. The
      <a href="/freestyle/tricks">trick dictionary</a> carries the
      canonical curated set.
    </p>
    {{/if}}

    <p class="observational-footer">
      Curated canonical trick definitions remain authoritative. See the
      <a href="/freestyle/tricks">Trick Dictionary</a>,
      <a href="/freestyle/operators">Operators &amp; Modifiers</a>,
      and <a href="/freestyle/glossary">Glossary</a> for the
      curator-confirmed reference.
    </p>
  </section>
</div>
