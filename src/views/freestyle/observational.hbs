{{!--
  /freestyle/observational — observational-layer trick entries.

  Layer-separation contract (per
  exploration/freestyle-public-coherence-wave-2026-05-18/
  curated_vs_observational_boundary.md):

    - Cards on this surface are visually distinct from canonical cards
      (a distinct "tracked tag" rather than a canonical hashtag chip,
      no canonical ADD chip, no trick-detail link).
    - Each card carries a source badge with tooltip attribution.
    - Status chip surfaces curator-review state.
    - NO links to /freestyle/tricks/{folkSlug} (these entries have no
      canonical detail page).

  Density contract:

    - Compact 2-line default visible per card.
    - <details> expansion for additional readings, formula, curator
      note, blockers, full source citation.
    - Flat list sorted by the source's numeric ADD claim ascending
      (entries without a numeric claim sort last); displayName is the
      secondary tiebreak. The numeric value is the source's own claim,
      surfaced for readability of source-claimed difficulty order. It
      is NOT a canonical ADD assertion.
    - Per-card external-claim label uses 'PB claim: 4' framing
      (source-attributed) rather than '4 ADD' (canonical-implying).
--}}
<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper freestyle-observational observed-page">
  <section class="content-section">
    <p class="observational-layer-note">{{content.layerNote}}</p>

    <p class="observational-canonical-refs">
      Where the official tricks live:
      {{#each content.canonicalReferences}}
        {{#unless @first}} &middot; {{/unless}}<a href="{{href}}">{{label}}</a>
      {{/each}}
    </p>

    {{#if content.sources.length}}
    <p class="observed-source-strip" aria-label="Sources represented on this page">
      Sources:
      {{#each content.sources}}
        {{#unless @first}} &middot; {{/unless}}<span class="observed-source-strip-item observed-source-strip-item--{{this}}">{{this}}</span>
      {{/each}}
    </p>
    {{/if}}

    {{#if content.totalEntries}}
      <p class="observed-count-strip" aria-label="Total observational entries">
        <strong>{{content.totalEntries}}</strong> observational tricks pending canonical review, grouped into four governance lanes below.
      </p>

      {{! ── Governance lanes (2026-05-24 slice). Four lanes; each lane
          renders only when it has entries. Cards retain the same shape
          as the previous flat grid; the lane sections are the only
          structural change. }}
      {{#with content.lanes}}

      {{#if promotionQueue.cardCount}}
      <section class="observed-lane observed-lane--promotion-queue" id="lane-promotion-queue" aria-label="Promotion queue lane">
        <div class="section-heading">
          <h2>{{promotionQueue.label}}</h2>
          <span class="section-count">{{promotionQueue.cardCount}}</span>
        </div>
        <p class="observed-lane-intro">{{promotionQueue.intro}}</p>
        <div class="observed-card-grid">
          {{#each promotionQueue.cards}}
            {{> observed-card-fields}}
          {{/each}}
        </div>
      </section>
      {{/if}}

      {{#if formulaReview.cardCount}}
      <section class="observed-lane observed-lane--formula-review" id="lane-formula-review" aria-label="Formula review lane">
        <div class="section-heading">
          <h2>{{formulaReview.label}}</h2>
          <span class="section-count">{{formulaReview.cardCount}}</span>
        </div>
        <p class="observed-lane-intro">{{formulaReview.intro}}</p>
        <div class="observed-card-grid">
          {{#each formulaReview.cards}}
            {{> observed-card-fields}}
          {{/each}}
        </div>
      </section>
      {{/if}}

      {{#if doctrineBlocked.cardCount}}
      <section class="observed-lane observed-lane--doctrine-blocked" id="lane-doctrine-blocked" aria-label="Doctrine blocked lane">
        <div class="section-heading">
          <h2>{{doctrineBlocked.label}}</h2>
          <span class="section-count">{{doctrineBlocked.cardCount}}</span>
        </div>
        <p class="observed-lane-intro">{{doctrineBlocked.intro}}</p>
        <div class="observed-card-grid">
          {{#each doctrineBlocked.cards}}
            {{> observed-card-fields}}
          {{/each}}
        </div>
      </section>
      {{/if}}

      {{#if sourceOnly.cardCount}}
      <section class="observed-lane observed-lane--source-only" id="lane-source-only" aria-label="Source-only documented lane">
        <div class="section-heading">
          <h2>{{sourceOnly.label}}</h2>
          <span class="section-count">{{sourceOnly.cardCount}}</span>
        </div>
        <p class="observed-lane-intro">{{sourceOnly.intro}}</p>
        <div class="observed-card-grid">
          {{#each sourceOnly.cards}}
            {{> observed-card-fields}}
          {{/each}}
        </div>
      </section>
      {{/if}}

      {{/with}}
    {{else}}
    <p class="observational-empty-state">
      No observational entries currently staged. The
      <a href="/freestyle/tricks">trick dictionary</a> carries the
      canonical curated set.
    </p>
    {{/if}}

    {{#if content.trackedNames.length}}
    <div id="tracked-vocabulary" class="observational-tracked">
      <h2>{{content.trackedNamesTotal}} more documented names</h2>
      <p class="text-muted">{{content.trackedNamesNote}}</p>
      {{#each content.trackedNames}}
      <h3>{{sourceLabel}} <span class="text-muted">({{names.length}})</span></h3>
      <ul class="observational-tracked-list">
        {{#each names}}
        <li>{{displayName}} <span class="tracked-tag">#{{slug}}</span>{{#if operationalNotation}} <span class="observational-tracked-formula">&equiv; <code>{{operationalNotation}}</code></span>{{/if}}</li>
        {{/each}}
      </ul>
      {{/each}}
    </div>
    {{/if}}

    <p class="observational-footer">
      The canonical trick definitions live in the
      <a href="/freestyle/tricks">Trick Dictionary</a>,
      <a href="/freestyle/operators">Operators &amp; Modifiers</a>,
      and <a href="/freestyle/glossary">Glossary</a>. Each entry above
      is a canonicalization candidate for an upcoming publication wave.
    </p>
  </section>
</div>
