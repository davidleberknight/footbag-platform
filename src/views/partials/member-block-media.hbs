{{!-- Member's media: links to the member's named galleries (cards) plus a
      "view all media" link. No inline thumbnails. Receives a ProfileMediaView;
      the caller renders it only when content.media.hasContent. --}}
<div class="profile-section">
  <h2 class="profile-section-heading">Media</h2>
  {{#if galleries.length}}
    <div class="card-grid card-grid-2col">
      {{#each galleries}}
        <div class="card">
          <a href="{{href}}" class="card-title">{{name}}</a>
          {{#if description}}<p class="card-description">{{description}}</p>{{/if}}
          <p class="card-meta">{{itemCount}} {{itemCountNoun}}</p>
        </div>
      {{/each}}
    </div>
  {{/if}}
  {{#if allMediaHref}}
    <p class="mt-4"><a href="{{allMediaHref}}" class="btn btn-outline">View All Media &rarr;</a></p>
  {{/if}}
</div>
