{{!--
  Operational (JOB) notation block (warm palette). Renders the role-
  classified tokens for the trick's operational notation chain.

  Suppressed for first-class tricks because their JOB row is already
  rendered by the trick-comparative-row notation summary card directly
  below the hero. Non-first-class tricks still get the full tokenized
  rendering here.
--}}
{{#if content.operationalNotation}}
{{#unless content.isFirstClass}}
<section class="content-section operational-notation-display" aria-label="Set notation">
  <div class="section-heading">
    <h2>Set notation</h2>
    <p class="section-intro">Execution mechanics -- the set-arc form showing how the body performs the trick.</p>
  </div>
  <code class="operational-notation-tokens">{{#each content.operationalNotation.tokens}}<span class="op-token op-token--{{cssRole}}" data-role="{{role}}" title="{{label}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}</code>
  {{#if content.operationalNotation.sourceNote}}
  <p class="operational-notation-source-note">{{content.operationalNotation.sourceNote}}</p>
  {{/if}}
  <p class="operational-notation-glossary-link">
    <a href="/freestyle/glossary#operational-notation">Token reference &rarr;</a>
  </p>
</section>
{{/unless}}
{{/if}}
