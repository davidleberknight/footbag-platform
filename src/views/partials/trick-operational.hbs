{{!--
  Operational notation block (warm palette). Renders only when operationalNotation is non-null.
  Source-provenance line + glossary deeplink preserved from O1d.
--}}
{{#if content.operationalNotation}}
<section class="content-section operational-notation-display" aria-label="Set notation (operational)">
  <div class="section-heading">
    <h2>Set notation (operational)</h2>
    <p class="section-intro">Execution mechanics -- how the body performs the trick. Independent of the semantic notation above.</p>
  </div>
  <code class="operational-notation-tokens">{{#each content.operationalNotation.tokens}}<span class="op-token op-token--{{cssRole}}" data-role="{{role}}" title="{{label}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}</code>
  {{#if content.operationalNotation.sourceNote}}
  <p class="operational-notation-source-note">{{content.operationalNotation.sourceNote}}</p>
  {{/if}}
  <p class="operational-notation-glossary-link">
    <a href="/freestyle/glossary#operational-notation">Token reference &rarr;</a>
  </p>
</section>
{{/if}}
