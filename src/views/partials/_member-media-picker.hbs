{{!--
  Member's-own-media picker. Renders a checkbox grid of the member's
  prior uploads; each checked row submits as `mediaIds=<mediaId>` in
  the parent form. The parent controller invokes addMediaToGallery
  with the collected ids after createGallery / updateGallery succeeds,
  applying the gallery's criteria tags to each picked item.

  Caller passes:
    pickerItems[] — each:
      { mediaId, mediaType, thumbnailUrl, caption, sourceFilename,
        uploadedAt, tags[] }

  Self-guards on pickerItems.length so contexts that don't pass the
  field (admin curator gallery edit) render nothing.
--}}
{{#if pickerItems.length}}
  <fieldset class="form-row member-media-picker">
    <legend class="form-label">Add items from your existing uploads</legend>
    <p class="form-help">
      Check items below to add them to this gallery. The gallery's criteria
      tags are applied to each checked item so it appears here. (Items stay
      in any other galleries they already match.)
    </p>
    <div class="picker-grid">
      {{#each pickerItems}}
        <label class="picker-cell">
          <input type="checkbox" name="mediaIds" value="{{mediaId}}">
          <img src="{{thumbnailUrl}}"
               alt="{{#if caption}}{{caption}}{{else}}{{sourceFilename}}{{/if}}"
               loading="lazy">
          <span class="picker-meta">
            {{#if caption}}{{caption}}{{else}}<code>{{sourceFilename}}</code>{{/if}}
            {{#if (eq mediaType "video")}} <span class="picker-badge">video</span>{{/if}}
          </span>
        </label>
      {{/each}}
    </div>
  </fieldset>
{{/if}}
