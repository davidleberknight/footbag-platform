<div id="find-members" class="profile-section">
  <h2 class="profile-section-heading">Find Members</h2>
  <div class="search-box-section">
      <form method="GET" action="{{formAction}}#find-members" class="search-box-form">
        <input type="text" name="q" minlength="2" maxlength="100"
               placeholder="Search by name..."
               value="{{query}}"
               aria-label="Search members by name"
               class="search-box-input" />
        <button type="submit" class="btn btn-primary">Search</button>
      </form>
    </div>

    {{#if hasQuery}}
      {{#if rateLimited}}
        <p class="text-muted">Too many searches just now. Please wait a moment and try again.</p>
      {{else if tooShort}}
        <p class="text-muted">Please enter at least 2 characters.</p>
      {{else if results.length}}
        <div class="search-box-card-results-head">
          <strong>Results</strong>
          <span class="section-count">{{results.length}}{{#if hasMore}}+{{/if}}</span>
        </div>
        {{#if hasMore}}
          <p class="text-muted">Too many results. Please refine your search.</p>
        {{/if}}
        <div class="search-box-results">
          {{#each results}}
            <div class="search-box-result">
              <a href="{{href}}">{{displayName}}</a>
              {{#if country}}<span class="text-muted">{{country}}</span>{{/if}}
              {{#if genderLabel}}<span class="text-muted">{{genderLabel}}</span>{{/if}}
              {{#if isHistorical}}<span class="badge badge-historical">Historical</span>{{else}}<span class="badge badge-member">Member</span>{{/if}}
              {{#if isHof}}<span class="badge badge-honor">HoF</span>{{/if}}
              {{#if isBap}}<span class="badge badge-honor">BAP</span>{{/if}}
              {{#if isBoard}}<span class="badge badge-honor">Board</span>{{/if}}
            </div>
          {{/each}}
        </div>
      {{else}}
        <p class="text-muted">No members found matching "{{query}}".</p>
      {{/if}}
    {{/if}}
</div>
