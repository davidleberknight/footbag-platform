{{!--
  Movement-intuition prose.
  Renders only when content.intuition is non-null — curator-locked
  flagship pages only. Source attribution rendered below the prose
  in a small muted line.

  Layer separation: prose only; never replaces notation, ADD
  accounting, or any ontology field. Inserts between trick-about
  (compositional reading) and trick-notation (symbolic structure)
  so the page reads movement-first → structure-second.
--}}
{{#if content.intuition}}
<section class="content-section trick-intuition" aria-label="Movement intuition">
  <div class="section-heading">
    <h2>Movement intuition</h2>
    {{#if content.sectionSubtitles.movementIntuition}}<p class="section-intro">{{content.sectionSubtitles.movementIntuition}}</p>{{/if}}
  </div>
  <p class="trick-intuition-prose">{{content.intuition.prose}}</p>
  <p class="trick-intuition-attribution">{{content.intuition.attribution}}</p>
  {{!-- Parent-delta line supplements the physical prose. When a trick has no
       intuition prose the delta renders in About instead, so it never stands
       alone under a Movement intuition heading. --}}
  {{#if content.intuitionDelta}}
  <p class="text-muted" data-intuition-delta>{{content.intuitionDelta}}</p>
  {{/if}}
</section>
{{/if}}
