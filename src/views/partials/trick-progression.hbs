{{!--
  Record progression table. Renders only when hasProgression is true.
--}}
{{#if content.hasProgression}}
<section class="content-section">
  <div class="section-heading">
    <h2>Record Progression</h2>
  </div>
  <table class="records-table">
    <thead>
      <tr>
        <th class="col-rank">#</th>
        <th>Holder</th>
        <th class="col-num">Count</th>
        <th>Adds</th>
        <th>Date</th>
        <th>Video</th>
      </tr>
    </thead>
    <tbody>
      {{#each content.progression}}
      <tr class="record-row">
        <td class="col-rank">{{add @index 1}}</td>
        <td class="col-holder">
          {{#if holderHref}}
            <a href="{{holderHref}}">{{holderName}}</a>
          {{else}}
            {{holderName}}
          {{/if}}
        </td>
        <td class="col-num">{{valueNumeric}}</td>
        <td class="col-adds">{{#if addsCount}}{{addsCount}}{{else}}&mdash;{{/if}}</td>
        <td class="col-date">
          {{#if achievedDate}}
            {{formatDate achievedDate}}{{#if dateApproximate}} <em>(approx.)</em>{{/if}}
          {{else}}
            &mdash;
          {{/if}}
        </td>
        <td class="col-video">
          {{#if videoUrl}}
            <a href="{{videoUrl}}" class="video-link" target="_blank" rel="noopener noreferrer"
               aria-label="Watch {{holderName}} {{../page.title}} record video">
              &#9654;{{#if videoTimecode}} {{videoTimecode}}{{/if}}
            </a>
          {{else}}
            &mdash;
          {{/if}}
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</section>
{{/if}}
