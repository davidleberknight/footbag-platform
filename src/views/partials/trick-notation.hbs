{{!--
  Curator notation block (cool palette, parser-tokenized). Renders only when
  notationDisplay is non-null. Token coloration and glossary deeplink anchor
  the canonical symbolic layer.
--}}
{{!-- Section 1 — Movement notation: the canonical symbolic layer. --}}
{{#if content.notationDisplay}}
<section class="content-section notation-display" aria-label="Movement notation">
  <div class="section-heading">
    <h2>Movement notation</h2>
    {{#if content.sectionSubtitles.movementNotation}}<p class="section-intro">{{content.sectionSubtitles.movementNotation}}</p>{{/if}}
  </div>
  <code class="notation-display-tokens">{{#each content.notationDisplay.tokens}}<span class="notation-token notation-{{cssRole}}" data-role="{{role}}" title="{{label}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}</code>
</section>
{{/if}}

{{!-- Section 2 — Execution notation: the set-arc (operational) form, in its own
     section so the page reads Movement notation -> Execution notation -> ADD ->
     Equivalent readings. Rendered the same way for bases and derivatives: when a
     trick carries operational notation (CORE_TRICK_SPEC / curator / DB), its JOB
     reads here. Source-provenance citation is intentionally NOT rendered (it is
     curator-internal metadata, not public detail-card copy). --}}
{{#if content.operationalNotation}}
<section class="content-section operational-notation-display" aria-label="Execution notation">
  <div class="section-heading">
    <h2>Execution notation</h2>
    {{#if content.sectionSubtitles.executionNotation}}<p class="section-intro">{{content.sectionSubtitles.executionNotation}}</p>{{/if}}
  </div>
  <code class="operational-notation-tokens">{{#each content.operationalNotation.tokens}}<span class="op-token op-token--{{cssRole}}" data-role="{{role}}" title="{{label}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}</code>
  {{#if content.executionExpanded}}
  {{!-- Spelled-out form for named-set-shorthand entries (e.g. '(railing set)'). --}}
  <p class="operational-notation-expanded"><span class="operational-notation-expanded-label">Expanded</span> <code>{{content.executionExpanded}}</code></p>
  {{/if}}
</section>
{{/if}}

{{!-- Section 3 — ADD derivation, directly below Execution notation so the
     notation card reads Movement notation -> Execution notation -> ADD for
     bases and derivatives alike. --}}
{{> trick-add-analysis}}

{{!-- Token reference: one glossary deeplink after the notation forms (before
     Equivalent readings), shown when either notation section rendered. --}}
{{#if (or content.notationDisplay content.operationalNotation)}}
<p class="notation-glossary-link">
  <a href="/freestyle/glossary#notation">Token reference &rarr;</a>
</p>
{{/if}}
