{{!--
  Curator notation block (cool palette, parser-tokenized). Renders only when
  notationDisplay is non-null. Token coloration and glossary deeplink anchor
  the canonical symbolic layer.
--}}
{{#if (or content.notationDisplay content.operationalNotation)}}
<section class="content-section notation-display" aria-label="Trick notation">
  <div class="section-heading">
    <h2>Movement notation</h2>
    {{#if content.notationSubtitle}}<p class="section-intro">{{content.notationSubtitle}}</p>{{/if}}
  </div>
  {{#if content.notationDisplay}}
  <code class="notation-display-tokens">{{#each content.notationDisplay.tokens}}<span class="notation-token notation-{{cssRole}}" data-role="{{role}}" title="{{label}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}</code>
  {{/if}}
  {{!-- Set-arc (operational) reading folded in: the execution form of the same
       notation. Suppressed for first-class tricks (their JOB row is in the
       comparative-row card under the hero). --}}
  {{#if content.operationalNotation}}{{#unless content.isFirstClass}}
  <div class="operational-notation-display">
    <div class="section-heading"><h3>Execution notation</h3></div>
    <p class="section-intro">How the body performs the trick, step by step.</p>
    <code class="operational-notation-tokens">{{#each content.operationalNotation.tokens}}<span class="op-token op-token--{{cssRole}}" data-role="{{role}}" title="{{label}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}</code>
    {{#if content.operationalNotation.sourceNote}}
    <p class="operational-notation-source-note">{{content.operationalNotation.sourceNote}}</p>
    {{/if}}
  </div>
  {{/unless}}{{/if}}
  <p class="notation-glossary-link">
    <a href="/freestyle/glossary#notation">Token reference &rarr;</a>
  </p>
</section>
{{/if}}

{{!--
  Layer 2 — Curated equivalence chain (editorial palette, progressive
  hierarchy). Renders when semanticNotation.layer == 'equivalence'. Coexists
  with Layer 1 when both exist. Visually editorial / pedagogical, distinct
  from Layer 1's canonical treatment.
--}}
{{#if content.semanticNotation}}
{{#if content.semanticNotation.isEquivalenceLayer}}
<section class="content-section equivalent-readings" aria-label="Equivalent readings">
  <div class="section-heading">
    <h2>Equivalent readings</h2>
    <p class="section-intro">
      Other ways the same trick reads &mdash; later rows progressively unfold the composition.
      {{#if content.semanticNotation.curatorConfirmPending}}
      <span class="equivalent-readings-pending-flag">pending</span>
      {{/if}}
    </p>
  </div>
  <ol class="equivalent-readings-list">
    {{#each content.semanticNotation.readings}}
    <li class="equivalent-reading equivalent-reading-depth-{{depthIndex}}">
      {{#each tokens}}{{#if (eq kind "link")}}<a class="equivalent-reading-token equivalent-reading-token-link" href="{{href}}">{{text}}</a>{{else}}<span class="equivalent-reading-token">{{text}}</span>{{/if}}{{#unless @last}} {{/unless}}{{/each}}
    </li>
    {{/each}}
  </ol>
  <p class="equivalent-readings-source">Different ways to express the same trick's composition. Tap any term to jump to its glossary entry.</p>
</section>
{{/if}}

{{!--
  Layer 3 — Base-lineage phrase. One-line prose pointing at the structural
  base when the trick has a resolvable base_trick but no chain and no
  curator notation. Quiet, restrained.
--}}
{{#if content.semanticNotation.isBaseLineageLayer}}
<section class="content-section semantic-base-lineage" aria-label="Trick lineage">
  <p class="semantic-base-lineage-phrase">Built on <a href="/freestyle/tricks/{{content.semanticNotation.baseSlug}}">{{content.semanticNotation.baseName}}</a>.</p>
</section>
{{/if}}

{{!--
  Layer 5b — Non-core curation-gap cue. Renders for decomposable tricks
  whose structural decomposition is not yet curator-authored. Pure prose;
  no compensatory navigation. Visually very quiet.
--}}
{{#if content.semanticNotation.isCurationGapLayer}}
<p class="semantic-notation-pending">Compositional reading pending curation.</p>
{{/if}}
{{/if}}
