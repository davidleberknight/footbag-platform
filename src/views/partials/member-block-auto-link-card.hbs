{{#if this}}
<div class="profile-section">
  <div class="card auto-link-card">
    <h2 class="card-title">We linked your account to a competition history record</h2>
    <p>
      We linked your IFPA account to the legacy footbag.org record for
      <strong>{{this.legacyDisplayName}}</strong>.
    </p>
    {{#if this.personName}}
    <p class="text-muted fs-sm">
      Historical record: {{this.personName}}.
    </p>
    {{/if}}
    <div class="auto-link-card-actions">
      <form method="post" action="{{this.confirmHref}}" class="auto-link-card-form">
        <button type="submit" class="btn btn-primary">Confirm, this is me</button>
      </form>
      <form method="post" action="{{this.dismissHref}}" class="auto-link-card-form">
        <button type="submit" class="btn btn-outline">Dismiss</button>
      </form>
      <form method="post" action="{{this.reportIncorrectHref}}" class="auto-link-card-form">
        <input type="hidden" name="claimAuditId" value="{{this.claimAuditId}}" />
        <button type="submit" class="btn btn-outline">Report incorrect</button>
      </form>
    </div>
  </div>
</div>
{{/if}}
