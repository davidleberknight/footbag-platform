{{!--
  Structural decomposition (parser diagnostic).
  Required param:
    collapsed - boolean. true = wrap in <details> closed by default (UX3b0 + UX2 pilot);
                          false = render inline expanded (legacy behavior).
--}}
{{#if content.notationGrammar}}
<section class="content-section notation-grammar-panel" aria-label="Structural decomposition">

  {{#if collapsed}}
  <details class="notation-grammar-collapsible">
    <summary>
      <span class="notation-grammar-summary-title">Structural decomposition</span>
      <span class="notation-grammar-summary-hint">Parser diagnostic. Click to expand.</span>
    </summary>
  {{else}}
  <div class="section-heading">
    <h2>Structural decomposition</h2>
    <p class="section-intro">A token-level reading of this trick's name. Asserted ADD is editorial truth; the computed value below is diagnostic.</p>
  </div>
  {{/if}}

  <dl class="detail-list">
    <dt>Status</dt>
    <dd>
      <strong>{{content.notationGrammar.statusLabel}}</strong>
      <span class="notation-grammar-status-key"> ({{content.notationGrammar.status}})</span>
      <p class="notation-grammar-status-description">{{content.notationGrammar.statusDescription}}</p>
    </dd>

    <dt>Asserted ADD</dt>
    <dd>{{#if content.notationGrammar.assertedAdds}}{{content.notationGrammar.assertedAdds}}{{else}}&mdash;{{/if}}</dd>

    <dt>Computed ADD</dt>
    <dd>
      {{#if content.notationGrammar.computedAdds}}{{content.notationGrammar.computedAdds}}{{else}}&mdash;{{/if}}
      {{#if content.notationGrammar.addsAgree}}
      <span class="notation-grammar-agree">(agrees with asserted)</span>
      {{else}}
      <span class="notation-grammar-disagree">(disagrees with asserted; asserted value is editorial truth)</span>
      {{/if}}
    </dd>

    {{#if content.notationGrammar.formula}}
    <dt>Derivation</dt>
    <dd><code>{{content.notationGrammar.formula}}</code></dd>
    {{/if}}
  </dl>

  {{#if content.notationGrammar.descriptiveRoles.length}}
  <div class="notation-grammar-layer">
    <h3>Descriptive roles</h3>
    <p class="notation-grammar-layer-intro">Per-token classification before any self-canonical-atom collapse. Preserves what the parser saw at each position.</p>
    <ul class="notation-grammar-role-list">
      {{#each content.notationGrammar.descriptiveRoles}}
      <li>
        <strong>{{label}}:</strong>
        {{#each tokens}}{{#unless @first}}, {{/unless}}<code>{{token}}</code>{{#if atomResolved}} <em>(atom)</em>{{/if}}{{/each}}
      </li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  {{#if content.notationGrammar.addContributingRoles.length}}
  <div class="notation-grammar-layer">
    <h3>ADD-contributing roles</h3>
    <p class="notation-grammar-layer-intro">Tokens whose weights feed the ADD math. May differ from the descriptive layer when a self-atom subsumes its components.</p>
    <ul class="notation-grammar-role-list">
      {{#each content.notationGrammar.addContributingRoles}}
      <li>
        <strong>{{label}}:</strong>
        {{#each tokens}}{{#unless @first}}, {{/unless}}<code>{{token}}</code>{{#if atomResolved}} <em>(atom)</em>{{/if}}{{/each}}
      </li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  {{#if content.notationGrammar.editorialDecomposition}}
  <div class="notation-grammar-editorial-decomposition" data-source="editorial">
    <h3>Editorial decomposition</h3>
    <p class="notation-grammar-layer-intro">Curator-asserted lineage from this row's <code>base_trick</code> and modifier links. Independent of the parser-derived structural decomposition above. Asserted ADD remains editorial truth.</p>

    <dl class="detail-list">
      <dt>Base</dt>
      <dd>
        {{#if content.notationGrammar.editorialDecomposition.baseSlug}}<code>{{content.notationGrammar.editorialDecomposition.baseSlug}}</code>{{else}}&mdash;{{/if}}
        {{#if content.notationGrammar.editorialDecomposition.baseAdds}}({{content.notationGrammar.editorialDecomposition.baseAdds}}){{/if}}
        {{#unless (eq content.notationGrammar.editorialDecomposition.baseStatus 'resolved')}}
        <span class="notation-grammar-editorial-flag">broken upstream link (<code>{{content.notationGrammar.editorialDecomposition.baseSlug}}</code> is not in the dictionary)</span>
        {{/unless}}
      </dd>

      {{#if content.notationGrammar.editorialDecomposition.modifiers.length}}
      <dt>Modifiers</dt>
      <dd>
        <ul class="notation-grammar-role-list">
          {{#each content.notationGrammar.editorialDecomposition.modifiers}}
          <li>
            <strong>{{name}}</strong>
            <span class="notation-grammar-editorial-modifier-meta">({{modifierType}}; +{{effectiveBonus}}{{#if rotBonusApplied}} on rotational base{{/if}})</span>
            {{#if notes}}<p class="notation-grammar-editorial-modifier-notes">{{notes}}</p>{{/if}}
          </li>
          {{/each}}
        </ul>
      </dd>
      {{else}}
      <dt>Modifiers</dt>
      <dd><span class="notation-grammar-editorial-flag">modifier coverage absent</span></dd>
      {{/if}}

      {{#if content.notationGrammar.editorialDecomposition.derivationText}}
      <dt>Composed</dt>
      <dd>
        <code>{{content.notationGrammar.editorialDecomposition.derivationText}}</code>
        {{#if (eq content.notationGrammar.editorialDecomposition.matchesAsserted true)}}
        <span class="notation-grammar-agree">(matches asserted)</span>
        {{else if (eq content.notationGrammar.editorialDecomposition.matchesAsserted false)}}
        <span class="notation-grammar-disagree">(differs from asserted; asserted is editorial truth)</span>
        {{/if}}
      </dd>
      {{/if}}
    </dl>
  </div>
  {{/if}}

  {{#if content.notationGrammar.editorialContext}}
  <div class="notation-grammar-editorial">
    <h3>Editorial context</h3>
    <p class="notation-grammar-editorial-text">{{content.notationGrammar.editorialContext}}</p>
  </div>
  {{/if}}

  {{#if content.notationGrammar.policyTokens.length}}
  <div class="notation-grammar-policy">
    <h3>Policy tokens</h3>
    <p class="notation-grammar-layer-intro">Tokens whose ADD weight or ontology placement is contested and pending expert review.</p>
    <ul class="notation-grammar-flat-list">
      {{#each content.notationGrammar.policyTokens}}
      <li><code>{{this}}</code></li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  {{#if content.notationGrammar.hasDiagnosticDetails}}
  <details class="notation-grammar-diagnostics">
    <summary>Diagnostic details</summary>

    {{#if content.notationGrammar.jobsNotationRaw}}
    <dl class="detail-list">
      <dt>Jobs notation</dt>
      <dd><code>{{content.notationGrammar.jobsNotationRaw}}</code></dd>
    </dl>
    {{/if}}

    {{#if content.notationGrammar.parseWarnings.length}}
    <div class="notation-grammar-warnings">
      <h3>Parse warnings</h3>
      <ul class="notation-grammar-flat-list">
        {{#each content.notationGrammar.parseWarnings}}
        <li><code>{{this}}</code></li>
        {{/each}}
      </ul>
    </div>
    {{/if}}
  </details>
  {{/if}}

  {{#if collapsed}}
  </details>
  {{/if}}
</section>
{{/if}}
