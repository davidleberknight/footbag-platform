{{!--
  Passback records table. Renders only when recordCount > 0.
--}}
{{#if content.recordCount}}
<section id="passback-records" class="content-section">
<div class="section-heading"><h2>Consecutive Records</h2></div>
<div class="records-table-wrap">
  <table class="records-table">
    <thead>
      <tr>
        <th class="col-rank">#</th>
        <th>Holder</th>
        <th class="col-num">Count</th>
        <th>ADD (recorded)</th>
        <th>Date</th>
        <th>Video</th>
      </tr>
    </thead>
    <tbody>
      {{#each content.records}}
      <tr>
        <td class="col-rank">{{add @index 1}}</td>
        <td class="col-holder">
          {{#if holderHref}}
            <a href="{{holderHref}}">{{holderName}}</a>
          {{else}}
            {{holderName}}
          {{/if}}
        </td>
        <td class="col-num">{{valueNumeric}}</td>
        <td class="col-adds">{{#if addsCount}}{{addsCount}}{{else}}&mdash;{{/if}}</td>
        <td class="col-date">
          {{#if achievedDate}}
            {{formatDate achievedDate}}{{#if dateApproximate}} <em>(approx.)</em>{{/if}}
          {{else}}
            &mdash;
          {{/if}}
        </td>
        <td>
          {{#if videoUrl}}
            <a href="{{videoUrl}}" class="video-link" target="_blank" rel="noopener noreferrer"
               aria-label="Watch {{holderName}} {{../page.title}} record video">
              &#9654;{{#if videoTimecode}} {{videoTimecode}}{{/if}}
            </a>
          {{else}}
            &mdash;
          {{/if}}
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
<p class="text-muted fs-sm mt-2">ADD (recorded) is the difficulty the recording source assigned when the record was logged. Where it differs from this trick's canonical ADD shown above, the canonical ADD is authoritative.</p>
</section>
{{/if}}
