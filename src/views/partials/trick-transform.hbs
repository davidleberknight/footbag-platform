{{#if content.transform}}
<section class="content-section trick-transform" aria-label="ALT formula (reverse-pair interpretation)">
  <dl class="trick-transform-fields">
    <dt>ALT</dt>
    <dd><code class="trick-transform-expression">{{content.transform.expression}}({{content.transform.baseAdd}}) = {{content.transform.totalAdd}} ADD</code></dd>
