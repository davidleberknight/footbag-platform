{{!--
  Trick hero block. Renders a metadata ribbon (family badge, ADD chip,
  record chip) in a single row directly below the h1. Below the ribbon:
  decomposition strip, formula, and summary in that order. Sparse pages
  without a heroDecomposition fall back to the records-side sortname
  subtitle for identity continuity.
--}}
<div class="hero hero-sm{{#if summary}} trick-hero-ux2{{/if}}">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    <p class="trick-hero-meta-ribbon" aria-label="Trick metadata">
      {{#if content.dictEntry.trickFamily}}
      <a class="trick-hero-meta-chip trick-hero-meta-chip-family" href="/freestyle/tricks?family={{content.dictEntry.trickFamily}}">{{content.dictEntry.trickFamily}} family</a>
      {{/if}}
      {{#if content.dictEntry}}
        {{#if content.dictEntry.isModifier}}
        <span class="trick-hero-meta-chip trick-hero-meta-chip-modifier">Modifier</span>
        {{else}}
          {{#if content.dictEntry.adds}}
          <span class="trick-hero-meta-chip trick-hero-meta-chip-adds">{{content.dictEntry.adds}} ADD</span>
          {{/if}}
        {{/if}}
      {{/if}}
      {{! Record chip removed from hero per FC slice — records still
          surface in the Passback Records table + pathways block lower
          on the page. The hero focuses on identity + ADD, not stats. }}
    </p>
    {{#if content.heroDecomposition}}
    <p class="trick-hero-decomposition" aria-label="Structural decomposition: {{#each content.heroDecomposition}}{{text}}{{#unless @last}} {{/unless}}{{/each}}">
      {{#each content.heroDecomposition}}<span class="hero-decomp-token hero-decomp-{{cssRole}}" data-kind="{{kind}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}
    </p>
    {{/if}}
    {{#unless content.heroDecomposition}}
      {{#if content.sortName}}<p class="hero-subtitle">{{content.sortName}}</p>{{/if}}
    {{/unless}}
    {{#if content.heroFormula}}
    <p class="trick-hero-formula" aria-label="ADD derivation">
      {{#each content.heroFormula}}{{#if (eq kind "operator")}}<span class="hero-formula-op">{{text}}</span>{{else if (eq kind "result")}}<span class="hero-formula-result">{{text}}</span>{{else}}<span class="hero-formula-token hero-formula-{{cssRole}}">{{text}}</span>{{#if weight}}<span class="hero-formula-weight">{{weight}}</span>{{/if}}{{/if}}{{#unless @last}} {{/unless}}{{/each}}
    </p>
    {{/if}}
    {{#if summary}}
    <p class="trick-hero-summary">{{summary}}</p>
    {{/if}}
  </div>
</div>
