{{!--
  Trick hero block. Carries identity only: the h1, then the structural
  decomposition strip, formula, and summary in that order. Sparse pages
  without a heroDecomposition fall back to the records-side sortname
  subtitle for identity continuity. The taxonomy ribbon (hashtag, family,
  ADD) renders in the page body, not the hero.
--}}
<div class="hero hero-sm{{#if summary}} trick-hero-ux2{{/if}}">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
        {{#if href}}<a href="{{href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    {{#if content.heroDecomposition}}
    <p class="trick-hero-decomposition" aria-label="Structural decomposition: {{#each content.heroDecomposition}}{{text}}{{#unless @last}} {{/unless}}{{/each}}">
      {{#each content.heroDecomposition}}<span class="hero-decomp-token hero-decomp-{{cssRole}}" data-kind="{{kind}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}
    </p>
    {{/if}}
    {{#unless content.heroDecomposition}}
      {{#if content.sortName}}<p class="hero-subtitle">{{content.sortName}}</p>{{/if}}
    {{/unless}}
    {{#if content.heroFormula}}
    <p class="trick-hero-formula" aria-label="ADD derivation">
      {{#each content.heroFormula}}{{#if isOperator}}<span class="hero-formula-op">{{text}}</span>{{else if isResult}}<span class="hero-formula-result">{{text}}</span>{{else}}<span class="hero-formula-token hero-formula-{{cssRole}}">{{text}}</span>{{#if weight}}<span class="hero-formula-weight">{{weight}}</span>{{/if}}{{/if}}{{#unless @last}} {{/unless}}{{/each}}
    </p>
    {{/if}}
    {{#if summary}}
    <p class="trick-hero-summary">{{summary}}</p>
    {{/if}}
  </div>
</div>
