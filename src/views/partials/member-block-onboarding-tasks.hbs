{{#if this.hasOutstanding}}
<div class="profile-section onboarding-task-widget">
  <h2 class="profile-section-heading">Onboarding</h2>
  <p class="text-muted fs-sm">Finish these steps to complete your member account. You can pick up where you left off any time.</p>

  {{#if this.pending.length}}
    <ul class="onboarding-task-list">
      {{#each this.pending}}
        <li class="onboarding-task-row">
          <span class="onboarding-task-label">{{taskLabel}}</span>
          <a href="{{ctaHref}}" class="btn btn-primary onboarding-task-cta">{{ctaLabel}}</a>
          {{#if dismissHref}}
            <form method="POST" action="{{dismissHref}}">
              <button type="submit" class="btn-link text-muted">Dismiss</button>
            </form>
          {{/if}}
        </li>
      {{/each}}
    </ul>
  {{/if}}

  {{#if this.paused.length}}
    <ul class="onboarding-task-list">
      {{#each this.paused}}
        <li class="onboarding-task-row onboarding-task-row-paused">
          <span class="onboarding-task-label">{{taskLabel}}</span>
          <a href="{{ctaHref}}" class="btn btn-outline onboarding-task-cta">{{ctaLabel}}</a>
        </li>
      {{/each}}
    </ul>
  {{/if}}

  {{#if this.skipped.length}}
    <p class="text-muted fs-sm mt-4">You skipped these. Reopen any time:</p>
    <ul class="onboarding-task-list onboarding-task-list-skipped">
      {{#each this.skipped}}
        <li class="onboarding-task-row onboarding-task-row-skipped">
          <span class="onboarding-task-label text-muted">{{taskLabel}}</span>
          <a href="{{ctaHref}}" class="btn btn-outline onboarding-task-cta">{{ctaLabel}}</a>
          {{#if dismissHref}}
            <form method="POST" action="{{dismissHref}}">
              <button type="submit" class="btn-link text-muted">Dismiss</button>
            </form>
          {{/if}}
        </li>
      {{/each}}
    </ul>
  {{/if}}
</div>
{{/if}}
