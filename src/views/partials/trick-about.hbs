{{!--
  About-this-trick section. Renders description + ADD composition + aliases + family note.
  Section header is sentence case (convention for all detail-page section headings).
--}}
{{#if content.dictEntry}}
<section class="content-section">
  <div class="section-heading">
    <h2>About this trick</h2>
  </div>

  {{#if content.dictEntry.description}}
    {{!--
      Placeholder-description suppressor. The DB `description` matched a known
      placeholder pattern (X-modified Y / X-and-Y modified Z / "Popular
      freestyle trick."). The literal description is suppressed; the build path
      under "How it's built" carries the composition instead. The DB row is
      preserved unchanged — this is a render-time-only suppression.
    --}}
    {{#unless content.descriptionIsPlaceholder}}
    <p class="trick-description">{{content.dictEntry.description}}</p>
    {{/unless}}
  {{/if}}

  {{#if content.dictEntry.isModifier}}
  <p class="trick-description">
    This is a <strong>modifier</strong> -- it has no fixed ADD value of its own. It adds a fixed
    difficulty bonus when layered onto a base trick.
  </p>
  {{/if}}

  <dl>

    {{!-- One "How it's built" row: the derived base-chain build path in
         build-path language (which already names the parent), else a bare
         base-trick link. The build path supersedes the separate Base trick row
         so the lineage is stated once. ADD arithmetic stays in ADD analysis. --}}
    {{#if content.buildPath}}
    <dt>How it's built</dt>
    <dd data-build-path>{{content.buildPath}}</dd>
    {{else if content.dictEntry.baseTrick}}
      {{#unless content.modifierLayering}}
      <dt>Base trick</dt>
      <dd>
        {{#if content.dictEntry.baseTrickSlug}}
          <a href="/freestyle/tricks/{{content.dictEntry.baseTrickSlug}}">{{content.dictEntry.baseTrick}}</a>
        {{else}}
          {{content.dictEntry.baseTrick}}
        {{/if}}
        {{#if content.dictEntry.baseTrickAdds}} ({{content.dictEntry.baseTrickAdds}} ADD){{/if}}
      </dd>
      {{/unless}}
    {{/if}}

    {{#if content.dictEntry.aliases.length}}
    <dt>Also known as</dt>
    <dd>{{#each content.dictEntry.aliases}}{{#unless @first}}, {{/unless}}{{this}}{{/each}}</dd>
    {{/if}}

  </dl>

  {{!-- Curator derivatives note: a concise line pointing at major higher-ADD
       derivatives, placed right after the build chain. --}}
  {{#if content.aboutDerivatives}}
  <p class="text-muted" data-about-derivatives>{{content.aboutDerivatives}}</p>
  {{/if}}

  {{!-- Parent-delta line for tricks with no physical intuition prose: it would
       stand alone under a Movement intuition heading otherwise, so it lives here
       beside the build path. Tricks with prose render the delta in Movement
       intuition instead. --}}
  {{#if content.intuitionDelta}}{{#unless content.intuition}}
  <p class="text-muted" data-intuition-delta>{{content.intuitionDelta}}</p>
  {{/unless}}{{/if}}

  {{#if content.dictEntry.familyNote}}
  <div>
    <p>{{content.dictEntry.familyNote}}</p>
  </div>
  {{/if}}

  {{!-- Base-atom -> operator cross-link: e.g. the spin atom points at Spinning
       tricks, so the relationship is explicit rather than inferred. --}}
  {{#if content.relatedOperator}}
  <p class="text-muted">See also: <a href="{{content.relatedOperator.href}}">{{content.relatedOperator.label}}</a></p>
  {{/if}}

</section>
{{/if}}
