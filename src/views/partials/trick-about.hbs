{{!--
  About-this-trick section. Renders description + ADD composition + aliases + family note.
  Section header is sentence case (convention for all detail-page section headings).
--}}
{{#if content.dictEntry}}
<section class="content-section">
  <div class="section-heading">
    <h2>About this trick</h2>
  </div>

  {{#if content.dictEntry.description}}
    {{#if content.descriptionIsPlaceholder}}
    {{!--
      Placeholder-description suppressor. The DB
      `description` matched a known placeholder pattern (X-modified Y /
      X-and-Y modified Z / "Popular freestyle trick."). The literal
      description is suppressed; the structured ADD-decomposition pill
      below renders instead. The DB row is preserved unchanged — this
      is a render-time-only suppression.
    --}}
    {{#if content.dictEntry.addComposition}}
    <p class="trick-description trick-description--decomposition-pill">{{content.dictEntry.addComposition}}</p>
    {{/if}}
    {{else}}
    <p class="trick-description">{{content.dictEntry.description}}</p>
    {{/if}}
  {{/if}}

  {{#if content.dictEntry.isModifier}}
  <p class="trick-description">
    This is a <strong>modifier</strong> -- it has no fixed ADD value of its own. It adds difficulty
    when layered onto a base trick, and the bonus depends on whether the base is rotational
    (whirl, mirage, torque, blender) or non-rotational.
  </p>
  {{/if}}

  <dl>

    {{#if content.dictEntry.addComposition}}
    <dt>How it's built</dt>
    <dd>{{content.dictEntry.addComposition}}</dd>
    {{else if content.dictEntry.baseTrick}}
      {{#unless content.modifierLayering}}
      <dt>Base trick</dt>
      <dd>
        {{#if content.dictEntry.baseTrickSlug}}
          <a href="/freestyle/tricks/{{content.dictEntry.baseTrickSlug}}">{{content.dictEntry.baseTrick}}</a>
        {{else}}
          {{content.dictEntry.baseTrick}}
        {{/if}}
        {{#if content.dictEntry.baseTrickAdds}} ({{content.dictEntry.baseTrickAdds}} ADD){{/if}}
      </dd>
      {{/unless}}
    {{/if}}

    {{!-- Build path, relocated from the retired Progressive Readings section. --}}
    {{#if content.buildPath}}
    <dt>Built from</dt>
    <dd data-build-path>{{content.buildPath}}</dd>
    {{/if}}

    {{#if content.dictEntry.aliases.length}}
    <dt>Also known as</dt>
    <dd>{{#each content.dictEntry.aliases}}{{#unless @first}}, {{/unless}}{{this}}{{/each}}</dd>
    {{/if}}

  </dl>

  {{#if content.dictEntry.familyNote}}
  <div>
    <p>{{content.dictEntry.familyNote}}</p>
  </div>
  {{/if}}

</section>
{{/if}}
