{{!--
  Notation summary card for first-class trick pages. Replaces the prior
  loud gold metadata strip with a compact neutral reference card.

  Visible rows (per first-class display contract):
    - Compact          — content.comparativeNotation.compactNotation
    - Operational      — content.comparativeNotation.jobLineage (label
                         "Operational" for atomic source, "Job" for
                         curator source). Hidden when tautological or
                         absent.
    - ADD breakdown    — content.comparativeNotation.addBreakdown
    - Official         — content.comparativeNotation.officialAdd + " ADD"
    - Video            — content.comparativeNotation.videoLabel

  Explicit absences:
    - NO "First-class" public badge (the heading is the only signal)
    - NO #slug title (redundant with hero h1)
    - NO Job tautology (suppressed at the service layer)
    - NO provenance / curator-internal language

  Layer contract: this strip carries Tier-2 (operational/Job lineage) +
  Tier-4 (ADD breakdown) patterns. Both are permitted on trick-detail
  per the 4-tier rendering hierarchy contract.
--}}
{{#if content.isFirstClass}}
{{#if content.comparativeNotation}}
<section class="trick-notation-summary" aria-label="Notation summary">
  <h2 class="trick-notation-summary-heading">Notation summary</h2>
  <dl class="trick-notation-summary-fields">
    <dt>Compact</dt>
    <dd class="trick-notation-summary-compact">{{content.comparativeNotation.compactNotation}}</dd>

    {{#if content.comparativeNotation.jobLineage}}
    <dt>{{#if (eq content.comparativeNotation.jobLineageSource 'atomic')}}Operational{{else}}Job{{/if}}</dt>
    <dd><code class="trick-notation-summary-chain">{{content.comparativeNotation.jobLineage}}</code></dd>
    {{/if}}

    <dt>ADD breakdown</dt>
    <dd><code class="trick-notation-summary-derivation">{{content.comparativeNotation.addBreakdown}}</code></dd>

    <dt>Official</dt>
    <dd class="trick-notation-summary-official">{{content.comparativeNotation.officialAdd}} ADD</dd>

    <dt>Video</dt>
    <dd class="trick-notation-summary-video trick-notation-summary-video--{{content.comparativeNotation.videoState}}">{{content.comparativeNotation.videoLabel}}</dd>
  </dl>
</section>
{{/if}}
{{/if}}
