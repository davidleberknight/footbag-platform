{{!--
  Notation summary card for first-class trick pages.

  Renders the compact JOB / ADD / ALT formula cluster as a labeled
  <dl> block.

  Rows (per the formula display contract):
    - JOB           — content.comparativeNotation.jobLineage
                      (curator-authored operational notation or atomic
                      flag-decomposition chain). Hidden when absent.
    - EXPANDED      — content.comparativeNotation.expandedNotation
                      (full spelled-out chain when JOB uses a named-set
                      shorthand, e.g. '(railing set)'). Hidden when absent
                      or identical to JOB.
    - ADD           — content.comparativeNotation.addBreakdown
                      (curator-published derivation, or atomic flag-
                      decomposition string). Always rendered when the
                      summary card renders at all.
    - ALT           — content.comparativeNotation.altFormula
                      (alternate interpretive formula, currently the 5
                      curator-locked rev(0) entries). Hidden when null.

  The compound-description slot is NOT a separate dl row — for atomic
  and simple tricks the JOB row carries the operational form on its
  own and no human-readable compound description renders. Only when
  the JOB row is genuinely empty does the slot collapse.

  No "Compact", "Official", or "Video" rows here — they were Tier-other
  metadata that diluted the formula focus; identity sits in the hero
  ribbon (hashtag chip, ADD chip, family chip) and media indicators
  sit in the media block.
--}}
{{#if content.isFirstClass}}
{{#if content.comparativeNotation}}
<section class="trick-notation-summary" aria-label="Notation summary">
  <h2 class="trick-notation-summary-heading">Notation summary</h2>
  <dl class="trick-notation-summary-fields">
    {{#if content.comparativeNotation.jobLineage}}
    <dt>JOB</dt>
    <dd><code class="trick-notation-summary-chain">{{content.comparativeNotation.jobLineage}}</code></dd>
    {{/if}}

    {{#if content.comparativeNotation.expandedNotation}}
    <dt>EXPANDED</dt>
    <dd><code class="trick-notation-summary-chain">{{content.comparativeNotation.expandedNotation}}</code></dd>
    {{/if}}

    <dt>ADD</dt>
    <dd><code class="trick-notation-summary-derivation">{{content.comparativeNotation.addBreakdown}}</code></dd>

    {{#if content.comparativeNotation.altFormula}}
    <dt>ALT</dt>
    <dd><code class="trick-notation-summary-alt">{{content.comparativeNotation.altFormula}}</code></dd>
    {{/if}}
  </dl>
</section>
{{/if}}
{{/if}}
