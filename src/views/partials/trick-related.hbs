{{!--
  Related tricks, split into labeled relationship groups (Same family / Shares a
  modifier / Movement neighbours or Swing elements / Built on / Structural
  ancestor). Partitioned in the service by each row's relating rule; the group
  label replaces the former per-row reason.
--}}
{{#if content.relatedGroups.length}}
<section class="content-section">
  <div class="section-heading">
    <h2>Related Tricks</h2>
  </div>
  {{#each content.relatedGroups}}
  <div class="related-group">
    <h3 class="related-group-label">{{label}}</h3>
    {{#if rationale}}<p class="relationship-why">{{rationale}}</p>{{/if}}
    <ul class="related-tricks-list">
      {{#each tricks}}
      <li>
        <a href="{{detailHref}}">{{canonicalName}}</a>
        <span class="trick-hashtag">{{hashtag}}</span>
      </li>
      {{/each}}
    </ul>
  </div>
  {{/each}}
</section>
{{/if}}
