{{!--
  Compact secondary row rendered beneath the primary dictionary-trick-
  card content when card.isFirstClass=true. Carries the OPERATIONAL/JOB
  chain (when meaningful — not tautological) plus the ADD breakdown.

  Render rules:
   - Chain row renders when firstClassChainLabel is set (JOB / OPERATIONAL)
   - When firstClassChainLabel is null AND firstClassChainIncomplete is
     true, render a muted honest incomplete-state line ("Job notation
     pending") so the absence is visible rather than silent. Keeps
     first-class cards visually balanced when upstream op-notation is
     genuinely missing.
   - ADD row hidden when firstClassAddBreakdown is null
   - Smaller typography than the primary card body
   - No provenance / curator-internal language
   - No "First-class" loud label
--}}
<div class="dict-card-first-class-row" aria-label="Notation summary">
  {{#if firstClassChainLabel}}
  <p class="dict-card-first-class-line">
    <span class="dict-card-first-class-label">{{firstClassChainLabel}}:</span>
    <code class="dict-card-first-class-value">{{firstClassChainValue}}</code>
  </p>
  {{else}}{{#if firstClassChainIncomplete}}
  <p class="dict-card-first-class-line dict-card-first-class-line--incomplete">
    <span class="dict-card-first-class-label">JOB:</span>
    <span class="dict-card-first-class-incomplete">canonical decomposition pending</span>
  </p>
  {{/if}}{{/if}}
  {{#if firstClassAddBreakdown}}
  <p class="dict-card-first-class-line">
    <span class="dict-card-first-class-label">ADD:</span>
    <code class="dict-card-first-class-value">{{firstClassAddBreakdown}}</code>
  </p>
  {{/if}}
</div>
