<section>
  <div class="section-heading">
    <h2>Membership</h2>
  </div>
  <div>
    <div class="membership-badges">
      <span class="badge badge-tier">{{tierBadgeText}}</span>
      {{#if activePlayer}}
        {{#if activePlayer.isCurrent}}
          <span class="badge badge-honor">
            Active Player
            {{#if activePlayer.expiresAtDisplay}}
              (through {{activePlayer.expiresAtDisplay}})
            {{/if}}
          </span>
        {{else if activePlayer.hasLapsed}}
          <span class="badge badge-coming-soon">Active Player expired</span>
        {{/if}}
      {{/if}}
    </div>
    {{#if activePlayer.hasLapsed}}
      <p class="text-muted">{{activePlayer.lapsedExplanation}}</p>
    {{/if}}
    {{#if underlyingTierBadgeText}}
      <p class="text-muted">{{underlyingTierBadgeText}}</p>
    {{/if}}
    <p>{{benefitsBlurb}}</p>
    <p class="membership-tiers-link"><a href="/ifpa">View IFPA membership rules</a></p>
    {{#if showUpgradeForm}}
      {{#if showTier1Upgrade}}
        <form method="POST" action="{{purchaseTierHref}}" class="membership-upgrade-form">
          <input type="hidden" name="tier" value="tier1" />
          <button type="submit" class="btn btn-primary">Upgrade to Tier 1</button>
        </form>
      {{/if}}
      {{#if showTier2Upgrade}}
        <form method="POST" action="{{purchaseTierHref}}" class="membership-upgrade-form">
          <input type="hidden" name="tier" value="tier2" />
          <button type="submit" class="btn btn-primary">Upgrade to Tier 2</button>
        </form>
      {{/if}}
    {{/if}}
  </div>
</section>
