{{!--
  Family lineage, grouped by ADD tier. Renders only when
  hasFamilyMembers is true. Numeric tiers ascend; non-numeric rows collapse
  into a "Modifiers" tier rendered last. Current trick row highlighted within
  its tier; tier rows linked to their respective detail pages.
--}}
{{#if content.hasFamilyMembers}}
<section class="content-section trick-family-lineage">
  <div class="section-heading">
    <h2>{{page.title}} Family</h2>
    <p class="section-intro">Tricks in this family, grouped by ADD value.</p>
  </div>
  {{! Family-anchor callout (Dictionary Pedagogy Phase 3). Renders only
      when this trick IS the family-anchor for a curator-confirmed
      terminal family. Teaches the dual role: the trick on this page
      is itself the productive root of the family below. }}
  {{#if content.familyAnchorContext}}
  <div class="trick-family-anchor-callout">
    <p>
      <strong>{{page.title}}</strong> is the
      <strong>family-anchor trick</strong> for the
      <a class="glossary-outward-link" href="{{content.familyAnchorContext.familyBrowseHref}}">{{content.familyAnchorContext.familyName}} family &rarr;</a>
    </p>
    <p class="trick-family-anchor-invariant">
      Conserved terminal mechanic: <code>{{content.familyAnchorContext.invariant}}</code>
    </p>
  </div>
  {{/if}}
  <div class="family-lineage">
    {{#each content.familyTiers}}
    <div class="family-lineage-tier{{#if hasCurrent}} family-lineage-tier-current{{/if}}">
      <div class="family-lineage-tier-label">{{addsLabel}}</div>
      <div class="family-lineage-tier-members">
        {{#each members}}
        <span class="family-lineage-member{{#if isCurrentTrick}} family-lineage-member-current{{/if}}">
          {{#if isCurrentTrick}}
            <strong>{{canonicalName}}</strong>
            <span class="family-lineage-here">&larr; here</span>
          {{else}}
            <a href="{{detailHref}}">{{canonicalName}}</a>
          {{/if}}
          {{#if hasRecords}}<span class="record-indicator" title="Has trick records">&#9733;</span>{{/if}}
        </span>
        {{/each}}
      </div>
    </div>
    {{/each}}
  </div>
</section>
{{/if}}
