{{!--
  Observed-trick card body. Extracted into a partial 2026-05-24 so the
  governance-lane sections on /freestyle/observational can each render
  their cards without duplicating the per-card markup. The card shape
  is unchanged from the prior inline form.

  Per the layer-separation contract:
    - tracked-tag (NOT canonical hashtag) — visually distinct dashed border
    - source badge with tooltip attribution
    - status chip surfacing curator-review state
    - external-claim label always source-attributed (never canonical ADD)
    - NO link to /freestyle/tricks/{folkSlug} (observational entries have no
      canonical detail page)
--}}
<article class="observed-card" data-folk-slug="{{folkSlug}}" data-governance-lane="{{governanceLane}}">
  <header class="observed-card-head">
    <span class="observed-card-source-badge observed-card-source-badge--{{sourceBadge}}" title="{{sourceTooltip}}" aria-label="Source: {{sourceTooltip}}">{{sourceBadge}}</span>
    <h3 class="observed-card-name">{{displayName}}</h3>
    <span class="observed-card-status-chip observed-card-status-chip--{{statusChip.tone}}">{{statusChip.label}}</span>
  </header>
  <p class="observed-card-meta">
    <span class="tracked-tag" aria-label="Documented name, not yet reviewed">#{{folkSlug}}</span>
    {{#if shortReading}}<span class="observed-card-reading"><span class="observed-card-equiv-sigil" aria-hidden="true">&equiv;</span> {{shortReading}}</span>{{/if}}
    {{#if externalClaimLabel}}<span class="observed-card-external-claim">{{externalClaimLabel}}</span>{{/if}}
  </p>
  {{#if hasDetails}}
  <details class="observed-card-details">
    <summary class="observed-card-details-summary">More</summary>
    {{#if detailExpansion.additionalReadings.length}}
    <ul class="observed-card-detail-readings">
      {{#each detailExpansion.additionalReadings}}
      <li><span class="observed-card-equiv-sigil" aria-hidden="true">&equiv;</span> {{this}}</li>
      {{/each}}
    </ul>
    {{/if}}
    {{#if detailExpansion.formula}}
    <p class="observed-card-detail-formula"><code>{{detailExpansion.formula}}</code></p>
    {{/if}}
    {{#if detailExpansion.curatorNote}}
    <p class="observed-card-detail-note"><em>Curator note:</em> {{detailExpansion.curatorNote}}</p>
    {{/if}}
    {{#if detailExpansion.blockers.length}}
    <p class="observed-card-detail-blockers">
      <em>Blockers:</em>
      {{#each detailExpansion.blockers}}{{#unless @first}}; {{/unless}}{{this}}{{/each}}
    </p>
    {{/if}}
    <p class="observed-card-detail-source">Source: {{detailExpansion.sourceCitation}}</p>
  </details>
  {{/if}}
</article>
