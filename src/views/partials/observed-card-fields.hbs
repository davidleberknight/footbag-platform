{{!--
  Observational confidence card (v2). Renders an ObservationalCard.

  Layer-separation contract: visually distinct from canonical cards — a tracked
  tag (bare slug, NOT a canonical hashtag), no canonical ADD chip, no
  trick-detail link, no media. Provisional ADD + decomposition are
  observationally extrapolated and labelled as such; parser-confidence and
  doctrine-confidence are SEPARATE chips and never imply canonical status.
--}}
<article class="observed-card" data-ecosystem="{{ecosystem}}">
  <header class="observed-card-head">
    <span class="observed-card-source-badge observed-card-source-badge--{{sourceBadge}}" title="{{sourceLabel}}" aria-label="Source: {{sourceLabel}}">{{sourceBadge}}</span>
    <h3 class="observed-card-name">{{name}}</h3>
    <span class="tracked-tag" title="Observational: not a canonical trick">{{slug}}</span>
  </header>
  <p class="observed-card-meta">
    {{#if addLabel}}<span class="observed-add">{{addLabel}}</span>{{/if}}
    {{#if parserConfidence}}<span class="observed-conf observed-conf--{{parserConfidence}}" title="Parser confidence">parser: {{parserConfidence}}</span>{{/if}}
    {{#if doctrineConfidence}}<span class="observed-conf observed-conf--{{doctrineConfidence}}" title="Doctrine confidence">doctrine: {{doctrineConfidence}}</span>{{/if}}
  </p>
  {{#if hasDetails}}
  <details class="observed-card-details">
    <summary class="observed-card-details-summary">Reading</summary>
    {{#if decomposition}}<p class="observed-card-detail-formula"><span class="observed-card-equiv-sigil" aria-hidden="true">&equiv;</span> <code>{{decomposition}}</code> <span class="text-muted">(extrapolated, not canonical)</span></p>{{/if}}
    {{#if curatorNote}}<p class="observed-card-detail-note"><em>Curator note:</em> {{curatorNote}}</p>{{/if}}
  </details>
  {{/if}}
</article>
