{{!--
  dictionary-trick-card.hbs — the canonical symbolic trick card.

  One renderer; progressive density (sparse plus deep through the same
  template). In browse density, operational notation is the visual center
  of gravity; in registry density, the notation-first hierarchy takes over.

  Two density modes controlled by the partial parameter:
      {{> dictionary-trick-card density="registry"}}  — inline single-line
      {{> dictionary-trick-card density="browse"}}    — vertical stack (default)

  Notation rendering follows a 2-tier suppression hierarchy in both
  densities:
    Tier 1: tokenizedEquivalences (chain registry + alias governance) —
            renders `≡ <reading>` lines with role-classified tokens.
    Tier 2: operationalNotation (parser-derived) — muted styling
            fallback when no chain reading exists.
  When neither is present, the notation row is silent; the card shows
  title + ADD chip only. The pendingDecomposition pill (rendered
  separately below the notation row) explicitly flags rows whose
  decomposition is curator-paced.

  Consumes: DictionaryTrickCard view-model from freestyleService.
  Used by: tricks.hbs across the five browse views.
--}}

{{#if (eq density "registry")}}
  {{! ── Registry density: single-line scan-oriented row ──────────────────
      Structure: slug · structural sentence · ADD · (optional media chip).
      Same wrapper class (.core-trick-equivalence dict-card-equivalence) as
      browse density — CSS handles inline-vs-block layout. ≡ sigil markup
      is present but visually suppressed via CSS in this density. }}
  <article class="dict-card dict-card--registry{{#if isExternalOnly}} dict-card--external-placeholder{{/if}}"
           data-trick-slug="{{slug}}"
           data-media-coverage="{{mediaCoverage}}">
    {{#if isExternalOnly}}
      <span class="dict-card-title">{{displayName}}</span>
    {{else}}
      <a class="dict-card-title" href="{{href}}">{{displayName}}</a>
    {{/if}}
    <span class="dict-card-hashtag" aria-label="Tag identity">#{{slug}}</span>

    {{#if tokenizedEquivalences.length}}
      <span class="core-trick-equivalence dict-card-equivalence dict-card-equivalence--inline">
        <span class="core-trick-equiv-sigil">&equiv;</span>
        {{#each tokenizedEquivalences.[0]}}{{#if glossaryAnchor}}<a class="sem-token sem-token--{{cssRole}} sem-token--linked" href="{{glossaryAnchor}}"{{#if isFamilyAnchor}} data-anchor="true"{{/if}} data-token-slug="{{slug}}">{{text}}</a>{{else}}<span class="sem-token sem-token--{{cssRole}}"{{#if isFamilyAnchor}} data-anchor="true"{{/if}} data-token-slug="{{slug}}">{{text}}</span>{{/if}}{{#unless @last}} {{/unless}}{{/each}}
      </span>
    {{else if operationalNotation}}
      <code class="dict-card-notation dict-card-notation--inline" aria-label="Operational notation">{{#each operationalNotation.tokens}}<span class="op-token op-token--{{cssRole}}" data-role="{{role}}" title="{{label}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}</code>
    {{/if}}

    <span class="dict-card-add{{#unless adds}} dict-card-add--unrated{{/unless}}" aria-label="{{addsLabel}}">{{addsLabel}}</span>

    {{#if pendingDecomposition}}
    <span class="dict-card-pending-pill" aria-label="Pending decomposition refinement"><em>pending decomposition refinement</em></span>
    {{/if}}

    {{#if hasReferenceMedia}}
    <span class="dict-card-media-chip dict-card-media-chip--{{mediaCoverage}}" aria-label="Media coverage">{{mediaCoverageLabel}}</span>
    {{/if}}

    {{#if statusBadge}}
    <span class="dict-card-status-badge">{{statusBadge}}</span>
    {{/if}}
    {{#if placeholderNote}}
    <p class="dict-card-placeholder-note">{{placeholderNote}}</p>
    {{/if}}
    {{#if isFirstClass}}
    {{> dictionary-trick-card-first-class-row}}
    {{/if}}
  </article>
{{else}}
  {{! ── Browse density (default): vertical stack matching ADD-View field order
      Canonical field order (BOTH densities — see PRESENTATION_OBJECT_HIERARCHY.md):
      1. title  →  2. formula  →  3. ADD chip  →  4. media chip  →  5. status badge  →  6. placeholder note
      Browse density stacks the same fields vertically; registry density flows them inline. }}
  <article class="dict-card dict-card--browse{{#if isExternalOnly}} dict-card--external-placeholder{{/if}}"
           data-trick-slug="{{slug}}"
           data-media-coverage="{{mediaCoverage}}">
    {{#if isExternalOnly}}
      <span class="dict-card-title">{{displayName}}</span>
    {{else}}
      <a class="dict-card-title" href="{{href}}">{{displayName}}</a>
    {{/if}}
    <span class="dict-card-hashtag" aria-label="Tag identity">#{{slug}}</span>

    {{#if tokenizedEquivalences.length}}
      {{#each tokenizedEquivalences}}
      <p class="core-trick-equivalence dict-card-equivalence">
        <span class="core-trick-equiv-sigil">&equiv;</span>
        {{#each this}}{{#if glossaryAnchor}}<a class="sem-token sem-token--{{cssRole}} sem-token--linked" href="{{glossaryAnchor}}"{{#if isFamilyAnchor}} data-anchor="true"{{/if}} data-token-slug="{{slug}}">{{text}}</a>{{else}}<span class="sem-token sem-token--{{cssRole}}"{{#if isFamilyAnchor}} data-anchor="true"{{/if}} data-token-slug="{{slug}}">{{text}}</span>{{/if}}{{#unless @last}} {{/unless}}{{/each}}
      </p>
      {{/each}}
    {{else if operationalNotation}}
      <code class="dict-card-notation" aria-label="Operational notation">{{#each operationalNotation.tokens}}<span class="op-token op-token--{{cssRole}}" data-role="{{role}}" title="{{label}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}</code>
    {{/if}}

    <span class="dict-card-add{{#unless adds}} dict-card-add--unrated{{/unless}}" aria-label="{{addsLabel}}">{{addsLabel}}</span>

    {{#if pendingDecomposition}}
    <span class="dict-card-pending-pill" aria-label="Pending decomposition refinement"><em>pending decomposition refinement</em></span>
    {{/if}}

    {{#if hasReferenceMedia}}
    <span class="dict-card-media-chip dict-card-media-chip--{{mediaCoverage}}" aria-label="Media coverage">{{mediaCoverageLabel}}</span>
    {{/if}}

    {{#if statusBadge}}
    <span class="dict-card-status-badge">{{statusBadge}}</span>
    {{/if}}
    {{#if placeholderNote}}
    <p class="dict-card-placeholder-note">{{placeholderNote}}</p>
    {{/if}}
    {{#if isFirstClass}}
    {{> dictionary-trick-card-first-class-row}}
    {{/if}}
  </article>
{{/if}}
