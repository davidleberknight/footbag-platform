{{!--
  dictionary-trick-card.hbs — the canonical symbolic trick card.

  Per DICTIONARY-SYMBOLIC-CARD-1 / SYMBOLIC_CARD_SPEC.md:
    - One renderer; progressive density (sparse + deep through same template)
    - Operational notation = visual center of gravity
    - Title + ADD + Operational notation + Aliases (when populated)
    - No prose descriptions; no spreadsheet feel

  Consumes a DictionaryTrickCard view-model from freestyleService.

  Used by: the By ADD view (slice 1). Future slices: By Family, By Category,
  By Component. The card shape is identical across views; only grouping wrappers differ.
--}}

<article class="dict-card{{#if isExternalOnly}} dict-card--external-placeholder{{/if}}"
         data-trick-slug="{{slug}}"
         data-media-coverage="{{mediaCoverage}}">
  <header class="dict-card-header">
    {{#if isExternalOnly}}
      <span class="dict-card-title">{{displayName}}</span>
    {{else}}
      <a class="dict-card-title" href="{{href}}">{{displayName}}</a>
    {{/if}}
    <span class="dict-card-add{{#unless adds}} dict-card-add--unrated{{/unless}}" aria-label="{{addsLabel}}">{{addsLabel}}</span>
  </header>

  {{#if operationalNotation}}
    <code class="dict-card-notation" aria-label="Operational notation">{{#each operationalNotation.tokens}}<span class="op-token op-token--{{cssRole}}" data-role="{{role}}" title="{{label}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}</code>
  {{else}}
    <p class="dict-card-notation dict-card-notation--pending" aria-label="Operational notation pending"><em>Notation pending</em></p>
  {{/if}}

  {{#if commonAliases.length}}
  <p class="dict-card-aliases"><span class="dict-card-aliases-label">aliases:</span> {{#each commonAliases}}{{#unless @first}}, {{/unless}}{{this}}{{/each}}</p>
  {{/if}}

  {{#if hasReferenceMedia}}
  <p class="dict-card-media-chip dict-card-media-chip--{{mediaCoverage}}" aria-label="Media coverage">
    {{#if (eq mediaCoverage "tutorial")}}Tutorial available{{else}}Demo only{{/if}}
  </p>
  {{/if}}

  {{#if statusBadge}}
  <p class="dict-card-status-badge">{{statusBadge}}</p>
  {{/if}}
  {{#if placeholderNote}}
  <p class="dict-card-placeholder-note">{{placeholderNote}}</p>
  {{/if}}
</article>
