{{!--
  dictionary-trick-card.hbs — the canonical symbolic trick card.

  CANONICAL CARD RENDERING CONTRACT (2026-05-27 normalization pass).
  Every card — first-class or not, in every browse view — renders the
  SAME slot order; empty slots are hidden. No slot is mutually
  exclusive with another. This replaced the prior 2-tier
  EITHER/OR (≡ reading XOR operational notation) which produced three
  incompatible visual modes (proper cards / raw op dumps / folk-name
  subtitle cards).

  Slot order (top → bottom, both densities):
    1. canonical title (linked anchor; plain span when external-only)
    2. hashtag (#slug identity)
    3. interpretation subtitle — `≡ <reading>` from tokenizedEquivalences
       (chain registry + alias governance). OPTIONAL. The human-readable
       decomposition / folk-name equivalence. Does NOT suppress the JOB
       block.
    4. JOB block — operational notation, ALWAYS rendered inside the
       labeled `.dict-card-notation-block` (leading "JOB" pill). This is
       the ONLY place raw operational notation may appear; it never
       floats as loose body text. Suppressed (null) for first-class
       cards, whose JOB/ADD render in the first-class-row partial below.
    5. ADD chip — labeled `N ADD` (`? ADD` when unrated).
    6. pending-decomposition pill / media chip / status badge (metadata).
    7. first-class-row (isFirstClass only) — the labeled `JOB:` / `ADD:`
       breakdown rows; honest "JOB: canonical decomposition pending" when upstream
       op-notation is genuinely absent.
    8. coreAtomLabel — neutral "core atom — <desc>" fallback line for
       the 12 core atoms when no chain reading / op-notation applies, so
       foundational atoms don't render emptier than their compounds.

  HARD RULE: operational notation appears ONLY inside the JOB block
  (`.dict-card-notation-block` / first-class-row). Never as loose text.

  Two density modes controlled by the partial parameter:
      {{> dictionary-trick-card density="registry"}}  — inline single-line
      {{> dictionary-trick-card density="browse"}}    — vertical stack (default)

  Consumes: DictionaryTrickCard view-model from freestyleService.
  Used by: tricks.hbs across the browse views.
--}}

{{#if (eq density "registry")}}
  {{! ── Registry density: single-line scan-oriented row ──────────────────
      Structure: slug · structural sentence · ADD · (optional media chip).
      Same wrapper class (.core-trick-equivalence dict-card-equivalence) as
      browse density — CSS handles inline-vs-block layout. ≡ sigil markup
      is present but visually suppressed via CSS in this density. }}
  <article class="dict-card dict-card--registry{{#if isExternalOnly}} dict-card--external-placeholder{{/if}}"
           data-trick-slug="{{slug}}"
           data-media-coverage="{{mediaCoverage}}">
    {{#if isExternalOnly}}
      <span class="dict-card-title">{{displayName}}</span>
    {{else}}
      <a class="dict-card-title" href="{{href}}">{{displayName}}</a>
    {{/if}}
    <span class="dict-card-hashtag" aria-label="Tag identity">{{hashtag}}</span>

    {{! Slot 3 — interpretation subtitle (optional). Does NOT suppress the JOB block. }}
    {{#if tokenizedEquivalences.length}}
      <span class="core-trick-equivalence dict-card-equivalence dict-card-equivalence--inline">
        <span class="core-trick-equiv-sigil">&equiv;</span>
        {{#each tokenizedEquivalences.[0]}}{{#if glossaryAnchor}}<a class="sem-token sem-token--{{cssRole}} sem-token--linked" href="{{glossaryAnchor}}"{{#if isFamilyAnchor}} data-anchor="true"{{/if}} data-token-slug="{{slug}}">{{text}}</a>{{else}}<span class="sem-token sem-token--{{cssRole}}"{{#if isFamilyAnchor}} data-anchor="true"{{/if}} data-token-slug="{{slug}}">{{text}}</span>{{/if}}{{#unless @last}} {{/unless}}{{/each}}
      </span>
    {{/if}}
    {{! Slot 5 — JOB block (operational notation). Independent of slot 3. }}
    {{#if operationalNotation}}
      <span class="dict-card-notation-block" aria-label="Set notation"><span class="dict-card-notation-label">JOB</span><code class="dict-card-notation dict-card-notation--inline">{{#each operationalNotation.tokens}}<span class="op-token op-token--{{cssRole}}" data-role="{{role}}" title="{{label}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}</code></span>
    {{/if}}

    <span class="dict-card-add{{#unless adds}} dict-card-add--unrated{{/unless}}" aria-label="{{addsLabel}}">{{addsLabel}}</span>

    {{#if pendingDecomposition}}
    <span class="dict-card-pending-pill" aria-label="Decomposition under review"><em>decomposition under review</em></span>
    {{/if}}

    {{#if hasReferenceMedia}}
    <span class="dict-card-media-chip dict-card-media-chip--{{mediaCoverage}}" aria-label="Media coverage">{{mediaCoverageLabel}}</span>
    {{/if}}

    {{#if statusBadge}}
    <span class="dict-card-status-badge">{{statusBadge}}</span>
    {{/if}}
    {{#if placeholderNote}}
    <p class="dict-card-placeholder-note">{{placeholderNote}}</p>
    {{/if}}
    {{#if isFirstClass}}
    {{> dictionary-trick-card-first-class-row}}
    {{/if}}
  </article>
{{else}}
  {{! ── Browse density (default): vertical stack matching ADD-View field order
      Canonical field order (BOTH densities):
      1. title  →  2. formula  →  3. ADD chip  →  4. media chip  →  5. status badge  →  6. placeholder note
      Browse density stacks the same fields vertically; registry density flows them inline. }}
  <article class="dict-card dict-card--browse{{#if isExternalOnly}} dict-card--external-placeholder{{/if}}"
           data-trick-slug="{{slug}}"
           data-media-coverage="{{mediaCoverage}}">
    {{#if isExternalOnly}}
      <span class="dict-card-title">{{displayName}}</span>
    {{else}}
      <a class="dict-card-title" href="{{href}}">{{displayName}}</a>
    {{/if}}
    <span class="dict-card-hashtag" aria-label="Tag identity">{{hashtag}}</span>

    {{! Slot 3 — interpretation subtitle(s) (optional). Does NOT suppress the JOB block. }}
    {{#if tokenizedEquivalences.length}}
      {{#each tokenizedEquivalences}}
      <p class="core-trick-equivalence dict-card-equivalence">
        <span class="core-trick-equiv-sigil">&equiv;</span>
        {{#each this}}{{#if glossaryAnchor}}<a class="sem-token sem-token--{{cssRole}} sem-token--linked" href="{{glossaryAnchor}}"{{#if isFamilyAnchor}} data-anchor="true"{{/if}} data-token-slug="{{slug}}">{{text}}</a>{{else}}<span class="sem-token sem-token--{{cssRole}}"{{#if isFamilyAnchor}} data-anchor="true"{{/if}} data-token-slug="{{slug}}">{{text}}</span>{{/if}}{{#unless @last}} {{/unless}}{{/each}}
      </p>
      {{/each}}
    {{/if}}
    {{! Slot 4 — "Also called" (folk names / aliases). Distinct from the ≡ structural readings. }}
    {{#if commonAliases.length}}
      <p class="dict-card-aliases" aria-label="Also called">
        Also called: {{#each commonAliases}}{{this}}{{#unless @last}} &middot; {{/unless}}{{/each}}
      </p>
    {{/if}}
    {{! Slot 5 — JOB block (operational notation). Independent of slot 3. }}
    {{#if operationalNotation}}
      <div class="dict-card-notation-block" aria-label="Set notation">
        <span class="dict-card-notation-label">JOB</span>
        <code class="dict-card-notation">{{#each operationalNotation.tokens}}<span class="op-token op-token--{{cssRole}}" data-role="{{role}}" title="{{label}}">{{text}}</span>{{#unless @last}} {{/unless}}{{/each}}</code>
      </div>
    {{/if}}

    <span class="dict-card-add{{#unless adds}} dict-card-add--unrated{{/unless}}" aria-label="{{addsLabel}}">{{addsLabel}}</span>

    {{#if pendingDecomposition}}
    <span class="dict-card-pending-pill" aria-label="Decomposition under review"><em>decomposition under review</em></span>
    {{/if}}

    {{#if hasReferenceMedia}}
    <span class="dict-card-media-chip dict-card-media-chip--{{mediaCoverage}}" aria-label="Media coverage">{{mediaCoverageLabel}}</span>
    {{/if}}

    {{#if statusBadge}}
    <span class="dict-card-status-badge">{{statusBadge}}</span>
    {{/if}}
    {{#if placeholderNote}}
    <p class="dict-card-placeholder-note">{{placeholderNote}}</p>
    {{/if}}
    {{#if isFirstClass}}
    {{> dictionary-trick-card-first-class-row}}
    {{/if}}
  </article>
{{/if}}
