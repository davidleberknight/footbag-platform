{{!--
  Click-to-play video facade. Context: { media: VideoMedia, eager?: boolean }.
  The video-facade.js handler binds to .video-facade and reads:
    data-platform        youtube | vimeo | s3
    data-embed-url       (youtube/vimeo only) iframe src to swap in
    data-video-src       (s3 only) playable URL for native <video>
  The anchor href provides the no-JS fallback (opens platform watch page,
  or directly plays the s3 file). Pass eager=true when this facade is the
  primary media of its page (the item viewer) so its thumbnail loads
  immediately; gallery tiles omit it and lazy-load.
--}}
<a class="video-facade"
   href="{{media.videoUrl}}"
   target="_blank" rel="noopener noreferrer"
   data-platform="{{media.videoPlatform}}"
   {{#if media.videoEmbedUrl}}data-embed-url="{{media.videoEmbedUrl}}"{{/if}}
   {{#unless media.videoEmbedUrl}}data-video-src="{{media.videoUrl}}"{{/unless}}
   aria-label="Play video: {{media.videoTitle}}">
  <img class="video-facade-thumb"
       src="{{media.thumbnailUrl}}"
       alt="{{media.videoTitle}}"
       loading="{{#if eager}}eager{{else}}lazy{{/if}}" />
  <span class="video-facade-play" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="48" height="48" focusable="false">
      <path d="M8 5v14l11-7z" fill="currentColor"/>
    </svg>
  </span>
</a>
