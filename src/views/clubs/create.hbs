{{! Club creation form }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    <p>Start a local footbag community.</p>
  </div>
</div>

<div class="wrapper">
  <section>

    <p class="text-muted fs-sm">Creating a club requires IFPA Membership (Tier 1) or above, because you become the club's first co-leader. Before creating, check the <a href="/clubs">clubs page</a> to see whether your club is already listed.</p>

    {{#if errorMessage}}
      <div class="form-error-banner" role="alert">
        <p>{{errorMessage}}</p>
        {{#if existingClubHref}}
          <p><a href="{{existingClubHref}}">View {{existingClubName}}</a></p>
        {{/if}}
        {{#if nearMatches.length}}
          <ul>
            {{#each nearMatches}}
              <li>{{#if clubHref}}<a href="{{clubHref}}">{{name}}</a>{{else}}{{name}}{{/if}}{{#if location}} ({{location}}){{/if}}</li>
            {{/each}}
          </ul>
        {{/if}}
      </div>
    {{/if}}

    <form method="POST" action="{{formAction}}" class="login-form">

      {{#if nearMatches.length}}
        <div class="form-field">
          <label>
            <input type="checkbox" name="confirm_near_matches" value="1" required />
            My club is distinct from the matches listed above.
          </label>
        </div>
      {{/if}}

      <div class="form-field">
        <label for="name">Club name</label>
        <input
          type="text"
          id="name"
          name="name"
          value="{{club.name}}"
          maxlength="150"
          required
        />
        {{#if fieldErrors.name}}
          <p class="form-field-error" role="alert">{{fieldErrors.name}}</p>
        {{/if}}
      </div>

      <div class="form-field">
        <label for="description">Description <span class="text-muted">(optional)</span></label>
        <textarea
          id="description"
          name="description"
          maxlength="2000"
          rows="3"
        >{{club.description}}</textarea>
        {{#if fieldErrors.description}}
          <p class="form-field-error" role="alert">{{fieldErrors.description}}</p>
        {{/if}}
      </div>

      <div class="form-field">
        <label for="city">City</label>
        <input
          type="text"
          id="city"
          name="city"
          value="{{club.city}}"
          required
        />
        {{#if fieldErrors.city}}
          <p class="form-field-error" role="alert">{{fieldErrors.city}}</p>
        {{/if}}
      </div>

      <div class="form-field">
        <label for="region">Region / State <span class="text-muted">(optional)</span></label>
        <input
          type="text"
          id="region"
          name="region"
          value="{{club.region}}"
        />
        {{#if fieldErrors.region}}
          <p class="form-field-error" role="alert">{{fieldErrors.region}}</p>
        {{/if}}
      </div>

      <div class="form-field">
        <label for="country">Country</label>
        <input
          type="text"
          id="country"
          name="country"
          value="{{club.country}}"
          required
        />
        {{#if fieldErrors.country}}
          <p class="form-field-error" role="alert">{{fieldErrors.country}}</p>
        {{/if}}
      </div>

      <div class="form-field">
        <label for="slug">Club hashtag</label>
        <div class="club-slug-group">
          <span class="club-slug-prefix">#club_</span>
          <input
            type="text"
            id="slug"
            name="slug"
            value="{{club.slug}}"
            pattern="[a-z0-9][a-z0-9_]*[a-z0-9]" minlength="2"
          />
        </div>
        <small class="form-hint">Your club's permanent hashtag. Leave blank to default from city name.</small>
        {{#if fieldErrors.slug}}
          <p class="form-field-error" role="alert">{{fieldErrors.slug}}</p>
        {{/if}}
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Create Club</button>
        <a href="{{cancelHref}}" class="btn btn-outline">Cancel</a>
      </div>

    </form>
  </section>
</div>

<script src="{{{asset 'js/club-create.js'}}}" defer></script>
