<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
      {{#if this.href}}<a href="{{this.href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    <p class="hero-hashtag">{{content.club.standardTagDisplay}}</p>
  </div>
</div>

<div class="wrapper">
  <div class="club-detail">

    <dl class="club-detail-meta">
      <dt>Location</dt>
      <dd>
        {{content.club.city}}{{#if content.club.region}}, {{content.club.region}}{{/if}},
        {{content.club.country}}
      </dd>
      {{#if content.club.externalUrl}}
      <dt>Website</dt>
      <dd>{{{externalLink content.club.externalUrl class="club-external-link"}}}</dd>
      {{/if}}
    </dl>

    {{#if content.club.description}}
    <div class="club-detail-description">
      <p>{{content.club.description}}</p>
    </div>
    {{/if}}

    {{#if content.club.contentEditHref}}
    <section class="mt-4">
      <div class="section-heading"><h2>Edit club content</h2></div>
      <form method="POST" action="{{content.club.contentEditHref}}" class="form-block">
        <div class="form-field">
          <label for="club_description">Description</label>
          <textarea id="club_description" name="description" rows="4" maxlength="2000">{{content.club.description}}</textarea>
        </div>
        <div class="form-field">
          <label for="club_external_url">External URL (verified before it appears publicly; leave blank to remove)</label>
          <input id="club_external_url" name="external_url" maxlength="2048" value="{{content.club.externalUrl}}" />
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Save changes</button>
      </form>
    </section>
    {{/if}}

    {{#if content.club.viewGalleryHref}}
    <div class="club-gallery-link">
      <a href="{{content.club.viewGalleryHref}}" class="btn btn-outline">View gallery</a>
    </div>
    {{/if}}

    {{#if content.club.leaders.length}}
    <section class="mt-4">
      <div class="section-heading"><h2>Leaders</h2></div>
      <ul class="club-member-list">
        {{#each content.club.leaders}}
        <li class="club-member-entry">
          {{#if personId}}
            <a class="club-leader-name" href="/history/{{personId}}">{{displayName}}</a>
          {{else}}
            <span class="club-leader-name">{{displayName}}</span>
          {{/if}}
          <span class="text-muted fs-sm">({{roleLabel}})</span>
          {{#if badgeLabel}}
            <span class="badge">{{badgeLabel}}</span>
          {{/if}}
          {{#if badgeNote}}
            <p class="text-muted fs-sm">{{badgeNote}}</p>
          {{/if}}
          {{#if showContact}}
            <a class="club-leader-email" href="mailto:{{contactEmail}}">{{contactEmail}}</a>
          {{/if}}
        </li>
        {{/each}}
      </ul>
    </section>
    {{/if}}

    {{#if isAuthenticated}}
    <div class="mt-4">
      {{#if content.club.viewerIsMember}}
        <p class="badge">You are a member of this club</p>
      {{else if content.club.viewerCanJoin}}
        <form method="POST" action="{{content.club.joinHref}}">
          <button type="submit" class="btn btn-primary">Join this club</button>
        </form>
      {{/if}}
    </div>

    {{#if (or content.club.viewerCanVolunteer content.club.viewerIsLeader)}}
    <section class="mt-4">
      <div class="section-heading"><h2>Leadership</h2></div>
      {{#if content.club.isLeaderless}}
        <p class="text-muted">This club has no co-leader yet. If you are a member, you can step up.</p>
      {{/if}}
      {{#if content.club.viewerCanVolunteer}}
        <form method="POST" action="{{content.club.volunteerHref}}">
          <button type="submit" class="btn btn-primary">Volunteer to co-lead this club</button>
        </form>
      {{/if}}
      {{#if content.club.viewerIsLeader}}
        <form method="POST" action="{{content.club.inviteHref}}" class="mt-4">
          <div class="form-field">
            <label for="invite-member-key">Invite a member to co-lead</label>
            <input type="text" id="invite-member-key" name="member_key" placeholder="member id or username" required />
          </div>
          <button type="submit" class="btn btn-outline">Invite</button>
        </form>
      {{/if}}
    </section>
    {{/if}}
    {{/if}}

    {{#if isAuthenticated}}
    {{#if content.club.members.length}}
    <div class="club-members">
      <div class="section-heading"><h2>Club members</h2></div>
      <ul class="club-member-list">
        {{#each content.club.members}}
        <li class="club-member-entry">
          {{#if href}}
            <a href="{{href}}">{{name}}</a>
          {{else}}
            <span>{{name}}</span>
          {{/if}}
          {{#if tierBadge}}
            <span class="badge badge-tier">{{tierBadge}}</span>
          {{/if}}
          {{#if isActivePlayer}}
            <span class="badge badge-honor">Active Player</span>
          {{/if}}
          {{#if isHof}}
            <span class="badge badge-honor">HoF</span>
          {{/if}}
          {{#if isBap}}
            <span class="badge badge-honor">BAP</span>
          {{/if}}
          {{#if isBoard}}
            <span class="badge badge-honor">Board</span>
          {{/if}}
          {{#if location}}
            <span class="text-muted fs-sm">{{location}}</span>
          {{/if}}
          {{#if genderLabel}}
            <span class="text-muted fs-sm">{{genderLabel}}</span>
          {{/if}}
          {{#if statusNote}}
            <span class="text-muted fs-sm">{{statusNote}}</span>
          {{/if}}
        </li>
        {{/each}}
      </ul>
    </div>
    {{/if}}
    {{else}}
    <div class="club-members-gate">
      <a href="/login?returnTo={{content.club.clubHref}}">Log in</a> to see club members.
    </div>
    {{/if}}

    {{!-- TEMP-DEVIATION: full classification diagnostic (curator view).
          Current: qcPanel diagnostic rendered inline on every club detail
            page for authenticated users (auth-gated, below members,
            always expanded so the full rule table and human-labeled
            inputs are visible at once).
          Target: remove this section when the A_Periodic_Club_Cleanup
            admin queue replaces inline diagnostic rendering. --}}
    {{#if isAuthenticated}}
    {{#if content.club.qcPanel}}
    <section class="club-qc-panel club-qc-panel--{{content.club.qcPanel.category}}" aria-label="Classification analysis (curator view)">
      <p class="club-qc-panel-banner"><strong>Curator view:</strong> classification diagnostic. Not part of the public design; will be removed before any production environment ships.</p>

      <p><span class="badge">{{content.club.qcPanel.categoryLabel}}</span>{{#if content.club.qcPanel.confidenceScore}} <span class="text-muted fs-sm">Confidence {{content.club.qcPanel.confidenceScore}}</span>{{/if}}</p>
      <p class="card-meta">{{#each content.club.vitality.metaChips}}{{this}}{{#unless @last}} &middot; {{/unless}}{{/each}}{{#if content.club.qcPanel.lastMemberActivityYear}} &middot; members active through {{content.club.qcPanel.lastMemberActivityYear}}{{/if}}</p>
      {{#if content.club.qcPanel.summaryTagline}}
      <p class="card-description">{{content.club.qcPanel.summaryTagline}}</p>
      {{/if}}

      <h2 class="club-qc-panel-heading">Why this category?</h2>
      <p class="club-qc-narrative">{{content.club.qcPanel.narrativeWhy}}</p>

      <dl class="club-qc-panel-summary">
        <dt>Cutover eligibility</dt>
        <dd>{{#if content.club.qcPanel.bootstrapEligible}}eligible for automatic cutover at launch{{else}}not eligible for automatic cutover (admin or wizard promotion required){{/if}}</dd>
        {{#if content.club.qcPanel.contactSignalSubstituteApplied}}
        <dt>Contact substitute</dt>
        <dd class="club-qc-warning">applied (no listed contact; classifier fell back to the any-member-active predicate)</dd>
        {{/if}}
      </dl>

      <h3 class="club-qc-panel-subheading">Rule firings (R1&ndash;R10), classifier as-built</h3>
      <table class="club-qc-rule-table">
        <thead>
          <tr><th scope="col">Fired</th><th scope="col">Rule</th><th scope="col">Stage</th></tr>
        </thead>
        <tbody>
          {{#each content.club.qcPanel.rules}}
          <tr class="club-qc-rule--{{#if fired}}fired{{else}}not-fired{{/if}}">
            <td class="club-qc-rule-fired-cell" aria-label="{{#if fired}}fired{{else}}did not fire{{/if}}">{{#if fired}}&#10003;{{else}}&#215;{{/if}}</td>
            <th scope="row">{{id}}: {{label}}</th>
            <td>{{stage}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <h3 class="club-qc-panel-subheading">Rule inputs</h3>
      <dl class="club-qc-inputs">
        {{#each content.club.qcPanel.inputs}}
        <dt>{{label}}</dt><dd>{{value}}</dd>
        {{/each}}
      </dl>

      {{#if content.club.qcPanel.signals}}
      <h3 class="club-qc-panel-subheading">Combination-gate signals, classifier as-designed</h3>
      <ul class="club-qc-signals">
        {{#each content.club.qcPanel.signals}}
        <li class="club-qc-signal club-qc-signal--{{kind}} club-qc-signal--{{stateKey}}">
          <span class="club-qc-signal-label">{{label}}</span>
          <span class="club-qc-signal-state">{{stateLabel}}</span>
          {{#if evidenceText}}<span class="club-qc-signal-evidence">{{evidenceText}}</span>{{/if}}
        </li>
        {{/each}}
      </ul>
      {{#if content.club.qcPanel.gateOutput}}
      <p class="club-qc-gate-output">
        Combination-gate result:
        {{#if content.club.qcPanel.gateOutput.classification}}
          <strong>{{content.club.qcPanel.gateOutput.classification}}</strong>
          {{#if content.club.qcPanel.gateOutput.matchedGateLabel}}({{content.club.qcPanel.gateOutput.matchedGateLabel}}){{/if}}
        {{else}}
          <em>not yet computed</em>
        {{/if}}
      </p>
      {{/if}}
      {{/if}}

      {{#if content.club.qcPanel.pipelineContext}}
      <h3 class="club-qc-panel-subheading">Pipeline context</h3>
      <dl class="club-qc-pipeline-context">
        <dt>Affiliations linked to this club</dt>
        <dd>{{content.club.qcPanel.pipelineContext.affiliationsTotal}} total
            ({{content.club.qcPanel.pipelineContext.affiliationsPendingCount}} pending)</dd>
      </dl>
      {{/if}}
    </section>
    {{/if}}
    {{/if}}

    {{#each navigation.contextLinks}}
    <div class="club-back-link">
      <a href="{{href}}" class="btn btn-outline">{{label}}</a>
    </div>
    {{/each}}

  </div>
</div>
