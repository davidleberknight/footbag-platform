<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
      {{#if this.href}}<a href="{{this.href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    <p class="club-hashtag hero-hashtag">{{content.club.standardTagDisplay}}</p>
  </div>
</div>

<div class="wrapper">
  <div class="club-detail">

    <dl class="club-detail-meta">
      <dt>Location</dt>
      <dd>
        {{content.club.city}}{{#if content.club.region}}, {{content.club.region}}{{/if}}
        &mdash; {{content.club.country}}
      </dd>
      {{#if content.club.externalUrl}}
      <dt>Website</dt>
      <dd><a href="{{content.club.externalUrl}}" class="club-external-link" target="_blank" rel="noopener noreferrer">{{content.club.externalUrl}}</a></dd>
      {{/if}}
    </dl>

    {{#if content.club.description}}
    <div class="club-detail-description">
      <p>{{content.club.description}}</p>
    </div>
    {{/if}}

    <section class="club-snapshot club-snapshot--{{content.club.vitality.statusLabelKebab}}" aria-label="Club snapshot">
      <h2 class="club-snapshot-heading">Club snapshot</h2>
      <dl class="club-snapshot-list">
        <dt>Known leaders</dt>
        <dd>{{content.club.vitality.knownLeadersText}}</dd>
        <dt>Members</dt>
        <dd>{{content.club.vitality.memberCountText}}</dd>
        <dt>Status</dt>
        <dd class="club-status-label">{{content.club.vitality.statusLabel}}</dd>
      </dl>
    </section>

    {{#if content.club.leaders.length}}
    <div class="club-leaders">
      <h2 class="club-leaders-heading">Leaders</h2>
      <ul class="club-leaders-list">
        {{#each content.club.leaders}}
        <li class="club-leader club-leader-{{status}}">
          {{#if personId}}
            <a class="club-leader-name" href="/history/{{personId}}">{{displayName}}</a>
          {{else}}
            <span class="club-leader-name">{{displayName}}</span>
          {{/if}}
          <span class="club-leader-role">&nbsp;&mdash;&nbsp;{{#if (eq role "leader")}}Leader{{else}}Co-leader{{/if}}</span>
          {{#if badgeLabel}}
            <span class="club-leader-badge">{{badgeLabel}}</span>
          {{/if}}
          {{#if badgeNote}}
            <p class="club-leader-note">{{badgeNote}}</p>
          {{/if}}
          {{#if showContact}}
            <a class="club-leader-email" href="mailto:{{contactEmail}}">{{contactEmail}}</a>
          {{/if}}
        </li>
        {{/each}}
      </ul>
    </div>
    {{/if}}

    {{#if isAuthenticated}}
    {{#if content.club.members.length}}
    <div class="club-members">
      <h2 class="club-members-heading">Members</h2>
      <ul class="club-member-list">
        {{#each content.club.members}}
        <li class="club-member-entry">{{name}}</li>
        {{/each}}
      </ul>
    </div>
    {{/if}}
    {{else}}
    <div class="club-members-gate">
      <a href="/login?returnTo={{content.club.clubHref}}">Log in</a> to see club members.
    </div>
    {{/if}}

    {{#each navigation.contextLinks}}
    <div class="club-back-link">
      <a href="{{href}}" class="btn btn-outline">{{label}}</a>
    </div>
    {{/each}}

  </div>
</div>
