<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
      {{#if this.href}}<a href="{{this.href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    <p class="hero-hashtag">{{content.club.standardTagDisplay}}</p>
  </div>
</div>

<div class="wrapper">
  <div class="club-detail">

    {{#if content.club.isInactive}}
    <p class="notice notice-warn">This club is inactive. It stays reachable by direct link but does not appear in the club directory. A co-leader can reactivate it at any time.</p>
    {{/if}}

    <dl class="club-detail-meta">
      <dt>Location</dt>
      <dd>
        {{content.club.city}}{{#if content.club.region}}, {{content.club.region}}{{/if}},
        {{content.club.country}}
      </dd>
      {{#if content.club.externalUrl}}
      <dt>Website</dt>
      <dd>{{{externalLink content.club.externalUrl class="club-external-link"}}}</dd>
      {{/if}}
    </dl>

    {{#if content.club.description}}
    <div class="club-detail-description">
      <p>{{content.club.description}}</p>
    </div>
    {{/if}}

    {{#if content.club.descriptionGated}}
    <div class="club-detail-description">
      <p class="text-muted">This club has an imported historical description that names individual people. It is shown to logged-in members only.</p>
    </div>
    {{/if}}

    {{#if content.club.contentEditHref}}
    <section class="mt-4">
      <div class="section-heading"><h2>Edit club content</h2></div>
      <form method="POST" action="{{content.club.contentEditHref}}" class="form-block">
        <div class="form-field">
          <label for="club_description">Description</label>
          <textarea id="club_description" name="description" rows="4" maxlength="2000">{{content.club.description}}</textarea>
        </div>
        <div class="form-field">
          <label for="club_external_url">External URL (verified before it appears publicly; leave blank to remove)</label>
          <input id="club_external_url" name="external_url" maxlength="2048" value="{{content.club.externalUrl}}" />
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Save Changes</button>
      </form>
    </section>
    {{/if}}

    {{#if content.club.viewGalleryHref}}
    <div class="club-gallery-link">
      <a href="{{content.club.viewGalleryHref}}" class="btn btn-outline">View Gallery</a>
    </div>
    {{/if}}

    {{#if content.club.leaders.length}}
    <section class="mt-4">
      <div class="section-heading"><h2>Leaders</h2></div>
      <ul class="club-member-list">
        {{#each content.club.leaders}}
        <li class="club-member-entry">
          {{#if personId}}
            <a class="club-leader-name" href="/history/{{personId}}">{{displayName}}</a>
          {{else}}
            <span class="club-leader-name">{{displayName}}</span>
          {{/if}}
          <span class="text-muted fs-sm">({{roleLabel}})</span>
          {{#if badgeLabel}}
            <span class="badge">{{badgeLabel}}</span>
          {{/if}}
          {{#if badgeNote}}
            <p class="text-muted fs-sm">{{badgeNote}}</p>
          {{/if}}
          {{#if showContact}}
            <a class="club-leader-email" href="mailto:{{contactEmail}}">{{contactEmail}}</a>
          {{/if}}
        </li>
        {{/each}}
      </ul>
    </section>
    {{/if}}

    {{#if isAuthenticated}}
    <div class="mt-4">
      {{#if content.club.viewerIsMember}}
        <p class="badge">You are a member of this club</p>
      {{else if content.club.viewerCanJoin}}
        <form method="POST" action="{{content.club.joinHref}}">
          <button type="submit" class="btn btn-primary">Join This Club</button>
        </form>
      {{/if}}
    </div>

    {{#if (or content.club.viewerCanVolunteer content.club.viewerIsLeader)}}
    <section class="mt-4">
      <div class="section-heading"><h2>Leadership</h2></div>
      {{#if content.club.isLeaderless}}
        <p class="text-muted">This club has no co-leader yet. If you are a member, you can step up.</p>
      {{/if}}
      {{#if content.club.viewerCanVolunteer}}
        <form method="POST" action="{{content.club.volunteerHref}}">
          <button type="submit" class="btn btn-primary">Volunteer to Co-lead This Club</button>
        </form>
      {{/if}}
      {{#if content.club.viewerIsLeader}}
        <form method="POST" action="{{content.club.inviteHref}}" class="mt-4">
          <div class="form-field">
            <label for="invite-member-key">Invite a member to co-lead</label>
            <input type="text" id="invite-member-key" name="member_key" placeholder="member id or username" required />
          </div>
          <button type="submit" class="btn btn-outline">Invite</button>
        </form>
      {{/if}}
    </section>
    {{/if}}
    {{/if}}

    {{#if isAuthenticated}}
    {{#if content.club.members.length}}
    <div class="club-members">
      <div class="section-heading"><h2>Club members</h2></div>
      <ul class="club-member-list">
        {{#each content.club.members}}
        <li class="club-member-entry">
          {{#if href}}
            <a href="{{href}}">{{name}}</a>
          {{else}}
            <span>{{name}}</span>
          {{/if}}
          {{#if tierBadge}}
            <span class="badge badge-tier">{{tierBadge}}</span>
          {{/if}}
          {{#if isActivePlayer}}
            <span class="badge badge-honor">Active Player</span>
          {{/if}}
          {{#if isHof}}
            <span class="badge badge-honor">HoF</span>
          {{/if}}
          {{#if isBap}}
            <span class="badge badge-honor">BAP</span>
          {{/if}}
          {{#if isBoard}}
            <span class="badge badge-honor">Board</span>
          {{/if}}
          {{#if location}}
            <span class="text-muted fs-sm">{{location}}</span>
          {{/if}}
          {{#if genderLabel}}
            <span class="text-muted fs-sm">{{genderLabel}}</span>
          {{/if}}
          {{#if statusNote}}
            <span class="text-muted fs-sm">{{statusNote}}</span>
          {{/if}}
        </li>
        {{/each}}
      </ul>
    </div>
    {{/if}}
    {{else}}
    <div class="club-members-gate">
      <a href="/login?returnTo={{content.club.clubHref}}">Log in</a> to see club members.
    </div>
    {{/if}}

    {{#each navigation.contextLinks}}
    <div class="club-back-link">
      <a href="{{href}}" class="btn btn-outline">{{label}}</a>
    </div>
    {{/each}}

  </div>
</div>
