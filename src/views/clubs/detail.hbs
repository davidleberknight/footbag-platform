<div class="hero hero-sm">
  <div>
    {{#if navigation.breadcrumbs}}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      {{#each navigation.breadcrumbs}}
      {{#if this.href}}<a href="{{this.href}}">{{label}}</a> <span class="breadcrumb-sep">/</span> {{else}}<span>{{label}}</span>{{/if}}
      {{/each}}
    </nav>
    {{/if}}
    <h1>{{page.title}}</h1>
    <p class="club-hashtag hero-hashtag">{{content.club.standardTagDisplay}}</p>
  </div>
</div>

<div class="wrapper">
  <div class="club-detail">

    <dl class="club-detail-meta">
      <dt>Location</dt>
      <dd>
        {{content.club.city}}{{#if content.club.region}}, {{content.club.region}}{{/if}},
        {{content.club.country}}
      </dd>
      {{#if content.club.externalUrl}}
      <dt>Website</dt>
      <dd>{{{externalLink content.club.externalUrl class="club-external-link"}}}</dd>
      {{/if}}
    </dl>

    {{#if content.club.description}}
    <div class="club-detail-description">
      <p>{{content.club.description}}</p>
    </div>
    {{/if}}

    {{#if content.club.contentEditHref}}
    <section class="mt-4">
      <div class="section-heading"><h2>Edit club content</h2></div>
      <form method="POST" action="{{content.club.contentEditHref}}" class="form-block">
        <div class="form-field">
          <label for="club_description">Description</label>
          <textarea id="club_description" name="description" rows="4" maxlength="2000">{{content.club.description}}</textarea>
        </div>
        <div class="form-field">
          <label for="club_external_url">External URL (verified before it appears publicly; leave blank to remove)</label>
          <input id="club_external_url" name="external_url" maxlength="2048" value="{{content.club.externalUrl}}" />
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Save changes</button>
      </form>
    </section>
    {{/if}}

    {{#if content.club.openSuggestions.length}}
    <section class="mt-4">
      <div class="section-heading">
        <h2>Suggested edits awaiting review</h2>
        <span class="section-count">{{content.club.openSuggestions.length}}</span>
      </div>
      {{#each content.club.openSuggestions}}
        <div class="card">
          <div class="card-title">{{fieldLabel}} suggestion from {{suggesterDisplayName}}</div>
          <p>{{proposedValue}}</p>
          {{#if note}}<p class="card-meta">{{note}}</p>{{/if}}
          <form method="POST" action="{{reviewHref}}" class="form-block">
            <input type="hidden" name="decision" value="approve" />
            <button type="submit" class="btn btn-primary btn-sm">Approve and apply</button>
          </form>
          <form method="POST" action="{{reviewHref}}" class="form-block">
            <input type="hidden" name="decision" value="reject" />
            <div class="form-field">
              <label for="reject_reason_{{id}}">Rejection reason</label>
              <input id="reject_reason_{{id}}" name="reason" required maxlength="500" />
            </div>
            <button type="submit" class="btn btn-outline btn-sm">Reject</button>
          </form>
        </div>
      {{/each}}
    </section>
    {{/if}}

    {{#if content.club.canSuggestContent}}
    <section class="mt-4">
      <div class="section-heading"><h2>See something wrong?</h2></div>
      <p class="text-muted fs-sm">Suggest a correction to this club's description or website link. A club contact or leader reviews suggestions before they appear.</p>
      <form method="POST" action="{{content.club.contentSuggestHref}}" class="form-block">
        <div class="form-field">
          <label for="suggest_field">What needs correcting?</label>
          <select id="suggest_field" name="field">
            <option value="description">Description</option>
            <option value="external_url">External URL</option>
          </select>
        </div>
        <div class="form-field">
          <label for="suggest_value">Proposed replacement</label>
          <textarea id="suggest_value" name="proposed_value" rows="3" maxlength="2000" required></textarea>
        </div>
        <div class="form-field">
          <label for="suggest_note">Note for the reviewer (optional)</label>
          <input id="suggest_note" name="note" maxlength="500" />
        </div>
        <button type="submit" class="btn btn-secondary btn-sm">Submit suggestion</button>
      </form>
    </section>
    {{/if}}

    {{#if content.club.viewGalleryHref}}
    <div class="club-gallery-link">
      <a href="{{content.club.viewGalleryHref}}" class="btn btn-outline">View gallery</a>
    </div>
    {{/if}}

    {{!-- At-a-glance card: merges club snapshot + classification status into
          one scannable block. Visible to all visitors. TEMP-DEVIATION fields
          (qcPanel.*) absent in production; section degrades to a plain
          leader/member count line in that case. --}}
    <section class="club-at-a-glance club-at-a-glance--{{content.club.vitality.statusLabelKebab}}{{#if content.club.qcPanel}} club-at-a-glance--{{content.club.qcPanel.category}}{{/if}}" aria-label="At a glance">
      {{#if content.club.qcPanel}}
      <div class="club-at-a-glance-header">
        <span class="club-qc-category-chip club-qc-category-chip--{{content.club.qcPanel.category}}">{{content.club.qcPanel.categoryLabel}}</span>
        {{#if content.club.qcPanel.confidenceScore}}
        <span class="club-qc-confidence">Confidence {{content.club.qcPanel.confidenceScore}}</span>
        {{/if}}
      </div>
      {{/if}}
      <p class="club-at-a-glance-stats">
        {{content.club.vitality.knownLeadersText}} known {{#if (eq content.club.vitality.knownLeadersCount 1)}}leader{{else}}leaders{{/if}}
        &middot; {{content.club.vitality.memberCountText}} {{#if (eq content.club.vitality.memberCount 1)}}member{{else}}members{{/if}}
        {{#if content.club.qcPanel.lastMemberActivityYear}}
        &middot; members active through {{content.club.qcPanel.lastMemberActivityYear}}
        {{/if}}
      </p>
      <p class="club-status-label club-status-label--{{content.club.vitality.statusLabelKebab}}">{{content.club.vitality.statusLabel}}</p>
      {{#if content.club.qcPanel.summaryTagline}}
      <p class="club-at-a-glance-tagline">{{content.club.qcPanel.summaryTagline}}</p>
      {{/if}}
    </section>

    {{#if content.club.leaders.length}}
    <div class="club-leaders">
      <h2 class="club-leaders-heading">Leaders</h2>
      <ul class="club-leaders-list">
        {{#each content.club.leaders}}
        <li class="club-leader club-leader-{{status}}">
          {{#if personId}}
            <a class="club-leader-name" href="/history/{{personId}}">{{displayName}}</a>
          {{else}}
            <span class="club-leader-name">{{displayName}}</span>
          {{/if}}
          <span class="club-leader-role">&nbsp;({{roleLabel}})</span>
          {{#if badgeLabel}}
            <span class="club-leader-badge">{{badgeLabel}}</span>
          {{/if}}
          {{#if badgeNote}}
            <p class="club-leader-note">{{badgeNote}}</p>
          {{/if}}
          {{#if showContact}}
            <a class="club-leader-email" href="mailto:{{contactEmail}}">{{contactEmail}}</a>
          {{/if}}
        </li>
        {{/each}}
      </ul>
    </div>
    {{/if}}

    {{#if isAuthenticated}}
    {{#if (or content.club.contactEmail content.club.whatsapp)}}
    <div class="club-contact-block mt-4">
      <h2 class="club-contact-heading">Contact</h2>
      {{#if content.club.contactEmail}}
        <p><a class="club-contact-email" href="mailto:{{content.club.contactEmail}}">{{content.club.contactEmail}}</a></p>
      {{/if}}
      {{#if content.club.whatsapp}}
        <p class="club-contact-whatsapp">WhatsApp: {{content.club.whatsapp}}</p>
      {{/if}}
    </div>
    {{/if}}
    <div class="club-join-block mt-4">
      {{#if content.club.viewerIsMember}}
        <p class="badge">You are a member of this club</p>
      {{else if content.club.viewerCanJoin}}
        <form method="POST" action="{{content.club.joinHref}}">
          <button type="submit" class="btn btn-primary">Join this club</button>
        </form>
      {{/if}}
    </div>
    {{#if content.club.members.length}}
    <div class="club-members">
      <h2 class="club-members-heading">Members</h2>
      <ul class="club-member-list">
        {{#each content.club.members}}
        <li class="club-member-entry">
          {{#if personId}}
            <a class="club-member-name" href="/history/{{personId}}">{{name}}</a>
          {{else}}
            <span class="club-member-name">{{name}}</span>
          {{/if}}
        </li>
        {{/each}}
      </ul>
    </div>
    {{/if}}
    {{#if content.club.unconfirmedMembers.length}}
    <div class="club-members club-members-unconfirmed">
      <h2 class="club-members-heading">Possible members from legacy records</h2>
      <p class="club-members-unconfirmed-note">Unconfirmed: these people have not yet confirmed their membership in onboarding.</p>
      <ul class="club-member-list">
        {{#each content.club.unconfirmedMembers}}
        <li class="club-member-entry">
          {{#if personId}}
            <a class="club-member-name" href="/history/{{personId}}">{{name}}</a>
          {{else}}
            <span class="club-member-name">{{name}}</span>
          {{/if}}
        </li>
        {{/each}}
      </ul>
      <p class="club-members-unconfirmed-cta"><a href="/register/wizard/club_affiliations">Is this you? Confirm your membership in onboarding</a></p>
    </div>
    {{/if}}
    {{else}}
    <div class="club-members-gate">
      <a href="/login?returnTo={{content.club.clubHref}}">Log in</a> to see club members.
    </div>
    {{/if}}

    {{!-- TEMP-DEVIATION: full classification diagnostic (curator view).
          Current: qcPanel diagnostic rendered inline on every club detail
            page for authenticated users (auth-gated, below members,
            always expanded so the full rule table and human-labeled
            inputs are visible at once).
          Target: remove this section when the A_Periodic_Club_Cleanup
            admin queue replaces inline diagnostic rendering. --}}
    {{#if isAuthenticated}}
    {{#if content.club.qcPanel}}
    <section class="club-qc-panel club-qc-panel--{{content.club.qcPanel.category}}" aria-label="Classification analysis (curator view)">
      <p class="club-qc-panel-banner"><strong>Curator view:</strong> classification diagnostic. Not part of the public design; will be removed before any production environment ships.</p>

      <h2 class="club-qc-panel-heading">Why this category?</h2>
      <p class="club-qc-narrative">{{content.club.qcPanel.narrativeWhy}}</p>

      <dl class="club-qc-panel-summary">
        <dt>Cutover eligibility</dt>
        <dd>{{#if content.club.qcPanel.bootstrapEligible}}eligible for automatic cutover at launch{{else}}not eligible for automatic cutover (admin or wizard promotion required){{/if}}</dd>
        {{#if content.club.qcPanel.contactSignalSubstituteApplied}}
        <dt>Contact substitute</dt>
        <dd class="club-qc-warning">applied (no listed contact; classifier fell back to the any-member-active predicate)</dd>
        {{/if}}
      </dl>

      <h3 class="club-qc-panel-subheading">Rule firings (R1&ndash;R10), classifier as-built</h3>
      <table class="club-qc-rule-table">
        <thead>
          <tr><th scope="col">Fired</th><th scope="col">Rule</th><th scope="col">Stage</th></tr>
        </thead>
        <tbody>
          {{#each content.club.qcPanel.rules}}
          <tr class="club-qc-rule club-qc-rule--{{#if fired}}fired{{else}}not-fired{{/if}}">
            <td class="club-qc-rule-fired-cell" aria-label="{{#if fired}}fired{{else}}did not fire{{/if}}">{{#if fired}}&#10003;{{else}}&#215;{{/if}}</td>
            <th scope="row">{{id}}: {{label}}</th>
            <td>{{stage}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <h3 class="club-qc-panel-subheading">Rule inputs</h3>
      <dl class="club-qc-inputs">
        {{#each content.club.qcPanel.inputs}}
        <dt>{{label}}</dt><dd>{{value}}</dd>
        {{/each}}
      </dl>

      {{#if content.club.qcPanel.signals}}
      <h3 class="club-qc-panel-subheading">Combination-gate signals, classifier as-designed</h3>
      <ul class="club-qc-signals">
        {{#each content.club.qcPanel.signals}}
        <li class="club-qc-signal club-qc-signal--{{kind}} club-qc-signal--{{#if isPresent}}present{{else}}{{#unless isPresent}}{{#if (eq isPresent null)}}unemitted{{else}}absent{{/if}}{{/unless}}{{/if}}">
          <span class="club-qc-signal-label">{{label}}</span>
          <span class="club-qc-signal-state">{{#if (eq isPresent null)}}(pipeline not yet emitting){{else}}{{#if isPresent}}observed{{else}}not observed{{/if}}{{/if}}</span>
          {{#if evidenceText}}<span class="club-qc-signal-evidence">{{evidenceText}}</span>{{/if}}
        </li>
        {{/each}}
      </ul>
      {{#if content.club.qcPanel.gateOutput}}
      <p class="club-qc-gate-output">
        Combination-gate result:
        {{#if content.club.qcPanel.gateOutput.classification}}
          <strong>{{content.club.qcPanel.gateOutput.classification}}</strong>
          {{#if content.club.qcPanel.gateOutput.matchedGateLabel}}({{content.club.qcPanel.gateOutput.matchedGateLabel}}){{/if}}
        {{else}}
          <em>not yet computed</em>
        {{/if}}
      </p>
      {{/if}}
      {{/if}}

      {{#if content.club.qcPanel.pipelineContext}}
      <h3 class="club-qc-panel-subheading">Pipeline context</h3>
      <dl class="club-qc-pipeline-context">
        <dt>Affiliations linked to this club</dt>
        <dd>{{content.club.qcPanel.pipelineContext.affiliationsTotal}} total
            ({{content.club.qcPanel.pipelineContext.affiliationsPendingCount}} pending)</dd>
        <dt>Live club row source</dt>
        <dd>{{content.club.qcPanel.pipelineContext.liveClubRowSource}}</dd>
        <dt>mapped_club_id stamped</dt>
        <dd>{{#if content.club.qcPanel.pipelineContext.mappedClubIdStamped}}yes{{else}}no{{/if}}
            (rule: {{content.club.qcPanel.pipelineContext.mappedClubIdStampRule}})</dd>
        {{#if content.club.qcPanel.pipelineContext.fallbackQueryApplied}}
        <dt>Schema-drift fallback</dt>
        <dd class="club-qc-warning">QC-panel query degraded to fallback for this row</dd>
        {{/if}}
      </dl>
      {{/if}}
    </section>
    {{/if}}
    {{/if}}

    {{#if isAuthenticated}}
    <section class="club-signal-section mt-6">
      <p class="text-muted fs-sm fw-600">Help us keep this listing accurate</p>
      <form method="POST" action="/clubs/{{content.club.clubKey}}/signal" class="stage-signal-form mt-2">
        <label class="radio-label"><input type="radio" name="activitySignal" value="active" /> Still active</label>
        <label class="radio-label"><input type="radio" name="activitySignal" value="not_active" /> Not active</label>
        <label class="radio-label"><input type="radio" name="activitySignal" value="not_sure" /> Not sure</label>
        <label class="radio-label"><input type="radio" name="activitySignal" value="never_heard_of_it" /> Never heard of it</label>
        <button type="submit" class="btn btn-secondary btn-sm mt-1">Submit</button>
      </form>
    </section>
    {{/if}}

    {{#each navigation.contextLinks}}
    <div class="club-back-link">
      <a href="{{href}}" class="btn btn-outline">{{label}}</a>
    </div>
    {{/each}}

  </div>
</div>
