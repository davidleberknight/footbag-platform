<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    <p class="hero-subtitle">
      Permanent persona harness, development and staging only. Pick a persona and
      click Switch to act as them.
    </p>
  </div>
</div>

<div class="wrapper">
  <p class="text-muted fs-sm mb-4">
    Each persona below is a seeded member you can act as, grouped by the authorization axis
    it exercises. Every seeded persona is validated end to end by the catalog coverage tests,
    switched in the route crawl, and run through the authorization matrix, so the list doubles
    as a coverage matrix. Loaded from the canonical catalog:
    {{personaCount}} persona{{#unless (eq personaCount 1)}}s{{/unless}}.
  </p>

  <section class="card card-static mb-8">
    <div class="card-title">Switch to a Real Member</div>
    <p class="card-description mb-2">
      Enter a real migrated legacy record's member id to build and act as its claimed account.
    </p>
    <form method="get" action="/dev/build-claim" class="search-box-form">
      <input type="text" name="as" required
             pattern="[A-Za-z0-9_-]{1,64}" autocomplete="off"
             placeholder="Legacy member ID" aria-label="Legacy member ID"
             class="search-box-input" />
      <button type="submit" class="btn btn-primary">Switch</button>
    </form>
  </section>

  <form method="post" action="/dev/personas/refresh" class="mb-8">
    <button type="submit" class="btn btn-outline">Refresh All Personas to Initial State</button>
  </form>

  {{#each groups}}
    <section class="mb-8">
      <h2 class="section-heading">{{dimension}}</h2>
      <div class="card-grid">
        {{#each personas}}
          <div class="card{{#unless backed}} dev-persona-muted{{/unless}}">
            <div class="card-title">{{displayName}}</div>
            <div class="card-meta">
              <code>{{slug}}</code>
              <span>{{tierLabel}}</span>
              {{#each roles}}<span class="badge">{{this}}</span>{{/each}}
              {{#each statusBadges}}<span class="badge{{#if muted}} badge-muted{{/if}}">{{text}}</span>{{/each}}
            </div>

            <p class="card-description">{{purpose}}</p>
            <p class="fs-sm"><strong>Verify:</strong> {{testingUsage}}</p>

            {{#if coverage.length}}
              <ul class="dev-persona-coverage">
                {{#each coverage}}<li>{{this}}</li>{{/each}}
              </ul>
            {{/if}}

            {{#unless backed}}
              <p class="fs-sm text-muted">
                {{#if blockedBy}}Blocked: {{blockedBy}}{{#if userStory}} ({{userStory}}){{/if}}{{else}}No seed data{{/if}}
              </p>
            {{/unless}}

            <div class="card-actions">
              {{#if switchable}}
                <a class="btn btn-primary" href="{{switchHref}}">Switch</a>
              {{else}}
                {{#if loginHref}}
                  <a class="btn btn-outline" href="{{loginHref}}">Log In</a>
                {{else}}
                  <span class="badge badge-muted">Not Seeded</span>
                {{/if}}
              {{/if}}
            </div>
          </div>
        {{/each}}
      </div>
    </section>
  {{/each}}

  {{#unless groups}}
    <div class="empty-state">No personas loaded.</div>
  {{/unless}}
</div>
