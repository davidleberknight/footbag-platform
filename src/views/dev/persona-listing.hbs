<div class="wrapper">
  <h1>{{page.title}}</h1>
  <p>
    Permanent persona harness (development and staging only). {{personaCount}} persona{{#unless (eq personaCount 1)}}s{{/unless}}
    loaded from the canonical catalog, grouped by the authorization axis each one exercises.
    Click Switch to issue a real session cookie and act as that persona.
  </p>

  <form method="post" action="/dev/personas/refresh" class="mb-4">
    <button type="submit" class="btn btn-primary">Refresh all personas to initial state</button>
  </form>

  {{#each groups}}
    <section class="mb-8">
      <h2 class="section-heading">{{dimension}}</h2>
      <table class="dev-persona-list">
        <thead>
          <tr>
            <th>Slug</th>
            <th>Tier</th>
            <th>Roles</th>
            <th>Why this persona exists</th>
            <th>How it's used in testing</th>
            <th>Coverage notes</th>
            <th>Act as</th>
          </tr>
        </thead>
        <tbody>
          {{#each personas}}
            <tr class="{{#unless backed}}dev-persona-unseeded{{/unless}}">
              <td>
                <code>{{slug}}</code>
                {{#if negative}}<span class="badge">deny / adjacent</span>{{/if}}
                {{#unless backed}}<span class="badge badge-muted">{{#if blockedBy}}blocked: {{blockedBy}}{{else}}no seed data{{/if}}{{#if userStory}} ({{userStory}}){{/if}}</span>{{/unless}}
              </td>
              <td>{{tierLabel}}</td>
              <td>
                {{#each roles}}<span class="badge">{{this}}</span> {{/each}}
              </td>
              <td>{{purpose}}</td>
              <td>{{testingUsage}}</td>
              <td>
                <ul class="dev-persona-coverage">
                  {{#each coverage}}
                    <li>{{this}}</li>
                  {{/each}}
                </ul>
              </td>
              <td>{{#if switchable}}<a href="{{switchHref}}">Switch</a>{{else}}{{#if loginHref}}<a href="{{loginHref}}">Log in</a>{{else}}<span class="text-muted">Not seeded</span>{{/if}}{{/if}}</td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </section>
  {{/each}}
</div>
