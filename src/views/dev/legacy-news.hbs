<div class="wrapper">
  <h1>{{page.title}}</h1>

  {{! Extremely explicit inspection-only / non-canonical banner. }}
  <div class="card mb-6">
    <p class="fw-600">⚠ LEGACY ARCHIVE — INSPECTION / DEBUG ONLY</p>
    <p>
      <strong>This is NOT canonical data and is NOT published.</strong> It is a
      read-only forensic view of legacy footbag.org news extracted into a local
      NDJSON file. Nothing here is part of the live site; no value shown has been
      promoted, normalized, or canonicalized; and this surface is never served in
      production (development and staging only). Do not cite, link, or treat any
      item here as authoritative.
    </p>
  </div>

  {{#if missing}}
    <div class="card">
      <p>
        No extracted news found at <code>{{ndjsonPath}}</code>. Run the news
        ingest first:
        <code>python legacy_data/legacy_archive/scripts/ingest.py --app news</code>.
      </p>
    </div>
  {{else}}
    <form method="get" action="/dev/legacy-news" class="mb-4">
      <input type="search" name="q" value="{{q}}" placeholder="Search headlines…" aria-label="Search headlines" />
      <button type="submit" class="btn btn-outline">Search</button>
      {{#if q}}<a class="btn btn-outline" href="/dev/legacy-news">Clear</a>{{/if}}
    </form>

    <p class="text-muted mb-4">
      {{totalRows}}
      {{#if q}}match{{#unless (eq totalRows 1)}}es{{/unless}} for &ldquo;{{q}}&rdquo;{{else}}news item{{#unless (eq totalRows 1)}}s{{/unless}}{{/if}}
      &middot; page {{pagination.page}} of {{pagination.totalPages}} &middot; newest first
    </p>

    {{#each rows}}
      <article class="card mb-3">
        <p class="card-meta">
          <span class="badge">#{{newsId}}</span>
          <span class="text-muted">{{date}}</span>
        </p>
        <p class="fw-600">{{headline}}</p>
        {{#if excerpt}}<p class="text-muted">{{excerpt}}</p>{{/if}}
        <details>
          <summary class="text-muted">Provenance</summary>
          <dl class="mt-2">
            <dt>legacy source</dt><dd><code>{{provenance.source}}</code></dd>
            <dt>legacy table</dt><dd><code>{{provenance.table}}</code></dd>
            <dt>legacy pk</dt><dd><code>{{provenance.pk}}</code></dd>
            <dt>dump sha256</dt><dd><code>{{provenance.dumpSha256}}</code></dd>
            <dt>dump date</dt><dd><code>{{provenance.dumpDate}}</code></dd>
            <dt>ingest run</dt><dd><code>{{provenance.ingestRunId}}</code></dd>
          </dl>
        </details>
      </article>
    {{/each}}

    {{#if pagination}}
      <nav class="mt-4">
        {{#if pagination.hasPrev}}<a class="btn btn-outline" href="{{pagination.prevHref}}">&larr; Prev</a>{{/if}}
        {{#if pagination.hasNext}}<a class="btn btn-outline" href="{{pagination.nextHref}}">Next &rarr;</a>{{/if}}
      </nav>
    {{/if}}
  {{/if}}
</div>
