<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    <p class="text-muted">Browse the freestyle world records, including superseded and low-confidence rows the public page hides. {{content.totalCount}} row(s).</p>
  </div>
</div>

<div class="wrapper">
  <section>
    {{#if content.hasRows}}
      <table class="freestyle-admin-table mt-2">
        <thead>
          <tr>
            <th>Holder</th>
            <th>Trick</th>
            <th>Value</th>
            <th>Type</th>
            <th>Confidence</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each content.rows}}
            <tr>
              <td>{{this.holderName}}</td>
              <td>{{this.trickName}}</td>
              <td>{{this.value}}</td>
              <td>{{this.recordType}}</td>
              <td>{{this.confidence}}</td>
              <td>{{this.statusLabel}}</td>
              <td><a href="{{this.editHref}}" class="btn btn-outline btn-sm">Edit</a></td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p class="text-muted mt-2">No freestyle records.</p>
    {{/if}}
  </section>
</div>
