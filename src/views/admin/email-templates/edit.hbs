<div class="hero hero-sm">
  <div>
    <h1>Edit email template</h1>
    <p class="text-muted">Editing <code>{{content.templateKey}}</code>. Plain text only; merge fields are filled at send time.</p>
  </div>
</div>

<div class="wrapper">
  <section>
    {{#if content.saved}}
    <p class="notice notice-info">Saved. The next send of this email uses the new wording.</p>
    {{/if}}
    {{#if content.hasErrors}}
    <div class="form-error-banner">
      {{#each content.errorList}}<p>{{this}}</p>{{/each}}
    </div>
    {{/if}}

    {{#if content.hasMergeFields}}
    <p class="text-muted">Merge fields this template must use: {{#each content.mergeFieldList}}<code>{{this}}</code> {{/each}}</p>
    {{else}}
    <p class="text-muted">This template has no merge fields; the message is fixed text.</p>
    {{/if}}

    <form method="POST" action="{{content.formAction}}">
      <fieldset>
        <p><label>Subject</label><br><input type="text" name="subjectTemplate" value="{{content.fields.subjectTemplate}}" size="80" /></p>
        <p><label>Body</label><br><textarea name="bodyTemplate" rows="14" cols="80">{{content.fields.bodyTemplate}}</textarea></p>
        <p><label>Classification</label><br>
          <select name="piiClassification">
            {{#each content.classificationOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
          </select>
        </p>
        <p><label><input type="checkbox" name="isEnabled" value="1" {{#if content.fields.isEnabled}}checked{{/if}} /> Enabled</label></p>
        {{#if content.isRestricted}}
        <p class="text-muted">This template carries a one-time credential link. Disabling it stops the platform from sending it at all, which breaks the account flow that depends on it.</p>
        {{else}}
        <p class="text-muted fs-sm">Disabling suppresses this email type entirely; the triggering action still completes.</p>
        {{/if}}
      </fieldset>
      <p><button type="submit" class="btn btn-primary">Save</button></p>
    </form>

    <p><a href="{{content.backHref}}" class="btn btn-outline">Back to Templates</a></p>
  </section>
</div>
