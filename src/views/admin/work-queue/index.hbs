<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    <p>{{content.totalOpen}} open item{{#unless (eq content.totalOpen 1)}}s{{/unless}}.</p>
  </div>
</div>

<div class="wrapper">
  {{#if content.resolvedFlag}}
    <p class="form-success-banner" role="status">Item resolved and email reply dispatched.</p>
  {{/if}}
  {{#if content.resolvedQuietFlag}}
    <p class="form-success-banner" role="status">Item resolved.</p>
  {{/if}}
  {{#if content.reviewedFlag}}
    <p class="form-success-banner" role="status">Item marked reviewed.</p>
  {{/if}}
  {{#if content.claimedFlag}}
    <p class="form-success-banner" role="status">Item claimed. It is now off the other admins' digest.</p>
  {{/if}}
  {{#if content.claimNoopFlag}}
    <p class="form-notice" role="status">That item was already claimed or is no longer open.</p>
  {{/if}}
  {{#if content.errorMessage}}
    <div class="form-error-banner" role="alert">{{content.errorMessage}}</div>
  {{/if}}

  {{#unless content.groups.length}}
    <section>
      <p class="text-muted">No open work-queue items.</p>
    </section>
  {{/unless}}

  {{#each content.groups}}
    <section>
      <div class="section-heading">
        <h2>{{categoryLabel}}</h2>
        <span class="section-count">{{items.length}}</span>
      </div>
      {{#each items}}
        <div class="card work-queue-item">
          <div class="card-title">{{taskTypeLabel}}</div>
          <p class="card-meta">
            Opened {{openedAtDisplay}}
            {{#if entityDisplayName}}
              &middot; {{#if entityHref}}<a href="{{entityHref}}">{{entityDisplayName}}</a>{{else}}{{entityDisplayName}}{{/if}}
            {{/if}}
          </p>
          {{#if reasonText}}
            <p>{{reasonText}}</p>
          {{/if}}
          {{#if detailText}}
            <p class="text-secondary">{{detailText}}</p>
          {{/if}}
          {{#if entityReference}}
            <p class="card-meta">{{entityReference.label}} {{entityReference.id}}</p>
          {{/if}}

          {{#if isClaimed}}
            <p class="card-meta">{{#if claimedByMe}}Claimed by you.{{else}}Claimed by {{claimedByName}}.{{/if}}</p>
          {{else}}
            <form method="POST" action="/admin/work-queue/{{id}}/claim" class="form-block">
              <button type="submit" class="btn btn-outline btn-sm">Claim</button>
            </form>
          {{/if}}

          {{#if isLinkHelpRequest}}
            {{#if linkHelp}}
              {{#if linkHelp.isDispute}}<p class="badge">Conflict dispute</p>{{/if}}
              <p>{{linkHelp.statement}}</p>
              <p class="card-meta">
                {{#if linkHelp.claimedLegacyUsername}}Claimed legacy username: {{linkHelp.claimedLegacyUsername}}.{{/if}}
                {{#if linkHelp.claimedLegacyEmail}} Claimed legacy email: {{linkHelp.claimedLegacyEmail}}.{{/if}}
                {{#if linkHelp.vouchers}} Vouchers: {{linkHelp.vouchers}}.{{/if}}
              </p>
            {{/if}}
            <form method="POST" action="/admin/work-queue/{{id}}/link-help/approve" class="form-block">
              <div class="form-field">
                <label for="link_help_target_{{id}}">Legacy account id to link</label>
                <input id="link_help_target_{{id}}" name="target_legacy_member_id" maxlength="200" />
              </div>
              <div class="form-field">
                <label for="link_help_target_hp_{{id}}">Historical person id to link</label>
                <input id="link_help_target_hp_{{id}}" name="target_historical_person_id" maxlength="200" />
              </div>
              <p class="card-meta">Enter exactly one target: the legacy account id, or the historical person id for a competition-record link.</p>
              <button type="submit" class="btn btn-primary btn-sm">Approve and Link</button>
            </form>
            <form method="POST" action="/admin/work-queue/{{id}}/link-help/reject" class="form-block">
              <div class="form-field">
                <label for="link_help_reason_{{id}}">Rejection reason</label>
                <textarea id="link_help_reason_{{id}}" name="reason" rows="2" maxlength="500" required></textarea>
              </div>
              <button type="submit" class="btn btn-outline btn-sm">Reject</button>
            </form>
            {{#if linkHelp.isDispute}}
            <form method="POST" action="/admin/work-queue/{{id}}/link-help/dispute-revert" class="form-block">
              <div class="form-field">
                <label for="dispute_holder_{{id}}">Current holder's member id (claim to revert)</label>
                <input id="dispute_holder_{{id}}" name="holder_member_id" required maxlength="200" />
              </div>
              <div class="form-field">
                <label for="dispute_reason_{{id}}">Dispute reason</label>
                <textarea id="dispute_reason_{{id}}" name="reason" rows="2" maxlength="500" required></textarea>
              </div>
              <button type="submit" class="btn btn-outline btn-sm">Uphold Dispute: Revert Holder's Claim</button>
            </form>
            {{/if}}
          {{else if isReviewFlag}}
            <form method="POST" action="/admin/work-queue/{{id}}/dismiss" class="form-block">
              <div class="form-field">
                <label for="review_note_{{id}}">Review note (optional)</label>
                <textarea id="review_note_{{id}}" name="note" rows="2" maxlength="500" placeholder="Internal note; not sent to the member"></textarea>
              </div>
              <p class="card-meta">Linking is not reverted here. To undo a wrong link, open a member link-help dispute and use the revert action.</p>
              <button type="submit" class="btn btn-outline btn-sm">Mark Reviewed</button>
            </form>
          {{else if isReconciliationItem}}
            <p><a href="/admin/payments/reconciliation" class="btn btn-outline btn-sm">Review on the Reconciliation Page</a></p>
          {{else if showResolveForm}}
            <form method="POST" action="/admin/work-queue/{{id}}/resolve" class="form-block">
              <div class="form-field">
                <label for="decision_label_{{id}}">Decision</label>
                <select id="decision_label_{{id}}" name="decision_label" required>
                  <option value="" disabled selected>Choose a decision&hellip;</option>
                  {{#each decisionLabels}}
                    <option value="{{value}}">{{label}}</option>
                  {{/each}}
                </select>
              </div>
              <div class="form-field">
                <label for="resolution_note_{{id}}">Resolution note</label>
                <textarea id="resolution_note_{{id}}" name="resolution_note" rows="2" maxlength="500" required placeholder="{{resolutionNotePlaceholder}}"></textarea>
              </div>
              <button type="submit" class="btn btn-primary btn-sm">Resolve</button>
            </form>
          {{/if}}
        </div>
      {{/each}}
    </section>
  {{/each}}
</div>
