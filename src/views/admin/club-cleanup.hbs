<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    <p>{{content.totalItems}} item(s) requiring attention.</p>
  </div>
</div>

<div class="wrapper">
  <section>
    <form method="GET" action="/admin/club-cleanup" class="cleanup-filter-form">
      <select name="category" class="cleanup-action-select">
        <option value="">All categories</option>
        {{#each content.filters.categoryOptions}}
          <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>
      <input type="text" name="region" placeholder="Region or country" class="cleanup-reason-input" value="{{content.filters.region}}" />
      <select name="sort" class="cleanup-action-select">
        <option value="">Default order</option>
        {{#each content.filters.sortOptions}}
          <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>
      <button type="submit" class="btn btn-outline btn-sm">Filter</button>
      {{#if content.filters.isFiltered}}
        <a href="/admin/club-cleanup" class="fs-sm">Clear</a>
      {{/if}}
    </form>
  </section>

  <section class="mt-4">
    {{#if content.itemGroups.length}}
      {{#each content.itemGroups}}
        <details class="cleanup-group">
          <summary>{{this.label}} ({{this.count}})</summary>
          <form method="POST" action="/admin/club-cleanup/bulk-resolve" class="cleanup-action-form mt-2">
            <input type="hidden" name="group" value="{{this.predicate}}" />
            <select name="action" class="cleanup-action-select">
              <option value="defer_30">Defer all 30d</option>
              <option value="defer_90">Defer all 90d</option>
              <option value="defer_180">Defer all 180d</option>
            </select>
            <input type="text" name="reasonText" placeholder="Shared reason" class="cleanup-reason-input" />
            <button type="submit" class="btn btn-outline btn-sm">Bulk defer group</button>
          </form>
          <table class="cleanup-queue-table mt-2">
            <thead>
              <tr>
                <th>Club</th>
                <th>Location</th>
                <th>Status</th>
                <th>Detail</th>
                <th>Recommendation</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              {{#each this.items}}
                <tr>
                  <td class="fw-600">{{this.clubName}}
                    {{#if this.claimLabel}}<br /><span class="text-muted fs-sm">{{this.claimLabel}}</span>{{else}}
                    <form method="POST" action="/admin/club-cleanup/claim" class="cleanup-action-form mt-1">
                      <input type="hidden" name="itemType" value="club" />
                      <input type="hidden" name="itemId" value="{{this.clubId}}" />
                      <button type="submit" class="btn btn-outline btn-sm">Claim</button>
                    </form>
                    {{/if}}
                  </td>
                  <td class="text-muted">{{this.clubCity}}{{#if this.clubCountry}}, {{this.clubCountry}}{{/if}}</td>
                  <td><span class="badge">{{this.clubStatus}}</span></td>
                  <td class="text-muted fs-sm">{{this.detail}}</td>
                  <td class="fs-sm">{{this.recommendedAction}}</td>
                  <td>
                    {{#if (eq this.predicate 'leaderless_active')}}
                    <a href="/admin/clubs/{{this.clubId}}/leadership" class="btn btn-primary btn-sm">Add a co-leader</a>
                    <form method="POST" action="/admin/club-cleanup/{{this.clubId}}/contact-members" class="cleanup-action-form mt-1">
                      <button type="submit" class="btn btn-outline btn-sm">Contact members</button>
                    </form>
                    {{/if}}
                    <form method="POST" action="/admin/club-cleanup/{{this.clubId}}/resolve" class="cleanup-action-form">
                      <input type="hidden" name="predicate" value="{{this.predicate}}" />
                      <select name="action" class="cleanup-action-select">
                        <option value="demote_inactive">Demote</option>
                        <option value="archive">Archive</option>
                        <option value="dismiss">Dismiss</option>
                        <option value="defer_30">Defer 30d</option>
                        <option value="defer_90">Defer 90d</option>
                        <option value="defer_180">Defer 180d</option>
                      </select>
                      <input type="text" name="reasonText" placeholder="Reason" class="cleanup-reason-input" />
                      <button type="submit" class="btn btn-outline btn-sm">Apply</button>
                    </form>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </details>
      {{/each}}
    {{else}}
      <p>No clubs require attention. Signals are collected during member onboarding.</p>
    {{/if}}
  </section>

  {{#if content.candidateFlags.length}}
  <section class="mt-8">
    <details class="cleanup-group">
    <summary>Wizard flags by candidate ({{content.candidateFlags.length}})</summary>
    <p class="text-muted fs-sm">Activity answers members left about club candidates that have no live club row yet, so the viability gates cannot evaluate them. One vote per member; a member's latest answer wins. Dismiss is terminal; deferred flags re-surface after the window with a deferred-by annotation. Promoting the candidate moves its votes to the live club's viability evaluation.</p>
    <form method="POST" action="/admin/club-cleanup/bulk-resolve" class="cleanup-action-form mt-2">
      <input type="hidden" name="group" value="candidate_flag" />
      <select name="action" class="cleanup-action-select">
        <option value="defer_30">Defer all 30d</option>
        <option value="defer_90">Defer all 90d</option>
        <option value="defer_180">Defer all 180d</option>
      </select>
      <input type="text" name="reasonText" placeholder="Shared reason" class="cleanup-reason-input" />
      <button type="submit" class="btn btn-outline btn-sm">Bulk defer group</button>
    </form>
    <table class="cleanup-queue-table mt-2">
      <thead>
        <tr>
          <th>Candidate</th>
          <th>Location</th>
          <th>Classification</th>
          <th>Signals</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.candidateFlags}}
          <tr>
            <td class="fw-600">{{this.displayName}}{{#if this.deferAnnotation}}<br /><span class="text-muted fs-sm">{{this.deferAnnotation}}</span>{{/if}}
              {{#if this.claimLabel}}<br /><span class="text-muted fs-sm">{{this.claimLabel}}</span>{{else}}
              <form method="POST" action="/admin/club-cleanup/claim" class="cleanup-action-form mt-1">
                <input type="hidden" name="itemType" value="candidate" />
                <input type="hidden" name="itemId" value="{{this.candidateId}}" />
                <button type="submit" class="btn btn-outline btn-sm">Claim</button>
              </form>
              {{/if}}
            </td>
            <td class="text-muted">{{this.city}}{{#if this.country}}, {{this.country}}{{/if}}</td>
            <td><span class="badge">{{this.classificationLabel}}</span></td>
            <td class="text-muted fs-sm">{{this.detail}}</td>
            <td>
              <form method="POST" action="/admin/club-cleanup/candidates/{{this.candidateId}}/resolve" class="cleanup-action-form">
                <input type="hidden" name="predicate" value="candidate_flags" />
                <select name="action" class="cleanup-action-select">
                  <option value="dismiss">Dismiss</option>
                  <option value="defer_30">Defer 30d</option>
                  <option value="defer_90">Defer 90d</option>
                  <option value="defer_180">Defer 180d</option>
                </select>
                <input type="text" name="reasonText" placeholder="Reason" class="cleanup-reason-input" />
                <button type="submit" class="btn btn-outline btn-sm">Apply</button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
    </details>
  </section>
  {{/if}}

  {{#if content.residue.length}}
  <section class="mt-8">
    <details class="cleanup-group">
    <summary>Unconfirmed legacy residue ({{content.residue.length}})</summary>
    <p class="text-muted fs-sm">Live clubs still showing legacy affiliations that no one has confirmed in onboarding. De-listing marks them as former-only so they stop rendering as possible members. The oldest-age column is an advisory grace signal; nothing is retired automatically.</p>
    <form method="POST" action="/admin/club-cleanup/bulk-delist-residue" class="cleanup-action-form mt-2">
      <input type="text" name="reasonText" placeholder="Shared reason" class="cleanup-reason-input" />
      <button type="submit" class="btn btn-outline btn-sm">De-list all unconfirmed</button>
    </form>
    <table class="cleanup-queue-table mt-2">
      <thead>
        <tr>
          <th>Club</th>
          <th>Location</th>
          <th>Status</th>
          <th>Unconfirmed</th>
          <th>Oldest</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.residue}}
          <tr>
            <td class="fw-600">{{this.clubName}}
              {{#if this.claimLabel}}<br /><span class="text-muted fs-sm">{{this.claimLabel}}</span>{{else}}
              <form method="POST" action="/admin/club-cleanup/claim" class="cleanup-action-form mt-1">
                <input type="hidden" name="itemType" value="club" />
                <input type="hidden" name="itemId" value="{{this.clubId}}" />
                <button type="submit" class="btn btn-outline btn-sm">Claim</button>
              </form>
              {{/if}}
            </td>
            <td class="text-muted">{{this.clubCity}}{{#if this.clubCountry}}, {{this.clubCountry}}{{/if}}</td>
            <td><span class="badge">{{this.clubStatus}}</span></td>
            <td>{{this.pendingCount}}</td>
            <td class="text-muted fs-sm">{{this.oldestPendingAgeLabel}}</td>
            <td>
              <form method="POST" action="/admin/club-cleanup/{{this.clubId}}/delist-residue" class="cleanup-action-form">
                <input type="text" name="reasonText" placeholder="Reason" class="cleanup-reason-input" />
                <button type="submit" class="btn btn-outline btn-sm">De-list unconfirmed</button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
    </details>
  </section>
  {{/if}}

  {{#if content.candidates.length}}
  <section class="mt-8">
    <details class="cleanup-group">
    <summary>Promotable candidates ({{content.candidates.length}})</summary>
    <p class="text-muted fs-sm">Legacy club candidates with no live club row yet. Promoting creates the live club and carries its unconfirmed legacy affiliations forward; members can also trigger promotion by confirming these clubs in onboarding. Demote moves an onboarding-visible candidate to dormant; archive is terminal.</p>
    <table class="cleanup-queue-table mt-2">
      <thead>
        <tr>
          <th>Candidate</th>
          <th>Location</th>
          <th>Classification</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.candidates}}
          <tr>
            <td class="fw-600">{{this.displayName}}{{#if this.deferAnnotation}}<br /><span class="text-muted fs-sm">{{this.deferAnnotation}}</span>{{/if}}
              {{#if this.claimLabel}}<br /><span class="text-muted fs-sm">{{this.claimLabel}}</span>{{else}}
              <form method="POST" action="/admin/club-cleanup/claim" class="cleanup-action-form mt-1">
                <input type="hidden" name="itemType" value="candidate" />
                <input type="hidden" name="itemId" value="{{this.candidateId}}" />
                <button type="submit" class="btn btn-outline btn-sm">Claim</button>
              </form>
              {{/if}}
            </td>
            <td class="text-muted">{{this.city}}{{#if this.country}}, {{this.country}}{{/if}}</td>
            <td><span class="badge">{{this.classificationLabel}}</span></td>
            <td>
              <form method="POST" action="/admin/club-cleanup/candidates/{{this.candidateId}}/promote" class="cleanup-action-form">
                <input type="text" name="reasonText" placeholder="Reason" class="cleanup-reason-input" />
                <button type="submit" class="btn btn-outline btn-sm">Promote to live club</button>
              </form>
              <form method="POST" action="/admin/club-cleanup/candidates/{{this.candidateId}}/resolve" class="cleanup-action-form mt-1">
                <select name="action" class="cleanup-action-select">
                  <option value="demote">Demote to dormant</option>
                  <option value="archive">Archive</option>
                  <option value="defer_30">Defer 30d</option>
                  <option value="defer_90">Defer 90d</option>
                  <option value="defer_180">Defer 180d</option>
                </select>
                <input type="text" name="reasonText" placeholder="Reason" class="cleanup-reason-input" />
                <button type="submit" class="btn btn-outline btn-sm">Apply</button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
    </details>
  </section>
  {{/if}}

  {{#if content.junkCandidates.length}}
  <section class="mt-8">
    <details class="cleanup-group">
    <summary>Junk-flagged candidates ({{content.junkCandidates.length}})</summary>
    <p class="text-muted fs-sm">Candidates the classifier marked junk. Junk never renders on any public surface. Confirm the verdict (terminal), or promote to dormant to return the candidate to normal evaluation.</p>
    <table class="cleanup-queue-table mt-2">
      <thead>
        <tr>
          <th>Candidate</th>
          <th>Location</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.junkCandidates}}
          <tr>
            <td class="fw-600">{{this.displayName}}
              {{#if this.claimLabel}}<br /><span class="text-muted fs-sm">{{this.claimLabel}}</span>{{else}}
              <form method="POST" action="/admin/club-cleanup/claim" class="cleanup-action-form mt-1">
                <input type="hidden" name="itemType" value="candidate" />
                <input type="hidden" name="itemId" value="{{this.candidateId}}" />
                <button type="submit" class="btn btn-outline btn-sm">Claim</button>
              </form>
              {{/if}}
            </td>
            <td class="text-muted">{{this.city}}{{#if this.country}}, {{this.country}}{{/if}}</td>
            <td>
              <form method="POST" action="/admin/club-cleanup/candidates/{{this.candidateId}}/resolve" class="cleanup-action-form">
                <select name="action" class="cleanup-action-select">
                  <option value="confirm_junk">Confirm junk</option>
                  <option value="promote_dormant">Promote to dormant</option>
                </select>
                <input type="text" name="reasonText" placeholder="Reason" class="cleanup-reason-input" />
                <button type="submit" class="btn btn-outline btn-sm">Apply</button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
    </details>
  </section>
  {{/if}}

  <section>
    <p class="mt-6"><a href="/admin">&larr; Admin Dashboard</a></p>
  </section>
</div>
