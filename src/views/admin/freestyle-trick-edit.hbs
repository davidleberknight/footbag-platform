<div class="hero hero-sm">
  <div>
    <h1>{{content.fields.canonicalName}}</h1>
    <p class="text-muted">Editing freestyle trick <code>{{content.slug}}</code>.</p>
  </div>
</div>

<div class="wrapper">
  <section>
    {{#if content.saved}}
    <p class="notice notice-info">Saved.</p>
    {{/if}}
    {{#if content.hasErrors}}
    <div class="form-error-banner">
      {{#each content.errorList}}<p>{{this}}</p>{{/each}}
    </div>
    {{/if}}

    <form method="POST" action="/admin/freestyle/tricks/{{content.slug}}/edit" class="freestyle-edit-form">
      <fieldset>
        <p><label>Canonical name</label><br><input type="text" name="canonicalName" value="{{content.fields.canonicalName}}" /></p>
        <p><label>ADD</label><br><input type="text" name="adds" value="{{content.fields.adds}}" /></p>
        <p><label>Movement notation</label><br><textarea name="movementNotation" rows="2">{{content.fields.movementNotation}}</textarea></p>
        <p><label>Execution notation</label><br><textarea name="executionNotation" rows="2">{{content.fields.executionNotation}}</textarea></p>
        <p><label>Trick family</label><br><input type="text" name="family" value="{{content.fields.family}}" /></p>
        <p><label>Base trick</label><br><input type="text" name="baseTrick" value="{{content.fields.baseTrick}}" /></p>
        <p><label>Category</label><br>
          <select name="category">
            {{#each content.categoryOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
          </select>
        </p>
        <p><label><input type="checkbox" name="isActive" {{#if content.fields.isActive}}checked{{/if}} /> Active</label></p>
        <p><label>Review status</label><br>
          <select name="reviewStatus">
            {{#each content.reviewStatusOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
          </select>
        </p>
      </fieldset>
      <p><button type="submit" class="btn btn-primary btn-sm">Save</button></p>
    </form>

    <h2 class="section-heading">Aliases</h2>
    {{#if content.hasAliasError}}
    <div class="form-error-banner">
      <p>{{content.aliasError}}</p>
    </div>
    {{/if}}
    {{#if content.hasAliases}}
    <ul class="freestyle-edit-list">
      {{#each content.aliases}}
      <li>
        <code>{{this.slug}}</code> {{this.text}} <span class="badge">{{this.type}}</span>
        <form method="POST" action="{{this.deleteHref}}" class="inline-form">
          <button type="submit" class="btn btn-outline btn-sm">Remove</button>
        </form>
      </li>
      {{/each}}
    </ul>
    {{else}}<p class="text-muted">No aliases.</p>{{/if}}

    <form method="POST" action="{{content.addAliasHref}}" class="freestyle-edit-form">
      <fieldset>
        <p><label>Add alias</label><br><input type="text" name="aliasText" value="{{content.aliasFormText}}" placeholder="Alias name" /></p>
        <p><label>Type</label><br>
          <select name="aliasType">
            {{#each content.aliasTypeOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
          </select>
        </p>
      </fieldset>
      <p><button type="submit" class="btn btn-primary btn-sm">Add Alias</button></p>
    </form>

    <h2 class="section-heading">Sources</h2>
    {{#if content.hasSourceError}}
    <div class="form-error-banner">
      <p>{{content.sourceError}}</p>
    </div>
    {{/if}}
    {{#if content.hasSources}}
    <ul class="freestyle-edit-list">
      {{#each content.sources}}
      <li>
        {{this.label}} <span class="badge">{{this.type}}</span>{{#if this.assertedAdds}} (asserts ADD {{this.assertedAdds}}){{/if}}
        <form method="POST" action="{{this.detachHref}}" class="inline-form">
          <button type="submit" class="btn btn-outline btn-sm">Detach</button>
        </form>
      </li>
      {{/each}}
    </ul>
    {{else}}<p class="text-muted">No sources.</p>{{/if}}

    {{#if content.hasUnlinkedSources}}
    <form method="POST" action="{{content.attachSourceHref}}" class="freestyle-edit-form">
      <fieldset>
        <p><label>Attach source</label><br>
          <select name="sourceId">
            <option value="">Choose a source</option>
            {{#each content.sourceOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}
          </select>
        </p>
        <p><label>External URL (optional)</label><br><input type="text" name="externalUrl" value="{{content.sourceFormExternalUrl}}" /></p>
        <p><label>Asserted ADD (optional)</label><br><input type="text" name="assertedAdds" value="{{content.sourceFormAssertedAdds}}" /></p>
      </fieldset>
      <p><button type="submit" class="btn btn-primary btn-sm">Attach Source</button></p>
    </form>
    {{else}}<p class="text-muted">All registry sources are linked.</p>{{/if}}

    <h2 class="section-heading">Modifier links</h2>
    {{#if content.hasModifierLinks}}
    <ul class="freestyle-edit-list">
      {{#each content.modifierLinks}}<li>{{this.name}} <code>{{this.slug}}</code> <span class="badge">{{this.type}}</span> (+{{this.addBonus}}, order {{this.applyOrder}})</li>{{/each}}
    </ul>
    {{else}}<p class="text-muted">No modifier links.</p>{{/if}}

    <p><a href="{{content.backHref}}" class="btn btn-outline btn-sm">Back to freestyle content</a></p>
  </section>
</div>
