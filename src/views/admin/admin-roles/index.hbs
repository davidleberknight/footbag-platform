<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
  </div>
</div>

<div class="wrapper">
  {{#if content.errorMessage}}
    <div class="form-error-banner" role="alert">{{content.errorMessage}}</div>
  {{/if}}
  {{#if content.notice}}
    <p class="form-success-banner" role="status">{{content.notice}}</p>
  {{/if}}

  <section>
    <div class="section-heading">
      <h2>Current administrators ({{content.admins.length}})</h2>
    </div>
    {{#unless content.admins.length}}
      <p class="text-muted">No administrators.</p>
    {{/unless}}
    {{#each content.admins}}
      <div class="card">
        <div class="card-title"><a href="{{profileHref}}">{{displayName}}</a> <span class="badge">{{slug}}</span></div>
        {{#if isSelf}}
          <p class="text-muted fs-sm">You cannot revoke your own admin role.</p>
        {{else}}
          <form method="POST" action="/admin/admin-roles/{{memberId}}/revoke" class="form-block">
            <div class="form-field">
              <label for="revoke_reason_{{memberId}}">Reason (required)</label>
              <input id="revoke_reason_{{memberId}}" name="reason" required maxlength="500" />
            </div>
            <button type="submit" class="btn btn-outline btn-sm">Revoke Admin Role</button>
          </form>
        {{/if}}
      </div>
    {{/each}}
  </section>

  <section>
    <div class="section-heading"><h2>Grant the admin role</h2></div>
    <p class="text-muted fs-sm">The member must already hold Tier 2 or Tier 3 status.</p>
    <form method="POST" action="/admin/admin-roles/grant" class="form-block">
      <div class="form-field">
        <label for="grant_member">Member id or slug</label>
        <input id="grant_member" name="member_key" required maxlength="200" />
      </div>
      <div class="form-field">
        <label for="grant_reason">Reason (required)</label>
        <input id="grant_reason" name="reason" required maxlength="500" />
      </div>
      <button type="submit" class="btn btn-primary btn-sm">Grant Admin Role</button>
    </form>
  </section>

  <p class="mt-4"><a href="/admin">Back to the admin dashboard</a></p>
</div>
