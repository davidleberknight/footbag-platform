{{!-- Admin curator named-gallery list. FH-owned named galleries; one row per gallery. --}}
<div class="wrapper">
  <h1>{{page.title}}</h1>
  <p>
    Public named galleries owned by the FH/curator system account. Membership is computed
    at request time by tag-AND match against each gallery's criteria-tag set, minus any
    item that carries an exclude tag.
  </p>
  <p>
    Edit metadata, sort order, or tag sets below. Use the Create button to add a new
    gallery; the Delete action in the row removes both the DB row and the JSON sidecar
    at <code>/curated/galleries/&lt;slug&gt;.json</code>.
  </p>

  <p>
    <a href="/admin/curator/galleries/new" class="btn btn-primary">Create new gallery</a>
  </p>

  {{#if savedFlag}}
    <div class="form-success-banner" role="status">
      Saved.
    </div>
  {{/if}}

  {{#if emptyState}}
    <p class="empty-state">No FH-owned named galleries yet. Use the Create button above, or run <code>python scripts/seed_fh_curator.py</code> to bootstrap from <code>/curated/galleries/*.json</code>.</p>
  {{else}}
    <table class="curator-list">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Description</th>
          <th>Sort order</th>
          <th>Criteria tags</th>
          <th>Exclude tags</th>
          <th>Items</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each items}}
          <tr>
            <td><code>{{id}}</code></td>
            <td>{{name}}</td>
            <td>{{description}}</td>
            <td><code>{{sortOrder}}</code></td>
            <td>
              {{#each criteriaTags}}
                <code class="tag-chip">{{this}}</code>
              {{/each}}
            </td>
            <td>
              {{#each excludeTags}}
                <code class="tag-chip">{{this}}</code>
              {{else}}
                <span class="text-muted">(none)</span>
              {{/each}}
            </td>
            <td>{{itemCount}}</td>
            <td>
              <a href="/admin/curator/galleries/{{id}}/edit">Edit</a>
              <a href="/media/{{id}}" target="_blank" rel="noopener noreferrer">View</a>
              <form method="POST" action="/admin/curator/galleries/{{id}}/delete" class="inline-form" onsubmit="return confirm('Delete gallery {{id}}? This removes both the DB row and the JSON sidecar at /curated/galleries/&lt;slug&gt;.json on disk.');">
                <button type="submit" class="btn-link-danger">Delete</button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{/if}}
</div>
