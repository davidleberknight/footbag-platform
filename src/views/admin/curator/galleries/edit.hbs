{{!-- Admin curator named-gallery edit form (FH-owned only). --}}
<div class="wrapper">
  <h1>{{page.title}}</h1>

  {{#if notFound}}
    <p class="error">Gallery <code>{{galleryId}}</code> not found.</p>
    <p><a href="/admin/curator/galleries">&lsaquo; Back to galleries</a></p>
  {{else}}
    <p>
      Editing <code>{{gallery.id}}</code>. Membership rule: an item appears in this gallery iff
      it carries every <strong>criteria tag</strong> AND no <strong>exclude tag</strong>.
    </p>

    {{> gallery-edit-form
        formAction=formAction
        gallery=gallery
        errorMessage=errorMessage
        cancelHref="/admin/curator/galleries"
    }}
  {{/if}}
</div>
