<div class="wrapper">
  <h1>{{page.title}}</h1>
  <p>
    Curated media uploaded by the FH/curator system account.
    Total: {{total}} item{{#unless (eq total 1)}}s{{/unless}}.
    <a href="/admin/curator/upload">Upload new</a>.
  </p>

  {{#if savedFlag}}
    <div class="form-success-banner" role="status">
      {{#if (eq savedFlag "edit")}}
        Saved. If this was a URL-reference (YouTube/Vimeo) item, the sidecar under <code>/curated/</code> was rewritten;
        run <code>python scripts/seed_fh_curator.py</code> to fully resync the platform DB.
      {{/if}}
      {{#if (eq savedFlag "delete")}}
        Deleted. If this was a URL-reference (YouTube/Vimeo) item, the sidecar under <code>/curated/</code> was removed;
        run <code>python scripts/seed_fh_curator.py</code> to fully resync the platform DB.
      {{/if}}
    </div>
  {{/if}}

  <form method="GET" action="/admin/curator/media" class="curator-list-filter">
    <label>
      Filter by tag:
      <input type="text" name="tag" value="{{tagFilter}}" placeholder="#example_tag">
    </label>
    <button type="submit">Apply</button>
    {{#if tagFilter}}
      <a href="/admin/curator/media">Clear filter</a>
    {{/if}}
  </form>

  {{#if emptyState}}
    <p class="empty-state">
      {{#if tagFilter}}
        No curated media match the tag <code>{{tagFilter}}</code>.
      {{else}}
        No curated media yet. <a href="/admin/curator/upload">Upload the first one</a>.
      {{/if}}
    </p>
  {{else}}
    <table class="curator-list">
      <thead>
        <tr>
          <th>Thumbnail</th>
          <th>
            <a href="{{sortLinks.type}}">Type</a>{{#if sortIndicator.type}} <span class="sort-indicator" aria-label="sorted ascending">▲</span>{{/if}}
          </th>
          <th>
            <a href="{{sortLinks.caption}}">Caption</a>{{#if sortIndicator.caption}} <span class="sort-indicator" aria-label="sorted ascending">▲</span>{{/if}}
          </th>
          <th>Tags</th>
          <th>
            <a href="{{sortLinks.date}}">Uploaded</a>{{#if (eq sortIndicator.date "desc")}} <span class="sort-indicator" aria-label="sorted descending">▼</span>{{/if}}{{#if (eq sortIndicator.date "asc")}} <span class="sort-indicator" aria-label="sorted ascending">▲</span>{{/if}}
          </th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each items}}
          <tr>
            <td>
              {{#if thumbnailUrl}}
                <img src="{{thumbnailUrl}}" alt="" class="curator-thumb" width="80" height="80">
              {{/if}}
            </td>
            <td>{{mediaType}}</td>
            <td>{{caption}}</td>
            <td>
              {{#each tags}}
                <code class="tag-chip">{{this}}</code>
              {{/each}}
            </td>
            <td>{{formatDate uploadedAt}}</td>
            <td>
              <a href="/admin/curator/media/{{mediaId}}/edit">Edit</a>
              {{#if (eq mediaId ../confirmDeleteId)}}
                <form method="POST" action="/admin/curator/media/{{mediaId}}/delete" class="inline-form">
                  <input type="hidden" name="confirmed" value="1" />
                  <span class="text-secondary">Are you sure?</span>
                  <button type="submit" class="delete-button">Confirm delete</button>
                  <a href="/admin/curator/media">Cancel</a>
                </form>
              {{else}}
                <form method="POST" action="/admin/curator/media/{{mediaId}}/delete" class="inline-form" data-confirm="Permanently delete this curated media item? This cannot be undone.">
                  <button type="submit" class="delete-button">Delete</button>
                </form>
              {{/if}}
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>

    <nav class="curator-pagination">
      Page {{currentPage}} of {{totalPages}}
      {{#if prevPageHref}}
        <a href="{{prevPageHref}}">&lsaquo; Previous</a>
      {{/if}}
      {{#if nextPageHref}}
        <a href="{{nextPageHref}}">Next &rsaquo;</a>
      {{/if}}
    </nav>
  {{/if}}
</div>
