<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    <p class="text-muted">Browse the freestyle trick dictionary. {{content.totalCount}} row(s) shown.</p>
  </div>
</div>

<div class="wrapper">
  <section>
    <form method="GET" action="/admin/freestyle/tricks" class="freestyle-admin-filter">
      <input type="text" name="q" placeholder="Search name or slug" value="{{content.filters.query}}" />
      <select name="active" aria-label="Filter by active state">
        {{#each content.filters.activeOptions}}
          <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>
      <select name="reviewStatus" aria-label="Filter by review status">
        {{#each content.filters.reviewStatusOptions}}
          <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>
      <button type="submit" class="btn btn-outline btn-sm">Search</button>
      {{#if content.filters.isFiltered}}
        <a href="/admin/freestyle/tricks" class="btn btn-outline btn-sm">Clear</a>
      {{/if}}
    </form>

    {{#if content.hasRows}}
      <table class="freestyle-admin-table mt-2">
        <thead>
          <tr>
            <th>Name</th>
            <th>Slug</th>
            <th>ADD</th>
            <th>Family</th>
            <th>Active</th>
            <th>Review status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each content.rows}}
            <tr>
              <td>{{this.displayName}}</td>
              <td><code>{{this.slug}}</code></td>
              <td>{{this.adds}}</td>
              <td>{{this.family}}</td>
              <td>{{#if this.isActive}}<span class="badge">Active</span>{{else}}Inactive{{/if}}</td>
              <td>{{this.reviewStatusLabel}}</td>
              <td><a href="{{this.editHref}}" class="btn btn-outline btn-sm">Edit</a></td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p class="text-muted mt-2">No freestyle tricks match your search.</p>
    {{/if}}
  </section>
</div>
