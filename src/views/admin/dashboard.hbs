<div class="hero hero-sm">
  <div>
    <h1>Admin Dashboard</h1>
    <p>Administrative actions for managing platform content and configuration.</p>
  </div>
</div>

<div class="wrapper">
  <section>
    <div class="card-grid card-grid-2col">
      <div class="card">
        <div class="card-title"><a href="/admin/curator/media">Curated media</a></div>
        <p class="card-description">Browse, edit, and delete curated photos and videos attributed to the system curator account. Upload new items from the list page.</p>
      </div>
      <div class="card">
        <div class="card-title"><a href="/admin/curator/galleries">Manage galleries</a></div>
        <p class="card-description">Create, edit, and delete the FH-curated named galleries that appear on /media. Member-owned galleries are managed by their owners.</p>
      </div>
      <div class="card">
        <div class="card-title"><a href="/admin/work-queue">Work queue</a></div>
        <p class="card-description">Open admin tasks across membership, events, media, payments, elections, and system. Member contact requests land here for review and resolution.</p>
      </div>
      <div class="card">
        <div class="card-title"><a href="/admin/club-cleanup">Club cleanup</a>{{#if content.backlog.hasBacklog}} <span class="badge">{{content.backlog.openCount}} open</span>{{/if}}</div>
        <p class="card-description">Review clubs with crowdsourced viability signals from onboarding. Demote inactive clubs, archive junk, or dismiss false positives.</p>
        {{#if content.backlog.hasBacklog}}
        <p class="card-meta">Oldest open item: {{content.backlog.oldestOpenAgeLabel}}</p>
        {{/if}}
      </div>
    </div>
  </section>
</div>
