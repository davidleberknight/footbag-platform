<div class="hero hero-sm">
  <div>
    <h1>Admin Dashboard</h1>
    <p>Administrative actions for managing platform content and configuration.</p>
  </div>
</div>

<div class="wrapper">
  <section>
    <div class="card-grid card-grid-2col">
      <div class="card">
        <div class="card-title"><a href="/admin/curator/media">Curated media</a></div>
        <p class="card-description">Browse, edit, and delete curated photos and videos attributed to the system curator account. Upload new items from the list page.</p>
      </div>
      <div class="card">
        <div class="card-title"><a href="/admin/curator/galleries">Manage galleries</a></div>
        <p class="card-description">Create, edit, and delete the FH-curated named galleries that appear on /media. Member-owned galleries are managed by their owners.</p>
      </div>
      <div class="card">
        <div class="card-title"><a href="/admin/work-queue">Work queue</a>{{#if content.workQueue.hasOpen}} <span class="badge">{{content.workQueue.totalOpen}} open</span>{{/if}}</div>
        <p class="card-description">Open admin tasks across membership, events, media, payments, elections, and system. Member contact requests land here for review and resolution.</p>
        {{#if content.workQueue.hasOpen}}
        <p class="card-meta">{{#each content.workQueue.categories}}<a href="{{this.href}}"{{#if this.hasUrgent}} class="fw-600"{{/if}}>{{this.label}}: {{this.count}}</a>{{#unless @last}} &middot; {{/unless}}{{/each}}</p>
        {{/if}}
      </div>
      <div class="card">
        <div class="card-title"><a href="/admin/club-cleanup">Club cleanup</a>{{#if content.backlog.hasBacklog}} <span class="badge">{{content.backlog.openCount}} open</span>{{/if}}</div>
        <p class="card-description">Review clubs with crowdsourced viability signals from onboarding. Demote inactive clubs, archive junk, or dismiss false positives.</p>
        {{#if content.backlog.hasBacklog}}
        <p class="card-meta">Oldest open item: {{content.backlog.oldestOpenAgeLabel}}</p>
        {{/if}}
      </div>
      <div class="card">
        <div class="card-title"><a href="/admin/freestyle/tricks">Freestyle content</a></div>
        <p class="card-description">Browse and search the freestyle trick dictionary by name or slug, filtered by active state and review status. Read-only for now; editing lands in a later slice.</p>
      </div>
      <div class="card">
        <div class="card-title"><a href="/admin/admin-roles">Admin roles</a></div>
        <p class="card-description">Grant or revoke the platform administrator role. Granting requires the member to hold Tier 2 or Tier 3, and every change is reasoned, audited, and emailed to the member.</p>
      </div>
      <div class="card">
        <div class="card-title"><a href="/admin/audit-log">Audit log</a></div>
        <p class="card-description">Search the append-only audit trail by member, date, action type, or category to investigate a complaint or confirm a flow logged correctly. Read-only.</p>
      </div>
      <div class="card">
        <div class="card-title"><a href="/admin/email-log">Email log</a></div>
        <p class="card-description">Browse outbound email by recipient, template, or status to diagnose a delivery problem or confirm a message was queued. Bodies shown as unpopulated templates; read-only.</p>
      </div>
      <div class="card">
        <div class="card-title"><a href="/admin/email-templates">Email templates</a></div>
        <p class="card-description">Edit the wording, enabled flag, and classification of the platform's outbound email templates. Audited per save; editing only.</p>
      </div>
    </div>
  </section>
</div>
