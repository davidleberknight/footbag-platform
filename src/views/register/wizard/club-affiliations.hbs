<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
  </div>
</div>

<div class="wrapper">
  <section>
    {{#if content.resolvedNotice}}
      <p class="form-success-banner" role="status">
        {{content.resolvedNotice.message}}
      </p>
    {{/if}}

    {{#if content.formError}}
      <p class="form-notice" role="alert">{{content.formError}}</p>
    {{/if}}

    {{#each content.leadershipOffers}}
      <div class="card card-static mb-4">
        <div class="card-title">{{this.clubName}} has no listed contact</div>
        <p>You're the first member to claim this club. Would you like to be its contact? You can step down at any time.</p>
        <form method="POST" action="/register/wizard/club_affiliations/leadership-offer" class="candidate-card-action">
          <input type="hidden" name="clubId" value="{{this.clubId}}" />
          <input type="hidden" name="decision" value="accept" />
          <button type="submit" class="btn btn-primary">Yes, make me the contact</button>
        </form>
        <form method="POST" action="/register/wizard/club_affiliations/leadership-offer" class="candidate-card-action">
          <input type="hidden" name="clubId" value="{{this.clubId}}" />
          <input type="hidden" name="decision" value="decline" />
          <button type="submit" class="btn btn-outline">No thanks</button>
        </form>
      </div>
    {{/each}}

    {{#if content.card}}
      {{#if (gt content.cardsRemaining 1)}}
        <p class="text-muted fs-sm">{{content.cardsRemaining}} clubs to review.</p>
      {{/if}}
      {{#if (eq content.cardsRemaining 1)}}
        {{#if (gt content.cardsTotal 1)}}
          <p class="text-muted fs-sm">Last one.</p>
        {{/if}}
      {{/if}}

      {{#if content.card.isMembership}}
        <h2>About {{content.card.clubName}}</h2>
        <p class="text-muted">Match strength: {{content.card.confidenceBandLabel}}</p>
        {{#if content.card.clubDescription}}<p class="text-muted fs-sm mt-2">{{content.card.clubDescription}}</p>{{/if}}
        {{#if content.card.clubExternalUrl}}
          <p class="fs-sm mt-1">{{externalLink content.card.clubExternalUrl label="Club website"}}</p>
        {{/if}}
        <p class="text-muted fs-sm">Source: legacy roster records.</p>
      {{/if}}

      {{#if content.card.isLeadership}}
        <h2>About {{content.card.clubName}}</h2>
        <p class="text-muted">Listed as: {{content.card.roleLabel}}</p>
        {{#if content.card.clubDescription}}<p class="text-muted fs-sm mt-2">{{content.card.clubDescription}}</p>{{/if}}
        {{#if content.card.clubExternalUrl}}
          <p class="fs-sm mt-1">{{externalLink content.card.clubExternalUrl label="Club website"}}</p>
        {{/if}}
        <p class="badge mt-2">{{content.card.classificationLabel}}</p>
        <ul class="signal-checklist mt-4">
          {{#each content.card.signals}}
            <li class="signal-checklist-row">
              <span class="signal-checklist-mark">{{#if this.isPresent}}&#10004;{{else}}&#9675;{{/if}}</span>
              <span class="signal-checklist-label">{{this.signalLabel}}</span>
            </li>
          {{/each}}
        </ul>
      {{/if}}

      {{#if content.card.isDisambiguation}}
        <h2>Which clubs in {{content.card.city}} were you part of?</h2>
        <p class="text-muted fs-sm">Select all that apply, or leave unchecked if none.</p>

        <form method="POST" action="{{content.submitHref}}" class="mt-6">
          <input type="hidden" name="kind" value="disambiguation" />
          {{#each content.card.clubs}}
            <input type="hidden" name="allCandidateIds" value="{{this.candidateId}}" />
          {{/each}}

          <ul class="disambiguation-club-list">
            {{#each content.card.clubs}}
              <li class="disambiguation-club-item">
                <label class="disambiguation-club-label">
                  <input type="checkbox" name="selectedCandidateIds" value="{{this.candidateId}}" />
                  <span class="fw-600">{{this.clubName}}</span>
                  <span class="text-muted fs-sm">({{this.confidenceBandLabel}} match)</span>
                </label>
                {{#if this.clubDescription}}<p class="text-muted fs-sm mt-1 mb-0">{{this.clubDescription}}</p>{{/if}}
                {{#if this.clubExternalUrl}}<p class="fs-sm mt-1 mb-0">{{externalLink this.clubExternalUrl label="Club website"}}</p>{{/if}}
              </li>
            {{/each}}
          </ul>

          <button type="submit" class="btn btn-primary mt-4">Confirm selection</button>
        </form>

        <p class="audit-notice text-muted fs-sm mt-4">This decision is recorded.</p>

        <form method="POST" action="{{content.skipHref}}" class="mt-6">
          <button type="submit" class="btn-link text-muted">Skip remaining clubs for now</button>
        </form>
      {{/if}}

      {{#unless content.card.isDisambiguation}}
      <form method="POST" action="{{content.submitHref}}" class="mt-6 wizard-card-actions">
        <input type="hidden" name="kind"        value="{{content.card.kind}}" />
        <input type="hidden" name="candidateId" value="{{content.card.candidateId}}" />

        <fieldset class="activity-signal-fieldset mt-4 mb-6">
          <legend class="fs-sm fw-600">
            {{content.card.questionLabel}}
          </legend>
          <label class="radio-label"><input type="radio" name="userDecision" value="confirm" required /> Yes</label>
          <label class="radio-label"><input type="radio" name="userDecision" value="decline" required /> No</label>
        </fieldset>

        <fieldset class="activity-signal-fieldset mt-4 mb-6">
          <legend class="fs-sm fw-600">Is {{content.card.clubName}} still active?</legend>
          <p class="text-muted fs-sm mb-2">This helps us keep club listings accurate.</p>
          <label class="radio-label"><input type="radio" name="activitySignal" value="active" required /> Still active</label>
          <label class="radio-label"><input type="radio" name="activitySignal" value="not_active" required /> Not active anymore</label>
          <label class="radio-label"><input type="radio" name="activitySignal" value="not_sure" required /> Not sure</label>
        </fieldset>

        <p class="audit-notice text-muted fs-sm mb-4">Both answers required. Your answers will be saved.</p>

        <button type="submit" class="btn btn-primary">Save answers</button>
      </form>

      <p class="text-muted fs-sm mt-4">Not the right club? <a href="{{content.clubsBrowseHref}}">Browse all clubs</a> to find yours; you can come back to finish onboarding from your dashboard.</p>

      <form method="POST" action="{{content.skipHref}}" class="mt-6">
        <button type="submit" class="btn-link text-muted">Skip remaining clubs for now</button>
      </form>
      {{/unless}}
    {{else}}
      {{#if content.isStage2a}}
        <h2>Clubs in your area</h2>
        <p class="text-muted fs-sm">We're updating our club listings. If you recognize any of these, let us know if they're still active.</p>
        {{#if content.nearbyCandidates.length}}
          <ul class="candidate-list">
            {{#each content.nearbyCandidates}}
              <li class="candidate-card">
                <div class="candidate-card-name">{{this.display_name}}</div>
                {{#if this.city}}<div class="candidate-card-meta">{{this.city}}, {{this.country}}</div>{{/if}}
                <form method="POST" action="/register/wizard/club_affiliations/stage-signal" class="stage-signal-form mt-2">
                  <input type="hidden" name="candidateId" value="{{this.id}}" />
                  <input type="hidden" name="stage" value="stage2a" />
                  <label class="radio-label"><input type="radio" name="activitySignal" value="active" /> Still active</label>
                  <label class="radio-label"><input type="radio" name="activitySignal" value="not_active" /> Not active anymore</label>
                  <label class="radio-label"><input type="radio" name="activitySignal" value="not_sure" /> Not sure</label>
                  <label class="radio-label"><input type="radio" name="activitySignal" value="never_heard_of_it" /> Never heard of it</label>
                  <button type="submit" class="btn btn-outline btn-sm mt-1">Submit</button>
                </form>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p>No clubs found in your area.</p>
        {{/if}}
      {{else if content.isStage2b}}
        <h2>More clubs in your area</h2>
        <p class="text-muted fs-sm">Help us confirm whether these clubs are still around.</p>
        {{#if content.nearbyCandidates.length}}
          <ul class="candidate-list">
            {{#each content.nearbyCandidates}}
              <li class="candidate-card">
                <div class="candidate-card-name">{{this.display_name}}</div>
                {{#if this.city}}<div class="candidate-card-meta">{{this.city}}, {{this.country}}</div>{{/if}}
                <form method="POST" action="/register/wizard/club_affiliations/stage-signal" class="stage-signal-form mt-2">
                  <input type="hidden" name="candidateId" value="{{this.id}}" />
                  <input type="hidden" name="stage" value="stage2b" />
                  <label class="radio-label"><input type="radio" name="activitySignal" value="active" /> Still active</label>
                  <label class="radio-label"><input type="radio" name="activitySignal" value="not_active" /> Not active anymore</label>
                  <label class="radio-label"><input type="radio" name="activitySignal" value="not_sure" /> Not sure</label>
                  <label class="radio-label"><input type="radio" name="activitySignal" value="never_heard_of_it" /> Never heard of it</label>
                  <button type="submit" class="btn btn-outline btn-sm mt-1">Submit</button>
                </form>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p>No additional clubs found in your area.</p>
        {{/if}}
      {{else}}
        <h2>Find your club</h2>
        <p>We didn't link a club to your account yet. You can browse the clubs map to find your local club, or create a new one if yours isn't listed.</p>
        <p class="mt-4"><a href="/clubs" class="btn btn-outline">Clubs map</a> {{#if content.memberCountry}}<a href="{{content.clubsBrowseHref}}" class="btn btn-outline">Clubs in {{content.memberCountry}}</a>{{/if}}</p>
        {{#if content.canCreateClub}}
          <p class="mt-2"><a href="/clubs/create" class="btn btn-primary">Create a new club</a></p>
        {{else}}
          <div class="notice-card notice-card--warn mt-4">
            <p class="m-0">Creating a club requires IFPA Membership (Tier 1) because you become the club leader.</p>
          </div>
        {{/if}}
      {{/if}}
    {{/if}}

    <p class="mt-2"><a href="{{content.dashboardHref}}">Back to dashboard</a></p>
  </section>
</div>
