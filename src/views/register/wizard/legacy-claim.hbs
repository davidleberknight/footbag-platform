<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
  </div>
</div>

<div class="wrapper">
  <section>
    <p>Link your account to your history on the old footbag.org so your past results and clubs show on your profile. Do one of these: pick a suggested match below, add an email or surname you used on the old site to sharpen the matches, or search by your old footbag.org member ID.</p>
    <p class="text-muted fs-sm">Never had an account on the old footbag.org? Use the Continue Without Linking option below.</p>

    <form method="POST" action="/register/wizard/legacy_claim/skip" class="card card-static mb-4">
      <p>Linking your old footbag.org history is the expected next step. Only continue without linking if you never had an account on the old site.</p>
      <div class="form-field">
        <label>
          <input type="checkbox" name="no_old_account" value="1" required />
          I never had an account on the old footbag.org.
        </label>
      </div>
      <button type="submit" class="btn btn-outline">Continue Without Linking a Past Account</button>
    </form>

    {{#if content.validationMessage}}
      <p class="form-notice" role="alert">{{content.validationMessage}}</p>
    {{/if}}

    {{#if content.helpRequestNotice}}
      <p class="form-success-banner" role="status">Your request has been sent to an administrator. We'll email you once it has been reviewed.</p>
    {{/if}}

    {{#if (eq content.anchorSavedNotice 'saved')}}
      <p class="form-success-banner" role="status">Saved. We re-checked for matches with your updated details.</p>
    {{else if (eq content.anchorSavedNotice 'removed')}}
      <p class="form-success-banner" role="status">Removed. We re-checked for matches with your updated details.</p>
    {{/if}}

    {{#if (eq content.anchorVerificationNotice 'sent')}}
      <p class="form-success-banner" role="status">If that address can receive mail, a confirmation link is on its way. Open it while signed in to this account.</p>
      {{#if content.emailPreview}}
        {{> simulated-email-card content.emailPreview}}
      {{/if}}
    {{else if (eq content.anchorVerificationNotice 'verified')}}
      <p class="form-success-banner" role="status">Mailbox confirmed. Matches found through this address are treated as a stronger link to your old account.</p>
    {{else if (eq content.anchorVerificationNotice 'invalid')}}
      <p class="form-notice" role="alert">That confirmation link is no longer valid. You can request a fresh one below.</p>
    {{/if}}

    {{#if content.conflictPrompt}}
      <div class="card card-static mb-4">
        <div class="card-title">We already have a claim under this name. Is one of these you?</div>
        <ul>
          {{#each content.conflictPrompt.records}}
            <li><strong>{{this.displayName}}</strong> <span class="text-muted fs-sm">({{this.sourceLabel}})</span></li>
          {{/each}}
        </ul>
        <p class="text-muted fs-sm">These records are already linked to another account. If one of them is yours, tell an administrator and we'll investigate.</p>
        <form method="POST" action="/register/wizard/legacy_claim/help-request" class="form-block">
          <input type="hidden" name="is_dispute" value="1" />
          <div class="form-field">
            <label for="disputeStatement">Which record is yours, and how can we verify that?</label>
            <textarea id="disputeStatement" name="statement" rows="3" maxlength="2000" required></textarea>
          </div>
          <button type="submit" class="btn btn-outline btn-sm">Yes, One of These Is Me (Ask an Administrator)</button>
        </form>
      </div>
    {{/if}}

    {{#if content.lowConfidenceBanner}}
      <p class="form-notice" role="status">We didn't find a confident match for your name. If you had an account on the old footbag.org, try searching below by your old member ID, username, or email. If you never had one, you can continue without linking.</p>
    {{/if}}

    {{#if content.autoLinkDriftNotice}}
      <p class="form-notice" role="status">Your suggested match is no longer applicable. Pick a candidate below or search by id.</p>
    {{/if}}

    {{#if content.sentNotice.show}}
      <div class="form-success-banner" role="status">
        If an eligible legacy record was found, a confirmation link has been sent to the email address on the old account. Open that link in this same browser, while you are still signed in, to complete the claim. The link expires in 24 hours.
      </div>
      {{#if content.sentNotice.outcomeNote}}
        <p class="form-notice" role="status">{{content.sentNotice.outcomeNote}}</p>
      {{/if}}
      {{#if content.emailPreview}}
        {{> simulated-email-card content.emailPreview}}
      {{/if}}
    {{/if}}

    {{#if content.candidates.length}}
      <h2>Suggested matches</h2>
      <ul class="candidate-list">
        {{#each content.candidates}}
          <li class="candidate-card">
            <div class="candidate-card-name">{{this.displayName}}</div>
            <div class="candidate-card-provenance">{{this.provenanceLabel}}</div>
            {{#if this.aliasesLabel}}<div class="candidate-card-meta">{{this.aliasesLabel}}</div>{{/if}}
            {{#if this.country}}<div class="candidate-card-meta">Country: {{this.country}}</div>{{/if}}
            {{#if this.clubAffiliations.length}}
              <div class="candidate-card-meta text-muted fs-sm">Clubs: {{#each this.clubAffiliations}}{{#if @index}}, {{/if}}{{this}}{{/each}}</div>
            {{/if}}
            {{#if this.eventsAttended.length}}
              <div class="candidate-card-meta text-muted fs-sm">Events: {{#each this.eventsAttended}}{{#if @index}}, {{/if}}{{this.title}} ({{this.year}}){{/each}}</div>
            {{/if}}
            {{#if this.bioExcerpt}}<div class="candidate-card-meta text-muted fs-sm">{{this.bioExcerpt}}</div>{{/if}}
            {{#if this.isHof}}<div class="candidate-card-meta">Hall of Fame</div>{{/if}}
            {{#if this.isBap}}<div class="candidate-card-meta">Big Add Posse</div>{{/if}}
            {{#if (eq this.claimMode 'auto_link_confirm')}}
              <form method="POST" action="/register/wizard/legacy_claim/auto-link/confirm" class="candidate-card-action">
                <input type="hidden" name="personId" value="{{this.personId}}" />
                <button type="submit" class="btn btn-primary">This Is Me, Link My History</button>
              </form>
              <form method="POST" action="/register/wizard/legacy_claim/auto-link/decline" class="candidate-card-action">
                {{#if this.stagedCandidateId}}
                <input type="hidden" name="candidateId" value="{{this.stagedCandidateId}}" />
                {{else}}
                <input type="hidden" name="personId" value="{{this.personId}}" />
                {{/if}}
                <button type="submit" class="btn btn-outline">This Is Not Me</button>
              </form>
            {{else if (eq this.claimMode 'cross_source_legacy')}}
              <form method="POST" action="/register/wizard/legacy_claim/cross-source/confirm" class="candidate-card-action">
                <input type="hidden" name="candidateId" value="{{this.stagedCandidateId}}" />
                <button type="submit" class="btn btn-primary">Yes, This Is Also Me</button>
              </form>
              <form method="POST" action="/register/wizard/legacy_claim/auto-link/decline" class="candidate-card-action">
                <input type="hidden" name="candidateId" value="{{this.stagedCandidateId}}" />
                <button type="submit" class="btn btn-outline">This Is Not Me</button>
              </form>
            {{else if (eq this.claimMode 'legacy_claim')}}
              <form method="POST" action="/register/wizard/legacy_claim/find" class="candidate-card-action">
                <input type="hidden" name="identifier" value="{{this.legacyMemberId}}" />
                {{#if @root.content.turnstileSiteKey}}
                  <div class="cf-turnstile" data-sitekey="{{@root.content.turnstileSiteKey}}"></div>
                {{/if}}
                <button type="submit" class="btn btn-primary">Claim This Account</button>
              </form>
            {{else if (eq this.claimMode 'hp_review_page')}}
              <p class="text-muted fs-sm">This record was found by name match, and same-name coincidences happen. Only claim it if these results are really yours.</p>
              <p class="candidate-card-action"><a href="/history/{{this.personId}}/claim" class="btn btn-primary">Claim This Record</a></p>
            {{else if (eq this.claimMode 'already_linked')}}
              {{#if this.alreadyLinkedSinceDisplay}}
                <p class="candidate-card-linked">Linked {{this.alreadyLinkedSinceDisplay}}.</p>
              {{/if}}
            {{/if}}
          </li>
        {{/each}}
      </ul>
    {{/if}}

    <h2>Help us find your record</h2>
    <p class="text-muted fs-sm">If you used a different email address or surname on footbag.org, tell us here and we'll look for matching records.</p>

    {{#if content.declaredAnchors.length}}
      <ul class="mb-4">
        {{#each content.declaredAnchors}}
          <li class="mb-2">
            <span class="badge">{{this.anchorTypeLabel}}</span> {{this.anchorValue}}
            {{#if this.verified}}<span class="badge">Mailbox verified</span>{{/if}}
            {{#if this.canRequestVerification}}
            <form method="POST" action="/register/wizard/legacy_claim/anchors/send-verification" class="inline-form">
              <input type="hidden" name="anchorId" value="{{this.id}}" />
              <button type="submit" class="btn-link fs-sm">Verify This Mailbox</button>
            </form>
            {{/if}}
            <form method="POST" action="/register/wizard/legacy_claim/anchors/remove" class="inline-form">
              <input type="hidden" name="anchorId" value="{{this.id}}" />
              <button type="submit" class="btn-link text-muted fs-sm">Remove</button>
            </form>
          </li>
        {{/each}}
      </ul>
    {{/if}}

    <form method="POST" action="/register/wizard/legacy_claim/anchors/add" class="card card-static mb-4">
      <div class="form-field">
        <label for="oldEmail">Email address used on the old footbag.org site</label>
        <input type="email" id="oldEmail" name="anchorValue" placeholder="your-old-email@example.com" required />
        <input type="hidden" name="anchorType" value="old_email" />
        <small class="form-hint">If you used a different email on the old footbag.org, enter it here. Matching the email you used there helps confirm your legacy claim is really you.</small>
      </div>
      <button type="submit" class="btn btn-outline">Add Old Email</button>
    </form>

    <form method="POST" action="/register/wizard/legacy_claim/anchors/add" class="card card-static mb-6">
      <div class="form-field">
        <label for="formerSurname">Surname used on the old site</label>
        <input type="text" id="formerSurname" name="anchorValue" placeholder="Your previous last name" required />
        <input type="hidden" name="anchorType" value="former_surname" />
        <small class="form-hint">If you used a different surname on footbag.org, enter it here to help us find your account.</small>
      </div>
      <button type="submit" class="btn btn-outline">Add Former Name</button>
    </form>

    <h2 class="mt-6">Search for your old account or competition record</h2>
    <form method="POST" action="/register/wizard/legacy_claim/find" class="login-form">
      <div class="form-field">
        <label for="identifier">Old footbag.org member ID, username, or email, or competition-record ID</label>
        <input type="text" id="identifier" name="identifier" required />
      </div>
      {{#if content.turnstileSiteKey}}
        <div class="cf-turnstile" data-sitekey="{{content.turnstileSiteKey}}"></div>
      {{/if}}
      <button type="submit" class="btn btn-outline">Find</button>
    </form>

    <h2 class="mt-6">Still can't find your records?</h2>
    <form method="POST" action="/register/wizard/legacy_claim/help-request" class="card card-static mb-4">
      <div class="form-field">
        <label for="helpStatement">Tell an administrator which records you believe are yours</label>
        <textarea id="helpStatement" name="statement" rows="3" maxlength="2000" required placeholder="I competed at Worlds 2003 under the name..."></textarea>
      </div>
      <div class="form-field">
        <label for="helpUsername">Old footbag.org username (if known)</label>
        <input type="text" id="helpUsername" name="claimed_legacy_username" maxlength="200" />
      </div>
      <div class="form-field">
        <label for="helpEmail">Old footbag.org email (if known)</label>
        <input type="text" id="helpEmail" name="claimed_legacy_email" maxlength="200" />
      </div>
      <div class="form-field">
        <label for="helpVouchers">Community members who can vouch for you (optional)</label>
        <input type="text" id="helpVouchers" name="vouchers" maxlength="200" />
      </div>
      <button type="submit" class="btn btn-outline">Send to an Administrator</button>
    </form>

    <p class="mt-2"><a href="{{content.dashboardHref}}">Back to dashboard</a></p>
  </section>
</div>
{{#if content.turnstileSiteKey}}
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" defer></script>
{{/if}}
