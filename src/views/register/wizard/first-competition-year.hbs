<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
  </div>
</div>

<div class="wrapper">
  <section>
    <p>The year you first played in a footbag competition. Optional (shown on your profile if set; leave blank to omit it).</p>

    {{#if content.error}}
      <p class="form-notice" role="alert">{{content.error}}</p>
    {{/if}}

    <form method="POST" action="/register/wizard/first_competition_year/submit" class="profile-edit-form">
      <div class="form-field">
        <label for="year">First competition year</label>
        <input type="number" id="year" name="year" min="1972" inputmode="numeric" value="{{content.yearValue}}" />
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save</button>
      </div>
    </form>

    <form method="POST" action="/register/wizard/first_competition_year/skip" class="mt-6">
      <button type="submit" class="btn-link text-muted">Skip for now</button>
    </form>

    <p class="mt-2"><a href="{{content.dashboardHref}}">Back to dashboard</a></p>
  </section>
</div>
