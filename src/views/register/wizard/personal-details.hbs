<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
  </div>
</div>

<div class="wrapper">
  <section>
    <div class="card card-static">
      <div class="card-title">Your Details</div>
      <p>Tell us where you live now and when you were born. These fields come first because we use them to find your old footbag.org records in the next step. The fields marked (required) must be filled in to save.</p>

      {{#if content.error}}
        <p class="form-notice" role="alert">{{content.error}}</p>
      {{/if}}

      <form method="POST" action="/register/wizard/personal_details/submit" class="form-block">
        <div class="form-field">
          <label for="city">City <span class="fw-600">(required)</span></label>
          <input type="text" id="city" name="city" maxlength="64" value="{{content.city}}" required />
        </div>

        <div class="form-field">
          <label for="region">Region / State <span class="text-muted">(optional)</span></label>
          <input type="text" id="region" name="region" maxlength="64" value="{{content.region}}" />
          <small class="form-hint">For the USA, use the official two-letter state code (e.g. CA). For other countries, enter your province, county, or region name.</small>
        </div>

        <div class="form-field">
          <label for="country">Country <span class="fw-600">(required)</span></label>
          <input type="text" id="country" name="country" maxlength="64" value="{{content.country}}" required />
        </div>

        <div class="form-field">
          <label for="birthDate">Date of birth <span class="fw-600">(required)</span></label>
          <input type="date" id="birthDate" name="birthDate" value="{{content.birthDate}}" required />
          <small class="form-hint">Your date of birth helps us match your old footbag.org account and competition records. It is private: only you and administrators can see it.</small>
        </div>

        <fieldset class="form-fieldset">
          <legend>Gender (competition eligibility) <span class="text-muted">(optional)</span></legend>
          <p class="text-muted fs-sm">Private: visible only to you and IFPA admins. Never shown on public pages, member search, or rosters. Used only for gender-based event-category eligibility. Choose 'Prefer not to say' to keep it undisclosed; you can record your gender anytime to enter women's or mixed-doubles draws.</p>
          <div class="form-field">
            <label>
              <input type="radio" name="gender" value="male" {{#if (eq content.gender "male")}}checked{{/if}} />
              Male
            </label>
            <label>
              <input type="radio" name="gender" value="female" {{#if (eq content.gender "female")}}checked{{/if}} />
              Female
            </label>
            <label>
              <input type="radio" name="gender" value="undisclosed" {{#if (eq content.gender "undisclosed")}}checked{{/if}} />
              Prefer not to say
            </label>
          </div>
        </fieldset>

        <div class="form-field">
          <label for="year">First competition year <span class="text-muted">(optional)</span></label>
          <input type="number" id="year" name="year" min="1972" inputmode="numeric"
                 value="{{content.yearValue}}" placeholder="e.g. 1998" />
          <small class="form-hint">Optional. The year you first competed in a footbag tournament. Will display on your profile if set.</small>
        </div>

        <div class="form-field">
          <label>
            <input type="hidden" name="showCompetitiveResults" value="0" />
            <input type="checkbox" name="showCompetitiveResults" value="1"
                   {{#if content.showCompetitiveResults}}checked{{/if}} />
            Show my competition results on my public profile
          </label>
          <small class="form-hint">You can change this any time from your profile settings.</small>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">{{content.submitLabel}}</button>
        </div>
      </form>
    </div>

    <p class="mt-2"><a href="{{content.dashboardHref}}">Back to dashboard</a></p>
  </section>
</div>
