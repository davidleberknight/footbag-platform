{{! Public members welcome page for unauthenticated visitors }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    <p>Join the International Footbag Players Association.</p>
  </div>
</div>

<div class="wrapper">

  <section>
    <h2>Why join?</h2>
    <p>The International Footbag Players Association is the global governing body for footbag, supporting players, clubs, and competitions since 1983. Membership is free at Tier 0 and unlocks tournament eligibility, club leadership roles, and IFPA governance participation at higher tiers.</p>
  </section>

  <section>
    <h2>Membership Tiers</h2>
    <ul class="tier-explainer">
      {{#each content.tiers}}
        <li>
          <strong>{{this.label}}</strong>
          <p>{{this.blurb}}</p>
        </li>
      {{/each}}
    </ul>
  </section>

  {{#if content.showJoinCtas}}
  <section>
    <div class="card">
      <div class="card-title">Become a Member</div>
      <p class="card-description">Become an IFPA Member to join a club, compete in a tournament, share photos and videos, and participate in the global footbag community.</p>
      <a href="/register" class="btn btn-primary">Sign Up</a>
    </div>

    <div class="card mt-4">
      <div class="card-title">Already a Member?</div>
      <p class="card-description">Sign in to manage your profile, and access IFPA Member features.</p>
      <a href="/login?returnTo=%2Fmembers" class="btn btn-outline">Log In</a>
    </div>
  </section>
  {{/if}}

</div>
