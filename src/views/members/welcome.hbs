{{! Public members welcome page for unauthenticated visitors }}

<div class="hero hero-sm hero-welcome">
  <div>
    <h1>{{page.title}}</h1>
    <p>Join the International Footbag Players Association.</p>
  </div>
</div>

<div class="wrapper members-welcome">

  <p class="members-welcome-intro">The International Footbag Players Association is the global governing body for footbag, supporting players, clubs, and competitions. Membership is free at Tier 0. Higher tiers unlock media uploads, club leadership, event organizing, voting in IFPA elections, and IFPA governance participation.</p>

  {{#if content.showJoinCtas}}
  <section>
    <div class="card">
      <div class="card-title">Had an account on the old footbag.org?</div>
      <p class="card-description">You will need to create a new account here first to become a member in the new system. During setup, you can link to your historical data, such as event results, and club affiliation.</p>
    </div>

    <div class="card mt-3">
      <div class="card-title">Become a Member</div>
      <p class="card-description">Become an IFPA Member to compete in events, join a club, upload photos and videos, organize events, vote in IFPA elections, and participate in the global footbag community.</p>
      <a href="/register" class="btn btn-primary">Sign Up</a>
    </div>

    <div class="card mt-3">
      <div class="card-title">Already a Member?</div>
      <p class="card-description">Sign in to manage your profile, and access IFPA Member features.</p>
      <a href="/login?returnTo=%2Fmembers" class="btn btn-outline">Log In</a>
    </div>
  </section>
  {{/if}}

  <section>
    <h2>Membership Tiers</h2>
    <ul class="tier-explainer">
      {{#each content.tiers}}
        <li class="tier-explainer-item">
          <div class="tier-explainer-head">
            <strong>{{this.label}}</strong>
            <span class="tier-explainer-price">{{this.price}}</span>
          </div>
          <ul class="tier-explainer-benefits">
            {{#each this.benefits}}
              <li>{{this}}</li>
            {{/each}}
          </ul>
        </li>
      {{/each}}
    </ul>
  </section>

</div>
