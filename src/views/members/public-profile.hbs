{{> player-hero heroData=content.heroData}}

<div class="wrapper">
  <section>
    {{#if content.avatarThumbUrl}}
    <div class="text-center mb-4">
      <img src="{{content.avatarThumbUrl}}" alt="{{content.displayName}}" class="profile-avatar-img" />
    </div>
    {{/if}}

    {{#if content.tierBadgeText}}
    <div class="membership-badges mb-4">
      <span class="badge badge-tier">{{content.tierBadgeText}}</span>
      {{#if content.isActivePlayer}}
        <span class="badge badge-honor">Active Player</span>
      {{/if}}
    </div>
    {{/if}}

    {{#if content.genderLabel}}
    <div class="profile-section">
      <p class="text-muted">Gender: {{content.genderLabel}}</p>
    </div>
    {{/if}}

    {{#if content.bio}}
    <div class="profile-section">
      <h2 class="profile-section-heading">About</h2>
      <p>{{content.bio}}</p>
    </div>
    {{/if}}

    {{#if content.clubs.length}}
    <div class="profile-section">
      <h2 class="profile-section-heading">Clubs</h2>
      <ul>
        {{#each content.clubs}}
          <li><a href="{{href}}">{{name}}</a></li>
        {{/each}}
      </ul>
    </div>
    {{/if}}

    {{#if (or content.contactEmail (or content.contactPhone content.contactWhatsapp))}}
    <div class="profile-section">
      <h2 class="profile-section-heading">Contact</h2>
      {{#if content.contactEmail}}
        <p><a href="mailto:{{content.contactEmail}}">{{content.contactEmail}}</a></p>
      {{/if}}
      {{#if content.contactPhone}}
        <p>Phone: {{content.contactPhone}}</p>
      {{/if}}
      {{#if content.contactWhatsapp}}
        <p>WhatsApp: {{content.contactWhatsapp}}</p>
      {{/if}}
    </div>
    {{/if}}

    {{#if content.links.length}}
    <div class="profile-section">
      <h2 class="profile-section-heading">Links</h2>
      <ul>
        {{#each content.links}}
          <li>{{{externalLink this.url label=this.label}}}</li>
        {{/each}}
      </ul>
    </div>
    {{/if}}

    {{#if content.media.hasContent}}
      {{> member-block-media content.media}}
    {{/if}}

    {{#if content.showCompetitiveResults}}
    <div class="profile-section">
      {{> player-results eventGroups=content.eventGroups firstCompetitionYear=content.firstCompetitionYear showFirstCompetitionYear=content.showFirstCompetitionYear}}
    </div>
    {{/if}}

  </section>
</div>
