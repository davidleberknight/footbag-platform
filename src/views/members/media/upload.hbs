{{!--
  Member-owned upload form. Owner-only view (anti-enumeration 404 elsewhere).
  2-tab layout: Photo / Video link. No MP4 upload because members link to
  YouTube or Vimeo rather than hosting video bytes, which avoids storage
  and transcoding costs for the member tier. Same CSS-only tab pattern as
  the admin curator form. Works without JavaScript.
--}}
<div class="wrapper">
  <h1>{{page.title}}</h1>
  <p>
    Upload a photo, or share a YouTube or Vimeo video link. Anything you upload is
    automatically tagged with your uploader marker, so it appears in your Personal Gallery.
    Add more hashtags to surface it in event, club, or topic galleries too.
    Tags starting with <code>#by_</code> are reserved for the system uploader marker
    and cannot be set by hand; <code>#curated</code> is similarly reserved.
  </p>

  {{#if errorMessage}}
    <div class="form-error-banner" role="alert">{{errorMessage}}</div>
  {{/if}}

  <form action="{{formAction}}" method="POST" enctype="multipart/form-data" class="upload-form curator-edit-form">

    <div class="upload-tabs">
      {{!-- Hidden radios act as the tab control. --}}
      <input type="radio" name="mediaType" value="photo" id="member-tab-photo"
        {{#if (eq formValues.mediaType "video")}}{{else}}checked{{/if}}
        class="upload-tab-radio">
      <input type="radio" name="mediaType" value="video" id="member-tab-video"
        {{#if (eq formValues.mediaType "video")}}checked{{/if}}
        class="upload-tab-radio">

      <div class="upload-tab-bar" role="tablist">
        <label for="member-tab-photo" class="upload-tab">Photo</label>
        <label for="member-tab-video" class="upload-tab">Video link</label>
      </div>

      <div class="upload-tab-panels">
        <div class="upload-tab-panel upload-tab-panel-photo">
          <fieldset>
            <legend>Photo file</legend>
            <label class="form-row">
              <span class="form-label">File (JPEG or PNG, up to 25&nbsp;MB):</span>
              <input type="file" name="photoFile" accept="image/jpeg,image/png">
            </label>
          </fieldset>
        </div>

        <div class="upload-tab-panel upload-tab-panel-video">
          <fieldset>
            <legend>YouTube / Vimeo link</legend>
            <label class="form-row">
              <span class="form-label">Platform:</span>
              <select name="videoPlatform">
                <option value="">--</option>
                <option value="youtube" {{#if (eq formValues.videoPlatform "youtube")}}selected{{/if}}>YouTube</option>
                <option value="vimeo"   {{#if (eq formValues.videoPlatform "vimeo")}}selected{{/if}}>Vimeo</option>
              </select>
            </label>
            <label class="form-row">
              <span class="form-label">URL:</span>
              <input type="url" name="videoUrl" value="{{formValues.videoUrl}}"
                     placeholder="https://www.youtube.com/watch?v=...">
            </label>
          </fieldset>
        </div>
      </div>
    </div>

    <fieldset>
      <legend>Details</legend>
      <label class="form-row">
        <span class="form-label">Caption (optional, up to 500 characters):</span>
        <textarea id="member-upload-caption" name="caption" maxlength="500" rows="3">{{formValues.caption}}</textarea>
      </label>
      <label class="form-row">
        <span class="form-label">Tags (optional, space-separated <code>#hashtags</code>):</span>
        <input id="member-upload-tags" type="text" name="tags" value="{{formValues.tags}}"
               placeholder="#freestyle #trick" data-tag-chips>
        <small class="form-help">The leading <code>#</code> is optional. Event and club tags follow canonical patterns: events use <code>#event_&lt;year&gt;_&lt;event-slug&gt;</code>, for example <code>#event_2026_worlds_japan</code>; clubs use <code>#club_&lt;location-slug&gt;</code>, for example <code>#club_tokyo</code>.</small>
      </label>
      {{#if tagSuggestions}}
      <div class="tag-suggestions" aria-label="Suggested tags">
        {{#if tagSuggestions.clubTags.length}}
        <div class="tag-suggestions-group">
          <span class="tag-suggestions-label">Your clubs:</span>
          {{#each tagSuggestions.clubTags}}
          <button type="button" class="tag-chip tag-suggestion" data-tag="{{normalized}}">{{display}}</button>
          {{/each}}
        </div>
        {{/if}}
        {{#if tagSuggestions.participatedEventTags.length}}
        <div class="tag-suggestions-group">
          <span class="tag-suggestions-label">Your events:</span>
          {{#each tagSuggestions.participatedEventTags}}
          <button type="button" class="tag-chip tag-suggestion" data-tag="{{normalized}}">{{display}}</button>
          {{/each}}
        </div>
        {{/if}}
        {{#if tagSuggestions.popularTags.length}}
        <div class="tag-suggestions-group">
          <span class="tag-suggestions-label">Popular:</span>
          {{#each tagSuggestions.popularTags}}
          <button type="button" class="tag-chip tag-suggestion" data-tag="{{normalized}}">{{display}}</button>
          {{/each}}
        </div>
        {{/if}}
      </div>
      {{/if}}
      {{#if galleries.length}}
      <label class="form-row">
        <span class="form-label">Add to gallery (optional):</span>
        <select id="member-upload-gallery" name="galleryId">
          <option value="">(none)</option>
          {{#each galleries}}
          <option value="{{id}}" {{#if (eq id ../formValues.galleryId)}}selected{{/if}}>{{name}}</option>
          {{/each}}
        </select>
        <small class="form-help">Gallery criteria tags will be added automatically.</small>
      </label>
      {{/if}}
      <label class="form-row">
        <span class="form-label">External URL (optional, link to source page or creator):</span>
        <input id="member-upload-external-url" type="url" name="externalUrl" value="{{formValues.externalUrl}}"
               placeholder="https://example.com/article">
      </label>
    </fieldset>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Upload</button>
      <a href="{{cancelHref}}" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>
<script src="/js/tag-chips.js" defer></script>
{{#if tagSuggestions}}
<script src="/js/tag-suggestions.js" defer></script>
{{/if}}
