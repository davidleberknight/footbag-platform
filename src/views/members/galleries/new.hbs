{{!-- Member's own new-gallery form. Owner-only view. --}}
<div class="wrapper">
  <h1>{{page.title}}</h1>
  <p>
    Create a new named gallery. Pick a name, an optional description, and the
    set of <strong>criteria tags</strong> that decides which media appears in
    your gallery (an item must carry every criteria tag to appear). Optionally
    add <strong>exclude tags</strong> to filter out a subset.
  </p>

  {{> gallery-edit-form
      formAction=formAction
      gallery=gallery
      errorMessage=errorMessage
      cancelHref=cancelHref
      submitLabel="Create gallery"
  }}
</div>
