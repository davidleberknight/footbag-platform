{{!-- Member's own new-gallery form. Owner-only view. --}}
<div class="wrapper">
  <h1>{{page.title}}</h1>
  <p>
    Create a new named gallery. Pick a name and an optional description.
    Add <strong>criteria tags</strong> to filter what appears here, or leave
    them empty to show everything you have uploaded. Optionally add
    <strong>exclude tags</strong> to filter out a subset.
  </p>

  {{> gallery-edit-form
      formAction=formAction
      gallery=gallery
      errorMessage=errorMessage
      cancelHref=cancelHref
      submitLabel="Create gallery"
      isCreate=true
      pickerItems=pickerItems
  }}
</div>
<script src="{{{asset 'js/tag-chips.js'}}}" defer></script>
