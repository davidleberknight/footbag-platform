{{!-- Member's own gallery edit form. Owner-only view. --}}
<div class="wrapper">
  <h1>{{page.title}}</h1>
  <p>
    Editing your gallery. Items appear here when they carry every
    <strong>criteria tag</strong> and no <strong>exclude tag</strong>.
    Leave criteria empty to show everything you have uploaded.
  </p>

  <p>
    Need to add new photos? <a href="{{uploadMediaHref}}">Upload more media</a>,
    then return here to attach them to this gallery.
  </p>

  {{> gallery-edit-form
      formAction=formAction
      gallery=gallery
      errorMessage=errorMessage
      cancelHref=cancelHref
      pickerItems=pickerItems
  }}
</div>
<script src="{{{asset 'js/tag-chips.js'}}}" defer></script>
