{{!-- Member's own named-gallery list. Owner-only view. --}}
<div class="wrapper">
  <h1>{{page.title}}</h1>
  <p>
    Your media collections. A gallery is a saved view of your photos and videos
    that match a set of hashtags. Items appear when they carry every required
    tag, and none of the excluded tags.
  </p>

  <p>
    <a href="{{content.uploadMediaHref}}" class="btn btn-primary">Upload media</a>
    <a href="{{content.newGalleryHref}}" class="btn">Create new gallery</a>
  </p>

  {{#if content.savedMessage}}
    <div class="form-success-banner" role="status">
      {{content.savedMessage}}
    </div>
  {{/if}}

  {{#if content.galleries.length}}
    <table class="curator-list">
      <thead>
        <tr>
          <th>Name</th>
          <th>Description</th>
          <th>Sort order</th>
          <th>Criteria tags</th>
          <th>Exclude tags</th>
          <th>Items</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each content.galleries}}
          <tr>
            <td>{{name}}</td>
            <td>{{description}}</td>
            <td><code>{{sortOrder}}</code></td>
            <td>
              {{#each criteriaTags}}
                <code class="tag-chip">{{this}}</code>
              {{/each}}
            </td>
            <td>
              {{#each excludeTags}}
                <code class="tag-chip">{{this}}</code>
              {{else}}
                <span class="text-muted">(none)</span>
              {{/each}}
            </td>
            <td>{{itemCount}}</td>
            <td>
              <a href="{{editHref}}">Edit</a>
              <a href="/media/{{id}}" target="_blank" rel="noopener noreferrer">View</a>
              {{#if isConfirmDelete}}
                <form method="POST" action="{{deleteHref}}" class="inline-form">
                  <input type="hidden" name="confirmed" value="1" />
                  <span class="text-secondary">Are you sure?</span>
                  <button type="submit" class="btn-link-danger">Confirm delete</button>
                  <a href="{{../content.listHref}}">Cancel</a>
                </form>
              {{else}}
                <form method="POST" action="{{deleteHref}}" class="inline-form" data-confirm="Delete this gallery? This cannot be undone.">
                  <button type="submit" class="btn-link-danger">Delete</button>
                </form>
              {{/if}}
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p class="empty-state">You haven't created any galleries yet.</p>
  {{/if}}
</div>
