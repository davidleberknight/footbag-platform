{{> player-hero heroData=content.heroData}}

<div class="wrapper">
  <section>
    {{#if page.notice}}
      <div class="form-success-banner" role="status">{{page.notice}}</div>
    {{/if}}
    <div class="profile-layout">

      <div class="profile-sidebar">
        <div class="profile-avatar-card card">
          {{#if content.avatarThumbUrl}}
          <img src="{{content.avatarThumbUrl}}" alt="{{content.displayName}}" class="profile-avatar-img" />
          {{else}}
          <div class="profile-avatar-placeholder" aria-hidden="true">&#128100;</div>
          {{/if}}
          <div class="profile-name">{{content.displayName}}</div>
          {{#if content.city}}
            <div class="profile-location text-muted">{{content.city}}{{#if content.region}}, {{content.region}}{{/if}}{{#if content.country}} · {{content.country}}{{/if}}</div>
          {{/if}}
          {{#each navigation.contextLinks}}
            <a href="{{href}}" class="btn btn-primary profile-edit-btn">{{label}}</a>
          {{/each}}
        </div>
      </div>

      <div class="profile-main">

        {{> member-block-onboarding-tasks content.dashboardTasks}}

        {{> member-block-membership content.membership}}

        <div class="profile-section">
          <h2 class="profile-section-heading">About</h2>
          {{#if content.bio}}
            <p>{{content.bio}}</p>
          {{else}}
            <p class="text-muted">No bio yet. <a href="{{content.profileBase}}/edit">Edit your profile</a> to tell people about yourself.</p>
          {{/if}}
        </div>

        {{#if content.links.length}}
        <div class="profile-section">
          <h2 class="profile-section-heading">Links</h2>
          <ul>
            {{#each content.links}}
              <li>{{{externalLink this.url label=this.label}}}</li>
            {{/each}}
          </ul>
        </div>
        {{/if}}

        {{> member-block-identity content.identity}}

        {{> member-block-claimed-legacy-identities content.claimedLegacyIdentities}}

        {{> member-block-quick-actions content.quickActions}}

        <div class="profile-section">
          {{> player-results eventGroups=content.eventGroups firstCompetitionYear=content.firstCompetitionYear showFirstCompetitionYear=content.showFirstCompetitionYear}}
          {{#unless content.showCompetitiveResults}}
            <p class="text-muted fs-sm">Only you can see this. Public viewers do not see your competition results because "Show my competition results on my profile" is off.</p>
          {{/unless}}
        </div>

        {{> member-block-search content.search}}

        {{> member-block-my-clubs content.myClubs}}

        {{#if content.media.hasContent}}
          {{> member-block-media content.media}}
        {{/if}}

        {{> member-block-coming-soon content.comingSoon}}

        <div class="profile-section">
          <h2 class="profile-section-heading">Account</h2>
          <ul class="profile-account-list">
            <li><span class="disabled">Account Settings</span></li>
            <li><a href="{{content.profileBase}}/edit/password">Change Password</a></li>
            <li><span class="disabled">Download My Data</span></li>
            <li><span class="disabled">Delete Account</span></li>
          </ul>
        </div>

      </div>
    </div>
  </section>
</div>
