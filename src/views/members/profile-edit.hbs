<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
  </div>
</div>

<div class="wrapper">
  <section>
    {{#each navigation.contextLinks}}
      <a href="{{href}}" class="back-link">&#8592; {{label}}</a>
    {{/each}}

    {{#if content.error}}
      <div class="form-error-banner" role="alert">
        {{content.error}}
      </div>
    {{/if}}

    {{!-- Read-only identity block --}}
    <div class="profile-identity-block">
      <dl class="identity-fields">
        <div class="identity-row">
          <dt>Name</dt>
          <dd>{{content.displayName}}</dd>
        </div>
        <div class="identity-row">
          <dt>Email</dt>
          <dd>{{content.loginEmail}}</dd>
        </div>
        <div class="identity-row">
          <dt>Profile URL</dt>
          <dd>{{content.profileUrl}}</dd>
        </div>
      </dl>
      <p class="identity-note">Your name and profile URL are permanent and set when you registered. <a href="/members/{{content.memberKey}}/contact-admin">Contact IFPA admin</a> if you need a correction.</p>
      {{#if content.legacyClaimCtaHref}}
        <p class="identity-claim-link">
          <a href="{{content.legacyClaimCtaHref}}">{{content.legacyClaimCtaLabel}}</a>
        </p>
      {{/if}}
    </div>

    {{!-- Avatar upload (separate form, multipart) --}}
    <fieldset class="form-fieldset">
      <legend>Avatar</legend>

      {{#if content.avatarError}}
        <p class="form-field-error" role="alert">{{content.avatarError}}</p>
      {{/if}}
      {{#if content.avatarSuccess}}
        <p class="form-success-banner" role="status">{{content.avatarSuccess}}</p>
      {{/if}}

      <div class="avatar-edit-row">
        {{#if content.avatarThumbUrl}}
          <img src="{{content.avatarThumbUrl}}" alt="Current avatar" class="avatar-edit-thumb" />
        {{else}}
          <div class="avatar-edit-placeholder">?</div>
        {{/if}}

        <form method="POST" action="/members/{{content.memberKey}}/avatar" enctype="multipart/form-data" class="avatar-edit-form">
          <div class="form-field">
            <label for="avatar">Upload new photo (JPEG or PNG, max 5 MB)</label>
            <input type="file" id="avatar" name="avatar" accept="image/jpeg,image/png" required />
          </div>
          <button type="submit" class="btn btn-primary btn-sm">Upload</button>
        </form>
      </div>
    </fieldset>

    {{!-- Editable profile fields --}}
    <form method="POST" class="form-block" id="profileEditForm">

      <fieldset class="form-fieldset">
        <legend>About You</legend>

        <div class="form-field">
          <label for="bio">Bio</label>
          <textarea
            id="bio"
            name="bio"
            maxlength="1000"
            rows="4"
            placeholder="Tell people about yourself..."
          >{{content.bio}}</textarea>
        </div>

        <div class="form-field">
          <label for="firstCompetitionYear">First year of competition</label>
          <input
            type="number"
            id="firstCompetitionYear"
            name="firstCompetitionYear"
            value="{{content.firstCompetitionYear}}"
            min="1972"
            max="2026"
            placeholder="e.g. 1995"
          />
          <small class="form-hint">Leave blank to hide from your profile.</small>
        </div>

        <div class="form-field">
          <label>
            <input type="hidden" name="showCompetitiveResults" value="0" />
            <input
              type="checkbox"
              name="showCompetitiveResults"
              value="1"
              {{#if content.showCompetitiveResults}}checked{{/if}}
            />
            Show competitive results on my public profile
          </label>
        </div>

        <div class="form-field">
          <label>
            <input type="hidden" name="showFirstCompetitionYear" value="0" />
            <input
              type="checkbox"
              name="showFirstCompetitionYear"
              value="1"
              {{#if content.showFirstCompetitionYear}}checked{{/if}}
            />
            Show first competition year on my public profile
          </label>
        </div>
      </fieldset>

      <fieldset class="form-fieldset">
        <legend>Location</legend>

        <div class="form-row-2col">
          <div class="form-field">
            <label for="city">City</label>
            <input
              type="text"
              id="city"
              name="city"
              value="{{content.city}}"
              autocomplete="address-level2"
            />
          </div>

          <div class="form-field">
            <label for="region">Region / State</label>
            <input
              type="text"
              id="region"
              name="region"
              value="{{content.region}}"
              autocomplete="address-level1"
            />
          </div>
        </div>

        <div class="form-field">
          <label for="country">Country</label>
          <input
            type="text"
            id="country"
            name="country"
            value="{{content.country}}"
            autocomplete="country-name"
          />
        </div>
      </fieldset>

      <fieldset class="form-fieldset">
        <legend>Gender (competition eligibility)</legend>
        <p class="text-muted fs-sm">Private: visible only to you and IFPA admins. Never shown on public pages, member search, or rosters. Used only for gender-based event-category eligibility.</p>
        <div class="form-field">
          <label>
            <input type="radio" name="gender" value="male" {{#if (eq content.gender "male")}}checked{{/if}} />
            Male
          </label>
          <label>
            <input type="radio" name="gender" value="female" {{#if (eq content.gender "female")}}checked{{/if}} />
            Female
          </label>
          <label>
            <input type="radio" name="gender" value="undisclosed" {{#if (eq content.gender "undisclosed")}}checked{{/if}} />
            Prefer not to say
          </label>
        </div>
      </fieldset>
    </form>

      <fieldset class="form-fieldset">
        <legend>Privacy &amp; Contact</legend>
        <p class="text-muted fs-sm">Contact details are never shown to the public. When you opt in, they are visible to logged-in members only.</p>

        <div class="form-field">
          <label for="phone">Phone (optional)</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            value="{{content.phone}}"
            autocomplete="tel"
            form="profileEditForm"
          />
        </div>
        <div class="form-field">
          <label>
            <input type="hidden" name="phoneVisible" value="0" form="profileEditForm" />
            <input type="checkbox" name="phoneVisible" value="1" form="profileEditForm" {{#if content.phoneVisible}}checked{{/if}} />
            Show my phone to logged-in members
          </label>
        </div>

        <div class="form-field">
          <label for="whatsapp">WhatsApp (optional)</label>
          <input
            type="tel"
            id="whatsapp"
            name="whatsapp"
            value="{{content.whatsapp}}"
            autocomplete="tel"
            form="profileEditForm"
          />
        </div>
        <div class="form-field">
          <label>
            <input type="hidden" name="whatsappVisible" value="0" form="profileEditForm" />
            <input type="checkbox" name="whatsappVisible" value="1" form="profileEditForm" {{#if content.whatsappVisible}}checked{{/if}} />
            Show my WhatsApp to logged-in members
          </label>
        </div>

        <div class="form-field">
          <label for="emailVisibility">Contact email visibility</label>
          <select id="emailVisibility" name="emailVisibility" form="profileEditForm" {{#if content.emailVisibilityLocked}}disabled{{/if}}>
            <option value="private"{{#if (eq content.emailVisibility 'private')}} selected{{/if}}>Private (only you)</option>
            <option value="members"{{#if (eq content.emailVisibility 'members')}} selected{{/if}}>Members only</option>
          </select>
          {{#if content.emailVisibilityLocked}}
            <small class="form-hint">Required at Members only while you co-lead a club.</small>
          {{/if}}
        </div>

        <div class="form-field">
          <label>
            <input type="hidden" name="searchable" value="0" form="profileEditForm" />
            <input type="checkbox" name="searchable" value="1" form="profileEditForm" {{#if content.searchable}}checked{{/if}} />
            Allow other members to find me in member search
          </label>
          <small class="form-hint">When on, other members can find you in member search. Your profile stays reachable by direct link and visible to club co-members either way.</small>
        </div>
      </fieldset>

      <fieldset class="form-fieldset">
        <legend>External links</legend>
        <p class="form-hint">Add up to 3 links (personal site, social media). Each link is checked before it appears on your profile.</p>
        {{#each content.linkSlots}}
          <div class="form-row-2col">
            <div class="form-field">
              <label for="link_label_{{@index}}">Label</label>
              <input
                type="text"
                id="link_label_{{@index}}"
                name="link_label"
                value="{{this.label}}"
                maxlength="80"
                form="profileEditForm"
              />
            </div>
            <div class="form-field">
              <label for="link_url_{{@index}}">URL</label>
              <input
                type="url"
                id="link_url_{{@index}}"
                name="link_url"
                value="{{this.url}}"
                maxlength="2048"
                placeholder="https://..."
                form="profileEditForm"
              />
            </div>
          </div>
        {{/each}}
      </fieldset>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary" form="profileEditForm">Save</button>
        <a href="/members/{{content.memberKey}}" class="btn btn-outline">Cancel</a>
      </div>

  </section>
</div>
