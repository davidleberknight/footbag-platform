{{! Historical-person claim confirmation page }}

<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
  </div>
</div>

<div class="wrapper">

  <section>
    <p>A historical player record is a read-only entry from the competitive footbag archive. Claiming it links your current account to this competitor identity so Hall of Fame status, country, and career results appear on your profile.</p>

    {{#if content.error}}
      <p class="form-field-error" role="alert">{{content.error}}</p>
      <p class="mt-6"><a href="{{content.cancelHref}}">Back</a></p>
    {{else}}
      <div class="card mb-6">
        <p class="m-0 fw-500">Historical record: {{content.personName}}</p>
        {{#if content.country}}
          <p class="m-0 mt-1 text-muted">Country: {{content.country}}</p>
        {{/if}}
        {{#if content.isHof}}
          <p class="m-0 mt-1 fw-500 text-secondary">Hall of Fame member</p>
        {{/if}}
        {{#if content.isBap}}
          <p class="m-0 mt-1 fw-500 text-secondary">BAP member</p>
        {{/if}}
        {{#if content.bioExcerpt}}
          <p class="m-0 mt-2 text-muted fs-sm">{{content.bioExcerpt}}</p>
        {{/if}}
      </div>

      {{#if content.clubAffiliations.length}}
        <h3>Club affiliations</h3>
        <ul>{{#each content.clubAffiliations}}<li>{{this}}</li>{{/each}}</ul>
      {{/if}}
      {{#if content.eventsAttended.length}}
        <h3>Events attended</h3>
        <ul>{{#each content.eventsAttended}}<li>{{this.title}} ({{this.year}})</li>{{/each}}</ul>
      {{/if}}

      {{#if content.firstNameWarning}}
        <div class="notice-card notice-card--warn-strong my-4">
          <p class="m-0">First-name difference: the historical record's first name does not exactly match the first name on your account. This is allowed if you use a common variant (e.g. Dave vs David). Proceed only if this record is you.</p>
        </div>
      {{/if}}

      <p>This will link your current account to the historical record and carry forward country, Hall of Fame status, and induction year where applicable. Your display name and login credentials will not be changed.</p>

      <form method="POST" action="/history/{{content.personId}}/claim/confirm">
        <button type="submit" class="btn btn-primary">Yes, This Is Me: Link the Record</button>
      </form>

      <p class="mt-4"><a href="{{content.cancelHref}}">Cancel</a></p>
    {{/if}}
  </section>

</div>
