{{! Events landing page — upcoming events + archive year links }}

<div class="hero hero-sm">
  <div>
    <h1>Footbag Events</h1>
    <p>Tournaments, competitions, and gatherings from around the world.</p>
  </div>
</div>

<div class="wrapper">

  {{! ── Past events by year ─────────────────────────────────────── }}
  {{#if archiveYears.length}}
  <section>
    <div class="section-heading">
      <h2>Past Events</h2>
    </div>
    <p class="text-muted mb-4">Browse completed events and results by year.</p>
    <div class="year-grid">
      {{#each archiveYears}}
        <a href="/events/year/{{this}}" class="year-pill">{{this}}</a>
      {{/each}}
    </div>
    <p class="text-muted" style="margin-top: 16px; font-size: 0.9rem;">Results data before 1997 is incomplete. More historical results are coming soon.</p>
  </section>
  {{/if}}

  {{! ── Upcoming events ─────────────────────────────────────────── }}
  <section>
    <div class="section-heading">
      <h2>Upcoming Events</h2>
      {{#if upcomingEvents.length}}
        <span class="section-count">{{upcomingEvents.length}}</span>
      {{/if}}
    </div>

    {{#if upcomingEvents.length}}
      <div class="card-grid">
        {{#each upcomingEvents}}
          {{> event-card}}
        {{/each}}
      </div>
    {{else}}
      <p class="text-muted">Upcoming events are a work in progress. Check back soon.</p>
    {{/if}}
  </section>

</div>
