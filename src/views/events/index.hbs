{{! Events landing page — upcoming events + archive year links }}

<div class="hero">
  <div>
    <h1>Footbag Events</h1>
    <p>Tournaments, competitions, and gatherings from around the world.</p>
  </div>
</div>

<div class="wrapper">

  {{! ── Upcoming events ─────────────────────────────────────────── }}
  <section>
    <div class="section-heading">
      <h2>Upcoming Events</h2>
      {{#if upcomingEvents.length}}
        <span class="section-count">{{upcomingEvents.length}}</span>
      {{/if}}
    </div>

    {{#if upcomingEvents.length}}
      <table class="results-table" style="width:100%">
        <thead>
          <tr>
            <th>Event</th>
            <th>Date</th>
            <th>Location</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {{#each upcomingEvents}}
            <tr>
              <td><a href="/events/{{eventKey}}">{{title}}</a></td>
              <td style="white-space:nowrap">{{startDate}}{{#if endDate}} – {{endDate}}{{/if}}</td>
              <td>{{city}}{{#if region}}, {{region}}{{/if}}, {{country}}</td>
              <td><span class="badge badge-{{status}}">{{status}}</span></td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <div class="empty-state">
        <p>No upcoming events are currently listed. Check back soon.</p>
      </div>
    {{/if}}
  </section>

  {{! ── Past events by year ─────────────────────────────────────── }}
  <section>
    <div class="section-heading">
      <h2>Past Events</h2>
    </div>

    {{#if archiveYears.length}}
      <p class="text-muted mb-4">Browse completed events and results by year.</p>
      <div class="year-grid">
        {{#each archiveYears}}
          <a href="/events/year/{{this}}" class="year-pill">{{this}}</a>
        {{/each}}
      </div>
    {{else}}
      <div class="empty-state">
        <p>No past events are available yet.</p>
      </div>
    {{/if}}
  </section>

</div>
