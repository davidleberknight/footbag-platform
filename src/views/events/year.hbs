{{! Year archive page — event list for a given year }}

<div class="hero hero-sm">
  <div>
    <h1>Footbag Events from {{year}}</h1>
  </div>
</div>

<div class="wrapper">
  <section style="padding-top: 24px;">

    <div class="year-page-nav">
      {{#if previousYear}}
        <a href="/events/year/{{previousYear}}" class="hero-year-arrow">&#8592; {{previousYear}}</a>
      {{else}}
        <span class="hero-year-arrow hero-year-arrow--disabled">&#8592;</span>
      {{/if}}

      {{#if nextYear}}
        <a href="/events/year/{{nextYear}}" class="hero-year-arrow">{{nextYear}} &#8594;</a>
      {{else}}
        <span class="hero-year-arrow hero-year-arrow--disabled">&#8594;</span>
      {{/if}}
    </div>

    {{#if events.length}}
      <div class="event-list">
        {{#each events}}
          <a href="/events/{{eventKey}}" class="event-list-row">
            <div class="event-list-main">
              <span class="event-list-title">{{title}}</span>
              {{#if hostClub}}<span class="event-list-host">{{hostClub}}</span>{{/if}}
            </div>
            <div class="event-list-meta">
              <span class="event-list-date">{{formatDate startDate}}{{#unless (eq startDate endDate)}} – {{formatDate endDate}}{{/unless}}</span>
              <span class="event-list-location">{{city}}{{#if region}}, {{region}}{{/if}}, {{country}}</span>
            </div>
          </a>
        {{/each}}
      </div>
    {{else}}
      <p class="text-muted">No events found for {{year}}.</p>
    {{/if}}

  </section>
</div>
