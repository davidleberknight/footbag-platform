<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p>{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">
  <section class="content-section">
    {{#if content.galleries.length}}
    <div class="card-grid card-grid-2col">
      {{#each content.galleries}}
      <div class="card">
        <div class="card-title">{{name}}</div>
        {{#if description}}<p>{{description}}</p>{{/if}}
        <div class="card-actions">
          <a href="{{href}}" class="btn btn-outline">Watch &rarr;</a>
        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <p class="text-muted">Tutorial galleries are coming soon.</p>
    {{/if}}
  </section>
</div>
