<div class="hero hero-sm">
  <div>
    <h1>Browse Media</h1>
    {{#if (eq content.mode "results")}}
      <p class="hero-subtitle">
        Showing {{content.totalItems}} {{#if (eq content.totalItems 1)}}item{{else}}items{{/if}}{{#if content.byMember}} by {{#if content.byMember.href}}<a href="{{content.byMember.href}}" class="tag-chip-link">{{content.byMember.display}}</a>{{else}}{{content.byMember.display}}{{/if}}{{#if content.criteriaTags.length}},{{/if}}{{/if}}{{#if content.criteriaTags.length}} tagged: {{#each content.criteriaTags}}{{display}}{{#unless @last}} {{/unless}}{{/each}}{{/if}}{{#if content.excludeTags.length}} - Excluding {{#if (eq content.excludeTags.length 1)}}tag{{else}}tags{{/if}}: {{#each content.excludeTags}}{{display}}{{#unless @last}} {{/unless}}{{/each}}{{/if}}
      </p>
    {{else}}
      <p class="hero-subtitle">Browse all photos and videos by tag. Pick one or more tags to include and (optionally) tags to exclude.</p>
    {{/if}}
  </div>
</div>

<div class="wrapper">

  <form method="GET" action="/media/browse" class="curator-edit-form">
    <label class="form-row">
      <span class="form-label">Include tags</span>
      <input type="text" name="tag" value="{{content.formIncludeText}}" placeholder="butterfly spike" data-tag-chips>
      <small class="form-help">Whitespace-separated. An item must carry every one of these tags to appear. The leading <code>#</code> is optional.</small>
    </label>

    <label class="form-row">
      <span class="form-label">Exclude tags</span>
      <input type="text" name="exclude" value="{{content.formExcludeText}}" placeholder="tutorial" data-tag-chips>
      <small class="form-help">Whitespace-separated. An item carrying any of these tags is filtered out. Optional.</small>
    </label>

    <div class="form-actions">
      <button type="submit">Browse</button>
    </div>
  </form>

  {{#if content.unresolvedTokens.length}}
    <p class="empty-state">
      No media found for: {{#each content.unresolvedTokens}}<code>#{{this}}</code>{{#unless @last}} {{/unless}}{{/each}}
    </p>
  {{/if}}

  {{#unless (eq content.mode "results")}}
    {{#if content.standardGalleries}}
      {{#if content.standardGalleries.clubs.length}}
      <section class="browse-standard-section" aria-labelledby="browse-club-galleries-heading">
        <h2 id="browse-club-galleries-heading" class="browse-section-heading">Club galleries</h2>
        <ul class="tag-chip-row">
          {{#each content.standardGalleries.clubs}}
          <li><a href="{{href}}" class="tag-chip">{{display}}</a></li>
          {{/each}}
        </ul>
      </section>
      {{/if}}
      {{#if content.standardGalleries.events.length}}
      <section class="browse-standard-section" aria-labelledby="browse-event-galleries-heading">
        <h2 id="browse-event-galleries-heading" class="browse-section-heading">Event galleries</h2>
        <ul class="tag-chip-row">
          {{#each content.standardGalleries.events}}
          <li><a href="{{href}}" class="tag-chip">{{display}}</a></li>
          {{/each}}
        </ul>
      </section>
      {{/if}}
    {{/if}}

    {{#if content.popularTags.length}}
    <section class="browse-popular-section" aria-labelledby="browse-popular-heading">
      <h2 id="browse-popular-heading" class="browse-section-heading">Popular tags</h2>
      <ul class="tag-chip-row">
        {{#each content.popularTags}}
        <li><a href="{{href}}" class="tag-chip">{{display}}</a></li>
        {{/each}}
      </ul>
    </section>
    {{/if}}

    <section class="browse-tags-help" aria-labelledby="browse-tags-help-heading">
      <h2 id="browse-tags-help-heading">About hashtags</h2>
      <p>Hashtags label every photo and video. They group content into discoverable feeds without a centralized taxonomy.</p>
      <ul class="browse-tags-help-list">
        <li><strong><a href="/media/browse?tag=curated" class="tag-chip-link">#curated</a></strong> marks content vetted by IFPA: tutorials, records, and showcase galleries.</li>
        <li><strong>Community tags</strong> are used by two or more members; they surface in the public hashtag directory.</li>
        <li><strong>Popular tags</strong> are the most-used community tags across the site.</li>
        <li><strong>Personal tags</strong> are used by a single member; they stay private to that member's gallery.</li>
      </ul>
      {{#unless content.popularTags.length}}
      <p class="browse-tags-help-try">Try one:</p>
      <ul class="tag-chip-row">
        <li><a href="/media/browse?tag=freestyle" class="tag-chip">#freestyle</a></li>
        <li><a href="/media/browse?tag=net" class="tag-chip">#net</a></li>
        <li><a href="/media/browse?tag=trick" class="tag-chip">#trick</a></li>
        <li><a href="/media/browse?tag=tutorial" class="tag-chip">#tutorial</a></li>
        <li><a href="/media/browse?tag=demo" class="tag-chip">#demo</a></li>
        <li><a href="/media/browse?tag=tricks_of_the_trade" class="tag-chip">#tricks_of_the_trade</a></li>
      </ul>
      {{/unless}}
    </section>
  {{/unless}}

  {{#if (eq content.mode "results")}}
    {{#if content.items.length}}
      <ul class="gallery-grid">
        {{#each content.items}}
          <li class="gallery-tile">
            {{#if media}}
              {{> video-facade media=media}}
            {{else}}
              <a href="{{displayHref}}" class="gallery-tile-media" target="_blank" rel="noopener noreferrer">
                <img src="{{thumbnailUrl}}" alt="{{caption}}" loading="lazy" />
              </a>
            {{/if}}
            {{#if caption}}<p class="gallery-tile-caption">{{caption}}</p>{{/if}}
            {{#if tags.length}}
              <ul class="gallery-tile-tags">
                {{#each tags}}
                  <li>{{#if href}}<a href="{{href}}" class="gallery-tile-tag">{{display}}</a>{{else}}<span class="gallery-tile-tag">{{display}}</span>{{/if}}</li>
                {{/each}}
              </ul>
            {{/if}}
            <p class="gallery-tile-date"><time datetime="{{uploadedAtIso}}">{{uploadedAtDisplay}}</time></p>
          </li>
        {{/each}}
      </ul>

      {{#if content.pagination}}
        {{#if (or content.pagination.hasPrev content.pagination.hasNext)}}
          <nav class="gallery-pagination" aria-label="Pagination">
            {{#if content.pagination.hasPrev}}<a href="{{content.pagination.prevHref}}" rel="prev">&larr; Previous</a>{{/if}}
            <span class="gallery-pagination-status">Page {{content.pagination.page}}</span>
            {{#if content.pagination.hasNext}}<a href="{{content.pagination.nextHref}}" rel="next">Next &rarr;</a>{{/if}}
          </nav>
        {{/if}}
      {{/if}}
    {{else}}
      <div class="empty-state">
        <p>No media yet.</p>
        {{#if content.popularTags.length}}
        <p>Try one of these popular tags:</p>
        <ul class="tag-chip-row">
          {{#each content.popularTags}}
          <li><a href="{{href}}" class="tag-chip">{{display}}</a></li>
          {{/each}}
        </ul>
        {{/if}}
      </div>
    {{/if}}
  {{/if}}

</div>
<script src="/js/tag-chips.js" defer></script>
