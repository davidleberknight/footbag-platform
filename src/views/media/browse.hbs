<div class="hero hero-sm">
  <div>
    <h1>Browse Media</h1>
    {{#if content.isResultsMode}}
      <p class="hero-subtitle">
        Showing {{content.totalItems}} {{content.totalItemsNoun}}{{#if content.byMember}} by {{#if content.byMember.href}}<a href="{{content.byMember.href}}" class="tag-chip-link">{{content.byMember.display}}</a>{{else}}{{content.byMember.display}}{{/if}}{{#if content.criteriaTags.length}},{{/if}}{{/if}}{{#if content.criteriaTags.length}} tagged: {{#each content.criteriaTags}}{{display}}{{#unless @last}} {{/unless}}{{/each}}{{/if}}{{#if content.excludeTags.length}} - Excluding {{content.excludeTagsNoun}}: {{#each content.excludeTags}}{{display}}{{#unless @last}} {{/unless}}{{/each}}{{/if}}
      </p>
    {{else}}
      <p class="hero-subtitle">Browse all photos and videos by hashtag.</p>
    {{/if}}
  </div>
</div>

<div class="wrapper">

  {{#if content.isResultsMode}}
  <p class="mt-4 mb-4"><a href="/media/browse" class="btn btn-outline">&larr; Browse All Media</a></p>
  {{/if}}

  {{#if content.filter}}
    {{> _tag-filter-bar filter=content.filter}}
  {{/if}}

  {{#if content.unresolvedTokens.length}}
    <p class="empty-state">
      No media found for: {{#each content.unresolvedTokens}}<code>#{{this}}</code>{{#unless @last}} {{/unless}}{{/each}}
    </p>
  {{/if}}

  {{#unless content.isResultsMode}}
    <section class="browse-search-section" aria-labelledby="browse-search-heading">
      <h2 id="browse-search-heading" class="browse-section-heading">Find media by hashtag</h2>
      <form method="GET" action="/media/browse" class="browse-search-form">
        <input type="text" name="tag" value="{{content.formIncludeText}}" data-tag-chips class="browse-search-input" placeholder="Include hashtags, e.g. tutorial passback_records" aria-label="Include hashtags">
        <input type="text" name="exclude" value="{{content.formExcludeText}}" data-tag-chips class="browse-search-input" placeholder="Exclude hashtags (optional)" aria-label="Exclude hashtags">
        <button type="submit" class="btn btn-primary">Browse</button>
      </form>
    </section>

    {{#if content.popularTags.length}}
    <section class="browse-popular-section" aria-labelledby="browse-popular-heading">
      <h2 id="browse-popular-heading" class="browse-section-heading">Suggested tags</h2>
      <ul class="tag-chip-row">
        {{#each content.popularTags}}
        <li><a href="{{href}}" class="tag-chip">{{display}}</a></li>
        {{/each}}
      </ul>
    </section>
    {{/if}}

    <section class="browse-tags-help" aria-labelledby="browse-tags-help-heading">
      <h2 id="browse-tags-help-heading">About hashtags</h2>
      <p>Hashtags label every photo and video and group them into discoverable feeds. Popular tags are the most-used public tags. Event and club tags follow fixed patterns (<code>#event_&lt;year&gt;_&lt;event-slug&gt;</code>, <code>#club_&lt;location-slug&gt;</code>). A tag used by a single member stays private to that member's gallery.</p>
    </section>
  {{/unless}}

  {{#if content.isResultsMode}}
    {{#if content.items.length}}
      <ul class="gallery-grid">
        {{#each content.items}}
          {{> _gallery-tile this}}
        {{/each}}
      </ul>

      {{#if content.pagination}}
        {{#if (or content.pagination.hasPrev content.pagination.hasNext)}}
          <nav class="gallery-pagination" aria-label="Pagination">
            {{#if content.pagination.hasPrev}}<a href="{{content.pagination.prevHref}}" rel="prev">&larr; Previous</a>{{/if}}
            <span class="gallery-pagination-status">Page {{content.pagination.page}}</span>
            {{#if content.pagination.hasNext}}<a href="{{content.pagination.nextHref}}" rel="next">Next &rarr;</a>{{/if}}
          </nav>
        {{/if}}
      {{/if}}
    {{else}}
      <div class="empty-state">
        <p>No media yet.</p>
        {{#if content.popularTags.length}}
        <p>Try one of these popular tags:</p>
        <ul class="tag-chip-row">
          {{#each content.popularTags}}
          <li><a href="{{href}}" class="tag-chip">{{display}}</a></li>
          {{/each}}
        </ul>
        {{/if}}
      </div>
    {{/if}}
  {{/if}}

</div>
<script src="{{{asset 'js/tag-chips.js'}}}" defer></script>
