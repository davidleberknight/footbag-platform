<div class="hero hero-sm">
  <div>
    <h1>{{content.gallery.name}}</h1>
    {{#if content.gallery.description}}<p>{{content.gallery.description}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  {{#if content.gallery.criteriaTags.length}}
    <section class="gallery-criteria" aria-label="Gallery criteria">
      <span class="gallery-criteria-label">Showing items tagged</span>
      <ul class="gallery-criteria-tags">
        {{#each content.gallery.criteriaTags}}<li class="gallery-criteria-tag">{{this}}</li>{{/each}}
      </ul>
      <span class="gallery-criteria-count">{{content.pagination.total}} {{#if (eq content.pagination.total 1)}}item{{else}}items{{/if}}</span>
    </section>
  {{/if}}

  {{#if content.items.length}}
    <ul class="gallery-grid">
      {{#each content.items}}
        <li class="gallery-tile">
          {{#if (eq mediaType 'video')}}
            <a href="{{displayHref}}" class="gallery-tile-media video-facade"
               data-platform="{{videoPlatform}}"
               {{#if videoEmbedUrl}}data-embed-url="{{videoEmbedUrl}}"{{/if}}
               {{#if (eq videoPlatform 's3')}}data-video-src="{{displayHref}}"{{/if}}
               target="_blank" rel="noopener noreferrer"
               aria-label="Play video: {{#if caption}}{{caption}}{{else}}Curator video{{/if}}">
              <img src="{{thumbnailUrl}}" alt="{{#if caption}}{{caption}}{{else}}Curator video{{/if}}" loading="lazy" />
              <span class="gallery-tile-play" aria-hidden="true">▶</span>
            </a>
          {{else}}
            <a href="{{displayHref}}" class="gallery-tile-media" target="_blank" rel="noopener noreferrer">
              <img src="{{thumbnailUrl}}" alt="{{#if caption}}{{caption}}{{else}}Curator photo{{/if}}" loading="lazy" />
            </a>
          {{/if}}
          {{#if caption}}<p class="gallery-tile-caption">{{caption}}</p>{{/if}}
          {{#if tags.length}}
            <ul class="gallery-tile-tags">
              {{! Tag chips do not link yet; per-tag pages are deferred to the broader media-browser story. }}
              {{#each tags}}<li class="gallery-tile-tag">{{this}}</li>{{/each}}
            </ul>
          {{/if}}
          <p class="gallery-tile-date"><time datetime="{{uploadedAtIso}}">{{uploadedAtDisplay}}</time></p>
        </li>
      {{/each}}
    </ul>

    {{#if (gt content.pagination.total content.pagination.pageSize)}}
      <nav class="gallery-pagination" aria-label="Gallery pagination">
        {{#if content.pagination.hasPrev}}<a href="{{content.pagination.prevHref}}" class="btn btn-outline">Previous</a>{{/if}}
        <span class="gallery-pagination-status">Page {{content.pagination.page}}</span>
        {{#if content.pagination.hasNext}}<a href="{{content.pagination.nextHref}}" class="btn btn-outline">Next</a>{{/if}}
      </nav>
    {{/if}}
  {{else}}
    <div class="empty-state">No media yet.</div>
  {{/if}}

</div>
