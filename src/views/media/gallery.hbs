<div class="hero hero-sm">
  <div>
    <h1>Named Gallery: {{content.gallery.name}}</h1>
    {{#if (or content.gallery.byMember content.gallery.criteriaTags.length)}}
      <p class="hero-subtitle">
        Showing {{content.totalItems}} {{content.totalItemsNoun}}{{#if content.gallery.byMember}} by {{#if content.gallery.byMember.href}}<a href="{{content.gallery.byMember.href}}" class="tag-chip-link">{{content.gallery.byMember.display}}</a>{{else}}{{content.gallery.byMember.display}}{{/if}}{{#if content.gallery.criteriaTags.length}},{{/if}}{{/if}}{{#if content.gallery.criteriaTags.length}} tagged: {{#each content.gallery.criteriaTags}}{{display}}{{#unless @last}} {{/unless}}{{/each}}{{/if}}{{#if content.gallery.excludeTags.length}} - Excluding {{content.excludeTagsNoun}}: {{#each content.gallery.excludeTags}}{{display}}{{#unless @last}} {{/unless}}{{/each}}{{/if}}
      </p>
    {{/if}}
  </div>
</div>

<div class="wrapper">

  {{#if content.gallery.description}}
    <p class="gallery-description">{{content.gallery.description}}</p>
  {{/if}}

  {{#if content.gallery.externalLinks.length}}
    <ul class="gallery-references">
      {{#each content.gallery.externalLinks}}
        <li>External URL: {{{externalLink url noIcon=true}}}</li>
      {{/each}}
    </ul>
  {{/if}}

  {{#if content.truncationNotice}}
    <div class="notice notice-info">{{content.truncationNotice}}</div>
  {{/if}}

  {{#if content.items.length}}
    <ul class="gallery-grid">
      {{#each content.items}}
        <li class="gallery-tile">
          {{#if media}}
            {{> video-facade media=media}}
          {{else}}
            <a href="{{displayHref}}" class="gallery-tile-media" target="_blank" rel="noopener noreferrer">
              <img src="{{thumbnailUrl}}" alt="{{caption}}" loading="lazy" />
            </a>
          {{/if}}
          {{#if caption}}<p class="gallery-tile-caption">{{caption}}</p>{{/if}}
          {{#if tags.length}}
            <ul class="gallery-tile-tags">
              {{#each tags}}
                <li>{{#if href}}<a href="{{href}}" class="gallery-tile-tag">{{display}}</a>{{else}}<span class="gallery-tile-tag">{{display}}</span>{{/if}}</li>
              {{/each}}
            </ul>
          {{/if}}
          <p class="gallery-tile-date"><time datetime="{{uploadedAtIso}}">{{uploadedAtDisplay}}</time></p>
        </li>
      {{/each}}
    </ul>
  {{else}}
    <div class="empty-state">
      <p>No photos or videos found with this tag</p>
      {{#if content.popularTags.length}}
      <p>Try one of these popular tags:</p>
      <ul class="tag-chip-row">
        {{#each content.popularTags}}
        <li><a href="{{href}}" class="tag-chip">{{display}}</a></li>
        {{/each}}
      </ul>
      {{/if}}
    </div>
  {{/if}}

</div>
