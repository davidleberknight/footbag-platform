<div class="hero hero-sm">
  <div>
    <h1>Named Gallery: {{content.gallery.name}}</h1>
    <p class="hero-attribution text-muted">
      Curated by
      {{#if content.gallery.owner.isSystem}}
        {{content.gallery.owner.displayName}}
      {{else}}
        <a href="/members/{{content.gallery.owner.slug}}">{{content.gallery.owner.displayName}}</a>
      {{/if}}
    </p>
    {{#if content.gallery.criteriaTags.length}}
      <p class="hero-subtitle">
        Showing {{content.totalItems}} {{#if (eq content.totalItems 1)}}item{{else}}items{{/if}} tagged: {{#each content.gallery.criteriaTags}}{{this}}{{#unless @last}} {{/unless}}{{/each}}{{#if content.gallery.excludeTags.length}} - Excluding {{#if (eq content.gallery.excludeTags.length 1)}}tag{{else}}tags{{/if}}: {{#each content.gallery.excludeTags}}{{this}}{{#unless @last}} {{/unless}}{{/each}}{{/if}}
      </p>
    {{/if}}
  </div>
</div>

<div class="wrapper">

  {{#if content.gallery.description}}
    <p class="gallery-description">{{content.gallery.description}}</p>
  {{/if}}

  {{#if content.items.length}}
    <ul class="gallery-grid">
      {{#each content.items}}
        <li class="gallery-tile">
          {{#if media}}
            {{> video-facade media=media}}
          {{else}}
            <a href="{{displayHref}}" class="gallery-tile-media" target="_blank" rel="noopener noreferrer">
              <img src="{{thumbnailUrl}}" alt="{{#if caption}}{{caption}}{{else}}Curator photo{{/if}}" loading="lazy" />
            </a>
          {{/if}}
          {{#if caption}}<p class="gallery-tile-caption">{{caption}}</p>{{/if}}
          <p class="gallery-tile-date"><time datetime="{{uploadedAtIso}}">{{uploadedAtDisplay}}</time></p>
        </li>
      {{/each}}
    </ul>
  {{else}}
    <div class="empty-state">No media yet.</div>
  {{/if}}

</div>
