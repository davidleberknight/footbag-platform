<div class="hero hero-sm">
  <div>
    <h1>Named Gallery: {{content.gallery.name}}</h1>
    {{#if (or content.gallery.byMember content.gallery.criteriaTags.length)}}
      <p class="hero-subtitle">
        Showing {{content.totalItems}} {{#if (eq content.totalItems 1)}}item{{else}}items{{/if}}{{#if content.gallery.byMember}} by {{#if content.gallery.byMember.href}}<a href="{{content.gallery.byMember.href}}" class="tag-chip-link">{{content.gallery.byMember.display}}</a>{{else}}{{content.gallery.byMember.display}}{{/if}}{{#if content.gallery.criteriaTags.length}},{{/if}}{{/if}}{{#if content.gallery.criteriaTags.length}} tagged: {{#each content.gallery.criteriaTags}}{{display}}{{#unless @last}} {{/unless}}{{/each}}{{/if}}{{#if content.gallery.excludeTags.length}} - Excluding {{#if (eq content.gallery.excludeTags.length 1)}}tag{{else}}tags{{/if}}: {{#each content.gallery.excludeTags}}{{display}}{{#unless @last}} {{/unless}}{{/each}}{{/if}}
      </p>
    {{/if}}
  </div>
</div>

<div class="wrapper">

  {{#if content.gallery.description}}
    <p class="gallery-description">{{content.gallery.description}}</p>
  {{/if}}

  {{#if content.items.length}}
    <ul class="gallery-grid">
      {{#each content.items}}
        <li class="gallery-tile">
          {{#if media}}
            {{> video-facade media=media}}
          {{else}}
            <a href="{{displayHref}}" class="gallery-tile-media" target="_blank" rel="noopener noreferrer">
              <img src="{{thumbnailUrl}}" alt="{{caption}}" loading="lazy" />
            </a>
          {{/if}}
          {{#if caption}}<p class="gallery-tile-caption">{{caption}}</p>{{/if}}
          <p class="gallery-tile-date"><time datetime="{{uploadedAtIso}}">{{uploadedAtDisplay}}</time></p>
        </li>
      {{/each}}
    </ul>
  {{else}}
    <div class="empty-state">No media yet.</div>
  {{/if}}

</div>
