<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p class="hero-subtitle">{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">
  {{#if content.hasGalleries}}
    <div class="card-grid card-grid-2col">
      {{#each content.galleries}}
      <div class="card">
        <a href="{{href}}" class="card-title">{{name}}</a>
        {{#if description}}<p class="card-description">{{description}}</p>{{/if}}
        <p class="card-meta">{{itemCount}} {{itemCountNoun}} by {{#if ownerHref}}<a href="{{ownerHref}}">{{ownerDisplayName}}</a>{{else}}{{ownerDisplayName}}{{/if}}</p>
      </div>
      {{/each}}
    </div>
  {{else}}
    <div class="empty-state">No member galleries yet.</div>
  {{/if}}
</div>
