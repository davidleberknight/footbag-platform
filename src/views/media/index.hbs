<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p>{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  {{#each content.groups}}
  <section class="content-section">
    <div class="section-heading">
      <h2>{{name}}</h2>
    </div>
    <div class="card-grid card-grid-2col">
      {{#each destinations}}
      <div class="card{{#if comingSoon}} card-coming-soon{{/if}}">
        <div class="card-title">{{title}}</div>
        <p>{{description}}</p>
        {{#if comingSoon}}
          <span class="badge badge-coming-soon">Coming soon</span>
        {{else}}
          <div class="card-actions">
            {{#each galleries}}
            <a href="{{href}}" class="btn btn-outline">{{name}} &rarr;</a>
            {{/each}}
          </div>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </section>
  {{/each}}

  <section class="content-section">
    <div class="section-heading">
      <h2>More ways to browse</h2>
    </div>
    <div class="card-grid card-grid-2col">
      <div class="card">
        <div class="card-title">Browse by hashtag</div>
        <p>Find every photo and video matching a set of hashtags.</p>
        <div class="card-actions">
          <a href="/media/browse" class="btn btn-outline">Browse by hashtag &rarr;</a>
        </div>
      </div>
      {{#each content.advancedGalleries}}
      <div class="card">
        <div class="card-title">{{name}}</div>
        {{#if description}}<p>{{description}}</p>{{/if}}
        <div class="card-actions">
          <a href="{{href}}" class="btn btn-outline">Browse all &rarr;</a>
        </div>
      </div>
      {{/each}}
    </div>
  </section>

</div>
