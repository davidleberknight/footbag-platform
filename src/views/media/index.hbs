<div class="hero hero-sm">
  <div>
    <h1>{{page.title}}</h1>
    {{#if page.intro}}<p>{{page.intro}}</p>{{/if}}
  </div>
</div>

<div class="wrapper">

  {{! ── Browse-by-hashtag entry tile, distinct from the collection cards ─ }}
  <section class="content-section">
    <ul class="gallery-grid">
      <li class="hub-card hub-card-browse">
        <a href="/media/browse" class="hub-card-link">
          <div class="hub-card-body">
            <h2 class="hub-card-name">Browse by hashtag</h2>
            <p class="hub-card-description">Find every photo and video matching a set of hashtags.</p>
          </div>
          <div class="hub-card-foot hub-card-foot-browse">
            <span class="hub-card-arrow" aria-hidden="true">&rarr;</span>
          </div>
        </a>
      </li>
    </ul>
  </section>

  {{! ── Primary media-collection cards, identical weight ─────────────── }}
  <section class="content-section">
    <div class="media-hub-grid">
      {{#each content.cards}}
      <div class="media-hub-card">
        <div class="card-title">{{title}}</div>
        <p>{{description}}</p>
        {{#if href}}
          <a href="{{href}}" class="btn btn-outline">{{cta}} &rarr;</a>
        {{else}}
          <span class="media-hub-soon">Coming soon</span>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </section>

  {{! ── Member-created galleries, preserved below the primary grid ───── }}
  {{#if content.memberGalleries.length}}
  <section class="content-section">
    <div class="section-heading">
      <h2>Member galleries</h2>
    </div>
    <div class="card-grid card-grid-2col">
      {{#each content.memberGalleries}}
      <div class="card">
        <div class="card-title">{{name}}</div>
        {{#if description}}<p>{{description}}</p>{{/if}}
        <div class="card-actions">
          <a href="{{href}}" class="btn btn-outline">Browse all &rarr;</a>
        </div>
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

</div>
